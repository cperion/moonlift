-- spongejit_lua_ssa.asdl
--
-- Lalin/PVM ASDL vocabulary for the SpongeJIT Lua SSA compiler rewrite.
--
-- Doctrine:
--   LuaSrc          answers: what did PUC encode?
--   LuaEvidence     answers: what did runtime/foundry prove and lease?
--   LuaFFI          answers: what Lua-visible C FFI declarations/types/values/facts exist.
--   LuaGC           answers: what explicit Lua GC objects/state/control facts exist.
--   LuaRT           answers: what Lua runtime semantic objects/state exist.
--   LuaExec         answers: what explicit semantic Lua CFG is executed over LuaRT.
--   CompileContract answers: what executable-route obligations/facts/invalidation assumptions are attached.
--   LalinCFG         answers: what explicit Lalin CFG is emitted.
--   Stencil         answers: what typed copy-and-patch backend artifact is materialized from LalinCFG.
--
-- Source opcode mechanics are code-shaping in LuaSrc and must be dead after LuaExec.
-- Physical residency is not semantic identity.
-- Runtime/Lalin output never rediscovers Lua opcode meaning.

module LuaSrc {
    Pc      = (number id) unique
    Slot    = (number id) unique
    UpRef   = (number id) unique
    KRef    = (number id) unique
    Imm     = (number value) unique
    Count   = (number value) unique
    Offset  = (number value) unique
    Ax      = (number value) unique

    RK = R(LuaSrc.Slot slot) unique
       | K(LuaSrc.KRef k) unique

    BinOp = Add | Sub | Mul | Mod | Pow | Div | IDiv | BAnd | BOr | BXor | Shl | Shr
    UnOp  = Unm | BNot | Not | Len
    CmpOp = Eq | Lt | Le | EqI | LtI | LeI | GtI | GeI | EqK
    GenericForPhase = GenericForPrep | GenericForCall | GenericForLoop

    Op = MOVE(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b) unique

       | LOADI(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Imm value) unique
       | LOADF(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Imm value) unique
       | LOADK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.KRef k) unique
       | LOADKX(LuaSrc.Pc pc, LuaSrc.Slot a, boolean has_extraarg, LuaSrc.Ax extraarg) unique
       | LOADFALSE(LuaSrc.Pc pc, LuaSrc.Slot a) unique
       | LFALSESKIP(LuaSrc.Pc pc, LuaSrc.Slot a) unique
       | LOADTRUE(LuaSrc.Pc pc, LuaSrc.Slot a) unique
       | LOADNIL(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Count count) unique

       | GETUPVAL(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.UpRef up) unique
       | SETUPVAL(LuaSrc.Pc pc, LuaSrc.Slot value, LuaSrc.UpRef up) unique
       | GETTABUP(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.UpRef up, LuaSrc.KRef key) unique
       | GETTABLE(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot table, LuaSrc.Slot key) unique
       | GETI(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot table, LuaSrc.Imm index) unique
       | GETFIELD(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot table, LuaSrc.KRef key) unique
       | SETTABUP(LuaSrc.Pc pc, LuaSrc.UpRef up, LuaSrc.KRef key, LuaSrc.RK value) unique
       | SETTABLE(LuaSrc.Pc pc, LuaSrc.Slot table, LuaSrc.Slot key, LuaSrc.RK value) unique
       | SETI(LuaSrc.Pc pc, LuaSrc.Slot table, LuaSrc.Imm index, LuaSrc.RK value) unique
       | SETFIELD(LuaSrc.Pc pc, LuaSrc.Slot table, LuaSrc.KRef key, LuaSrc.RK value) unique
       | NEWTABLE(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Count array_hint, LuaSrc.Count hash_hint, boolean uses_extraarg, LuaSrc.Ax extraarg) unique
       | SELF(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot receiver, LuaSrc.KRef key) unique

       | ADDI(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Imm rhs) unique
       | ADDK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | SUBK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | MULK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | MODK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | POWK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | DIVK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | IDIVK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | BANDK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | BORK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | BXORK(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.KRef rhs) unique
       | SHLI(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Imm lhs, LuaSrc.Slot rhs) unique
       | SHRI(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Imm rhs) unique

       | ADD(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | SUB(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | MUL(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | MOD(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | POW(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | DIV(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | IDIV(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | BAND(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | BOR(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | BXOR(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | SHL(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique
       | SHR(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot lhs, LuaSrc.Slot rhs) unique

       | MMBIN(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Slot rhs, LuaSrc.BinOp op) unique
       | MMBINI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, LuaSrc.BinOp op, boolean operands_flipped) unique
       | MMBINK(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.KRef rhs, LuaSrc.BinOp op, boolean operands_flipped) unique
       | UNM(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b) unique
       | BNOT(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b) unique
       | NOT(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b) unique
       | LEN(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b) unique
       | CONCAT(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot first, LuaSrc.Slot last) unique

       | CLOSE(LuaSrc.Pc pc, LuaSrc.Slot a) unique
       | TBC(LuaSrc.Pc pc, LuaSrc.Slot a) unique
       | JMP(LuaSrc.Pc pc, LuaSrc.Offset offset) unique

       | EQ(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Slot rhs, boolean polarity) unique
       | LT(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Slot rhs, boolean polarity) unique
       | LE(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Slot rhs, boolean polarity) unique
       | EQK(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.KRef rhs, boolean polarity) unique
       | EQI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, boolean polarity, boolean rhs_is_float) unique
       | LTI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, boolean polarity, boolean rhs_is_float) unique
       | LEI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, boolean polarity, boolean rhs_is_float) unique
       | GTI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, boolean polarity, boolean rhs_is_float) unique
       | GEI(LuaSrc.Pc pc, LuaSrc.Slot lhs, LuaSrc.Imm rhs, boolean polarity, boolean rhs_is_float) unique
       | TEST(LuaSrc.Pc pc, LuaSrc.Slot a, boolean polarity) unique
       | TESTSET(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot b, boolean polarity) unique

       | CALL(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Count nargs, LuaSrc.Count nresults) unique
       | TAILCALL(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Count nargs, LuaSrc.Count hidden_vararg_count, boolean close_upvalues) unique
       | RETURN(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Count nresults, LuaSrc.Count c, boolean close_upvalues) unique
       | RETURN0(LuaSrc.Pc pc) unique
       | RETURN1(LuaSrc.Pc pc, LuaSrc.Slot value) unique

       | FORLOOP(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Offset offset) unique
       | FORPREP(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Offset offset) unique
       | TFORPREP(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Offset offset) unique
       | TFORCALL(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Count nresults) unique
       | TFORLOOP(LuaSrc.Pc pc, LuaSrc.Slot base, LuaSrc.Offset offset) unique

       | SETLIST(LuaSrc.Pc pc, LuaSrc.Slot table, LuaSrc.Count narray, LuaSrc.Count start, boolean uses_extraarg, LuaSrc.Ax extraarg) unique
       | CLOSURE(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.KRef proto) unique
       | VARARG(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot vararg_table, LuaSrc.Count wanted, boolean uses_vararg_table) unique
       | GETVARG(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Slot base, LuaSrc.Slot index) unique
       | ERRNNIL(LuaSrc.Pc pc, LuaSrc.Slot a, LuaSrc.Ax name_index) unique
       | VARARGPREP(LuaSrc.Pc pc, LuaSrc.Count fixed_params) unique
       | EXTRAARG(LuaSrc.Pc pc, LuaSrc.Ax ax) unique

       | UnsupportedOpcode(LuaSrc.Pc pc, string opcode_name) unique

    Window = (LuaSrc.Op* ops) unique
}

module LuaRegion {
    SlotWindow = (LuaSrc.Slot first, LuaSrc.Slot last) unique

    LoopEdge = EnterBody(LuaSrc.Pc from_pc, LuaSrc.Pc to_pc) unique
             | Skip(LuaSrc.Pc from_pc, LuaSrc.Pc to_pc) unique
             | Continue(LuaSrc.Pc from_pc, LuaSrc.Pc to_pc) unique
             | Done(LuaSrc.Pc from_pc, LuaSrc.Pc to_pc) unique

    NumericForState = (LuaSrc.Slot index, LuaSrc.Slot limit, LuaSrc.Slot step, LuaSrc.Slot external) unique
    GenericForState = (LuaSrc.Slot generator, LuaSrc.Slot state, LuaSrc.Slot control, LuaSrc.Slot first_result) unique

    Region = NumericFor(LuaSrc.Slot base,
                        LuaSrc.Pc prep_pc,
                        LuaSrc.Pc body_entry_pc,
                        LuaSrc.Pc loop_pc,
                        LuaSrc.Pc exit_pc,
                        LuaRegion.SlotWindow slots,
                        LuaRegion.NumericForState state,
                        LuaRegion.LoopEdge* edges) unique
           | GenericFor(LuaSrc.Slot base,
                        LuaSrc.Pc prep_pc,
                        LuaSrc.Pc call_pc,
                        LuaSrc.Pc loop_pc,
                        LuaSrc.Pc exit_pc,
                        LuaRegion.SlotWindow slots,
                        LuaRegion.GenericForState state,
                        LuaRegion.LoopEdge* edges) unique

    RegionSet = (LuaRegion.Region* regions) unique
}

module LuaFact {
    Subject = SrcSlot(LuaSrc.Slot slot) unique
            | CanonSlot(number slot_class) unique
            | Const(LuaSrc.KRef k) unique
            | Upvalue(LuaSrc.UpRef up) unique
            | TableValue(number id) unique
            | Callsite(LuaSrc.Pc pc) unique
            | Memory(string domain) unique
            | Global unique

    Predicate = IsNil
              | IsFalse
              | IsTrue
              | IsBool
              | IsI64
              | IsF64
              | IsNumber
              | IsString
              | IsTable
              | IsClosure
              | NonZeroI64
              | ConstI64
              | ConstF64
              | KeyConst
              | ShapeKnown
              | ShapeEq
              | MetatableAbsent
              | FieldOffset
              | ArrayHit
              | BoundsOk
              | ArrayBaseOffset
              | ArrayLenOffset
              | KnownCallTarget
              | TargetEq
              | BarrierClean

    Dependency = ShapeEpoch
               | MetatableEpoch
               | ConstEpoch
               | UpvalueEpoch
               | TableEpoch
               | CallTargetEpoch
               | GcBarrierProtocol
               | VmAbiEpoch

    Fact = (LuaFact.Subject subject,
            LuaFact.Predicate predicate,
            string value_key,
            LuaFact.Dependency* deps) unique

    PayloadLease = ShapePayload(LuaFact.Subject subject,
                                LuaSrc.Pc pc,
                                string shape_key,
                                LuaFact.Dependency* deps) unique
                 | FieldPayload(LuaFact.Subject subject,
                                LuaSrc.KRef key,
                                LuaSrc.Pc pc,
                                string shape_key,
                                LuaFact.Dependency* deps) unique
                 | ArrayPayload(LuaFact.Subject subject,
                                LuaSrc.Pc pc,
                                LuaFact.Dependency* deps) unique
                 | CallTargetPayload(LuaFact.Subject subject,
                                     LuaSrc.Pc pc,
                                     string target_key,
                                     LuaFact.Dependency* deps) unique
                 | StaticClosureTargetPayload(LuaFact.Subject subject,
                                              LuaSrc.Pc pc,
                                              LuaRT.ClosureIdentity closure,
                                              LuaRT.ResolvedCallTarget target,
                                              LuaFact.Dependency* deps) unique
                 | StaticCalleeRegionPayload(LuaFact.Subject subject,
                                             LuaSrc.Pc pc,
                                             LuaRT.ClosureIdentity closure,
                                             LuaExec.StaticRegionBinding binding,
                                             LuaExec.Region region,
                                             LuaFact.Dependency* deps) unique
                 | StaticClosureValuePayload(LuaFact.Subject subject,
                                             LuaSrc.Pc pc,
                                             LuaRT.ClosureIdentity closure,
                                             LuaRT.ResolvedCallTarget target,
                                             LuaExec.StaticRegionBinding binding,
                                             LuaGC.GCEffect allocation,
                                             LuaFact.Dependency* deps) unique
                 | BarrierPayload(LuaSrc.Pc pc,
                                  LuaFact.Dependency* deps) unique

    Bundle = (LuaFact.Fact* facts, LuaFact.PayloadLease* payloads) unique

    Evidence = (LuaFact.Fact* observed,
                LuaFact.PayloadLease* payloads,
                LuaRegion.RegionSet regions) unique
}

module LuaFFI {
    Name = (string text) unique
    CName = (string text) unique

    CTypeId = (number id) unique
    CDeclId = (number id) unique
    CLibId = (number id) unique
    CSymbolId = (number id) unique
    CCallbackId = (number id) unique
    CMetatypeId = (number id) unique
    CNameId = (number id) unique
    CFinalizerId = (number id) unique

    CScalarKind = CVoid
                | CBool
                | CChar
                | CSChar
                | CUChar
                | CShort
                | CUShort
                | CInt
                | CUInt
                | CLong
                | CULong
                | CLongLong
                | CULongLong
                | CInt8
                | CUInt8
                | CInt16
                | CUInt16
                | CInt32
                | CUInt32
                | CInt64
                | CUInt64
                | CSizeT
                | CSSizeT
                | CPtrDiffT
                | CFloat
                | CDouble
                | CLongDouble

    CSignedness = Signed
                | Unsigned
                | Signless

    CAbi = PlatformDefaultABI
         | SystemVAMD64
         | Win64
         | AArch64SysV
         | CDeclABI
         | StdCallABI
         | FastCallABI
         | ThisCallABI
         | VectorCallABI
         | UnsupportedABI(string name) unique

    CParamMode = CValueParam
               | CPointerParam
               | CArrayDecayParam
               | CVarargParam

    CType = ScalarType(LuaFFI.CTypeId id,
                       LuaFFI.CScalarKind kind,
                       LuaFFI.CSignedness signedness,
                       number size_bytes,
                       number align_bytes) unique
          | PointerType(LuaFFI.CTypeId id,
                        LuaFFI.CType pointee,
                        boolean is_const,
                        boolean is_volatile) unique
          | ArrayType(LuaFFI.CTypeId id,
                      LuaFFI.CType element,
                      number count,
                      number size_bytes,
                      number align_bytes) unique
          | IncompleteArrayType(LuaFFI.CTypeId id,
                                LuaFFI.CType element) unique
          | FunctionType(LuaFFI.CTypeId id,
                         LuaFFI.CAbi abi,
                         LuaFFI.CType return_type,
                         LuaFFI.CParamList params) unique
          | StructType(LuaFFI.CTypeId id,
                       LuaFFI.CName name,
                       LuaFFI.CRecordLayout layout) unique
          | UnionType(LuaFFI.CTypeId id,
                      LuaFFI.CName name,
                      LuaFFI.CRecordLayout layout) unique
          | EnumType(LuaFFI.CTypeId id,
                     LuaFFI.CName name,
                     LuaFFI.CEnumLayout layout) unique
          | TypedefType(LuaFFI.CTypeId id,
                        LuaFFI.CName name,
                        LuaFFI.CType aliased) unique
          | OpaqueTagType(LuaFFI.CTypeId id,
                          LuaFFI.CName name) unique

    CParam = (LuaFFI.CName name,
              LuaFFI.CType type,
              LuaFFI.CParamMode mode) unique

    CParamList = (LuaFFI.CParam* params,
                  boolean is_variadic) unique

    CFieldKind = NormalField
               | BitField
               | FlexibleArrayMember

    CField = (LuaFFI.CName name,
              LuaFFI.CType type,
              LuaFFI.CFieldKind kind,
              number offset_bits,
              number width_bits) unique

    CRecordLayout = (LuaFFI.CName name,
                     boolean is_union,
                     boolean is_complete,
                     number size_bytes,
                     number align_bytes,
                     LuaFFI.CField* fields,
                     string layout_hash) unique

    CEnumItem = (LuaFFI.CName name,
                 number value) unique

    CEnumLayout = (LuaFFI.CName name,
                   LuaFFI.CScalarKind repr,
                   number size_bytes,
                   number align_bytes,
                   LuaFFI.CEnumItem* items,
                   string layout_hash) unique

    CLibKind = ProcessLibrary
             | DynamicLibrary
             | StaticArchive
             | FrameworkLibrary
             | BuiltinLibrary

    CLib = (LuaFFI.CLibId id,
            LuaFFI.CName name,
            LuaFFI.CLibKind kind,
            string path,
            boolean loaded) unique

    CSymbolKind = FunctionSymbol
                | DataSymbol
                | CallbackSymbol

    CSymbol = (LuaFFI.CSymbolId id,
               LuaFFI.CName name,
               LuaFFI.CLib library,
               LuaFFI.CSymbolKind kind,
               LuaFFI.CType type,
               LuaFFI.CAbi abi,
               boolean resolved,
               string address_key) unique

    CStorageKind = InlineStorageKind
                 | ExternalPointerStorageKind
                 | OwnedHeapStorageKind
                 | BorrowedBufferStorageKind
                 | StaticSymbolStorageKind

    CStorage = InlineStorage(string content_hash, number byte_size) unique
             | ExternalPointerStorage(string address_key, number byte_size) unique
             | OwnedHeapStorage(string address_key, number byte_size) unique
             | BorrowedBufferStorage(string owner_key, number byte_size) unique
             | StaticSymbolStorage(LuaFFI.CSymbol symbol, number byte_size) unique

    OwnershipState = BorrowedOwnership
                   | OwnedOwnership
                   | ReleasedOwnership
                   | FinalizerAttachedOwnership
                   | FinalizerRunningOwnership
                   | FinalizedOwnership

    CFinalizer = NoFinalizer unique
               | CFunctionFinalizer(LuaFFI.CFinalizerId id,
                                    LuaFFI.CSymbol symbol) unique
               | LuaCallableFinalizer(LuaFFI.CFinalizerId id,
                                      LuaFFI.CName lua_ref) unique

    CData = (LuaFFI.CType type,
             LuaFFI.CStorage storage,
             LuaFFI.CFinalizer finalizer,
             LuaFFI.OwnershipState ownership,
             LuaFFI.CMetatypeId metatype) unique

    CCallback = (LuaFFI.CCallbackId id,
                 LuaFFI.CType function_type,
                 LuaFFI.CAbi abi,
                 LuaFFI.CName lua_ref,
                 string thunk_key,
                 boolean live) unique

    FFIRegistry = (LuaFFI.CType* types,
                   LuaFFI.CRecordLayout* records,
                   LuaFFI.CEnumLayout* enums,
                   LuaFFI.CLib* libraries,
                   LuaFFI.CSymbol* symbols,
                   LuaFFI.CCallback* callbacks,
                   LuaFFI.CData* cdata,
                   LuaFFI.CFinalizer* finalizers) unique

    FFIErrorKind = CDefParseError
                 | UnsupportedCDeclaration
                 | UnknownCType
                 | IncompleteCType
                 | LayoutError
                 | LibraryLoadError
                 | SymbolResolutionError
                 | AllocationError
                 | CastError
                 | FieldLookupError
                 | IndexError
                 | CallSignatureError
                 | CallbackError
                 | FinalizerError

    FFIError = (LuaFFI.FFIErrorKind kind,
                LuaFFI.CName message) unique

    OperationOutcome = CDefOk(LuaFFI.CDeclId decl,
                              LuaFFI.FFIRegistry registry) unique
                     | TypeQueryOk(LuaFFI.CType type) unique
                     | LayoutQueryOk(LuaFFI.CType type,
                                     number size_bytes,
                                     number align_bytes,
                                     string layout_hash) unique
                     | LoadLibraryOk(LuaFFI.CLib library) unique
                     | ResolveSymbolOk(LuaFFI.CSymbol symbol) unique
                     | NewCDataOk(LuaFFI.CData cdata) unique
                     | CastOk(LuaFFI.CData cdata) unique
                     | FieldAccessOk(LuaFFI.CData owner,
                                     LuaFFI.CField field) unique
                     | IndexAccessOk(LuaFFI.CData owner,
                                     LuaFFI.CType element_type) unique
                     | FFICallOk(LuaFFI.CType return_type) unique
                     | CallbackOk(LuaFFI.CCallback callback) unique
                     | FinalizerOk(LuaFFI.CFinalizer finalizer) unique
                     | FFIErrorResult(LuaFFI.FFIError error) unique

    Fact = FFITypeEq(LuaFFI.CTypeId type_id,
                     LuaFFI.CType type) unique
         | FFISymbolResolved(LuaFFI.CSymbolId symbol,
                             string address_key) unique
         | FFILayoutEq(LuaFFI.CTypeId type_id,
                       string layout_hash) unique
         | FFICallbackLive(LuaFFI.CCallbackId callback) unique

    CValueConversion = LuaToCValue(LuaRT.ValueRef lua_value, LuaFFI.CType type) unique
                     | CToLuaValue(LuaFFI.CType type, LuaRT.ValueRef lua_value) unique

    FFICallShape = (LuaFFI.CSymbolId symbol,
                    LuaFFI.CAbi abi,
                    LuaFFI.CParamList params,
                    LuaFFI.CType return_type,
                    LuaFFI.CValueConversion* conversions,
                    LuaRT.CallRef call) unique

    CDataOwnershipTransition = (LuaFFI.CData cdata,
                                LuaFFI.OwnershipState from_state,
                                LuaFFI.OwnershipState to_state,
                                LuaFact.Dependency* deps) unique

    FFICallbackEntry = (LuaFFI.CCallbackId callback,
                        LuaFFI.CAbi abi,
                        LuaRT.CallShape call,
                        LuaRT.OutcomeCause cause) unique
}

module LuaRT {
    Name = (string text) unique
    Pc = (number value) unique
    Slot = (number index) unique
    Count = (number value) unique
    Ax = (number value) unique

    ValueTag = NilTag
             | EmptySlotTag
             | AbsentKeyTag
             | NoTableTag
             | FalseTag
             | TrueTag
             | IntegerTag
             | FloatTag
             | ShortStringTag
             | LongStringTag
             | TableTag
             | LuaClosureTag
             | CClosureTag
             | LightCFunctionTag
             | UserdataTag
             | LightUserdataTag
             | ThreadTag
             | CDataTag

    NilKind = OrdinaryNil
            | EmptySlotSentinel
            | AbsentKeySentinel
            | NoTableSentinel

    BoolKind = LuaFalse | LuaTrue
    NumberKind = IntegerNumber | FloatNumber
    StringKind = ShortString | LongString
    GCColor = White | Gray | Black

    FrameRef = (LuaRT.Name name) unique
    StackRef = (LuaRT.FrameRef frame) unique
    ConstRef = (number index) unique
    ProtoRef = (LuaSrc.KRef proto) unique
    UpvalueRef = (LuaRT.Name name) unique
    VarargRef = (LuaRT.FrameRef frame) unique
    TableRef = (LuaRT.Name name) unique
    StringRef = (LuaRT.Name name) unique
    ClosureRef = (LuaRT.Name name) unique
    FunctionRef = (LuaRT.Name name) unique
    UserdataRef = (LuaRT.Name name) unique
    ThreadRef = (LuaRT.Name name) unique
    PointerRef = (LuaRT.Name name) unique

    UpvalueStorageKind = OpenStackUpvalue | ClosedHeapUpvalue | DeadUpvalue

    UpvalueIdentity = (LuaRT.UpvalueRef upvalue,
                       LuaRT.ProtoRef proto,
                       LuaRT.ClosureRef owner,
                       LuaRT.FrameRef frame,
                       LuaRT.Slot captured_slot,
                       LuaRT.UpvalueStorageKind storage,
                       number close_epoch,
                       number alias_epoch) unique

    ClosureIdentity = (LuaRT.ClosureRef closure,
                       LuaRT.ProtoRef proto,
                       LuaRT.UpvalueIdentity* upvalues,
                       number closure_epoch) unique

    ValueRef = StackValue(LuaRT.FrameRef frame, LuaRT.Slot slot) unique
             | ConstValue(LuaRT.ConstRef const) unique
             | UpvalueValue(LuaRT.UpvalueRef upvalue) unique
             | VarargValue(LuaRT.VarargRef vararg, LuaRT.Count index) unique
             | TempValue(LuaRT.Name name) unique
             | TableValue(LuaRT.TableRef table) unique
             | ClosureValue(LuaRT.ClosureRef closure) unique
             | UserdataValue(LuaRT.UserdataRef userdata) unique
             | ThreadValue(LuaRT.ThreadRef thread) unique

    TValue = NilValue(LuaRT.NilKind kind) unique
           | BoolValue(LuaRT.BoolKind kind) unique
           | IntValue(number value) unique
           | FloatValue(number value) unique
           | StringValue(LuaRT.StringRef string, LuaRT.StringKind kind) unique
           | TableValueNode(LuaRT.TableRef table) unique
           | LuaClosureValue(LuaRT.ClosureRef closure) unique
           | CClosureValue(LuaRT.ClosureRef closure) unique
           | LightCFunctionValue(LuaRT.FunctionRef function) unique
           | UserdataValueNode(LuaRT.UserdataRef userdata) unique
           | LightUserdataValue(LuaRT.PointerRef pointer) unique
           | ThreadValueNode(LuaRT.ThreadRef thread) unique
           | CDataValueNode(LuaFFI.CData cdata) unique

    ValueProjection = ProjectTag
                    | ProjectNilKind
                    | ProjectBool
                    | ProjectInteger
                    | ProjectFloat
                    | ProjectStringRef
                    | ProjectTableRef
                    | ProjectClosureRef
                    | ProjectUserdataRef
                    | ProjectThreadRef
                    | ProjectPayloadBits

    TypeTest = IsNil
             | IsOrdinaryNil
             | IsFalse
             | IsFalsey
             | IsTruthy
             | IsBoolean
             | IsInteger
             | IsFloat
             | IsNumber
             | IsString
             | IsTable
             | IsLuaClosure
             | IsCClosure
             | IsFunction
             | IsUserdata
             | IsThread
             | IsCData
             | IsCollectable
             | IsAbsentKey
             | IsEmptySlot

    Truthiness = FalseyNil
               | FalseyFalse
               | TruthyValue

    CountSpec = FixedCount(number count) unique
              | OpenFromTop(LuaRT.TopRef top) unique
              | OpenFromVarargs(LuaRT.VarargSource source) unique
              | OpenFromVarargsAtBase(LuaRT.Slot base, LuaRT.VarargSource source) unique
              | DynamicCount(LuaRT.ValueRef count_value) unique
              | UnknownCount(string reason) unique

    TopRef = (LuaRT.FrameRef frame) unique

    StackWindowKind = CallWindow
                    | ReturnWindow
                    | VarargWindow
                    | ConstructorWindow
                    | IteratorWindow
                    | AssignmentWindow

    StackWindow = (LuaRT.StackWindowKind kind,
                   LuaRT.FrameRef frame,
                   LuaRT.Slot base,
                   LuaRT.CountSpec count) unique

    ValueSeqKind = FixedSeq
                 | OpenSeq
                 | AdjustedSeq
                 | VarargSeq
                 | CallResultSeq

    ValueSeq = (LuaRT.ValueSeqKind kind,
                LuaRT.ValueRef* values,
                LuaRT.CountSpec count,
                LuaRT.SequenceOrigin origin) unique

    SequenceOrigin = FromStackWindow(LuaRT.StackWindow window) unique
                   | FromCallResult(LuaRT.CallRef call) unique
                   | FromVarargs(LuaRT.VarargSource source) unique
                   | FromLiteralValues unique
                   | FromAdjusted(LuaRT.ValueSeq source) unique
                   | FromArityNormalization(LuaRT.ArityNormalization normalization) unique

    ResultAdjustment = ExactCount(LuaRT.Count count) unique
                     | OpenResult unique
                     | FillNilTo(LuaRT.Count count) unique
                     | TruncateTo(LuaRT.Count count) unique
                     | PropagateOpenTail unique

    ArityKind = FixedArity
              | OpenArity
              | VarargArity
              | UnknownArity

    ArityShape = (LuaRT.CountSpec provided,
                  LuaRT.CountSpec wanted,
                  LuaRT.ResultAdjustment adjustment,
                  LuaRT.ArityKind kind) unique

    ResultRouteKind = DirectReturnRoute
                    | OutcomeReturnRoute
                    | StackWindowRoute
                    | ContinuationRoute
                    | TailCallFrameRoute
                    | YieldRoute
                    | ClosePendingRoute

    ResultDestination = ReturnDestination unique
                      | OutcomeDestination unique
                      | StackWindowDestination(LuaRT.StackWindow window) unique
                      | ContinuationDestination(LuaRT.Name continuation) unique
                      | TailCallDestination(LuaRT.FrameRef frame) unique
                      | YieldDestination(LuaRT.ResumePoint resume_point) unique
                      | ClosePendingDestination(LuaRT.CloseChain chain) unique

    ResultChannel = (LuaRT.Name id,
                     LuaRT.ResultRouteKind kind,
                     LuaRT.ResultDestination destination,
                     LuaRT.CountSpec count) unique

    ResultBundle = (LuaRT.ValueSeq values,
                    LuaRT.ResultChannel channel) unique

    FrameEffectKind = SetTopEffect | StoreSeqEffect | ReplaceFrameEffect | PreserveFrameEffect

    FrameEffect = (LuaRT.FrameEffectKind kind,
                   LuaRT.FrameRef frame,
                   LuaRT.StackWindow window,
                   LuaRT.CountSpec count) unique

    ArityNormalization = (LuaRT.ValueSeq source,
                          LuaRT.ArityShape shape,
                          LuaRT.ResultBundle result,
                          LuaRT.FrameEffect* effects) unique

    Frame = (LuaRT.FrameRef id,
             LuaRT.StackRef stack,
             LuaRT.TopRef top,
             LuaRT.VarargSource varargs,
             LuaRT.CloseChain close_chain,
             LuaRT.Pc pc) unique

    VarargSource = NoVarargs unique
                 | HiddenFrameVarargs(LuaRT.FrameRef frame, LuaRT.Count count) unique
                 | VarargTableSource(LuaRT.TableRef table, LuaRT.Count count) unique

    VarargAccess = VarargIndex(LuaRT.VarargSource source, LuaRT.ValueRef key) unique
                 | VarargFixedCopy(LuaRT.VarargSource source, LuaRT.Count count) unique
                 | VarargOpenCopy(LuaRT.VarargSource source) unique
                 | VarargNField(LuaRT.VarargSource source) unique

    TableShape = ArrayOnly
               | HashOnly
               | MixedArrayHash
               | UnknownShape

    TableHashEntryState = HashEmpty
                        | HashOccupied
                        | HashTombstone

    TableHashEntry = (LuaRT.TableHashEntryState state,
                      LuaRT.ValueRef key,
                      LuaRT.ValueRef value) unique

    TableRefState = (LuaRT.TableRef table,
                     LuaRT.TableShape shape,
                     LuaRT.MetatableRef metatable) unique

    MetatableRef = NoMetatable unique
                 | TableMetatable(LuaRT.TableRef table) unique
                 | UserdataMetatable(LuaRT.UserdataRef userdata) unique
                 | TypeMetatable(LuaRT.ValueTag tag) unique
                 | UnknownMetatable unique

    RawGetResult = RawHit(LuaRT.ValueRef value) unique
                 | RawMiss(LuaRT.NilKind absent_sentinel) unique

    RawSetResult = RawUpdated unique
                 | RawInserted unique
                 | RawSetNilKeyError unique
                 | RawSetNaNKeyError unique
                 | RawSetBarrierRequired unique

    TableLookupState = LookupStart(LuaRT.ValueRef table, LuaRT.ValueRef key) unique
                     | LookupRawTable(LuaRT.TableRef table, LuaRT.ValueRef key) unique
                     | LookupMetatable(LuaRT.ValueRef receiver, LuaRT.Metamethod method) unique
                     | LookupIndexTableChain(LuaRT.TableRef next_table, LuaRT.Count depth) unique
                     | LookupIndexFunctionCall(LuaRT.ValueRef function, LuaRT.ValueRef receiver, LuaRT.ValueRef key) unique
                     | LookupComplete(LuaRT.ValueRef value) unique
                     | LookupTypeError(LuaRT.ValueRef receiver, LuaRT.ValueRef key) unique
                     | LookupLoopLimitExceeded unique

    TableSetState = SetStart(LuaRT.ValueRef table, LuaRT.ValueRef key, LuaRT.ValueRef value) unique
                  | SetRawTable(LuaRT.TableRef table, LuaRT.ValueRef key, LuaRT.ValueRef value) unique
                  | SetMetatable(LuaRT.ValueRef receiver, LuaRT.Metamethod method) unique
                  | SetNewIndexTableChain(LuaRT.TableRef next_table, LuaRT.Count depth) unique
                  | SetNewIndexFunctionCall(LuaRT.ValueRef function, LuaRT.ValueRef receiver, LuaRT.ValueRef key, LuaRT.ValueRef value) unique
                  | SetComplete unique
                  | SetTypeError(LuaRT.ValueRef receiver, LuaRT.ValueRef key) unique
                  | SetLoopLimitExceeded unique

    -- PUC ltm.h order: INDEX, NEWINDEX, GC, MODE, LEN, EQ, arithmetic,
    -- bitwise, unary, order, CONCAT, CALL, CLOSE.
    Metamethod = TM_INDEX
               | TM_NEWINDEX
               | TM_GC
               | TM_MODE
               | TM_LEN
               | TM_EQ
               | TM_ADD
               | TM_SUB
               | TM_MUL
               | TM_MOD
               | TM_POW
               | TM_DIV
               | TM_IDIV
               | TM_BAND
               | TM_BOR
               | TM_BXOR
               | TM_SHL
               | TM_SHR
               | TM_UNM
               | TM_BNOT
               | TM_LT
               | TM_LE
               | TM_CONCAT
               | TM_CALL
               | TM_CLOSE

    MetatableEpoch = (LuaRT.MetatableRef metatable, number epoch) unique

    MetamethodSlot = (LuaRT.MetatableRef metatable,
                      LuaRT.Metamethod method,
                      LuaRT.ValueRef slot_value,
                      number slot_epoch) unique

    MetamethodLookupStep = CheckReceiverMetatable(LuaRT.ValueRef receiver, LuaRT.MetatableEpoch epoch) unique
                         | CheckTypeMetatable(LuaRT.ValueTag tag, LuaRT.MetatableEpoch epoch) unique
                         | CheckMetamethodSlot(LuaRT.MetamethodSlot slot) unique
                         | FollowIndexTable(LuaRT.TableRef table, number depth) unique
                         | InvokeMetamethodCandidate(LuaRT.ValueRef function) unique

    MetamethodLookupResult = MetamethodFoundResult(LuaRT.ValueRef function) unique
                           | MetamethodMissingResult unique
                           | MetamethodLookupTypeError(LuaRT.ValueRef receiver) unique
                           | MetamethodLookupLoopLimitExceeded unique

    MetamethodLookupPath = (LuaRT.ValueRef receiver,
                            LuaRT.Metamethod method,
                            LuaRT.MetamethodLookupStep* steps,
                            LuaRT.MetamethodLookupResult result,
                            LuaFact.Dependency* deps) unique

    MetamethodDispatch = (LuaRT.MetamethodLookupPath path,
                          LuaRT.CallShape call,
                          LuaRT.ResultChannel result_channel) unique

    CallRef = (LuaRT.Name name) unique

    CallableKind = CallableLuaClosure
                 | CallableCClosure
                 | CallableLightCFunction
                 | CallableViaCallMetamethod
                 | NotCallable

    TailCallMode = NotTailCall | TailCallReplace | TailCallWithClose
    YieldPolicy = NonYieldingCall | YieldingCall | YieldForbidden

    CallShape = (LuaRT.CallRef call,
                 LuaRT.ValueRef callee,
                 LuaRT.StackWindow args,
                 LuaRT.CountSpec wanted_results,
                 LuaRT.TailCallMode tail_mode,
                 LuaRT.YieldPolicy yield_policy) unique

    CallContinuationKind = CallReturn
                         | CallError
                         | CallYield
                         | TailCallReplaceFrame
                         | CallMetamethodRetry

    CallResult = (LuaRT.CallRef call,
                  LuaRT.ValueSeq results,
                  LuaRT.CallContinuationKind continuation) unique

    CallTarget = UnknownCallTarget(LuaRT.ValueRef callee) unique
               | DirectLuaClosureTarget(LuaRT.ValueRef callee, LuaRT.ClosureRef closure) unique
               | DirectCClosureTarget(LuaRT.ValueRef callee, LuaRT.ClosureRef closure) unique
               | DirectLightCFunctionTarget(LuaRT.ValueRef callee, LuaRT.FunctionRef function) unique
               | MetamethodFunctionTarget(LuaRT.ValueRef callee, LuaRT.MetamethodLookupPath path) unique
               | FFISymbolTarget(LuaRT.ValueRef callee, LuaFFI.CSymbolId symbol) unique

    CallStateKind = CallStart
                  | CallTargetResolved
                  | CallFramePrepared
                  | CallRunning
                  | CallResultsReady
                  | CallErrored
                  | CallYielded
                  | CallUnsupported

    CallState = (LuaRT.CallRef call,
                 LuaRT.CallShape shape,
                 LuaRT.CallTarget target,
                 LuaRT.CallStateKind state,
                 LuaRT.ResultChannel result_channel) unique

    CallFrameRef = (LuaRT.Name name) unique

    CallTargetIdentity = UnknownTargetIdentity unique
                       | LuaClosureTargetIdentity(LuaRT.ClosureRef closure,
                                                   LuaSrc.KRef proto,
                                                   number closure_handle,
                                                   LuaFact.Dependency* deps) unique
                       | CClosureTargetIdentity(LuaRT.ClosureRef closure,
                                                 number function_handle,
                                                 LuaFact.Dependency* deps) unique
                       | LightCFunctionTargetIdentity(LuaRT.FunctionRef function,
                                                        number function_handle,
                                                        LuaFact.Dependency* deps) unique
                       | MetamethodTargetIdentity(LuaRT.MetamethodLookupPath path,
                                                  LuaFact.Dependency* deps) unique
                       | FFISymbolTargetIdentity(LuaFFI.CSymbolId symbol,
                                                 LuaFact.Dependency* deps) unique

    ResolvedCallTarget = (LuaRT.CallRef call,
                          LuaRT.CallTarget target,
                          LuaRT.CallTargetIdentity identity,
                          LuaRT.CallableKind callable) unique

    CallArgChannel = (LuaRT.CallRef call,
                      LuaRT.ValueSeq args,
                      LuaRT.ArityShape shape) unique

    CallFrameLayout = (LuaRT.CallFrameRef id,
                       LuaRT.FrameRef caller,
                       LuaRT.FrameRef callee,
                       LuaRT.Slot callee_slot,
                       LuaRT.Slot arg_base,
                       LuaRT.CountSpec arg_count,
                       LuaRT.Slot result_base,
                       LuaRT.CountSpec result_count,
                       LuaRT.Count frame_slots) unique

    CallFrameStateKind = CallFrameUnprepared
                       | CallFrameArgsStored
                       | CallFrameActive
                       | CallFrameResultsReady
                       | CallFrameReleased
                       | CallFrameUnsupported

    CallResultChannel = (LuaRT.CallRef call,
                         LuaRT.ResultChannel channel,
                         LuaRT.ArityNormalization normalization) unique

    CallFrameState = (LuaRT.CallRef call,
                      LuaRT.CallFrameLayout layout,
                      LuaRT.CallArgChannel args,
                      LuaRT.CallResultChannel results,
                      LuaRT.ResolvedCallTarget target,
                      LuaRT.CallFrameStateKind state) unique

    ErrorKind = TypeError
              | ArithmeticError
              | CompareError
              | TableIndexNilError
              | TableIndexNaNError
              | NotCallableError
              | CloseError
              | RuntimeError
              | ErrNnilError

    ErrorState = (LuaRT.ErrorKind kind,
                  LuaRT.ValueRef error_object,
                  LuaRT.Pc saved_pc,
                  LuaRT.TopRef saved_top) unique

    YieldState = (LuaRT.Pc saved_pc,
                  LuaRT.TopRef saved_top,
                  LuaRT.ValueSeq yielded_values,
                  LuaRT.ResumePoint resume_point) unique

    ResumePoint = ResumeCall
                | ResumeMetamethod
                | ResumeTableGet
                | ResumeTableSet
                | ResumeArithmetic
                | ResumeComparison
                | ResumeConcat
                | ResumeClose
                | ResumeReturn
                | ResumeTForCall

    CloseChain = (LuaRT.FrameRef frame,
                  LuaRT.CloseItem* items) unique

    CloseItem = (LuaRT.Slot slot,
                 LuaRT.ValueRef value,
                 LuaRT.CloseState state) unique

    CloseState = ClosePending
               | CloseSkippedFalsey
               | CloseMethodLookup
               | CloseMethodFound(LuaRT.ValueRef method) unique
               | CloseCallRunning
               | CloseComplete
               | CloseErrorState(LuaRT.ErrorState error) unique
               | CloseYieldState(LuaRT.YieldState yield) unique

    OutcomeCause = DirectReturnCause
                 | CallCause(LuaRT.CallRef call) unique
                 | MetamethodCause(LuaRT.MetamethodLookupPath path) unique
                 | IteratorCause(LuaRT.LoopTopology topology) unique
                 | CloseCause(LuaRT.CloseChain chain) unique
                 | FinalizerCause(LuaRT.Name finalizer) unique
                 | AllocationCause(LuaRT.Name allocation) unique
                 | FFICallbackCause(LuaFFI.CCallbackId callback) unique

    CloseAction = CloseSkipFalsey(LuaRT.CloseItem item) unique
                | CloseLookupMethod(LuaRT.CloseItem item, LuaRT.MetamethodLookupPath path) unique
                | CloseInvokeMethod(LuaRT.CloseItem item, LuaRT.CallShape call) unique
                | ClosePropagateOriginal(LuaRT.ResultBundle result) unique
                | CloseReplaceWithError(LuaRT.ErrorState error) unique
                | CloseYieldAndResume(LuaRT.YieldState yield) unique

    ClosePlan = (LuaRT.CloseChain chain,
                 LuaRT.OutcomeCause cause,
                 LuaRT.CloseAction* actions,
                 LuaRT.ResultBundle pending_result) unique

    LoopTopology = NumericForTopology(LuaRT.Pc prep_pc, LuaRT.Pc loop_pc, LuaRT.Pc body_start, LuaRT.Pc exit_pc) unique
                 | GenericForTopology(LuaRT.Pc prep_pc, LuaRT.Pc call_pc, LuaRT.Pc loop_pc, LuaRT.Pc body_start, LuaRT.Pc exit_pc) unique

    NumericForState = IntegerForState(LuaRT.Slot base,
                                      LuaRT.ValueRef count,
                                      LuaRT.ValueRef step,
                                      LuaRT.ValueRef control) unique
                    | FloatForState(LuaRT.Slot base,
                                    LuaRT.ValueRef limit,
                                    LuaRT.ValueRef step,
                                    LuaRT.ValueRef control) unique

    GenericForState = (LuaRT.Slot base,
                       LuaRT.ValueRef iterator,
                       LuaRT.ValueRef state,
                       LuaRT.ValueRef control,
                       LuaRT.ValueRef closing,
                       LuaRT.Count wanted_results) unique

    SetListState = (LuaRT.TableRef table,
                    LuaRT.StackWindow values,
                    LuaRT.CountSpec value_count,
                    LuaRT.Count start_index,
                    boolean uses_extraarg,
                    LuaRT.Ax extraarg) unique

    Guard = TypeGuard(LuaRT.ValueRef value, LuaRT.TypeTest test) unique
          | TagGuard(LuaRT.ValueRef value, LuaRT.ValueTag tag) unique
          | ShapeGuard(LuaRT.TableRef table, LuaRT.TableShape shape) unique
          | MetatableGuard(LuaRT.ValueRef value, LuaRT.MetatableRef metatable) unique
          | NonZeroGuard(LuaRT.ValueRef value) unique
          | BoundsGuard(LuaRT.StackWindow window) unique
          | CompanionGuard(LuaRT.Pc pc, LuaRT.CompanionKind kind) unique

    CompanionKind = FollowingJmp
                  | FollowingMMBIN
                  | FollowingExtraArg

    ArithmeticOp = ArithAdd
                 | ArithSub
                 | ArithMul
                 | ArithMod
                 | ArithPow
                 | ArithDiv
                 | ArithIDiv

    ArithmeticFallback = NumericArithmetic
                       | StringToNumberUnsupported
                       | MetamethodCallUnsupported
                       | ArithmeticTypeError

    ArithmeticCompanion = (LuaRT.Pc arithmetic_pc,
                           LuaRT.Pc companion_pc,
                           LuaRT.ArithmeticOp op,
                           boolean operands_flipped) unique

    OperationKind = OpAdd | OpSub | OpMul | OpMod | OpPow | OpDiv | OpIDiv
                  | OpBand | OpBor | OpBXor | OpShl | OpShr
                  | OpUnm | OpBNot | OpNot | OpLen | OpConcat
                  | OpEq | OpLt | OpLe | OpTest | OpTestSet

    OperandSourceKind = RegisterOperand | ImmediateOperand | ConstantOperand

    OperationOperand = (LuaRT.OperandSourceKind source,
                        LuaRT.ValueRef value,
                        boolean flipped) unique

    CompanionContext = NoCompanion unique
                     | MMBINCompanion(LuaRT.Pc pc, LuaRT.Metamethod method) unique
                     | MMBINICompanion(LuaRT.Pc pc, LuaRT.Metamethod method, boolean operands_flipped) unique
                     | MMBINKCompanion(LuaRT.Pc pc, LuaRT.Metamethod method, boolean operands_flipped) unique
                     | ExtraArgCompanion(LuaRT.Pc pc, LuaRT.Ax ax) unique

    LuaOperation = (LuaRT.Pc pc,
                    LuaRT.OperationKind kind,
                    LuaRT.OperationOperand* operands,
                    LuaRT.ValueRef* results,
                    LuaRT.CompanionContext companion,
                    LuaRT.MetamethodLookupPath metamethod_path) unique
}

module LuaGC {
    Name = (string text) unique

    GCObjectRef = (LuaGC.Name name) unique

    GCColor = White0
            | White1
            | Gray
            | Black
            | Fixed
            | Dead

    GCObjectKind = StringKind
                 | TableKind
                 | ClosureKind
                 | ProtoKind
                 | ThreadKind
                 | UserdataKind
                 | CDataKind
                 | UpvalueKind

    GCPhase = Pause
            | Propagate
            | Atomic
            | SweepString
            | SweepObjects
            | CallFinalizers

    GCRef = NoGCRef unique
          | SomeGCRef(LuaGC.GCObjectRef object) unique

    GCHeader = (LuaGC.GCObjectRef object,
                LuaGC.GCRef next,
                LuaGC.GCObjectKind kind,
                LuaGC.GCColor color,
                number flags,
                number epoch) unique

    GCLimits = (number pause_debt,
                number step_multiplier,
                number emergency_threshold) unique

    GCLists = (LuaGC.GCRef all,
               LuaGC.GCRef gray,
               LuaGC.GCRef gray_again,
               LuaGC.GCRef weak_tables,
               LuaGC.GCRef ephemeron_tables,
               LuaGC.GCRef finalizable,
               LuaGC.GCRef to_finalize) unique

    Allocator = (LuaGC.Name ctx,
                 LuaGC.Name alloc_fn,
                 LuaGC.Name realloc_fn,
                 LuaGC.Name free_fn) unique

    GCState = (LuaGC.GCPhase phase,
               LuaGC.GCColor current_white,
               LuaGC.GCLists lists,
               number total_bytes,
               number debt,
               LuaGC.GCLimits limits,
               number global_epoch,
               number barrier_epoch,
               LuaGC.Allocator allocator) unique

    TValueTag = GCNilTag
              | GCBoolTag
              | GCI64Tag
              | GCF64Tag
              | GCStringTag
              | GCTableTag
              | GCClosureTag
              | GCUserdataTag
              | GCCDataTag
              | GCThreadTag
              | GCLightUserdataTag

    LuaValueGCRef = (LuaRT.ValueRef value,
                     LuaGC.TValueTag tag,
                     LuaGC.GCRef ref) unique

    LuaTValueGCRef = (LuaRT.TValue value,
                      LuaGC.TValueTag tag,
                      LuaGC.GCRef ref) unique

    FinalizerKind = NoFinalizerKind
                  | LuaGCMetamethodFinalizer(LuaRT.ValueRef method) unique
                  | FFICFunctionFinalizer(LuaFFI.CSymbolId symbol) unique
                  | FFILuaFinalizer(LuaFFI.CFinalizerId finalizer) unique
                  | UserdataFinalizer(LuaRT.ValueRef method) unique

    FinalizerRef = (LuaGC.Name id,
                    LuaGC.FinalizerKind kind,
                    boolean attached) unique

    FinalizerResult = FinalizerCompleted unique
                    | FinalizerYielded(LuaRT.YieldState yield) unique
                    | FinalizerErrored(LuaRT.ErrorState error) unique

    TString = (LuaGC.GCHeader header,
               LuaRT.StringRef string,
               number byte_len,
               number hash,
               string content_hash) unique

    TableObject = (LuaGC.GCHeader header,
                   LuaRT.TableRef table,
                   LuaRT.TableShape shape,
                   LuaRT.MetatableRef metatable,
                   number array_size,
                   number hash_size,
                   number table_epoch,
                   number shape_epoch) unique

    LClosure = (LuaGC.GCHeader header,
                LuaRT.ClosureRef closure,
                LuaRT.ProtoRef proto,
                LuaRT.UpvalueIdentity* upvalues) unique

    UserdataObject = (LuaGC.GCHeader header,
                      LuaRT.UserdataRef userdata,
                      LuaRT.MetatableRef metatable,
                      number payload_bytes,
                      LuaGC.FinalizerRef finalizer) unique

    CDataObject = (LuaGC.GCHeader header,
                   LuaFFI.CData cdata,
                   LuaFFI.CTypeId type_id,
                   LuaFFI.CStorage storage,
                   LuaGC.FinalizerRef finalizer) unique

    ProtoObject = (LuaGC.GCHeader header,
                   LuaRT.ProtoRef proto,
                   string proto_hash) unique

    ThreadObject = (LuaGC.GCHeader header,
                    LuaRT.ThreadRef thread,
                    LuaRT.FrameRef* frames) unique

    UpvalueObject = (LuaGC.GCHeader header,
                     LuaRT.UpvalueIdentity identity,
                     LuaRT.ValueRef value) unique

    CollectableObject = GCStringObject(LuaGC.TString string) unique
                      | GCTableObject(LuaGC.TableObject table) unique
                      | GCClosureObject(LuaGC.LClosure closure) unique
                      | GCUserdataObject(LuaGC.UserdataObject userdata) unique
                      | GCCDataObject(LuaGC.CDataObject cdata) unique
                      | GCProtoObject(LuaGC.ProtoObject proto) unique
                      | GCThreadObject(LuaGC.ThreadObject thread) unique
                      | GCUpvalueObject(LuaGC.UpvalueObject upvalue) unique

    RootKind = StackRoot(LuaRT.FrameRef frame, LuaRT.Slot slot) unique
             | RegistryRoot unique
             | GlobalTableRoot unique
             | MetatableCacheRoot unique
             | OpenUpvalueRoot(LuaRT.UpvalueRef upvalue) unique
             | CCallbackRoot(LuaFFI.CCallbackId callback) unique
             | JitMaterializedCodeRoot(LuaGC.Name template_id) unique

    GCRoot = (LuaGC.RootKind kind,
              LuaGC.GCRef value) unique

    RootSet = (LuaGC.GCRoot* roots) unique

    BarrierKind = ObjectToObjectBarrier(LuaGC.GCRef parent, LuaGC.GCRef child) unique
                | TableSlotBarrier(LuaRT.TableRef table, LuaRT.ValueRef value, LuaGC.GCRef child) unique
                | UpvalueWriteBarrier(LuaRT.UpvalueRef upvalue, LuaRT.ValueRef value, LuaGC.GCRef child) unique
                | CDataRefBarrier(LuaFFI.CData owner, LuaGC.GCRef child) unique

    BarrierAction = NoBarrierAction unique
                  | MarkChild(LuaGC.GCRef child) unique
                  | RegrayParent(LuaGC.GCRef parent) unique
                  | EnqueueGrayAgain(LuaGC.GCRef parent) unique

    GCFact = BarrierClean(LuaGC.BarrierKind barrier) unique
           | ObjectEpoch(LuaGC.GCRef object, number epoch) unique
           | TableEpoch(LuaRT.TableRef table, number epoch) unique
           | ShapeEpoch(string shape_key, number epoch) unique
           | GCPhaseFact(LuaGC.GCPhase phase) unique
           | NoFinalizerFact(LuaGC.GCRef object) unique
           | FinalizerAttachedFact(LuaGC.GCRef object, LuaGC.FinalizerRef finalizer) unique
           | LuaValueGCRefFact(LuaGC.LuaValueGCRef value_ref) unique
           | LuaTValueGCRefFact(LuaGC.LuaTValueGCRef value_ref) unique

    GCErrorKind = AllocationFailure
                | InvalidObjectRef
                | InvalidBarrier
                | FinalizerFailure
                | WeakProcessingFailure
                | InvariantFailure

    AllocRequest = (LuaGC.GCState state,
                    LuaGC.GCObjectKind kind,
                    number size_bytes,
                    number align_bytes) unique

    AllocResult = Allocated(LuaGC.GCHeader header) unique
                | AllocStepRequired(number debt) unique
                | AllocOutOfMemory(number size_bytes) unique
                | AllocEmergencyCollectRequired unique

    StepRequest = (LuaGC.GCState state,
                   number budget) unique

    StepResult = StepProgressed(number remaining_budget) unique
               | StepCompletedCycle unique
               | StepFinalizersPending(number count) unique
               | StepOutOfMemory unique

    MarkRequest = (LuaGC.GCState state,
                   LuaGC.GCRef ref) unique

    TraverseRequest = (LuaGC.GCState state,
                       LuaGC.GCRef ref) unique

    MarkResult = MarkSkipped(LuaGC.GCRef ref) unique
               | MarkEnqueued(LuaGC.GCRef ref) unique
               | TraverseChildren(LuaGC.GCRef parent, LuaGC.GCRef* children) unique
               | MarkError(LuaGC.GCErrorKind error) unique

    BarrierResult = BarrierCleanResult unique
                  | BarrierChildMarked(LuaGC.GCRef child) unique
                  | BarrierParentRegrayed(LuaGC.GCRef parent) unique
                  | BarrierErrored(LuaGC.GCErrorKind error) unique

    FinalizerRequest = (LuaGC.GCState state,
                        LuaGC.FinalizerRef finalizer,
                        LuaRT.ValueRef self,
                        LuaRT.ErrorState error_context) unique

    FinalizerProcessingResult = FinalizerProcessed(LuaGC.FinalizerResult result) unique
                              | FinalizersPending(number count) unique
                              | FinalizerProcessError(LuaGC.GCErrorKind error) unique

    WeakProcessRequest = (LuaGC.GCState state,
                          LuaRT.TableRef table) unique

    WeakProcessResult = WeakProcessed(number removed) unique
                      | WeakNeedsAnotherPass unique
                      | WeakProcessError(LuaGC.GCErrorKind error) unique

    EphemeronProcessRequest = (LuaGC.GCState state,
                               LuaRT.TableRef table) unique

    EphemeronProcessResult = EphemeronProcessed(number progressed) unique
                           | EphemeronNeedsAnotherPass unique
                           | EphemeronProcessError(LuaGC.GCErrorKind error) unique

    Control = AllocControl(LuaGC.AllocRequest request, LuaGC.AllocResult result) unique
            | StepControl(LuaGC.StepRequest request, LuaGC.StepResult result) unique
            | MarkControl(LuaGC.MarkRequest request, LuaGC.MarkResult result) unique
            | TraverseControl(LuaGC.TraverseRequest request, LuaGC.MarkResult result) unique
            | BarrierControl(LuaGC.BarrierKind barrier, LuaGC.BarrierAction action, LuaGC.BarrierResult result) unique
            | FinalizerControl(LuaGC.FinalizerRequest request, LuaGC.FinalizerProcessingResult result) unique
            | WeakProcessControl(LuaGC.WeakProcessRequest request, LuaGC.WeakProcessResult result) unique
            | EphemeronProcessControl(LuaGC.EphemeronProcessRequest request, LuaGC.EphemeronProcessResult result) unique

    GCEffect = GCAllocationEffect(LuaGC.AllocRequest request, LuaGC.AllocResult result) unique
             | GCRootEffect(LuaGC.RootSet roots) unique
             | GCBarrierEffect(LuaGC.BarrierKind barrier, LuaGC.BarrierAction action, LuaGC.BarrierResult result) unique
             | GCFinalizerEffect(LuaGC.FinalizerRequest request, LuaGC.FinalizerProcessingResult result) unique
             | GCEpochEffect(LuaGC.GCFact fact) unique
}

module LuaExec {
    Name = (string text) unique
    RegionId = (LuaExec.Name name) unique
    RegionRef = (LuaExec.RegionId id) unique

    Module = (LuaExec.Region* regions,
              LuaExec.Kernel* kernels) unique

    Kernel = (LuaExec.Name id,
              LuaRT.Frame frame,
              LuaExec.Region body,
              LuaExec.Contract contract) unique

    Region = (LuaExec.Name id,
              LuaExec.RegionKind kind,
              LuaExec.Param* params,
              LuaExec.Continuation* continuations,
              LuaExec.BlockId entry,
              LuaExec.Block* blocks) unique

    RegionKind = CoreWindowRegion
               | LoadMoveRegion
               | BranchRegion
               | ArithmeticRegion
               | TableAccessRegion
               | TableGetRegion
               | TableSetRegion
               | LenRegion
               | ConcatRegion
               | CallRegion
               | TailCallRegion
               | ReturnRegion
               | VarargRegion
               | SetListRegion
               | CloseRegion
               | MetatableRegion
               | ClosureRegion
               | UpvalueRegion
               | GCAllocRegion
               | FFIRegion
               | NumericForRegion
               | GenericForRegion
               | ErrorRegion
               | YieldRegion
               | GuardRegion
               | OpcodeFamilyRegion

    OpcodeFamily = LoadMoveFamily
                 | ArithmeticFamily
                 | CompareBranchFamily
                 | ReturnFamily
                 | CallFamily
                 | TailCallFamily
                 | TableAccessFamily
                 | TableSetFamily
                 | ConstructorFamily
                 | VarargFamily
                 | ClosureFamily
                 | UpvalueFamily
                 | NumericForFamily
                 | GenericForFamily
                 | CloseTBCFamily
                 | MetatableFamily
                 | GCFamily
                 | FFIFamily
                 | ErrorYieldFamily
                 | UnsupportedFamily

    RegionDescriptor = (LuaExec.RegionId id,
                        LuaExec.RegionKind kind,
                        LuaExec.OpcodeFamily family,
                        LuaRT.Pc start_pc,
                        LuaRT.Pc end_pc) unique

    ModuleId = (LuaExec.Name name) unique

    ModuleDescriptor = (LuaExec.ModuleId id,
                        LuaExec.RegionDescriptor* regions,
                        LuaExec.RegionDescriptor* kernels) unique

    StaticRegionRole = StaticCalleeBodyRegion
                     | StaticContinuationRegion
                     | StaticInlineOnlyRegion
                     | StaticKernelBodyRegion

    StaticRegionBinding = (LuaExec.RegionRef region,
                           LuaExec.RegionDescriptor descriptor,
                           LuaExec.StaticRegionRole role) unique

    CallContinuationRegion = (LuaRT.CallRef call,
                              LuaExec.RegionRef callee_region,
                              LuaExec.ContRef return_cont,
                              LuaExec.ContRef error_cont,
                              LuaExec.ContRef yield_cont) unique

    StaticRegionInvocation = (LuaExec.Name id,
                              LuaExec.StaticRegionBinding target,
                              LuaExec.Arg* args,
                              LuaExec.ContBinding* continuations,
                              LuaExec.CallContinuationRegion call_continuation) unique

    StaticCallProducts = (LuaRT.CallRef call,
                          LuaRT.CallShape call_shape,
                          LuaRT.ClosureIdentity closure,
                          LuaRT.ResolvedCallTarget resolved_target,
                          LuaRT.CallArgChannel arg_channel,
                          LuaRT.CallResultChannel result_channel,
                          LuaRT.ResultChannel result_route,
                          LuaRT.ArityNormalization result_normalization,
                          LuaRT.CallFrameLayout layout,
                          LuaRT.CallFrameState frame_state,
                          LuaExec.CallContinuationRegion call_continuation,
                          LuaExec.StaticRegionInvocation invocation,
                          LuaExec.StaticRegionBinding static_binding,
                          LuaExec.Region static_region,
                          LuaRT.FrameRef callee_frame,
                          LuaRT.FrameRef caller_frame,
                          number result_base,
                          number result_count,
                          number arg_count) unique

    StaticCallProductResult = StaticCallProductsOk(LuaExec.StaticCallProducts products) unique
                            | StaticCallProductsReject(string* errors) unique

    StaticClosureProducts = (number pc,
                             number slot,
                             LuaSrc.KRef proto,
                             LuaRT.ClosureIdentity closure,
                             LuaRT.ResolvedCallTarget resolved_target,
                             LuaExec.StaticRegionBinding static_binding,
                             LuaGC.GCEffect allocation,
                             number handle) unique

    StaticClosureProductResult = StaticClosureProductsOk(LuaExec.StaticClosureProducts products) unique
                               | StaticClosureProductsReject(string* errors) unique

    BlockId = (LuaExec.Name name) unique
    BlockRef = (LuaExec.BlockId id) unique

    Type = LuaValueType
         | LuaValueSeqType
         | LuaFrameType
         | LuaTableType
         | LuaStringType
         | LuaClosureType
         | LuaErrorType
         | LuaYieldType
         | LuaCountType
         | LuaBoolType
         | LuaNumberType
         | LuaValueWithTagType(LuaRT.ValueTag tag) unique
         | LuaValueWithTypeTestType(LuaRT.TypeTest test) unique
         | LalinType(string lalin_type) unique

    Param = (LuaExec.Name name,
             LuaExec.Type type) unique

    ContinuationKind = OkCont
                     | ErrorCont
                     | YieldCont
                     | ReturnCont
                     | GuardFailCont
                     | TailCallCont
                     | CloseCont
                     | LocalCont

    Continuation = (LuaExec.Name id,
                    LuaExec.ContinuationKind kind,
                    LuaExec.Param* params) unique

    ContRef = (LuaExec.Name id) unique

    ContBinding = (LuaExec.ContRef continuation,
                   LuaExec.BlockRef target,
                   LuaExec.Arg* args) unique

    Arg = (LuaExec.Name name,
           LuaExec.Value value) unique

    Value = RuntimeValue(LuaRT.ValueRef value) unique
          | RuntimeSeq(LuaRT.ValueSeq seq) unique
          | RuntimeFrame(LuaRT.FrameRef frame) unique
          | ConstTValue(LuaRT.TValue value) unique
          | TempValue(LuaExec.Name name) unique
          | UnitValue unique

    Expr = ValueExpr(LuaExec.Value value) unique
         | TypeTestExpr(LuaRT.ValueRef value, LuaRT.TypeTest test) unique
         | TruthinessExpr(LuaRT.ValueRef value) unique
         | NotTruthinessExpr(LuaRT.ValueRef value) unique
         | ProjectExpr(LuaRT.ValueRef value, LuaRT.ValueProjection projection) unique
         | StackLoadExpr(LuaRT.StackRef stack, LuaRT.Slot slot) unique
         | TopValueExpr(LuaRT.TopRef top) unique
         | CountExpr(LuaRT.CountSpec count) unique
         | ValueSeqExpr(LuaRT.ValueSeq seq) unique
         | VarargAccessExpr(LuaRT.VarargAccess access) unique
         | RawGetExpr(LuaRT.TableRef table, LuaRT.ValueRef key) unique
         | RawSetExpr(LuaRT.TableRef table, LuaRT.ValueRef key, LuaRT.ValueRef value) unique
         | TableRawGetExpr(LuaRT.ValueRef table_value, LuaRT.ValueRef key) unique
         | TableRawGetHitExpr(LuaExec.Value rawget) unique
         | TableRawGetValueOrNilExpr(LuaExec.Value rawget) unique
         | TableRawSetCanWriteExpr(LuaRT.ValueRef table_value, LuaRT.ValueRef key) unique
         | TableWriteBarrierNeededExpr(LuaRT.ValueRef table_value, LuaRT.ValueRef value) unique
         | TableLenExpr(LuaRT.ValueRef table_value) unique
         | StringLenExpr(LuaRT.ValueRef value) unique
         | LenNoMetaExpr(LuaRT.ValueRef value) unique
         | LenNoMetaOkExpr(LuaRT.ValueRef value) unique
         | StringConcat2Expr(LuaRT.ValueRef left, LuaRT.ValueRef right) unique
         | CDataAccessOkExpr(LuaRT.ValueRef cdata,
                             LuaFFI.CScalarKind scalar,
                             LuaFFI.CTypeId type_id,
                             number offset_bytes,
                             number width_bytes) unique
         | CDataScalarLoadExpr(LuaRT.ValueRef cdata,
                               LuaFFI.CScalarKind scalar,
                               LuaFFI.CTypeId type_id,
                               number offset_bytes,
                               number width_bytes) unique
         | ArithmeticNumericOkExpr(LuaRT.ArithmeticOp op, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
         | ArithmeticNoMetaExpr(LuaRT.ArithmeticOp op, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
         | ArithmeticErrorValueExpr(LuaRT.ArithmeticOp op, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
         | MetamethodLookupPathExpr(LuaRT.MetamethodLookupPath lookup) unique
         | LuaOperationExpr(LuaRT.LuaOperation operation) unique
         | AdjustResultsExpr(LuaRT.ValueSeq seq, LuaRT.ResultAdjustment adjustment) unique
         | NormalizeResultsExpr(LuaRT.ValueSeq seq, LuaRT.ArityShape shape) unique
         | ResultChannelExpr(LuaRT.ResultChannel channel) unique
         | CallStateExpr(LuaRT.CallState call) unique
         | ResolvedCallTargetExpr(LuaRT.ResolvedCallTarget target) unique
         | CallArgChannelExpr(LuaRT.CallArgChannel channel) unique
         | CallFrameStateExpr(LuaRT.CallFrameState frame) unique
         | CallResultChannelExpr(LuaRT.CallResultChannel channel) unique
         | MetamethodDispatchExpr(LuaRT.MetamethodDispatch dispatch) unique
         | ClosePlanExpr(LuaRT.ClosePlan plan) unique
         | GCEffectExpr(LuaGC.GCEffect effect) unique
         | RegionDescriptorExpr(LuaExec.RegionDescriptor descriptor) unique
         | StaticRegionBindingExpr(LuaExec.StaticRegionBinding binding) unique
         | StaticRegionInvocationExpr(LuaExec.StaticRegionInvocation invocation) unique
         | NumberOpExpr(LuaExec.NumberOp op, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
         | StringConcatExpr(LuaRT.ValueSeq values) unique

    NumberOp = Add
             | Sub
             | Mul
             | Mod
             | Pow
             | Div
             | IDiv
             | Band
             | Bor
             | Bxor
             | Shl
             | Shr
             | Unm
             | Bnot

    Choice = BoolChoice(LuaExec.Value value) unique
           | TypeChoice(LuaRT.ValueRef value, LuaRT.TypeTest test) unique
           | TruthinessChoice(LuaRT.ValueRef value) unique
           | NumericChoice(LuaExec.NumericTest test, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
           | EqualityChoice(LuaRT.ValueRef left, LuaRT.ValueRef right) unique
           | RawGetHitChoice(LuaRT.RawGetResult result) unique
           | ArithmeticNumericChoice(LuaRT.ArithmeticOp op, LuaRT.ValueRef left, LuaRT.ValueRef right) unique
           | MetamethodPresentChoice(LuaRT.MetamethodLookupPath lookup) unique
           | CountChoice(LuaRT.CountSpec count) unique
           | GuardChoice(LuaRT.Guard guard) unique

    NumericTest = Eq
                | Lt
                | Le
                | Gt
                | Ge
                | NonZero

    Op = Let(LuaExec.Name dst, LuaExec.Expr expr) unique
       | AssignValue(LuaRT.ValueRef dst, LuaExec.Value src) unique
       | AssignSeq(LuaRT.StackWindow dst, LuaRT.ValueSeq src, LuaRT.ResultAdjustment adjustment) unique
       | SetTop(LuaRT.TopRef top, LuaRT.CountSpec count) unique
       | TableRawSet(LuaRT.ValueRef table_value, LuaRT.ValueRef key, LuaRT.ValueRef value) unique
       | TableWriteBarrier(LuaRT.ValueRef table_value, LuaRT.ValueRef value) unique
       | CDataScalarStore(LuaRT.ValueRef cdata,
                          LuaFFI.CScalarKind scalar,
                          LuaFFI.CTypeId type_id,
                          number offset_bytes,
                          number width_bytes,
                          LuaRT.ValueRef value) unique
       | Project(LuaExec.Name dst, LuaRT.ValueRef src, LuaRT.ValueProjection projection) unique
       | Guard(LuaRT.Guard guard, LuaExec.ContRef on_fail) unique
       | PrepareCallFrame(LuaRT.CallFrameState frame) unique
       | ReceiveCallResults(LuaRT.CallFrameState frame) unique
       | EmitRegion(LuaExec.Name region, LuaExec.Arg* args, LuaExec.ContBinding* continuations) unique

    Terminator = Jump(LuaExec.BlockRef target, LuaExec.Arg* args) unique
               | Branch(LuaExec.Choice choice, LuaExec.BlockRef if_true, LuaExec.BlockRef if_false) unique
               | BranchArgs(LuaExec.Choice choice,
                            LuaExec.BlockRef if_true, LuaExec.Arg* true_args,
                            LuaExec.BlockRef if_false, LuaExec.Arg* false_args) unique
               | Continue(LuaExec.ContRef continuation, LuaExec.Arg* args) unique
               | Return(LuaRT.ValueSeq values) unique
               | Error(LuaRT.ErrorState error) unique
               | Yield(LuaRT.YieldState yield) unique
               | Unreachable unique

    Block = (LuaExec.BlockId id,
             LuaExec.Param* params,
             LuaExec.Op* ops,
             LuaExec.Terminator terminator) unique

    Contract = (LuaExec.Obligation* obligations,
                LuaExec.Guarantee* guarantees) unique

    Obligation = RequiresGuard(LuaRT.Guard guard) unique
               | RequiresResolvedRegion(LuaExec.Name region) unique
               | RequiresContinuation(LuaExec.ContRef continuation) unique
               | RequiresCompanion(LuaRT.Pc pc, LuaRT.CompanionKind kind) unique
               | RequiresRegionDescriptor(LuaExec.RegionDescriptor descriptor) unique
               | RequiresArityShape(LuaRT.ArityShape shape) unique
               | RequiresResultChannel(LuaRT.ResultChannel channel) unique
               | RequiresResolvedCallTarget(LuaRT.ResolvedCallTarget target) unique
               | RequiresCallFrameLayout(LuaRT.CallFrameLayout layout) unique
               | RequiresCallArgChannel(LuaRT.CallArgChannel channel) unique
               | RequiresCallResultChannel(LuaRT.CallResultChannel channel) unique
               | RequiresResultRoute(LuaRT.ResultChannel channel) unique
               | RequiresFrameEffect(LuaRT.FrameEffect effect) unique
               | RequiresStaticRegion(LuaExec.StaticRegionBinding binding) unique
               | RequiresStaticRegionInvocation(LuaExec.StaticRegionInvocation invocation) unique
               | RequiresCallContinuationRegion(LuaExec.CallContinuationRegion region) unique
               | RequiresMetamethodLookupPath(LuaRT.MetamethodLookupPath path) unique
               | RequiresClosureIdentity(LuaRT.ClosureIdentity identity) unique
               | RequiresUpvalueIdentity(LuaRT.UpvalueIdentity identity) unique
               | RequiresGCEffect(LuaGC.GCEffect effect) unique
               | RequiresFFICallShape(LuaFFI.FFICallShape call) unique
               | RequiresLuaOperation(LuaRT.LuaOperation operation) unique
               | RequiresLoopTopology(LuaRT.LoopTopology topology) unique
               | RequiresClosePlan(LuaRT.ClosePlan plan) unique

    Guarantee = ProducesValue(LuaRT.ValueRef value) unique
              | PreservesFrame(LuaRT.FrameRef frame) unique
              | UpdatesTop(LuaRT.TopRef top) unique
              | ClosesChain(LuaRT.CloseChain chain) unique
              | DescribesRegion(LuaExec.RegionDescriptor descriptor) unique
              | NormalizesArity(LuaRT.ArityNormalization normalization) unique
              | ProducesResultChannel(LuaRT.ResultChannel channel) unique
              | ResolvesCallTarget(LuaRT.ResolvedCallTarget target) unique
              | PreparesCallFrame(LuaRT.CallFrameState frame) unique
              | ProducesCallResults(LuaRT.CallResultChannel channel) unique
              | ProducesResultRoute(LuaRT.ResultChannel channel) unique
              | AppliesFrameEffect(LuaRT.FrameEffect effect) unique
              | ProvidesStaticRegion(LuaExec.StaticRegionBinding binding) unique
              | InvokesStaticRegion(LuaExec.StaticRegionInvocation invocation) unique
              | BindsCallContinuationRegion(LuaExec.CallContinuationRegion region) unique
              | ResolvesMetamethodLookupPath(LuaRT.MetamethodLookupPath path) unique
              | UsesClosureIdentity(LuaRT.ClosureIdentity identity) unique
              | UsesUpvalueIdentity(LuaRT.UpvalueIdentity identity) unique
              | AppliesGCEffect(LuaGC.GCEffect effect) unique
              | UsesFFICallShape(LuaFFI.FFICallShape call) unique
              | DescribesLuaOperation(LuaRT.LuaOperation operation) unique
              | DescribesLoopTopology(LuaRT.LoopTopology topology) unique
              | AppliesClosePlan(LuaRT.ClosePlan plan) unique
}

module CompileContract {
    FactRole = Selector | Required | Checked | Produced | Killed

    FactUse = (CompileContract.FactRole role,
               LuaFact.Subject subject,
               LuaFact.Predicate predicate,
               string value_key,
               LuaFact.Dependency* deps) unique

    PayloadUse = (LuaFact.PayloadLease payload) unique

    SemanticAssumption = AssumesCallTarget(LuaRT.CallTarget target) unique
                       | AssumesCallTargetIdentity(LuaRT.CallTargetIdentity identity) unique
                       | AssumesResolvedCallTarget(LuaRT.ResolvedCallTarget target) unique
                       | AssumesCallFrameLayout(LuaRT.CallFrameLayout layout) unique
                       | AssumesCallArgChannel(LuaRT.CallArgChannel channel) unique
                       | AssumesCallResultChannel(LuaRT.CallResultChannel channel) unique
                       | AssumesArityShape(LuaRT.ArityShape shape) unique
                       | AssumesResultChannel(LuaRT.ResultChannel channel) unique
                       | AssumesResultRoute(LuaRT.ResultChannel channel) unique
                       | AssumesFrameEffect(LuaRT.FrameEffect effect) unique
                       | AssumesMetatable(LuaRT.ValueRef value, LuaRT.MetatableRef metatable) unique
                       | AssumesMetatableEpoch(LuaRT.MetatableEpoch epoch) unique
                       | AssumesMetamethodLookupPath(LuaRT.MetamethodLookupPath path) unique
                       | AssumesNoMetamethod(LuaRT.MetamethodLookupPath path) unique
                       | AssumesClosureIdentity(LuaRT.ClosureIdentity identity) unique
                       | AssumesUpvalueIdentity(LuaRT.UpvalueIdentity identity) unique
                       | AssumesStaticRegion(LuaExec.StaticRegionBinding binding) unique
                       | AssumesStaticRegionInvocation(LuaExec.StaticRegionInvocation invocation) unique
                       | AssumesCallContinuationRegion(LuaExec.CallContinuationRegion region) unique
                       | AssumesRegionDescriptor(LuaExec.RegionDescriptor descriptor) unique
                       | AssumesModuleDescriptor(LuaExec.ModuleDescriptor descriptor) unique
                       | AssumesLuaOperation(LuaRT.LuaOperation operation) unique
                       | AssumesCompanionContext(LuaRT.CompanionContext companion) unique
                       | AssumesLoopTopology(LuaRT.LoopTopology topology) unique
                       | AssumesClosePlan(LuaRT.ClosePlan plan) unique
                       | AssumesOutcomeCause(LuaRT.OutcomeCause cause) unique
                       | AssumesGCEffect(LuaGC.GCEffect effect) unique
                       | AssumesGCObjectEpoch(LuaGC.GCFact fact) unique
                       | AssumesFinalizer(LuaGC.FinalizerRef finalizer) unique
                       | AssumesFFILayout(LuaFFI.CTypeId type_id, string layout_hash) unique
                       | AssumesFFICallShape(LuaFFI.FFICallShape call) unique
                       | AssumesFFICallbackEntry(LuaFFI.FFICallbackEntry callback) unique
                       | AssumesCDataOwnership(LuaFFI.CDataOwnershipTransition transition) unique

    Transfer = (CompileContract.FactUse* facts,
                CompileContract.PayloadUse* payloads) unique

    Obligation = RequiresFact(CompileContract.FactUse fact) unique
               | RequiresPayload(CompileContract.PayloadUse payload) unique
               | RequiresRuntimeGuard(LuaRT.Guard guard) unique
               | RequiresExecObligation(LuaExec.Obligation obligation) unique
               | RequiresCompanion(LuaRT.Pc pc, LuaRT.CompanionKind kind) unique
               | RequiresResolvedRegion(LuaExec.Name region) unique
               | RequiresContinuation(LuaExec.ContRef continuation) unique
               | RequiresSemanticAssumption(CompileContract.SemanticAssumption assumption) unique

    Guarantee = GuaranteesFact(CompileContract.FactUse fact) unique
              | GuaranteesExec(LuaExec.Guarantee guarantee) unique
              | ProducesRuntimeValue(LuaRT.ValueRef value) unique
              | PreservesRuntimeFrame(LuaRT.FrameRef frame) unique
              | UpdatesRuntimeTop(LuaRT.TopRef top) unique
              | GuaranteesSemanticAssumption(CompileContract.SemanticAssumption assumption) unique

    Contract = (CompileContract.Transfer transfer,
                CompileContract.Obligation* obligations,
                CompileContract.Guarantee* guarantees,
                LuaFact.Dependency* dependencies) unique
}

module LalinCFG {
    Name = (string text) unique
    TypeRef = (string lalin_type) unique
    KernelId = (LalinCFG.Name name) unique
    RegionId = (LalinCFG.Name name) unique
    BlockId = (LalinCFG.Name name) unique
    ContId = (LalinCFG.Name name) unique

    KernelKind = InlineSpan | FunctionFastPath

    OutcomeKind = NormalReturnOutcome | LuaErrorOutcome | LuaYieldOutcome

    ParamMode = ValueParam | ReadonlyPtr | WriteonlyPtr | NoaliasPtr
    Param = (LalinCFG.Name name, LalinCFG.TypeRef type, LalinCFG.ParamMode mode) unique

    ContinuationKind = LocalContinuation | RegionOk | RegionError | RegionYield | RegionGuardFail | KernelExit
    Continuation = (LalinCFG.ContId id, LalinCFG.Param* params, LalinCFG.ContinuationKind kind) unique

    RegionRef = (LalinCFG.RegionId id) unique
    BlockRef = (LalinCFG.BlockId id) unique
    ContRef = (LalinCFG.ContId id) unique

    Const = I64Const(number value) unique
          | F64Const(number value) unique
          | BoolConst(boolean value) unique
          | StringConst(string value) unique

    Place = StackSlot(number index) unique
          | ConstSlot(number index) unique
          | UpvalueSlot(number index) unique
          | VarargSlot(number index) unique
          | Temp(LalinCFG.Name name) unique
          | FrameTop unique
          | ExecCtx unique
          | TableField(LalinCFG.Value table, LalinCFG.Value key) unique
          | ArrayElement(LalinCFG.Value table, LalinCFG.Value index) unique

    Value = PlaceValue(LalinCFG.Place place) unique
          | ConstValue(LalinCFG.Const const) unique
          | ParamValue(LalinCFG.Name name) unique
          | UnitValue unique

    PrimOp = AddI64 | SubI64 | MulI64 | DivF64 | ModI64 | IDivI64
           | Eq | Lt | Le | Not | Truthy
           | LoadTag | LoadArrayLen | RawGet | RawSet
           | CheckNil | CheckNonNil
           | StringLen | StringConcatPrimitive

    Expr = ValueExpr(LalinCFG.Value value) unique
         | Primitive(LalinCFG.PrimOp op, LalinCFG.Value* args) unique
         | Load(LalinCFG.Place place) unique
         | AddressOf(LalinCFG.Place place) unique
         | Convert(LalinCFG.TypeRef type, LalinCFG.Value value) unique
         | RuntimeBoxNil(LuaRT.NilKind kind) unique
         | RuntimeBoxBool(LalinCFG.Value value) unique
         | RuntimeBoxI64(LalinCFG.Value value) unique
         | RuntimeBoxF64(LalinCFG.Value value) unique
         | RuntimeBoxRef(LuaRT.ValueTag tag, LalinCFG.Value handle) unique
         | RuntimeTag(LalinCFG.Value value) unique
         | RuntimePayloadI64(LalinCFG.Value value) unique
         | RuntimePayloadF64(LalinCFG.Value value) unique
         | RuntimeTruthiness(LalinCFG.Value value) unique
         | RuntimeTypeTest(LalinCFG.Value value, LuaRT.TypeTest test) unique
         | RuntimeOutcomeReturn(LalinCFG.Value count, LalinCFG.Value* values, LalinCFG.Value value_buffer) unique
         | RuntimeOutcomeReturnSeq(LalinCFG.Value seq) unique
         | RuntimeOutcomeError(LuaRT.ErrorKind kind, LalinCFG.Value error_value, LalinCFG.Value saved_pc, LalinCFG.Value saved_top) unique
         | RuntimeOutcomeYield(LuaRT.ResumePoint resume_point, LalinCFG.Value count, LalinCFG.Value* values, LalinCFG.Value saved_pc, LalinCFG.Value saved_top) unique
         | RuntimeOutcomeYieldSeq(LuaRT.ResumePoint resume_point,
                                  LalinCFG.Value seq,
                                  LalinCFG.Value saved_pc,
                                  LalinCFG.Value saved_top) unique
         | RuntimeStackLoad(LalinCFG.Value stack, LalinCFG.Value index) unique
         | RuntimeTopLoad(LalinCFG.Value top_ptr) unique
         | RuntimeOpenCountFromTop(LalinCFG.Value top, LalinCFG.Value base) unique
         | RuntimeValueSeqFixed(LalinCFG.Value count, LalinCFG.Value* values) unique
         | RuntimeValueSeqFromStack(LalinCFG.Value stack, LalinCFG.Value base, LalinCFG.Value count) unique
         | RuntimeValueSeqFromVarargs(LalinCFG.Value varargs, LalinCFG.Value count) unique
         | RuntimeValueSeqAdjust(LalinCFG.Value seq, LuaRT.ResultAdjustment adjustment) unique
         | RuntimeValueSeqNormalize(LalinCFG.Value seq, LuaRT.ArityShape shape) unique
         | RuntimeValueSeqCount(LalinCFG.Value seq) unique
         | RuntimeValueSeqValue(LalinCFG.Value seq, number index) unique
         | RuntimeValueSeqBuffer(LalinCFG.Value seq) unique
         | RuntimeValueSeqBase(LalinCFG.Value seq) unique
         | RuntimeClassifyCallee(LalinCFG.Value callee) unique
         | RuntimeCallTargetCheck(LalinCFG.Value callee,
                                  LuaRT.ResolvedCallTarget target) unique
         | RuntimeCallFramePrepare(LalinCFG.Value caller_stack,
                                   LalinCFG.Value callee_stack,
                                   LuaRT.CallFrameLayout layout,
                                   LalinCFG.Value args) unique
         | RuntimeCallFrameResultSeq(LalinCFG.Value callee_stack,
                                      LuaRT.CallFrameLayout layout,
                                      LuaRT.CallResultChannel channel) unique
         | RuntimeVarargSource(LalinCFG.Value values, LalinCFG.Value count, LalinCFG.Value table_handle) unique
         | RuntimeVarargCount(LalinCFG.Value source) unique
         | RuntimeVarargGet(LalinCFG.Value source, LalinCFG.Value key) unique
         | RuntimeTableRawGet(LalinCFG.Value tables, LalinCFG.Value table_value, LalinCFG.Value key) unique
         | RuntimeRawGetHit(LalinCFG.Value rawget) unique
         | RuntimeRawGetValue(LalinCFG.Value rawget) unique
         | RuntimeRawGetValueOrNil(LalinCFG.Value rawget) unique
         | RuntimeTableRawSetCanWrite(LalinCFG.Value tables, LalinCFG.Value table_value, LalinCFG.Value key) unique
         | RuntimeTableWriteBarrierNeeded(LalinCFG.Value tables, LalinCFG.Value table_value, LalinCFG.Value value) unique
         | RuntimeTableArrayLen(LalinCFG.Value tables, LalinCFG.Value table_value) unique
         | RuntimeStringLen(LalinCFG.Value strings, LalinCFG.Value value) unique
         | RuntimeLenNoMeta(LalinCFG.Value strings, LalinCFG.Value tables, LalinCFG.Value value) unique
         | RuntimeLenNoMetaOk(LalinCFG.Value strings, LalinCFG.Value tables, LalinCFG.Value value) unique
         | RuntimeStringConcat2(LalinCFG.Value strings, LalinCFG.Value left, LalinCFG.Value right) unique
         | RuntimeStringToNumberOk(LalinCFG.Value strings, LalinCFG.Value value) unique
         | RuntimeStringToNumber(LalinCFG.Value strings, LalinCFG.Value value) unique
         | RuntimeArithmeticNumericOk(LuaRT.ArithmeticOp op, LalinCFG.Value strings, LalinCFG.Value left, LalinCFG.Value right) unique
         | RuntimeArithmeticNoMeta(LuaRT.ArithmeticOp op, LalinCFG.Value strings, LalinCFG.Value left, LalinCFG.Value right) unique
         | RuntimeArithmeticErrorValue(LuaRT.ArithmeticOp op, LalinCFG.Value strings, LalinCFG.Value left, LalinCFG.Value right) unique
         | RuntimeCDataAccessOk(LalinCFG.Value cdata_bank,
                                LalinCFG.Value cdata_value,
                                LuaFFI.CScalarKind scalar,
                                LuaFFI.CTypeId type_id,
                                number offset_bytes,
                                number width_bytes) unique
         | RuntimeCDataLoadScalar(LalinCFG.Value cdata_bank,
                                  LalinCFG.Value cdata_value,
                                  LuaFFI.CScalarKind scalar,
                                  LuaFFI.CTypeId type_id,
                                  number offset_bytes,
                                  number width_bytes) unique
         | RuntimeOutcomeKind(LalinCFG.Value outcome) unique
         | RuntimeOutcomeCount(LalinCFG.Value outcome) unique
         | RuntimeOutcomeValueTag(LalinCFG.Value outcome, number index) unique
         | RuntimeOutcomeValuePayloadI64(LalinCFG.Value outcome, number index) unique
         | RuntimeOutcomeValuePayloadF64(LalinCFG.Value outcome, number index) unique
         | RuntimeOutcomeErrorKind(LalinCFG.Value outcome) unique
         | RuntimeOutcomeErrorValueTag(LalinCFG.Value outcome) unique
         | RuntimeOutcomeErrorValuePayloadI64(LalinCFG.Value outcome) unique
         | RuntimeOutcomeSavedPc(LalinCFG.Value outcome) unique
         | RuntimeOutcomeYieldKind(LalinCFG.Value outcome) unique

    Arg = (LalinCFG.Name name, LalinCFG.Value value) unique

    TypeTest = IsNil | IsBool | IsI64 | IsF64 | IsString | IsTable
             | IsClosure | IsFunction | IsThread | IsUserdata

    NumericTest = NumEq | NumLt | NumLe | NumGt | NumGe | NumNonZero

    Metamethod = Add | Sub | Mul | Mod | Pow | Div | IDiv | Band | Bor | Bxor
               | Shl | Shr | Unm | Bnot | EqMM | LtMM | LeMM | Index | NewIndex
               | Call | Len | Concat | Close

    Choice = BoolChoice(LalinCFG.Value value) unique
           | NilChoice(LalinCFG.Value value) unique
           | TypeChoice(LalinCFG.Value value, LalinCFG.TypeTest test) unique
           | NumericChoice(LalinCFG.NumericTest test, LalinCFG.Value left, LalinCFG.Value right) unique
           | EqualityChoice(LalinCFG.Value left, LalinCFG.Value right) unique
           | MetamethodPresentChoice(LalinCFG.Value value, LalinCFG.Metamethod metamethod) unique
           | GuardChoice(CompileContract.FactUse* facts) unique

    ExitProtocol = ReturnExit | ErrorExit | GuardDeoptExit | YieldExit | UnsupportedExit

    Projection = ValueKind | Payload | ArrayLength | Shape | Metatable

    ContBinding = (LalinCFG.ContRef continuation, LalinCFG.BlockRef target) unique

    Op = Let(LalinCFG.Place dst, LalinCFG.Expr expr) unique
       | Assign(LalinCFG.Place dst, LalinCFG.Value src) unique
       | Store(LalinCFG.Place dst, LalinCFG.Value src) unique
       | RuntimeStackStore(LalinCFG.Value stack, LalinCFG.Value index, LalinCFG.Value value) unique
       | RuntimeValueSeqStore(LalinCFG.Value stack,
                            LalinCFG.Value base,
                            LalinCFG.Value seq) unique
       | RuntimeCallFrameStoreArgs(LalinCFG.Value callee_stack,
                                   LuaRT.CallFrameLayout layout,
                                   LalinCFG.Value args) unique
       | RuntimeTopStore(LalinCFG.Value top_ptr, LalinCFG.Value top) unique
       | RuntimeTableRawSet(LalinCFG.Value tables, LalinCFG.Value table_value, LalinCFG.Value key, LalinCFG.Value value) unique
       | RuntimeTableWriteBarrier(LalinCFG.Value tables, LalinCFG.Value table_value, LalinCFG.Value value) unique
       | RuntimeCDataScalarStore(LalinCFG.Value cdata_bank,
                                LalinCFG.Value cdata_value,
                                LuaFFI.CScalarKind scalar,
                                LuaFFI.CTypeId type_id,
                                number offset_bytes,
                                number width_bytes,
                                LalinCFG.Value value) unique
       | EmitRegion(LalinCFG.RegionRef region, LalinCFG.Arg* args, LalinCFG.ContBinding* continuations) unique
       | Project(LalinCFG.Place dst, LalinCFG.Value src, LalinCFG.Projection projection) unique
       | Assert(LalinCFG.Expr condition, LalinCFG.ExitProtocol on_fail) unique

    SwitchArm = (LalinCFG.Const match, LalinCFG.BlockRef target) unique

    Terminator = Jump(LalinCFG.BlockRef target, LalinCFG.Arg* args) unique
               | Branch(LalinCFG.Choice choice, LalinCFG.BlockRef if_true, LalinCFG.BlockRef if_false) unique
               | BranchArgs(LalinCFG.Choice choice,
                            LalinCFG.BlockRef if_true, LalinCFG.Arg* true_args,
                            LalinCFG.BlockRef if_false, LalinCFG.Arg* false_args) unique
               | Switch(LalinCFG.Value value, LalinCFG.SwitchArm* arms, LalinCFG.BlockRef default) unique
               | Continue(LalinCFG.ContRef continuation, LalinCFG.Arg* args) unique
               | Return(LalinCFG.Value* values) unique
               | Exit(LalinCFG.ExitProtocol protocol, LalinCFG.Value* args) unique
               | Unreachable unique

    Block = (LalinCFG.BlockId id, LalinCFG.Param* params, LalinCFG.Op* ops, LalinCFG.Terminator terminator) unique

    Region = (LalinCFG.RegionId id,
              LalinCFG.Param* params,
              LalinCFG.Continuation* continuations,
              LalinCFG.BlockId entry,
              LalinCFG.Block* blocks) unique

    Kernel = (LalinCFG.KernelId id,
              LalinCFG.KernelKind kind,
              LalinCFG.Param* params,
              LalinCFG.TypeRef* returns,
              LalinCFG.Region body,
              CompileContract.Contract contract) unique

    Module = (LalinCFG.Region* regions, LalinCFG.Kernel* kernels) unique
}

module Stencil {
    Name = (string text) unique

    StencilModule = (Stencil.BankIndex bank,
                     Stencil.StencilTemplate* templates,
                     Stencil.Symbol* symbols,
                     Stencil.Linkage linkage) unique

    BankIndex = (Stencil.VariantKey* variants,
                 Stencil.TemplateIndexEntry* entries) unique

    TemplateIndexEntry = (Stencil.VariantKey key,
                          Stencil.Name template_name) unique

    StencilTemplate = (Stencil.Name name,
                       Stencil.StencilKind kind,
                       Stencil.VariantKey variant,
                       Stencil.CodeBlobRef code,
                       Stencil.PatchHole* holes,
                       Stencil.Reloc* relocs,
                       Stencil.Symbol* local_symbols,
                       Stencil.MaterializationPlan plan) unique

    StencilKind = KernelStencil
                | RegionStencil
                | BlockStencil
                | BranchStencil
                | CallStencil
                | GuardStencil
                | RuntimeBoundaryStencil

    VariantKey = (Stencil.StencilKind stencil_kind,
                  LalinCFG.KernelKind kernel_kind,
                  CompileContract.Contract contract,
                  Stencil.Placement placement,
                  Stencil.TargetABI target_abi,
                  Stencil.FeatureSet features) unique

    FeatureSet = (string arch,
                  string os,
                  string cpu_features,
                  string codegen_version) unique

    TargetABI = (string triple,
                 string calling_convention,
                 string pointer_width,
                 string endian) unique

    CodeBlobRef = (Stencil.Name symbol,
                   number byte_size,
                   string content_hash) unique

    Symbol = (Stencil.Name name,
              Stencil.SymbolKind kind,
              Stencil.SymbolVisibility visibility,
              number offset) unique

    SymbolKind = EntrySymbol
               | LocalLabel
               | ExternalTarget
               | ContinuationTarget
               | PatchAnchor

    SymbolVisibility = Local
                     | BankExported
                     | ExternalImported

    PatchHole = (Stencil.Name id,
                 Stencil.PatchKind kind,
                 number offset,
                 number width_bytes,
                 Stencil.PatchEncoding encoding,
                 Stencil.PatchSource source) unique

    PatchKind = ImmediatePatch
              | StackOffsetPatch
              | ConstAddressPatch
              | BranchTargetPatch
              | CallTargetPatch
              | SymbolAddressPatch
              | FrameLayoutPatch
              | RegisterPatch
              | VTablePatch
              | FFISymbolAddr64Patch
              | FFIFieldOffsetPatch
              | FFISizeOfPatch
              | FFIAlignOfPatch
              | FFICallbackThunkPatch
              | GCStatePtrPatch
              | GCAllocatorFnPatch
              | GCObjectLayoutOffsetPatch
              | GCBarrierEntryAddrPatch
              | GCFinalizerQueuePtrPatch
              | GCEpochAddressPatch
              | GCEpochExpectedPatch

    PatchEncoding = U8
                  | U16
                  | U32
                  | U64
                  | I32
                  | I64
                  | PcRel32
                  | PcRel64
                  | Abs64
                  | TargetSpecific(string encoding) unique

    PatchSource = FromImmediate(Stencil.ImmediateOperand imm) unique
                | FromStack(Stencil.StackOperand stack) unique
                | FromRegister(Stencil.RegisterOperand reg) unique
                | FromSymbol(Stencil.Symbol symbol) unique
                | FromMaterializationValue(Stencil.Name name) unique
                | FromFFISymbol(LuaFFI.CSymbol symbol) unique
                | FromFFIFieldOffset(LuaFFI.CTypeId type_id, LuaFFI.CName field) unique
                | FromFFITypeLayout(LuaFFI.CTypeId type_id) unique
                | FromFFICallback(LuaFFI.CCallback callback) unique
                | FromGCState(LuaGC.Name state) unique
                | FromGCAllocator(LuaGC.Name allocator, LuaGC.Name function_name) unique
                | FromGCObjectLayout(LuaGC.GCObjectKind kind, LuaGC.Name field) unique
                | FromGCBarrierEntry(LuaGC.BarrierKind barrier) unique
                | FromGCFinalizerQueue(LuaGC.Name state) unique
                | FromGCEpoch(LuaGC.GCFact fact) unique
                | FromCallTarget(LuaRT.CallTarget target) unique
                | FromCallTargetIdentity(LuaRT.CallTargetIdentity identity) unique
                | FromCallFrameLayout(LuaRT.CallFrameLayout layout) unique
                | FromRegionDescriptor(LuaExec.RegionDescriptor descriptor) unique
                | FromStaticRegion(LuaExec.StaticRegionBinding binding) unique
                | FromStaticRegionInvocation(LuaExec.StaticRegionInvocation invocation) unique
                | FromClosureIdentity(LuaRT.ClosureIdentity identity) unique
                | FromUpvalueIdentity(LuaRT.UpvalueIdentity identity) unique
                | FromMetatableEpoch(LuaRT.MetatableEpoch epoch) unique
                | FromMetamethodLookupPath(LuaRT.MetamethodLookupPath path) unique
                | FromLuaOperation(LuaRT.LuaOperation operation) unique
                | FromLoopTopology(LuaRT.LoopTopology topology) unique
                | FromGCEffect(LuaGC.GCEffect effect) unique
                | FromFFICallShape(LuaFFI.FFICallShape call) unique
                | FromFFICallbackEntry(LuaFFI.FFICallbackEntry callback) unique
                | FromCDataOwnership(LuaFFI.CDataOwnershipTransition transition) unique
                | FromUpvalueEpoch(LuaRT.UpvalueIdentity upvalue) unique

    Reloc = (Stencil.Name id,
             Stencil.RelocKind kind,
             number offset,
             Stencil.Symbol target,
             number addend) unique

    RelocKind = AbsAddr
              | PcRel
              | GotRelative
              | PltRelative
              | SectionRelative
              | TargetReloc(string name) unique

    RegisterClass = GPR
                  | FPR
                  | Vector
                  | Predicate
                  | TargetRegisterClass(string name) unique

    RegisterOperand = (Stencil.RegisterClass class,
                       Stencil.Name register) unique

    StackOperand = (Stencil.Name frame,
                    number slot,
                    number byte_offset,
                    number width_bytes) unique

    ImmediateOperand = ImmI64(number value) unique
                     | ImmF64(number value) unique
                     | ImmBool(boolean value) unique
                     | ImmSymbol(Stencil.Symbol symbol) unique
                     | ImmBytes(string hash, number byte_size) unique

    Operand = RegisterOp(Stencil.RegisterOperand reg) unique
            | StackOp(Stencil.StackOperand stack) unique
            | ImmediateOp(Stencil.ImmediateOperand imm) unique
            | SymbolOp(Stencil.Symbol symbol) unique

    Placement = (Stencil.RegisterOperand* fixed_registers,
                 Stencil.StackOperand* stack_slots,
                 Stencil.Operand* operands) unique

    MaterializationPlan = (Stencil.PatchSite* patch_sites,
                           Stencil.LinkStep* link_steps,
                           Stencil.EntryPoint entry) unique

    MaterializedImage = (Stencil.Name template_name,
                         Stencil.CodeBlobRef code,
                         string bytes,
                         Stencil.Symbol entry,
                         number entry_offset,
                         Stencil.MaterializationRecord* records) unique

    MaterializationRecord = AppliedPatch(Stencil.Name id,
                                         number offset,
                                         number width_bytes,
                                         Stencil.PatchEncoding encoding,
                                         string value) unique
                          | AppliedReloc(Stencil.Name id,
                                         number offset,
                                         Stencil.RelocKind kind,
                                         string value) unique

    PublishEntryMetadata = (Stencil.VariantKey variant,
                            Stencil.Name template_name,
                            Stencil.Symbol entry,
                            number entry_offset,
                            string entry_address_placeholder,
                            number image_size,
                            string image_hash,
                            Stencil.TargetABI target_abi,
                            Stencil.FeatureSet features,
                            string generation_id) unique

    MaterializedBundle = (Stencil.Name id,
                          string generation_id,
                          string manifest_digest,
                          Stencil.MaterializedImage* images,
                          Stencil.PublishEntryMetadata* entries) unique

    PatchSite = (Stencil.PatchHole hole,
                 Stencil.PatchValue value) unique

    PatchValue = PatchImmediate(Stencil.ImmediateOperand imm) unique
               | PatchStack(Stencil.StackOperand stack) unique
               | PatchRegister(Stencil.RegisterOperand reg) unique
               | PatchSymbol(Stencil.Symbol symbol) unique
               | PatchComputed(Stencil.Name name) unique

    LinkStep = ResolveInternalBranch(Stencil.Symbol from, Stencil.Symbol to) unique
             | ResolveInternalCall(Stencil.Symbol from, Stencil.Symbol to) unique
             | ResolveExternalSymbol(Stencil.Symbol symbol) unique
             | ApplyReloc(Stencil.Reloc reloc) unique

    EntryPoint = (Stencil.Symbol symbol,
                  Stencil.TargetABI abi) unique

    Linkage = (Stencil.Symbol* exported,
               Stencil.Symbol* imported,
               Stencil.Reloc* required_relocs) unique
}

module LuaCompile {
    SourceEvent = CanonicalPucEvent(string op,
                                    number pc,
                                    number a,
                                    number b,
                                    number c,
                                    number bx,
                                    number ax,
                                    number vb,
                                    number vc,
                                    number nresults,
                                    boolean k,
                                    number extraarg,
                                    boolean has_extraarg,
                                    number sb,
                                    boolean has_sb,
                                    number sc,
                                    boolean has_sc,
                                    number sj,
                                    boolean has_sj,
                                    boolean isfloat,
                                    boolean has_isfloat) unique
                | DecodedSourceOp(LuaSrc.Op op) unique

    SourceEventBatch = (LuaCompile.SourceEvent* events) unique

    EvidenceRecord = EvidenceFact(LuaFact.Fact fact) unique
                   | EvidencePayload(LuaFact.PayloadLease payload) unique

    EvidenceInput = (LuaCompile.EvidenceRecord* records,
                     LuaRegion.RegionSet regions) unique

    Unit = (LuaSrc.Window source,
            LuaFact.Evidence evidence) unique

    ExecProduct = ExecKernel(LuaExec.Kernel kernel) unique
                | ExecModule(LuaExec.Module module) unique

    ExecLowerResult = ExecLowerOk(LuaCompile.ExecProduct product) unique
                    | ExecLowerReject(string* errors) unique

    LalinLowerResult = LalinLowerOk(LalinCFG.Kernel kernel) unique
                    | LalinLowerReject(string* errors) unique

    StaticInlineResult = StaticInlineOk(LuaExec.Kernel kernel) unique
                       | StaticInlineReject(string* errors) unique

    DiagnosticStage = LuaSrcDecode
                    | LuaSrcValidate
                    | LuaExecLower
                    | LuaExecValidate
                    | LalinCFGLower
                    | LalinCFGValidate
                    | LalinCFGEmit
                    | StencilValidate
                    | StencilMaterialize
                    | Foundry

    DiagnosticReason = ContradictoryEvidence
                     | MissingFact
                     | MissingPayloadLease
                     | UnsupportedOpcode
                     | UnsupportedFactCombination
                     | UnsupportedSemanticCase
                     | UnsupportedLoopRegion
                     | UnsupportedProjection
                     | ValidationFailure
                     | LoweringFailure
                     | InternalInvariantFailure
                     | StencilMaterializationFailure

    Diagnostic = (LuaCompile.DiagnosticStage stage,
                  LuaCompile.DiagnosticReason reason,
                  LuaSrc.Pc pc,
                  LuaSrc.Op source_op,
                  string message,
                  LuaFact.Fact* missing_facts,
                  LuaFact.PayloadLease* missing_payloads) unique

    Product = LalinKernel(LalinCFG.Kernel kernel) unique

    Result = Ok(LuaCompile.Product product) unique
           | Reject(LuaCompile.Diagnostic diagnostic) unique
}

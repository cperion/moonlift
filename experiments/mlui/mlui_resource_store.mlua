-- mlui_resource_store.mlua — Resource lifecycle and borrow resolvers.
--
-- Implements all R.ui_borrow_* (slot+generation resolvers) and all
-- R.ui_*_retain / R.ui_*_publish / R.ui_*_release regions.
--
-- Every Ref handle encodes (slot index, generation) packed into a u32:
--   upper 24 bits = slot index, lower 8 bits = generation
-- This keeps the first live handle readable as 1 while preserving 0 as invalid.
-- The unpacking is store-private.

local H = lalin.require("mlui_types")
local T = H.T
local R = H.R
local F = H.F

local Mem = lalin.require("mlui_memory")

local MLUI_GEN_MASK = 0x000000FF
local MLUI_SLOT_SHIFT = 8

-- All borrow resolvers follow the same slot+generation pattern.

local ui_borrow_node = region @{R.ui_borrow_node}
entry start()
    let raw: u32 = repr(node)
    if raw == as(u32, 0) then jump missing(node = node) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.nodes.n then jump missing(node = node) end
    let slot: T.UiNodeSlot = kernel.nodes.slots[idx]
    if slot.live == false then jump missing(node = node) end
    if slot.gen ~= gen then jump stale(node = node) end
    jump borrowed(node = as(ptr(T.UiNodeRecord), as(ptr(u8), kernel.nodes.slots) + idx * sizeof(T.UiNodeSlot)))
end
end

local ui_borrow_content = region @{R.ui_borrow_content}
entry start()
    let raw: u32 = repr(content)
    if raw == as(u32, 0) then jump missing(content = content) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.content.n then jump missing(content = content) end
    let slot: T.UiContentSlot = kernel.content.slots[idx]
    if slot.live == false then jump missing(content = content) end
    if slot.gen ~= gen then jump stale(content = content) end
    jump borrowed(content = as(ptr(T.UiContent), as(ptr(u8), kernel.content.slots) + idx * sizeof(T.UiContentSlot)))
end
end

local ui_borrow_text_layout = region @{R.ui_borrow_text_layout}
entry start()
    let raw: u32 = repr(layout)
    if raw == as(u32, 0) then jump missing(layout = layout) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.text_layouts.n then jump missing(layout = layout) end
    let slot: T.UiTextLayoutSlot = kernel.text_layouts.slots[idx]
    if slot.live == false then jump missing(layout = layout) end
    if slot.gen ~= gen then jump stale(layout = layout) end
    jump borrowed(layout = as(ptr(T.UiTextLayout), as(ptr(u8), kernel.text_layouts.slots) + idx * sizeof(T.UiTextLayoutSlot)))
end
end

local ui_borrow_paint = region @{R.ui_borrow_paint}
entry start()
    let raw: u32 = repr(paint)
    if raw == as(u32, 0) then jump missing(paint = paint) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.paint.n_program then jump missing(paint = paint) end
    if gen == as(u32, 0) then jump missing(paint = paint) end
    let prog: T.UiPaintProgram = kernel.paint.programs[idx]
    if gen ~= as(u32, 1) then jump stale(paint = paint) end
    jump borrowed(program = as(ptr(T.UiPaintProgram), as(ptr(u8), kernel.paint.programs) + idx * sizeof(T.UiPaintProgram)))
end
end

local ui_borrow_image = region @{R.ui_borrow_image}
entry start()
    let raw: u32 = repr(image)
    if raw == as(u32, 0) then jump missing(image = image) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.images.n then jump missing(image = image) end
    let slot: T.UiImageSlot = kernel.images.slots[idx]
    if slot.live == false then jump missing(image = image) end
    if slot.gen ~= gen then jump stale(image = image) end
    jump borrowed(image = as(ptr(T.UiImageRecord), as(ptr(u8), kernel.images.slots) + idx * sizeof(T.UiImageSlot)))
end
end

local ui_borrow_font = region @{R.ui_borrow_font}
entry start()
    let raw: u32 = repr(font)
    if raw == as(u32, 0) then jump missing(font = font) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.fonts.n then jump missing(font = font) end
    let slot: T.UiFontSlot = kernel.fonts.slots[idx]
    if slot.live == false then jump missing(font = font) end
    if slot.gen ~= gen then jump stale(font = font) end
    jump borrowed(font = as(ptr(T.UiFontRecord), as(ptr(u8), kernel.fonts.slots) + idx * sizeof(T.UiFontSlot)))
end
end

local ui_borrow_value = region @{R.ui_borrow_value}
entry start()
    let raw: u32 = repr(value)
    if raw == as(u32, 0) then jump missing(value = value) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.values.n then jump missing(value = value) end
    let slot: T.UiValueSlot = kernel.values.slots[idx]
    if slot.live == false then jump missing(value = value) end
    if slot.gen ~= gen then jump stale(value = value) end
    jump borrowed(value = as(ptr(T.UiValueRecord), as(ptr(u8), kernel.values.slots) + idx * sizeof(T.UiValueSlot)))
end
end

local ui_visit_value = region @{R.ui_visit_value}
entry start()
    let kind: u8 = value.kind
    if kind == as(u8, 0) then jump none end
    if kind == as(u8, 1) then jump integer(value = value.n) end
    if kind == as(u8, 2) then jump number(value = value.x) end
    if kind == as(u8, 3) then jump point(x = value.x, y = value.y) end
    if kind == as(u8, 4) then jump text(content = value.text) end
    if kind == as(u8, 5) then jump id(id = value.id) end
    jump invalid_kind(kind = kind)
end
end

-- Helper: allocate a slot in a slot+generation store.
-- Does NOT grow; caller ensures capacity before calling.
-- Returns oom when store is full (caller should grow and retry).

local ui_slot_alloc = region slot_alloc(kernel: ptr(T.UiKernel),
                                          p_n: ptr(index),
                                          p_cap: ptr(index),
                                          p_slots: ptr(ptr(u8)),
                                          p_free: ptr(u32),
                                          slot_size: index,
                                          grow_region: ptr(u8);
    allocated(idx: index, gen: u32)
  | oom(needed: index))
entry start()
    let head: u32 = p_free[0]
    if head == as(u32, 0) then
        let n: index = p_n[0]
        let cap: index = p_cap[0]
        if n >= cap then
            jump oom(needed = (n + 1) * slot_size)
        end
        p_n[0] = n + 1
        jump allocated(idx = n, gen = 1)
    end
    let slot_idx: index = as(index, head - 1)
    let base: ptr(u8) = p_slots[0]
    let slot_ptr: ptr(u8) = base + slot_idx * slot_size
    let next_free: u32 = as(ptr(u32), slot_ptr)[0]
    p_free[0] = next_free
    jump allocated(idx = slot_idx, gen = 1)
end
end

local ui_content_retain = region @{R.ui_content_retain}
entry start()
    let alloc: ptr(T.UiAllocator) = Mem.mlui_get_alloc(kernel)
    let n_bytes: index = len(bytes)
    let copy_ptr: ptr(u8) = Mem.mlui_alloc_bytes(alloc, n_bytes, 1)
    if copy_ptr == as(ptr(u8), 0) then jump oom(needed = n_bytes) end
    Mem.mlui_copy_bytes(copy_ptr, &(bytes[0]), n_bytes)
    if kernel.content.free_head ~= 0 then
        let slot_idx: index = as(index, kernel.content.free_head - 1)
        let base: ptr(u8) = as(ptr(u8), kernel.content.slots)
        let slot_ptr: ptr(T.UiContentSlot) = as(ptr(T.UiContentSlot), base + slot_idx * sizeof(T.UiContentSlot))
        let next_free: u32 = as(ptr(u32), slot_ptr)[0]
        let p_free: ptr(u32) = &(kernel.content.free_head)
        p_free[0] = next_free
        jump slot_ok(idx = slot_idx, gen = 1, copy_ptr = copy_ptr, n_bytes = n_bytes)
    end
    let n: index = kernel.content.n
    let cap: index = kernel.content.cap
    if n >= cap then jump alloc_fail(needed = (n + 1) * sizeof(T.UiContentSlot), copy_ptr = copy_ptr, n_bytes = n_bytes) end
    let p_n: ptr(index) = &(kernel.content.n)
    p_n[0] = n + 1
    jump slot_ok(idx = n, gen = 1, copy_ptr = copy_ptr, n_bytes = n_bytes)
end
block slot_ok(idx: index, gen: u32, copy_ptr: ptr(u8), n_bytes: index)
    let base: ptr(u8) = as(ptr(u8), kernel.content.slots)
    let slot_ptr: ptr(T.UiContentSlot) = as(ptr(T.UiContentSlot), base + idx * sizeof(T.UiContentSlot))
    (*slot_ptr).gen = gen
    (*slot_ptr).live = true
    (*slot_ptr).content.bytes = view(copy_ptr, n_bytes)
    (*slot_ptr).content.layout_affecting = layout_affecting
    let ref: u32 = (as(u32, idx) << MLUI_SLOT_SHIFT) | (gen & MLUI_GEN_MASK)
    jump retained(content = T.UiContentRef.from_repr(ref))
end
block alloc_fail(needed: index, copy_ptr: ptr(u8), n_bytes: index)
    let afree: ptr(T.UiAllocator) = Mem.mlui_get_alloc(kernel)
    Mem.mlui_free_bytes(afree, copy_ptr, n_bytes, 1)
    jump oom(needed = needed)
end
end

local ui_content_publish = region @{R.ui_content_publish}
entry start()
    let raw: u32 = repr(content)
    if raw == as(u32, 0) then jump missing(content = content) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.content.n then jump missing(content = content) end
    let slot: T.UiContentSlot = kernel.content.slots[idx]
    if slot.live == false then jump missing(content = content) end
    if slot.gen ~= gen then jump stale(content = content) end
    jump published(content = T.UiContentRef.from_repr(raw))
end
end

local ui_content_release = region @{R.ui_content_release}
entry start()
    let raw: u32 = repr(content)
    if raw == as(u32, 0) then jump missing(content = content) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.content.n then jump missing(content = content) end
    let base: ptr(u8) = as(ptr(u8), kernel.content.slots)
    let slot_ptr: ptr(T.UiContentSlot) = as(ptr(T.UiContentSlot), base + idx * sizeof(T.UiContentSlot))
    let slot: T.UiContentSlot = slot_ptr[0]
    if slot.live == false then jump missing(content = content) end
    if slot.gen ~= gen then jump stale(content = content) end
    (*slot_ptr).live = false
    let p_fh: ptr(u32) = &(kernel.content.free_head)
    as(ptr(u32), slot_ptr)[0] = p_fh[0]
    p_fh[0] = as(u32, idx + 1)
    jump released
end
end

local ui_paint_retain = region @{R.ui_paint_retain}
entry start()
    let kind: u8 = program.kind
    if kind == as(u8, 0) then jump invalid_program(kind = kind) end
    emit ui_slot_alloc(kernel,
        &(kernel.paint.n_program), &(kernel.paint.cap_program),
        as(ptr(ptr(u8)), &(kernel.paint.programs)),
        as(ptr(u32), 0),
        sizeof(T.UiPaintProgram), as(ptr(u8), 0);
        allocated = ok, oom = fail)
end
block ok(idx: index, gen: u32)
    let base: ptr(u8) = as(ptr(u8), kernel.paint.programs)
    let slot_ptr: ptr(T.UiPaintProgram) = as(ptr(T.UiPaintProgram), base + idx * sizeof(T.UiPaintProgram))
    slot_ptr[0] = program[0]
    let ref: u32 = (as(u32, idx) << MLUI_SLOT_SHIFT) | (gen & MLUI_GEN_MASK)
    jump retained(paint = T.UiPaintRef.from_repr(ref))
end
block fail(needed: index)
    jump oom(needed = needed)
end
end

local ui_paint_publish = region @{R.ui_paint_publish}
entry start()
    let raw: u32 = repr(paint)
    jump published(paint = T.UiPaintRef.from_repr(raw))
end
end

local ui_paint_release = region @{R.ui_paint_release}
entry start()
    jump released
end
end

local ui_image_register = region @{R.ui_image_register}
entry start()
    emit ui_slot_alloc(kernel,
        &(kernel.images.n), &(kernel.images.cap),
        as(ptr(ptr(u8)), &(kernel.images.slots)),
        &(kernel.images.free_head),
        sizeof(T.UiImageSlot), as(ptr(u8), 0);
        allocated = ok, oom = fail)
end
block ok(idx: index, gen: u32)
    let base: ptr(u8) = as(ptr(u8), kernel.images.slots)
    let slot_ptr: ptr(T.UiImageSlot) = as(ptr(T.UiImageSlot), base + idx * sizeof(T.UiImageSlot))
    (*slot_ptr).gen = gen
    (*slot_ptr).live = true
    (*slot_ptr).image.id = id
    (*slot_ptr).image.backend_key = backend_key
    (*slot_ptr).image.w = w
    (*slot_ptr).image.h = h
    let ref: u32 = (as(u32, idx) << MLUI_SLOT_SHIFT) | (gen & MLUI_GEN_MASK)
    jump registered(image = T.UiImageRef.from_repr(ref))
end
block fail(needed: index)
    jump oom(needed = needed)
end
end


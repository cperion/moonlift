local ui_value_retain = region @{R.ui_value_retain}
entry start()
    let kind: u8 = value.kind
    if kind > as(u8, 5) then jump invalid_value(kind = kind) end
    emit ui_slot_alloc(kernel,
        &(kernel.values.n), &(kernel.values.cap),
        as(ptr(ptr(u8)), &(kernel.values.slots)),
        &(kernel.values.free_head),
        sizeof(T.UiValueSlot), as(ptr(u8), 0);
        allocated = ok, oom = fail)
end
block ok(idx: index, gen: u32)
    let base: ptr(u8) = as(ptr(u8), kernel.values.slots)
    let slot_ptr: ptr(T.UiValueSlot) = as(ptr(T.UiValueSlot), base + idx * sizeof(T.UiValueSlot))
    (*slot_ptr).gen = gen
    (*slot_ptr).live = true
    (*slot_ptr).value = value[0]
    let ref: u32 = (as(u32, idx) << MLUI_SLOT_SHIFT) | (gen & MLUI_GEN_MASK)
    jump retained(value = T.UiValueRef.from_repr(ref))
end
block fail(needed: index)
    jump oom(needed = needed)
end
end

local ui_value_publish = region @{R.ui_value_publish}
entry start()
    let raw: u32 = repr(value)
    jump published(value = T.UiValueRef.from_repr(raw))
end
end

local ui_value_release = region @{R.ui_value_release}
entry start()
    let raw: u32 = repr(value)
    if raw == as(u32, 0) then jump missing(value = value) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.values.n then jump missing(value = value) end
    let base: ptr(u8) = as(ptr(u8), kernel.values.slots)
    let slot_ptr: ptr(T.UiValueSlot) = as(ptr(T.UiValueSlot), base + idx * sizeof(T.UiValueSlot))
    let slot: T.UiValueSlot = slot_ptr[0]
    if slot.live == false then jump missing(value = value) end
    if slot.gen ~= gen then jump stale(value = value) end
    (*slot_ptr).live = false
    let p_fh: ptr(u32) = &(kernel.values.free_head)
    as(ptr(u32), slot_ptr)[0] = p_fh[0]
    p_fh[0] = as(u32, idx + 1)
    jump released

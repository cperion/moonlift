end

local ui_text_layout_retain = region @{R.ui_text_layout_retain}
entry start()
    let raw: u32 = repr(content)
    if raw == as(u32, 0) then jump missing_content(content = content) end
    let cidx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    if cidx >= kernel.content.n then jump missing_content(content = content) end
    let cslot: T.UiContentSlot = kernel.content.slots[cidx]
    if cslot.live == false then jump missing_content(content = content) end
    emit ui_slot_alloc(kernel,
        &(kernel.text_layouts.n), &(kernel.text_layouts.cap),
        as(ptr(ptr(u8)), &(kernel.text_layouts.slots)),
        &(kernel.text_layouts.free_head),
        sizeof(T.UiTextLayoutSlot), as(ptr(u8), 0);
        allocated = ok, oom = fail)
end
block ok(idx: index, gen: u32)
    let base: ptr(u8) = as(ptr(u8), kernel.text_layouts.slots)
    let slot_ptr: ptr(T.UiTextLayoutSlot) = as(ptr(T.UiTextLayoutSlot), base + idx * sizeof(T.UiTextLayoutSlot))
    (*slot_ptr).gen = gen
    (*slot_ptr).live = true
    (*slot_ptr).layout.content = content
    (*slot_ptr).layout.max_w = max_w
    let ref: u32 = (as(u32, idx) << MLUI_SLOT_SHIFT) | (gen & MLUI_GEN_MASK)
    jump retained(layout = T.UiTextLayoutRef.from_repr(ref))
end
block fail(needed: index)
    jump oom(needed = needed)
end
end

local ui_text_layout_publish = region @{R.ui_text_layout_publish}
entry start()
    let raw: u32 = repr(layout)
    jump published(layout = T.UiTextLayoutRef.from_repr(raw))
end
end

local ui_text_layout_release = region @{R.ui_text_layout_release}
entry start()
    let raw: u32 = repr(layout)
    if raw == as(u32, 0) then jump missing(layout = layout) end
    let idx: index = as(index, raw >> MLUI_SLOT_SHIFT)
    let gen: u32 = raw & MLUI_GEN_MASK
    if idx >= kernel.text_layouts.n then jump missing(layout = layout) end
    let base: ptr(u8) = as(ptr(u8), kernel.text_layouts.slots)
    let slot_ptr: ptr(T.UiTextLayoutSlot) = as(ptr(T.UiTextLayoutSlot), base + idx * sizeof(T.UiTextLayoutSlot))
    let slot: T.UiTextLayoutSlot = slot_ptr[0]
    if slot.live == false then jump missing(layout = layout) end
    if slot.gen ~= gen then jump stale(layout = layout) end
    (*slot_ptr).live = false
    let p_fh: ptr(u32) = &(kernel.text_layouts.free_head)
    as(ptr(u32), slot_ptr)[0] = p_fh[0]
    p_fh[0] = as(u32, idx + 1)
    jump released
end
end

return {
    ui_borrow_node = ui_borrow_node,
    ui_borrow_content = ui_borrow_content,
    ui_borrow_text_layout = ui_borrow_text_layout,
    ui_borrow_paint = ui_borrow_paint,
    ui_borrow_image = ui_borrow_image,
    ui_borrow_font = ui_borrow_font,
    ui_borrow_value = ui_borrow_value,
    ui_visit_value = ui_visit_value,
    ui_content_retain = ui_content_retain,
    ui_content_publish = ui_content_publish,
    ui_content_release = ui_content_release,
    ui_paint_retain = ui_paint_retain,
    ui_paint_publish = ui_paint_publish,
    ui_paint_release = ui_paint_release,
    ui_image_register = ui_image_register,
    ui_image_release = ui_image_release,
    ui_font_register = ui_font_register,
    ui_font_release = ui_font_release,
    ui_value_retain = ui_value_retain,
    ui_value_publish = ui_value_publish,
    ui_value_release = ui_value_release,
    ui_text_layout_retain = ui_text_layout_retain,
    ui_text_layout_publish = ui_text_layout_publish,
    ui_text_layout_release = ui_text_layout_release,
}

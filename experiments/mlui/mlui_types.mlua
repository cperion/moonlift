  | missing(value: T.UiValueRef))
end

R.ui_expand_compose = region ui_expand_compose(kernel: ptr(T.UiKernel), compose: ptr(T.UiComposeBuffer);
    expanded(auth: ptr(T.UiAuthBuffer))

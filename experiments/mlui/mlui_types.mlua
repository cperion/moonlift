  | missing(layout: T.UiTextLayoutRef))
end

R.ui_borrow_paint = region ui_borrow_paint(readonly kernel: ptr(T.UiKernel), paint: T.UiPaintRef;
    borrowed(program: lease(kernel) ptr(T.UiPaintProgram))
  | stale(paint: T.UiPaintRef)
  | missing(paint: T.UiPaintRef))
end

R.ui_borrow_image = region ui_borrow_image(readonly kernel: ptr(T.UiKernel), image: T.UiImageRef;
    borrowed(image: lease(kernel) ptr(T.UiImageRecord))

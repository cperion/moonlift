    let alloc: ptr(T.UiAllocator) = mlui_get_alloc(kernel)
    let old_layout: ptr(u8) = as(ptr(u8), kernel.scene.layout_nodes)
    let old_layout_bytes: index = cap * sizeof(T.UiLayoutNode)
    let new_layout_bytes: index = new_cap * sizeof(T.UiLayoutNode)
    let new_layout: ptr(u8) = mlui_realloc_bytes(alloc, old_layout, old_layout_bytes, new_layout_bytes, 8)
    if new_layout == as(ptr(u8), 0) then jump oom(needed = new_layout_bytes) end
    mlui_zero_bytes(new_layout + old_layout_bytes, new_layout_bytes - old_layout_bytes)
    let old_decor: ptr(u8) = as(ptr(u8), kernel.scene.decor_nodes)
    let old_decor_bytes: index = cap * sizeof(T.UiDecorNode)
    let new_decor_bytes: index = new_cap * sizeof(T.UiDecorNode)
    let new_decor: ptr(u8) = mlui_realloc_bytes(alloc, old_decor, old_decor_bytes, new_decor_bytes, 8)
    if new_decor == as(ptr(u8), 0) then jump oom(needed = new_decor_bytes) end
    mlui_zero_bytes(new_decor + old_decor_bytes, new_decor_bytes - old_decor_bytes)
    let p_data: ptr(ptr(T.UiLayoutNode)) = &(kernel.scene.layout_nodes)
    let p_decor: ptr(ptr(T.UiDecorNode)) = &(kernel.scene.decor_nodes)
    let p_cap: ptr(index) = &(kernel.scene.cap_node)
    p_data[0] = as(ptr(T.UiLayoutNode), new_layout)
    p_decor[0] = as(ptr(T.UiDecorNode), new_decor)
    p_cap[0] = new_cap
    jump grown
end
end


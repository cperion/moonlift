-- mlui_memory.mlua — Memory primitives for the MLUI kernel.
--
-- Private helpers: allocation, reallocation, freeing, zeroing, copying,
-- and per-buffer growth regions for every MLUI kernel buffer.
--
-- Uses UiAllocator callbacks when present; defaults to extern malloc/realloc/free.
-- All allocation failures flow through region oom(needed) exits.

local H = lalin.require("mlui_types")
local T = H.T
local R = H.R
local F = H.F

local default_malloc = extern default_malloc(size: index): ptr(u8) end
local default_realloc = extern default_realloc(ptr: ptr(u8), new_size: index): ptr(u8) end
local default_free = extern default_free(ptr: ptr(u8)): void end

local mlui_get_alloc = func(kernel: ptr(T.UiKernel)): ptr(T.UiAllocator)
    return as(ptr(T.UiAllocator), 0)
end

local mlui_alloc_bytes = func(a: ptr(T.UiAllocator), size: index, align: index): ptr(u8)
    if a == as(ptr(T.UiAllocator), 0) then return default_malloc(size) end
    let cb: func(ptr(u8), index, index): ptr(u8) = a[0].alloc_fn
    return cb(a[0].ctx, size, align)
end

local mlui_realloc_bytes = func(a: ptr(T.UiAllocator), p: ptr(u8),
                                 old_size: index, new_size: index,
                                 align: index): ptr(u8)
    if a == as(ptr(T.UiAllocator), 0) then return default_realloc(p, new_size) end
    let cb: func(ptr(u8), ptr(u8), index, index, index): ptr(u8) = a[0].realloc_fn
    return cb(a[0].ctx, p, old_size, new_size, align)
end

local mlui_free_bytes = func(a: ptr(T.UiAllocator), p: ptr(u8),
                              size: index, align: index): void
    if a == as(ptr(T.UiAllocator), 0) then default_free(p) return end
    let cb: func(ptr(u8), ptr(u8), index, index) = a[0].free_fn
    cb(a[0].ctx, p, size, align)
    return
end

local mlui_zero_bytes = func(p: ptr(u8), n: index): void
    block loop(i: index = 0)
        if i >= n then return end
        p[i] = as(u8, 0)
        jump loop(i = i + 1)
    end
end

local mlui_copy_bytes = func(dst: ptr(u8), src: ptr(u8), n: index): void
    block loop(i: index = 0)
        if i >= n then return end
        dst[i] = src[i]
        jump loop(i = i + 1)
    end
end

--------------------------------------------------------------------------------
-- Core growth region: grow a flat element buffer.
-- Takes mutable ptr(index) for count and cap, ptr(ptr(u8)) for data pointer.
-- Doubles capacity when room is insufficient.  Exits through grown or oom.
--------------------------------------------------------------------------------

local mlui_grow_elems = region grow_elems(kernel: ptr(T.UiKernel),
                                           p_count: ptr(index),
                                           p_cap: ptr(index),
                                           p_data: ptr(ptr(u8)),
                                           elem_size: index,
                                           needed: index;
    grown
  | oom(needed: index))
entry start()
    let count: index = p_count[0]
    let cap: index = p_cap[0]
    let avail: index = cap - count
    if avail >= needed then jump grown end
    let want: index = count + needed
    var new_cap: index = cap * 2
    if new_cap < want then new_cap = want end
    let old_ptr: ptr(u8) = p_data[0]
    let old_bytes: index = cap * elem_size
    let new_bytes: index = new_cap * elem_size
    let alloc: ptr(T.UiAllocator) = mlui_get_alloc(kernel)
    let new_ptr: ptr(u8) = mlui_realloc_bytes(alloc, old_ptr, old_bytes, new_bytes, 8)
    if new_ptr == as(ptr(u8), 0) then jump oom(needed = new_bytes) end
    mlui_zero_bytes(new_ptr + old_bytes, new_bytes - old_bytes)
    p_data[0] = new_ptr
    p_cap[0] = new_cap
    jump grown
end
end

--------------------------------------------------------------------------------
-- Per-store growth regions.
--
-- Each operates on a specific kernel field path, using &(k.field)[0] for
-- stores and direct reads for loads.
--------------------------------------------------------------------------------

local mlui_grow_node_slots = region grow_node_slots(kernel: ptr(T.UiKernel), needed: index;
    grown | oom(needed: index))
entry start()
    let n: index = kernel.nodes.n
    let cap: index = kernel.nodes.cap
    let avail: index = cap - n
    if avail >= needed then jump grown end
    let want: index = n + needed
    var new_cap: index = cap * 2
    if new_cap < want then new_cap = want end
    let old_ptr: ptr(u8) = as(ptr(u8), kernel.nodes.slots)
    let old_bytes: index = cap * sizeof(T.UiNodeSlot)
    let new_bytes: index = new_cap * sizeof(T.UiNodeSlot)
    let alloc: ptr(T.UiAllocator) = mlui_get_alloc(kernel)
    let new_ptr: ptr(u8) = mlui_realloc_bytes(alloc, old_ptr, old_bytes, new_bytes, 8)
    if new_ptr == as(ptr(u8), 0) then jump oom(needed = new_bytes) end
    mlui_zero_bytes(new_ptr + old_bytes, new_bytes - old_bytes)
    let p_slots: ptr(ptr(T.UiNodeSlot)) = &(kernel.nodes.slots)
    let p_cap: ptr(index) = &(kernel.nodes.cap)
    p_slots[0] = as(ptr(T.UiNodeSlot), new_ptr)
    p_cap[0] = new_cap
    jump grown
end
end


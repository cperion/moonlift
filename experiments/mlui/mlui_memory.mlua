    let alloc: ptr(T.UiAllocator) = mlui_get_alloc(kernel)
    let new_ptr: ptr(u8) = mlui_realloc_bytes(alloc, old_ptr, old_bytes, new_bytes, 8)
    if new_ptr == as(ptr(u8), 0) then jump oom(needed = new_bytes) end
    mlui_zero_bytes(new_ptr + old_bytes, new_bytes - old_bytes)
    let p_data: ptr(ptr(u32)) = &(kernel.solve.children)
    let p_cap: ptr(index) = &(kernel.solve.cap_child)
    p_data[0] = as(ptr(u32), new_ptr)
    p_cap[0] = new_cap
    jump grown
end
end


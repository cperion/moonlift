T.QueryProgram = struct QueryProgram
    kind: @{T.ProgramKind},
    image: QueryImageRef,
    block: InstructionBlock,
    register_count: u32,
    frame_count: u32,
    temp_count: u32,
    result_shape: @{T.ResultShape},
    row_profile: @{T.RowProfileId},
    policy_digest: @{T.Digest64},
    target_digest: @{T.Digest64},
    guards: ptr(ProgramGuard),
    guard_count: index,
    program_epoch: @{T.Epoch},
end

T.QueryProgramSlot = struct QueryProgramSlot
    slot: @{T.SlotHeader},
    program: QueryProgram,
end

T.TempValue = struct TempValue
    kind: @{T.TempKind},
    node: @{T.NodeId},
    bytes_start: u32,
    bytes_len: u32,
    aux: u64,
end

T.ValueSlot = struct ValueSlot
    kind: @{T.ValueSlotKind},       -- consumed only by visit_value_slot
    doc: JsonDocRef,
    node: @{T.NodeId},
    temp: u32,
    bool_value: bool,
    i64_value: i64,
    f64_value: f64,

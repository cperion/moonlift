-- jsonq_stack.mlua
-- Canonical Moonlift/LLPVM design contract for JsonQ.
--
-- This file is intentionally one large, grep-shaped stack definition.
-- It owns:
--   * public Moonlift type forest (T)
--   * public region protocols (R)
--   * C/FFI ABI seals (F)
--   * LLPVM operation languages
--   * semantic worlds
--   * machine/cache wiring
--
-- It does not contain region bodies.  Bodies live in machine files whose
-- names match the machines declared here.  This file is the architecture.

local moon = require "moonlift"
local ll = require "llpvm"

local M = {
    T = {},
    R = {},
    F = {},
    C = {},
    L = {},
    W = {},
    Machine = {},
    Phase = {},
    Build = {},
}

local T = M.T
local R = M.R
local F = M.F
local C = M.C

-- --------------------------------------------------------------------------
-- Scalar aliases and constants
-- --------------------------------------------------------------------------
-- Aliases are Lua-level names for schema clarity.  They are not source-level
-- generics or erased runtime types.

T.Bool32             = moon.u32
T.Tag8               = moon.u8
T.SmallCount         = moon.u16
T.Reg                = moon.u16
T.FrameSlot          = moon.u16
T.LabelId            = moon.u32
T.BlockId            = moon.u32
T.SymbolId           = moon.u32
T.PathId             = moon.u32
T.ConstId            = moon.u32
T.BuiltinId          = moon.u32
T.ParamId            = moon.u32
T.RowProfileId       = moon.u32
T.PolicyId           = moon.u32
T.Digest64           = moon.u64
T.Epoch              = moon.u64
T.ByteOffset         = moon.index
T.ByteLen            = moon.index
T.NodeId             = moon.u32
T.EntryId            = moon.u32
T.SegmentId          = moon.u32
T.PageId             = moon.u32
T.Score              = moon.u32
T.JsonqStatus        = moon.i32
T.JsonqErrorCode     = moon.u32
T.JsonqWarningCode   = moon.u32
T.CompareOp          = moon.u8
T.LogicOp            = moon.u8
T.OrderDirection     = moon.u8
T.PathStepKind       = moon.u8
T.Cardinality        = moon.u8
T.ValueClass         = moon.u8
T.ResultShape        = moon.u8
T.ResultFormat       = moon.u8
T.MissingPolicy      = moon.u8
T.DuplicatePolicy    = moon.u8
T.NumberPolicy       = moon.u8
T.StringPolicy       = moon.u8
T.OutputPolicy       = moon.u8
T.IndexMode          = moon.u8
T.IndexKeyKind       = moon.u8
T.WalkMode           = moon.u8
T.JoinMode           = moon.u8
T.AggregateOp        = moon.u8
T.SortNulls          = moon.u8
T.SortStability      = moon.u8
T.ScanKind           = moon.u8
T.TempKind           = moon.u8
T.JsonNodeKind       = moon.u8
T.RowKeyKind         = moon.u8
T.ValueSlotKind      = moon.u8
T.FrameKind          = moon.u8
T.SinkKind           = moon.u8
T.BufferKind         = moon.u8
T.ProgramKind        = moon.u8
T.CollectionKind     = moon.u8
T.EncodingKind       = moon.u8

C.dialect = {
    jsonq = 1,
    jq_filter_subset = 2,
    sql_json_path = 3,
}

C.value_class = {
    unknown = 0,
    missing = 1,
    null = 2,
    bool = 3,
    number = 4,
    string = 5,
    array = 6,
    object = 7,
    row = 8,
    stream = 9,
}

C.cardinality = {
    zero = 0,
    zero_or_one = 1,
    exactly_one = 2,
    zero_or_more = 3,
    one_or_more = 4,
}

C.result_shape = {
    json_values = 1,
    json_array = 2,
    rows = 3,
    scalar = 4,
    count_only = 5,
}

C.missing_policy = {
    strict = 1,
    optional = 2,
    jq_null = 3,
    sql_null = 4,
    exists_test = 5,
}

C.duplicate_policy = {
    preserve_all = 1,
    first = 2,
    last = 3,
    reject = 4,
}

C.number_policy = {
    preserve_text = 1,
    exact_decimal_compare = 2,
    i64_checked = 3,
    f64_checked = 4,
}

C.string_policy = {
    utf8_exact = 1,
    utf8_normalized = 2,
    raw_escape_preserving = 3,
}

C.index_mode = {
    exists = 1,
    equality = 2,
    range = 3,
    covering_value = 4,
    covering_row = 5,
}

C.compare_op = {
    eq = 1,
    ne = 2,
    lt = 3,
    le = 4,
    gt = 5,
    ge = 6,
    same_type = 7,
    contains = 8,
    starts_with = 9,
}

C.walk_mode = {
    children = 1,
    descendants_preorder = 2,
    descendants_postorder = 3,
    leaves = 4,
}

C.path_step_kind = {
    field = 1,
    index = 2,
    any_child = 3,
    recursive = 4,
}

C.program_kind = {
    portable = 1,
    catalog_bound = 2,
}

-- --------------------------------------------------------------------------
-- Stable backend handles
-- --------------------------------------------------------------------------
-- Ref = backend-resolved durable identity.  Id = dense or external value that
-- does not itself grant backend memory access.

T.JsonqVmRef = handle JsonqVmRef : u64 invalid 0
    domain JsonqRuntimeRegistry
    target JsonqVm
end

T.JsonDocRef = handle JsonDocRef : u64 invalid 0
    domain JsonStore
    target JsonImage
end

T.JsonCollectionRef = handle JsonCollectionRef : u64 invalid 0
    domain JsonStore
    target JsonCollection
end

T.CatalogSnapshotRef = handle CatalogSnapshotRef : u64 invalid 0
    domain JsonStore
    target CatalogSnapshot
end

T.PathIndexRef = handle PathIndexRef : u64 invalid 0
    domain JsonStore
    target PathIndex
end

T.QueryProgramRef = handle QueryProgramRef : u64 invalid 0
    domain JsonqVm
    target QueryProgram
end

T.QueryImageRef = handle QueryImageRef : u64 invalid 0
    domain JsonqVm
    target QueryImage
end

T.QueryResultRef = handle QueryResultRef : u64 invalid 0
    domain JsonqVm
    target ResultCursor
end

T.JsonqBufferRef = handle JsonqBufferRef : u64 invalid 0
    domain JsonqVm
    target JsonqBuffer
end

T.PreparedCacheRef = handle PreparedCacheRef : u64 invalid 0
    domain JsonqVm
    target PreparedCacheEntry
end

-- --------------------------------------------------------------------------
-- Generic products
-- --------------------------------------------------------------------------

T.ByteRange = struct ByteRange
    start: index,
    len: index,
end

T.SourceSpan = struct SourceSpan
    source: @{T.SymbolId},
    start: index,
    len: index,
    line: index,
    column: index,
end

T.ByteViewHeader = struct ByteViewHeader
    data: ptr(u8),
    len: index,
    stride: index,
end

T.ArenaHeader = struct ArenaHeader
    data: ptr(u8),
    used: index,
    cap: index,
    epoch: @{T.Epoch},
end

T.SlotHeader = struct SlotHeader
    gen: u32,
    live: bool,
    next_free: u32,
end

T.PolicyBundle = struct PolicyBundle
    dialect: u32,
    missing_policy: @{T.MissingPolicy},
    duplicate_policy: @{T.DuplicatePolicy},
    number_policy: @{T.NumberPolicy},
    string_policy: @{T.StringPolicy},
    output_policy: @{T.OutputPolicy},
    max_depth: index,
    max_result_bytes: index,
    digest: @{T.Digest64},
end

T.TargetProfile = struct TargetProfile
    pointer_bits: u32,
    endian: u32,
    simd_lanes: u32,
    cache_line_bytes: u32,
    allow_unaligned_loads: bool,
    wasm_safe: bool,
    digest: @{T.Digest64},
end

T.Diagnostic = struct Diagnostic
    code: u32,
    severity: u8,
    primary: @{T.SourceSpan},
    secondary: @{T.SourceSpan},
    note_atom: @{T.SymbolId},
    help_atom: @{T.SymbolId},
end

T.DiagnosticBuffer = struct DiagnosticBuffer
    items: ptr(Diagnostic),
    count: index,
    cap: index,
    suppressed_count: index,
end

-- --------------------------------------------------------------------------
-- Symbol and path products
-- --------------------------------------------------------------------------

T.SymbolEntry = struct SymbolEntry
    hash: u64,
    bytes_start: index,
    bytes_len: index,
    decoded_start: index,
    decoded_len: index,
end

T.SymbolStore = struct SymbolStore
    entries: ptr(SymbolEntry),
    entry_count: index,
    entry_cap: index,
    bytes: ptr(u8),
    byte_count: index,
    byte_cap: index,
    epoch: @{T.Epoch},
end

T.PathStep = struct PathStep
    kind: @{T.PathStepKind},
    key: @{T.SymbolId},
    index_value: i64,
    flags: u32,
end

T.PathSpec = struct PathSpec
    first_step: index,
    step_count: index,
    digest: @{T.Digest64},
end

T.PathStore = struct PathStore
    paths: ptr(PathSpec),
    path_count: index,
    path_cap: index,
    steps: ptr(PathStep),
    step_count: index,
    step_cap: index,
    epoch: @{T.Epoch},
end

-- --------------------------------------------------------------------------
-- JSON image and store products
-- --------------------------------------------------------------------------

T.JsonNode = struct JsonNode
    kind: @{T.JsonNodeKind},        -- consumed only by visit_json
    flags: u8,
    first: u32,                     -- first child / entry / byte offset
    count: u32,                     -- child count or byte length
    aux: u32,                       -- atom id, number flags, side-table id
    span_start: u32,
    span_len: u32,
end

T.ObjectEntry = struct ObjectEntry
    key: @{T.SymbolId},
    value: @{T.NodeId},
    key_span_start: u32,
    key_span_len: u32,
end

T.ArrayEntry = struct ArrayEntry
    value: @{T.NodeId},
end

T.NumberSlice = struct NumberSlice
    bytes_start: u32,
    bytes_len: u32,
    flags: u32,
end

T.DecodedStringSlice = struct DecodedStringSlice
    bytes_start: u32,
    bytes_len: u32,
    flags: u32,
end

T.ObjectSideIndex = struct ObjectSideIndex
    first_sorted_entry: u32,
    count: u32,
    build_epoch: @{T.Epoch},
end

T.JsonImage = struct JsonImage
    nodes: ptr(JsonNode),
    node_count: index,
    node_cap: index,
    object_entries: ptr(ObjectEntry),
    object_entry_count: index,
    object_entry_cap: index,
    array_entries: ptr(ArrayEntry),
    array_entry_count: index,
    array_entry_cap: index,
    bytes: ptr(u8),
    byte_count: index,
    byte_cap: index,
    side_indexes: ptr(ObjectSideIndex),
    side_index_count: index,
    side_index_cap: index,
    root: @{T.NodeId},
    image_epoch: @{T.Epoch},
    policy_digest: @{T.Digest64},
end

T.JsonValueAddr = struct JsonValueAddr
    doc: JsonDocRef,
    node: @{T.NodeId},
end

T.JsonDocSlot = struct JsonDocSlot
    slot: @{T.SlotHeader},
    image: JsonImage,
    source_name: @{T.SymbolId},
    loaded_epoch: @{T.Epoch},
end

T.JsonCollection = struct JsonCollection
    kind: @{T.CollectionKind},
    docs: ptr(JsonDocRef),
    doc_count: index,
    doc_cap: index,
    collection_epoch: @{T.Epoch},
    policy_digest: @{T.Digest64},
end

T.JsonCollectionSlot = struct JsonCollectionSlot
    slot: @{T.SlotHeader},
    collection: JsonCollection,
end

-- --------------------------------------------------------------------------
-- Index products
-- --------------------------------------------------------------------------

T.IndexKey = struct IndexKey
    kind: @{T.IndexKeyKind},        -- consumed only by compare_index_key
    flags: u8,
    bool_value: bool,
    i64_value: i64,
    f64_value: f64,
    atom: @{T.SymbolId},
    bytes_start: u32,
    bytes_len: u32,
end

T.IndexEntry = struct IndexEntry
    key: IndexKey,
    doc: JsonDocRef,
    node: @{T.NodeId},
    ordinal: u64,
end

T.IndexSegment = struct IndexSegment
    segment_id: @{T.SegmentId},
    entries: ptr(IndexEntry),
    entry_count: index,
    entry_cap: index,
    min_key: IndexKey,
    max_key: IndexKey,
    source_epoch: @{T.Epoch},
    live: bool,
end

T.PathIndex = struct PathIndex
    path: @{T.PathId},
    mode: @{T.IndexMode},
    duplicate_policy: @{T.DuplicatePolicy},
    number_policy: @{T.NumberPolicy},
    string_policy: @{T.StringPolicy},
    collection: JsonCollectionRef,
    collection_epoch: @{T.Epoch},
    segments: ptr(IndexSegment),
    segment_count: index,
    segment_cap: index,
    index_epoch: @{T.Epoch},
    digest: @{T.Digest64},
end

T.PathIndexSlot = struct PathIndexSlot
    slot: @{T.SlotHeader},
    index: PathIndex,
end

T.IndexCatalog = struct IndexCatalog
    indexes: ptr(PathIndexSlot),
    index_count: index,
    index_cap: index,
    free_head: u32,
    catalog_epoch: @{T.Epoch},
end

T.CatalogIndexFact = struct CatalogIndexFact
    index: PathIndexRef,
    path: @{T.PathId},
    mode: @{T.IndexMode},
    collection_epoch: @{T.Epoch},
    index_epoch: @{T.Epoch},
    policy_digest: @{T.Digest64},
    estimated_rows: u64,
    selectivity_score: @{T.Score},
end

T.CatalogSnapshot = struct CatalogSnapshot
    collection: JsonCollectionRef,
    collection_epoch: @{T.Epoch},
    catalog_epoch: @{T.Epoch},
    policy_digest: @{T.Digest64},
    facts: ptr(CatalogIndexFact),
    fact_count: index,
    fact_cap: index,
    digest: @{T.Digest64},
end

T.CatalogSnapshotSlot = struct CatalogSnapshotSlot
    slot: @{T.SlotHeader},
    snapshot: CatalogSnapshot,
end

T.JsonStore = struct JsonStore
    docs: ptr(JsonDocSlot),
    doc_count: index,
    doc_cap: index,
    doc_free_head: u32,
    collections: ptr(JsonCollectionSlot),
    collection_count: index,
    collection_cap: index,
    collection_free_head: u32,
    snapshots: ptr(CatalogSnapshotSlot),
    snapshot_count: index,
    snapshot_cap: index,
    snapshot_free_head: u32,
    symbols: SymbolStore,
    paths: PathStore,
    indexes: IndexCatalog,
    store_epoch: @{T.Epoch},
end

-- --------------------------------------------------------------------------
-- Query runtime products
-- --------------------------------------------------------------------------

T.QueryImage = struct QueryImage
    bytes: ptr(u8),
    byte_count: index,
    root_stream_id: u32,
    root_op_count: u32,
    image_version: u32,
    digest: @{T.Digest64},
end

T.ProgramGuard = struct ProgramGuard

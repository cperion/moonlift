    source: @{T.NodeId},
    next_index: index,
    end_index: index,
    dst: @{T.Reg},
    aux: u64,
end

T.RowKey = struct RowKey
    kind: @{T.RowKeyKind},
    atom: @{T.SymbolId},
    index_value: i64,
end

T.ScalarAtom = struct ScalarAtom
    value_class: @{T.ValueClass},
    bool_value: bool,
    i64_value: i64,
    f64_value: f64,
    atom: @{T.SymbolId},
    bytes_start: u32,
    bytes_len: u32,
end

T.JsonTreeRow = struct JsonTreeRow
    doc: JsonDocRef,
    value: @{T.NodeId},
    parent: @{T.NodeId},
    id: u64,
    parent_id: u64,
    key: RowKey,
    path: @{T.PathId},
    value_class: @{T.ValueClass},
    atom: ScalarAtom,

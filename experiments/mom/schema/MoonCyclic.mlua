M.TreeBackItemResult = union TreeBackItemResult | TreeBackItemResult(cmds: view(i32)) end

-- MoonTree TypeIndexBaseResult
M.TypeIndexBaseResult = union TypeIndexBaseResult | TypeIndexBaseResult(base: M.IndexBase, elem: ptr(M.Type), issues: view(M.TypeIssue)) end

-- MoonVec VecLocalFact
M.VecLocalFact = struct VecLocalFact binding: M.Binding; value: M.VecExprId; ty: ptr(M.Type) end

-- MoonHost MluaSource
M.MluaSource = struct MluaSource name: ptr(u8); source: ptr(u8) end

-- MoonHost HostValueId
M.HostValueId = struct HostValueId key: ptr(u8); pretty: ptr(u8) end

M.ProtocolRole = struct ProtocolRole role: ptr(u8); target: ptr(u8) end

M.HostCdef = struct HostCdef layout: M.HostLayoutId; source: ptr(u8) end

M.HostAccessPlan = struct HostAccessPlan subject: i32; entries: view(i32) end

M.HostExportAbi = union HostExportAbi
    | HostExportDescriptorPtr(descriptor: M.HostViewDescriptor)
    | HostExportExpandedScalars(ty: ptr(M.Type))
end

M.HostExposeSubject = union HostExposeSubject
    | HostExposeType(ty: ptr(M.Type))
    | HostExposePtr(pointee: ptr(M.Type))
    | HostExposeView(elem: ptr(M.Type))
end

M.HostExposeTarget = union HostExposeTarget
    | HostExposeLua | HostExposeTerra | HostExposeC | HostExposeMoonlift
end

M.HostMutability = union HostMutability | HostReadonly | HostMutable | HostInteriorMutable end

M.HostBoundsPolicy = union HostBoundsPolicy | HostBoundsChecked | HostBoundsUnchecked end

M.HostExposeFacet = struct HostExposeFacet target: M.HostExposeTarget; abi: M.HostExposeAbi; mode: M.HostExposeMode end

M.HostAccessEntry = struct HostAccessEntry key: M.HostAccessKey; op: M.HostAccessOp end

M.HostFactSet = struct HostFactSet facts: view(M.HostLayoutFact) end

M.HostLayoutReject = union HostLayoutReject
    | HostRejectJsonInRust
    | HostRejectDynamicObjectArena(reason: ptr(u8))
    | HostRejectUnknownFieldKind(kind: ptr(u8))
    | HostRejectInvalidLayout(reason: ptr(u8))
    | HostRejectBareBoolInBoundaryStruct(type_name: ptr(u8), field_name: ptr(u8))
    | HostRejectInvalidPackedAlign(type_name: ptr(u8), align: i32)
    | HostRejectConflictingCdef(layout: M.HostLayoutId)
end

M.HostLayoutFact = union HostLayoutFact
    | HostFactTypeLayout(layout: M.HostTypeLayout)
    | HostFactCdef(cdef: M.HostCdef)
    | HostFactField(owner: M.HostLayoutId, field: M.HostFieldLayout)
    | HostFactViewDescriptor(descriptor: M.HostViewDescriptor)
    | HostFactExpose(public_name: ptr(u8), layout: M.HostLayoutId, facet: M.HostExposeFacet)
    | HostFactAccessPlan(plan: M.HostAccessPlan)
    | HostFactViewPlan(plan: M.HostViewPlan)
    | HostFactLuaFfi(plan: M.HostLuaFfiPlan)
    | HostFactTerra(plan: M.HostTerraPlan)
    | HostFactC(plan: M.HostCPlan)
    | HostFactProducer(plan: M.HostProducerPlan)
end

M.HostProducerPlan = struct HostProducerPlan name: ptr(u8); kind: M.HostProducerKind; outputs: view(M.HostTypeLayout) end

M.HostProducerKind = union HostProducerKind
    | HostProducerLowLevelMoonlift | HostProducerLuaFfi
    | HostProducerRustTypedRecordMemory | HostProducerExternal
end

M.HostViewPlan = struct HostViewPlan
    layout: M.HostTypeLayout
    owner: M.HostOwner
    expose: M.HostExposeMode
    access: M.HostAccessPlan
end

M.HostAccessOp = union HostAccessOp
    | HostAccessDirectField(field: M.HostFieldLayout)
    | HostAccessDecodeBool(field: M.HostFieldLayout)
    | HostAccessEncodeBool(field: M.HostFieldLayout)
    | HostAccessViewIndex(descriptor: M.HostViewDescriptor)
    | HostAccessViewFieldAt(descriptor: M.HostViewDescriptor, field: M.HostFieldLayout)
    | HostAccessViewLen(descriptor: M.HostViewDescriptor)
    | HostAccessViewData(descriptor: M.HostViewDescriptor)
    | HostAccessViewStride(descriptor: M.HostViewDescriptor)
    | HostAccessPointerCast(layout: M.HostTypeLayout)
    | HostAccessIterateFields(layout: M.HostLayoutId)
    | HostAccessMaterializeTable(subject: M.HostAccessSubject)
    | HostAccessReject(reason: ptr(u8))
end

M.HostAccessKey = union HostAccessKey
    | HostAccessField(name: ptr(u8))
    | HostAccessIndex | HostAccessLen | HostAccessData | HostAccessStride
    | HostAccessMethod(name: ptr(u8))
    | HostAccessPairs | HostAccessIpairs | HostAccessToTable
end

M.HostAccessSubject = union HostAccessSubject
    | HostAccessRecord(layout: M.HostTypeLayout)
    | HostAccessPtr(layout: M.HostTypeLayout)
    | HostAccessView(descriptor: M.HostViewDescriptor)
end

M.HostLifetime = union HostLifetime
    | HostLifetimeStatic | HostLifetimeOwned
    | HostLifetimeBorrowed(owner_name: ptr(u8))
    | HostLifetimeGeneration(session_id: i32, generation: i32)
    | HostLifetimeExternal(name: ptr(u8))
end

M.HostExposeAbi = union HostExposeAbi
    | HostExposeAbiDefault | HostExposeAbiPointer
    | HostExposeAbiDescriptor | HostExposeAbiDataLenStride
    | HostExposeAbiExpandedScalars | HostExposeAbiOpaque(reason: ptr(u8))
end

M.HostExposeMode = union HostExposeMode
    | HostExposeProxy(kind: M.HostProxyKind, cache: M.HostProxyCachePolicy, mutability: M.HostMutability, bounds: M.HostBoundsPolicy)
    | HostExposeEagerTable(policy: M.HostMaterializePolicy)
    | HostExposeScalar(rep: M.HostFieldRep)
    | HostExposeOpaque(reason: ptr(u8))
end

M.HostMaterializePolicy = union HostMaterializePolicy
    | HostMaterializeProjectedFields | HostMaterializeFullCopy | HostMaterializeBorrowedView
end

M.HostProxyCachePolicy = union HostProxyCachePolicy | HostProxyCacheNone | HostProxyCacheLazy | HostProxyCacheEager end

M.HostProxyKind = union HostProxyKind
    | HostProxyPtr | HostProxyView | HostProxyBufferView
    | HostProxyTypedRecord | HostProxyOpaque
end

M.HostLuaFfiPlan = struct HostLuaFfiPlan module_name: ptr(u8); cdefs: view(M.HostCdef); access_plans: view(M.HostAccessPlan) end

M.HostViewDescriptor = struct HostViewDescriptor id: M.HostLayoutId; name: ptr(u8); abi: i32; descriptor_layout: M.HostTypeLayout end

M.HostTerraPlan = struct HostTerraPlan module_name: ptr(u8); source: ptr(u8); layouts: view(M.HostTypeLayout); views: view(M.HostViewDescriptor) end

M.HostCPlan = struct HostCPlan header_name: ptr(u8); source: ptr(u8); layouts: view(M.HostTypeLayout); views: view(M.HostViewDescriptor) end

M.RegionProtocol = struct RegionProtocol name: ptr(u8); roles: view(M.ProtocolRole) end

M.MluaRegionTypeResult = struct MluaRegionTypeResult frag: M.RegionFrag; issues: view(M.TypeIssue) end

M.MluaLoopSource = union MluaLoopSource
    | MluaLoopControlStmt(region: M.ControlStmtRegion)
    | MluaLoopControlExpr(region: M.ControlExprRegion)
end

M.MluaLoopExpandResult = struct MluaLoopExpandResult
    entry: M.EntryControlBlock
    blocks: view(M.ControlBlock)
    issues: view(M.TypeIssue)
end

M.FragmentDeps = struct FragmentDeps
    region_frags: view(M.RegionFrag)
    expr_frags: view(M.ExprFrag)
end

M.RegionFragMeta = struct RegionFragMeta
    name: ptr(u8)
    frag: M.RegionFrag
    protocol: i32
    deps: M.FragmentDeps
end

M.HostValueRef = struct HostValueRef id: M.HostValueId; kind: M.HostValueKind end

M.HostValueKind = union HostValueKind
    | HostValueRegionFrag | HostValueExprFrag
    | HostValueType | HostValueDecl | HostValueModule | HostValueLua
end

M.VecExprEnv = struct VecExprEnv index: M.Binding; locals: view(M.VecLocalFact) end

M.VecStmtResult = union VecStmtResult
    | VecStmtLocal(local: M.VecLocalFact, facts: view(M.VecExprFact))
    | VecStmtStore(store: i32, facts: view(M.VecExprFact))
    | VecStmtIgnored(facts: view(M.VecExprFact))
end

-- MoonVec VecExprResult
M.VecExprResult = union VecExprResult | VecExprResult(value: M.VecExprId, facts: view(M.VecExprFact), ty: ptr(M.Type)) end

-- MoonHost HostStructDecl
M.HostStructDecl = struct HostStructDecl
    id: M.HostLayoutId
    name: ptr(u8)
    repr: M.HostRepr
    fields: view(M.HostFieldDecl)
end

-- MoonSem ConstStmtResult
M.ConstStmtResult = union ConstStmtResult
    | ConstStmtResult(exprs: view(i32), issues: view(M.TypeIssue))
    | ConstStmtFallsThrough
    | ConstStmtReturnVoid
    | ConstStmtReturnValue(value: i32)
    | ConstStmtYieldVoid
    | ConstStmtYieldValue(value: i32)
    | ConstStmtJump(target: M.BlockLabel, args: view(M.JumpArg))
end

return M

M:add_func(mom_scan_line_comment_stop)
M:add_func(mom_scan_antiquote_close)
M:add_func(mom_scan_ident_stop)
M:add_func(mom_scan_number_stop)
M:add_func(mom_number_kind)
M:add_func(mom_emit_token)
M:add_func(mom_lex_into)
M:add_func(mom_emit_event)
M:add_func(mom_skip_seps)
M:add_func(mom_find_simple_end)
M:add_func(mom_is_nested_end_opener)
M:add_func(mom_find_nested_end)
M:add_func(mom_find_lparen_after_name)
M:add_func(mom_parse_param_events)
M:add_func(mom_parse_struct_field_events)
M:add_func(mom_parse_union_variant_events)
M:add_func(mom_parse_module_events)
M:add_func(mom_event)
M:add_func(mom_peek_state)
M:add_func(mom_advance_state)
M:add_func(mom_accept_state)
M:add_func(mom_skip_sep_state)
M:add_func(mom_lbp)
M:add_func(mom_parse_type_state)
M:add_func(mom_parse_expr_bp)
M:add_func(mom_stmt_stop)
M:add_func(mom_parse_stmt_list_state)
M:add_func(mom_skip_balanced_parens)
M:add_func(mom_parse_decl_state)
M:add_func(mom_parse_full_events)

return M

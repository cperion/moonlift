local ExternalConsumers = {
    host_drive_loop = true,
    external_frontend = true,
}

local function consumer_known(name)
    return RegionRegistry[name] ~= nil or ExternalConsumers[name] == true
end

local function sort_keys(t)
    local keys = {}
    for k, _ in pairs(t) do
        keys[#keys + 1] = k
    end
    table.sort(keys)
    return keys
end

local protocol_names = sort_keys(ProtocolVariants)

local total = 0
local producer_ok = 0
local consumer_ok = 0
local wired = 0

print("--- vm surface coverage matrix ---")
print("protocol,variant,producer,producer_ok,consumers,consumers_ok,wired")

for _, proto in ipairs(protocol_names) do
    local variants = ProtocolVariants[proto]
    local producer = ProducerByProtocol[proto]
    local producer_exists = RegionRegistry[producer] ~= nil
    local consumers = ConsumersByProtocol[proto] or {}

    local consumers_exist = true
    for _, c in ipairs(consumers) do
        if not consumer_known(c) then
            consumers_exist = false
            break
        end
    end

    for _, v in ipairs(variants) do
        total = total + 1
        if producer_exists then producer_ok = producer_ok + 1 end
        if consumers_exist then consumer_ok = consumer_ok + 1 end
        local key = proto .. "." .. v
        local is_wired = WiredVariants[key] == true
        if is_wired then wired = wired + 1 end

        print(string.format(
            "%s,%s,%s,%s,%s,%s,%s",
            proto,
            v,
            producer,
            producer_exists and "yes" or "no",
            table.concat(consumers, ";"),
            consumers_exist and "yes" or "no",
            is_wired and "yes" or "no"
        ))
    end
end

print(string.format("summary: variants=%d producer_ok=%d consumer_ok=%d wired=%d", total, producer_ok, consumer_ok, wired))

-- Core gate: fail fast if the primary 5-mode path regresses.
local CoreRequiredVariants = {
    "ModeProto.mode_cold",
    "ModeProto.mode_warm",
    "ModeProto.mode_recording",
    "ModeProto.mode_compiling",
    "ModeProto.mode_native",

    "ColdProto.cold_next",
    "ColdProto.cold_halt",
    "WarmProto.warm_next",
    "WarmProto.warm_halt",

    "RecordingProto.rec_next",
    "RecordingProto.rec_halt",

    "CompilingProto.comp_next",
    "NativeProto.nat_next",

    "RecDecodeProto.rec_decoded",
    "RecDecodeProto.rec_decode_halt",
    "RecObserveProto.rec_observed",
    "RecFoldProto.rec_fold_keep",
    "RecFoldProto.rec_fold_abort",

    "CompRaProto.comp_ra_done",
    "CompEmitProto.comp_emit_done",
    "CompPatchProto.comp_patch_done",
    "CompInstallProto.comp_install_done",

    "NatEnterProto.nat_enter_done",
    "NatRunProto.nat_run_exit",
    "NatExitDecodeProto.nat_decode_to_warm",
    "NatExitDecodeProto.nat_decode_to_recording",
    "NatRestoreProto.nat_restore_done",
}

local missing_core = {}
for _, key in ipairs(CoreRequiredVariants) do
    if WiredVariants[key] ~= true then
        missing_core[#missing_core + 1] = key
    end
end

if #missing_core > 0 then
    print("core_wiring_missing," .. table.concat(missing_core, ";"))
    error("core wiring gate failed")
end

print(string.format("core_wiring_gate,ok,required=%d", #CoreRequiredVariants))

-- Priority plan for next wiring work.
local PriorityByVariant = {}

local function mark_priority(rank, label, keys)
    for _, key in ipairs(keys) do
        PriorityByVariant[key] = { rank = rank, label = label }
    end
end

mark_priority(1, "recording closeout", {
    "RecSnapProto.rec_snap_none",
    "RecSnapProto.rec_snap_added",
    "RecCommitProto.rec_commit_continue",
    "RecCommitProto.rec_commit_to_compiling",
    "RecCommitProto.rec_commit_abort",
    "RecordingProto.rec_to_compiling",
    "RecordingProto.rec_abort_to_warm",
    "WarmProto.warm_to_recording",
})

mark_priority(2, "compile/native completion", {
    "CompStubProto.comp_stub_done",
    "CompStubProto.comp_stub_fail",
    "CompRaProto.comp_ra_fail",
    "CompEmitProto.comp_emit_fail",
    "CompPatchProto.comp_patch_fail",
    "CompInstallProto.comp_install_fail",
    "CompilingProto.comp_to_native",
    "CompilingProto.comp_fail",
    "NativeProto.nat_to_warm",
    "NativeProto.nat_to_recording",
    "NatExitDecodeProto.nat_decode_halt",
    "NatRestoreProto.nat_restore_fail",
    "NatEnterProto.nat_enter_fail",
})

mark_priority(3, "trace/exit linkage", {
    "TraceProto.tr_start",
    "TraceProto.tr_record",
    "TraceProto.tr_end",
    "TraceProto.tr_asm",
    "TraceProto.tr_abort",
    "RootProto.root_started",
    "RootProto.root_ignored",
    "SideProto.side_started",
    "SideProto.side_skipped",
    "ExitProto.exit_restore_interp",
    "ExitProto.exit_side_hot",
    "ExitProto.exit_err",
    "StitchProto.stitch_linked",
    "StitchProto.stitch_rejected",
    "RecFoldProto.rec_fold_replace",
})

mark_priority(4, "runtime subsystems", {
    "GCProtoFlow.gc_propagate",
    "GCProtoFlow.gc_sweep",
    "GCProtoFlow.gc_finalize",
    "GCProtoFlow.gc_pause",
    "BarrierProto.barrier_forward",
    "BarrierProto.barrier_back",
    "BarrierProto.barrier_none",
    "CallProto.call_lua",
    "CallProto.call_c",
    "CallProto.call_ff",
    "CallProto.call_err",
    "ReturnProto.ret_ok",
    "ReturnProto.ret_yield",
    "ReturnProto.ret_err",
    "MetaProto.meta_ok",
    "MetaProto.meta_call_mm",
    "MetaProto.meta_err",
    "FFIProto.ffi_ctype_parse",
    "FFIProto.ffi_cdata_alloc",
    "FFIProto.ffi_call_c",
    "FFIProto.ffi_callback",
    "FFIProto.ffi_err",
    "HookProto.hook_line",
    "HookProto.hook_call",
    "HookProto.hook_ret",
    "HookProto.hook_profile",
    "VMEventProto.vmevent_bc",
    "VMEventProto.vmevent_trace",
    "VMEventProto.vmevent_record",
    "VMEventProto.vmevent_texit",
    "VmProto.vm_step",
    "VmProto.vm_halt",
    "ModeProto.mode_bad",
    "ColdProto.cold_to_warm",
    "NativeProto.nat_halt",
})

mark_priority(5, "frontend", {
    "ParseProto.parse_chunk",
    "ParseProto.parse_proto_done",
    "ParseProto.parse_err",
    "BCLoadProto.bcload_ok",
    "BCLoadProto.bcload_err",
})

local unwired = {}
for _, proto in ipairs(protocol_names) do
    for _, v in ipairs(ProtocolVariants[proto]) do
        local key = proto .. "." .. v
        if WiredVariants[key] ~= true then
            local p = PriorityByVariant[key]
            unwired[#unwired + 1] = {
                key = key,
                rank = p and p.rank or 99,
                label = p and p.label or "unclassified",
            }
        end
    end
end

table.sort(unwired, function(a, b)
    if a.rank ~= b.rank then return a.rank < b.rank end
    return a.key < b.key
end)

print("--- unwired by priority ---")
for i, item in ipairs(unwired) do
    if i > 40 then
        print(string.format("...,more=%d", #unwired - 40))
        break
    end
    print(string.format("%02d,%s,%s", item.rank, item.label, item.key))
end

return "vm surface model loaded"

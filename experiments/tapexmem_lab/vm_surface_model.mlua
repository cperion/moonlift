-- Canonical VM surface model (single file)
--
-- Whole design surface =
--   (1) Struct forest: memory/ABI layout
--   (2) Protocol forest: continuation contracts
--
-- No implementation logic here: only type + protocol signatures.

-- ============================================================
-- 1) Struct forest
-- ============================================================

-- ---------- Value / object core ----------

local TValue = struct TValue
    tag: u8
    bits: u64
end

local GCHeader = struct GCHeader
    gct: u8
    marked: u8
    flags: u16
end

local GCString = struct GCString
    hdr: GCHeader
    hash: u32
    len: u32
    sid: u32
    data: ptr(u8)
end

local GCUpval = struct GCUpval
    hdr: GCHeader
    closed: u8
    immutable: u8
    value_ptr: ptr(TValue)
end

local GCProto = struct GCProto
    hdr: GCHeader
    numparams: u8
    framesize: u8
    sizebc: u32
    bytecode: view(u32)
    constants: view(TValue)
    uvdesc: view(u16)
    trace_anchor: u16
end

local GCFunc = struct GCFunc
    hdr: GCHeader
    ffid: u8
    nupvalues: u8
    proto_ptr: ptr(GCProto)
end

local Node = struct Node
    key: TValue
    val: TValue
    next_ptr: ptr(u8)
end

local GCTable = struct GCTable
    hdr: GCHeader
    array_part: view(TValue)
    hash_part: view(Node)
    asize: u32
    hmask: u32
end

local CData = struct CData
    hdr: GCHeader
    ctypeid: u16
    payload: ptr(u8)
end

-- ---------- Thread / global ----------

local LuaThread = struct LuaThread
    hdr: GCHeader
    status: u8
    stack: view(TValue)
    base: u32
    top: u32
    maxstack: u32
end

local CallFrame = struct CallFrame
    func_ptr: ptr(GCFunc)
    base: u32
    top: u32
    pc: u32
end

local RegisterFile = struct RegisterFile
    slots: view(TValue)
    window_base: u32
    window_top: u32
end

local GCState = struct GCState
    total: u64
    threshold: u64
    state: u8
    debt: i64
    estimate: u64
end

local StrInternState = struct StrInternState
    table_ptr: ptr(GCString)
    mask: u32
    count: u32
    next_sid: u32
end

local GlobalState = struct GlobalState
    gc: GCState
    str: StrInternState
    vmstate: i32
    hookmask: u8
    vmevmask: u8
    current_thread: ptr(LuaThread)
end

-- ---------- Dispatch / hotness ----------

local HotCountTable = struct HotCountTable
    slots: view(u16)
end

local DispatchState = struct DispatchState
    dispatchmode: u8
    hotloop: u16
    hotexit: u16
    tryside: u16
    hotcounts: ptr(HotCountTable)
end

-- ---------- Trace / IR / snapshot (LuaJIT-faithful schema) ----------

-- IR refs are 16-bit biased indices in LuaJIT (REF_BIAS = 0x8000).
-- Constants grow downward (< REF_BIAS), instructions upward (>= REF_BIAS).
local IrIns = struct IrIns
    op1: u16
    op2: u16
    ot: u16        -- packed opcode+type+guard flag class
    prev: u16      -- pre-RA chain link / post-RA reg+spill overlay
end

-- Optional side payload for constant slots (LuaJIT uses union overlays).
local IrConst64 = struct IrConst64
    lo: u32
    hi: u32
end

-- Snapshot header (mirrors SnapShot in lj_jit.h).
local Snapshot = struct Snapshot
    mapofs: u32
    ref: u16       -- first IR ref for this snapshot
    mcofs: u16     -- machine-code offset for exit-stub mapping
    nslots: u8
    topslot: u8
    nent: u8       -- number of compressed entries
    count: u8      -- taken-exit counter (255 = SNAPCOUNT_DONE)
end

-- Compressed snapshot map entry (slot + flags + ref).
-- flags include FRAME/CONT/NORESTORE/KEYINDEX class bits.
local SnapEntry = struct SnapEntry
    raw: u32
end

-- Optional decoded side-exit view (derived from snapshots + patch table).
local ExitInfo = struct ExitInfo
    snap_no: u16
    taken_count: u16
    link_trace: u16
    link_type: u8
    reserved: u8
end

-- Trace object core (inspired by GCtrace layout, minus GC header details).
local Trace = struct Trace
    trace_id: u16
    root_id: u16
    link_id: u16
    nextroot_id: u16
    nextside_id: u16

    start_pc: u32
    start_ins: u32

    nsnap: u16
    nins: u16
    nk: u16
    nchild: u16
    topslot: u8
    sinktags: u8
    linktype: u8
    reserved0: u8

    nsnapmap: u32
    szmcode: u32
    mcloop: u32
    spadjust: u16
    reserved1: u16

    ir: view(IrIns)
    ir_const64: view(IrConst64)
    snaps: view(Snapshot)
    snapmap: view(SnapEntry)
    exits: view(ExitInfo)
    entry_ptr: ptr(u8)
end

local TraceStore = struct TraceStore
    traces: view(Trace)
    count: u16
    freetrace: u16
    sizetrace: u16
end

-- Penalty/blacklist slot model (round-robin cache in LuaJIT).
local HotPenalty = struct HotPenalty
    pc: u32
    val: u16
    reason: u16
end

-- Transient recording builder state.
local TraceBuilder = struct TraceBuilder
    start_pc: u32
    parent: u16
    exit_no: u16

    nins: u16
    nk: u16
    nsnap: u16
    nsnapmap: u32

    baseslot: u16
    maxslot: u16
    framedepth: i32
    retdepth: i32

    needsnap: u8
    mergesnap: u8
    bcskip: u8
    retryrec: u8

    abort_reason: i32
end

local JitState = struct JitState
    state: u8
    flags: u32

    parent: u16
    exit_no: u16
    cur_trace_id: u16

    hotloop: u16
    hotexit: u16
    tryside: u16

    maxrecord: u32
    maxirconst: u32
    maxsnap: u16
    maxside: u16
    maxtrace: u16

    instunroll: i32
    loopunroll: i32
    tailcalled: i32

    penaltyslot: u32
    penalties: view(HotPenalty)
end

-- ---------- Canonical LuaJIT IRDEF tables (ops/types/modes) ----------

local LuaJITIrOperandMode = {
    ref = 0,
    lit = 1,
    cst = 2,
    ___ = 3,
}

-- Base mode class plus modifier bits (from lj_ir.h IRM_* flags).
local LuaJITIrModeClass = {
    N = 0,
    R = 0,
    A = 0x20,
    L = 0x40,
    S = 0x60,
    C = 0x10,
    W = 0x80,
}


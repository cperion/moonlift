    comp_stub = comp_stub,
    comp_install = comp_install,

    nat_enter = nat_enter,
    nat_run = nat_run,
    nat_exit_decode = nat_exit_decode,
    nat_restore = nat_restore,

    gc_step = gc_step,
    barrier_step = barrier_step,
    call_step = call_step,
    return_step = return_step,
    meta_step = meta_step,
    trace_step = trace_step,
    root_start = root_start,

    { id = 18, name = "U16", size_expr = "2" },
    { id = 19, name = "INT", size_expr = "4" },
    { id = 20, name = "U32", size_expr = "4" },
    { id = 21, name = "I64", size_expr = "8" },
    { id = 22, name = "U64", size_expr = "8" },
    { id = 23, name = "SOFTFP", size_expr = "4" },
}

local LuaJITIrOpIdByName = {}
for _, d in ipairs(LuaJITIrOpTable) do
    LuaJITIrOpIdByName[d.name] = d.id
end

if #LuaJITIrOpTable ~= 101 then error("LuaJIT IRDEF drift: expected 101 ops") end
if #LuaJITIrTypeTable ~= 24 then error("LuaJIT IRTDEF drift: expected 24 types") end
if LuaJITIrOpIdByName.KINT ~= 23 then error("LuaJIT IRDEF mismatch: KINT") end
if LuaJITIrOpIdByName.ADD ~= 41 then error("LuaJIT IRDEF mismatch: ADD") end
if LuaJITIrOpIdByName.RETF ~= 11 then error("LuaJIT IRDEF mismatch: RETF") end

-- ---------- Codegen pipeline ----------

local RegAssignment = struct RegAssignment
    dst: u8
    src1: u8
    src2: u8
    spill: u8
end

local PatchEntry = struct PatchEntry
    at_pos: u32
    target_ir: u16
    kind: u8
end

local CodeArena = struct CodeArena
    base: ptr(u8)
    size: u32
    pos: u32
end

local IRArena = struct IRArena
    buf: view(IrIns)
    pos: u32
end

local SnapArena = struct SnapArena
    buf: view(u8)
    pos: u32
end

-- ---------- FFI / parser ----------

local CType = struct CType
    info: u32
    size: u32
    name_ptr: ptr(GCString)
end

local CTState = struct CTState
    ctab: view(CType)
    top: u32
    miscmap_ptr: ptr(GCTable)
end

local LexState = struct LexState
    line: i32
    token: i32
    chunkname_ptr: ptr(GCString)
end

local ParseState = struct ParseState
    lex: ptr(LexState)
    proto_out: ptr(GCProto)
end

-- ---------- Iterator machine root ----------

local IteratorState = struct IteratorState
    mode: u8
    pc: u32
    exit_reason: i32

    current_func: ptr(GCProto)
    current_trace: ptr(Trace)
    builder: ptr(TraceBuilder)

    regs: ptr(RegisterFile)
    thread: ptr(LuaThread)
    global: ptr(GlobalState)

    dispatch: ptr(DispatchState)
    jit: ptr(JitState)

    ir_arena: ptr(IRArena)
    snap_arena: ptr(SnapArena)
    code_arena: ptr(CodeArena)
    trace_store: ptr(TraceStore)

    ctype_state: ptr(CTState)
end

local VMState = struct VMState
    iterator: ptr(IteratorState)
    global: ptr(GlobalState)
end

-- ============================================================
-- 2) Protocol forest
-- ============================================================

-- ---------- Top-level / mode protocols ----------

local VmProto = union VmProto vm_step() | vm_halt(code: i32) end

local ModeProto = union ModeProto
    mode_cold()
  | mode_warm()
  | mode_recording()
  | mode_compiling()
  | mode_native()
  | mode_bad(code: i32)
end

local ColdProto = union ColdProto cold_next() | cold_to_warm() | cold_halt(code: i32) end
local WarmProto = union WarmProto warm_next() | warm_to_recording(start_pc: u32) | warm_halt(code: i32) end
local RecordingProto = union RecordingProto rec_next() | rec_to_compiling() | rec_abort_to_warm(code: i32) | rec_halt(code: i32) end
local CompilingProto = union CompilingProto comp_next() | comp_to_native(trace_id: u16) | comp_fail(code: i32) end
local NativeProto = union NativeProto nat_next() | nat_to_warm() | nat_to_recording() | nat_halt(code: i32) end

-- ---------- Recording subprotocols ----------

local RecDecodeProto = union RecDecodeProto rec_decoded(op: u8, bc: u32) | rec_decode_halt(code: i32) end
local RecObserveProto = union RecObserveProto rec_observed(op: u8, bc: u32) end
local RecFoldProto = union RecFoldProto rec_fold_keep(op: u8, bc: u32) | rec_fold_replace(ref: u16) | rec_fold_abort(code: i32) end
local RecSnapProto = union RecSnapProto rec_snap_none() | rec_snap_added() end
local RecCommitProto = union RecCommitProto rec_commit_continue() | rec_commit_to_compiling() | rec_commit_abort(code: i32) end

-- ---------- Compiling subprotocols ----------

local CompRaProto = union CompRaProto comp_ra_done() | comp_ra_fail(code: i32) end
local CompEmitProto = union CompEmitProto comp_emit_done() | comp_emit_fail(code: i32) end
local CompPatchProto = union CompPatchProto comp_patch_done() | comp_patch_fail(code: i32) end
local CompStubProto = union CompStubProto comp_stub_done() | comp_stub_fail(code: i32) end
local CompInstallProto = union CompInstallProto comp_install_done(trace_id: u16) | comp_install_fail(code: i32) end

-- ---------- Native subprotocols ----------

local NatEnterProto = union NatEnterProto nat_enter_done() | nat_enter_fail(code: i32) end
local NatRunProto = union NatRunProto nat_run_exit(exit_kind: i32) end
local NatExitDecodeProto = union NatExitDecodeProto nat_decode_to_warm() | nat_decode_to_recording() | nat_decode_halt(code: i32) end
local NatRestoreProto = union NatRestoreProto nat_restore_done() | nat_restore_fail(code: i32) end

-- ---------- GC / barriers ----------

local GCProtoFlow = union GCProtoFlow gc_propagate() | gc_sweep() | gc_finalize() | gc_pause() end
local BarrierProto = union BarrierProto barrier_forward() | barrier_back() | barrier_none() end

-- ---------- Calls / returns / metamethods ----------

local CallProto = union CallProto call_lua() | call_c() | call_ff() | call_err(code: i32) end
local ReturnProto = union ReturnProto ret_ok() | ret_yield() | ret_err(code: i32) end
local MetaProto = union MetaProto meta_ok() | meta_call_mm(mm: u8) | meta_err(code: i32) end

-- ---------- Trace linking / exits ----------

local TraceProto = union TraceProto tr_start() | tr_record() | tr_end() | tr_asm() | tr_abort(code: i32) end
local RootProto = union RootProto root_started() | root_ignored() end
local SideProto = union SideProto side_started() | side_skipped() end
local ExitProto = union ExitProto exit_restore_interp() | exit_side_hot() | exit_err(code: i32) end
local StitchProto = union StitchProto stitch_linked() | stitch_rejected(code: i32) end

-- ---------- FFI / parse / load / hooks ----------

local FFIProto = union FFIProto ffi_ctype_parse() | ffi_cdata_alloc() | ffi_call_c() | ffi_callback() | ffi_err(code: i32) end
local ParseProto = union ParseProto parse_chunk() | parse_proto_done() | parse_err(code: i32) end
local BCLoadProto = union BCLoadProto bcload_ok() | bcload_err(code: i32) end
local HookProto = union HookProto hook_line() | hook_call() | hook_ret() | hook_profile() end
local VMEventProto = union VMEventProto vmevent_bc() | vmevent_trace() | vmevent_record() | vmevent_texit() end

-- ============================================================
-- 3) Region signature forest
-- ============================================================

local drive = region drive(vm: ptr(VMState)) -> VmProto
entry start() jump vm_step() end
end

local mode_select = region mode_select(it: ptr(IteratorState)) -> ModeProto
entry start() jump mode_cold() end
end

local run_cold = region run_cold(it: ptr(IteratorState)) -> ColdProto
entry start() jump cold_next() end
end

local run_warm = region run_warm(it: ptr(IteratorState)) -> WarmProto
entry start() jump warm_next() end
end

local run_recording = region run_recording(it: ptr(IteratorState)) -> RecordingProto
entry start() jump rec_next() end
end

local run_compiling = region run_compiling(it: ptr(IteratorState)) -> CompilingProto
entry start() jump comp_next() end
end

local run_native = region run_native(it: ptr(IteratorState)) -> NativeProto
entry start() jump nat_next() end
end

-- Recording pipeline signatures.
local rec_decode = region rec_decode(it: ptr(IteratorState)) -> RecDecodeProto
entry start() jump rec_decode_halt(code = -1) end
end

local rec_observe = region rec_observe(it: ptr(IteratorState), op: u8, bc: u32) -> RecObserveProto
entry start() jump rec_observed(op = op, bc = bc) end
end

local rec_fold = region rec_fold(it: ptr(IteratorState), op: u8, bc: u32) -> RecFoldProto
entry start() jump rec_fold_keep(op = op, bc = bc) end
end

local rec_snapshot = region rec_snapshot(it: ptr(IteratorState), op: u8, bc: u32) -> RecSnapProto
entry start() jump rec_snap_none() end
end

local rec_commit = region rec_commit(it: ptr(IteratorState)) -> RecCommitProto
entry start() jump rec_commit_continue() end
end

-- Compiling pipeline signatures.
local comp_ra = region comp_ra(it: ptr(IteratorState)) -> CompRaProto
entry start() jump comp_ra_done() end
end

local comp_emit = region comp_emit(it: ptr(IteratorState)) -> CompEmitProto
entry start() jump comp_emit_done() end
end

local comp_patch = region comp_patch(it: ptr(IteratorState)) -> CompPatchProto
entry start() jump comp_patch_done() end
end

local comp_stub = region comp_stub(it: ptr(IteratorState)) -> CompStubProto
entry start() jump comp_stub_done() end
end

local comp_install = region comp_install(it: ptr(IteratorState)) -> CompInstallProto
entry start() jump comp_install_fail(code = -1) end
end

-- Native pipeline signatures.
local nat_enter = region nat_enter(it: ptr(IteratorState)) -> NatEnterProto
entry start() jump nat_enter_done() end
end

local nat_run = region nat_run(it: ptr(IteratorState)) -> NatRunProto
entry start() jump nat_run_exit(exit_kind = 0) end
end

local nat_exit_decode = region nat_exit_decode(it: ptr(IteratorState), exit_kind: i32) -> NatExitDecodeProto
entry start() jump nat_decode_to_warm() end
end

local nat_restore = region nat_restore(it: ptr(IteratorState)) -> NatRestoreProto
entry start() jump nat_restore_done() end
end

-- Other subsystem signatures.
local gc_step = region gc_step(vm: ptr(VMState)) -> GCProtoFlow
entry start() jump gc_pause() end
end

local barrier_step = region barrier_step(vm: ptr(VMState)) -> BarrierProto
entry start() jump barrier_none() end
end

local call_step = region call_step(vm: ptr(VMState)) -> CallProto
entry start() jump call_lua() end
end

local return_step = region return_step(vm: ptr(VMState)) -> ReturnProto
entry start() jump ret_ok() end
end

local meta_step = region meta_step(vm: ptr(VMState)) -> MetaProto
entry start() jump meta_ok() end
end

local trace_step = region trace_step(vm: ptr(VMState)) -> TraceProto
entry start() jump tr_start() end
end

local root_start = region root_start(vm: ptr(VMState)) -> RootProto
entry start() jump root_started() end
end

local side_start = region side_start(vm: ptr(VMState)) -> SideProto
entry start() jump side_skipped() end
end

local exit_step = region exit_step(vm: ptr(VMState)) -> ExitProto
entry start() jump exit_restore_interp() end
end

local stitch_step = region stitch_step(vm: ptr(VMState), parent_trace: u16, exit_id: u16, child_trace: u16) -> StitchProto
entry start() jump stitch_rejected(code = -1) end
end

local ffi_step = region ffi_step(vm: ptr(VMState)) -> FFIProto
entry start() jump ffi_ctype_parse() end
end

local parse_step = region parse_step(vm: ptr(VMState), ps: ptr(ParseState)) -> ParseProto
entry start() jump parse_chunk() end
end

local bcload_step = region bcload_step(vm: ptr(VMState), ps: ptr(ParseState)) -> BCLoadProto
entry start() jump bcload_ok() end
end

local hook_step = region hook_step(vm: ptr(VMState)) -> HookProto
entry start() jump hook_line() end
end

local vmevent_step = region vmevent_step(vm: ptr(VMState)) -> VMEventProto
entry start() jump vmevent_bc() end
end

-- ============================================================
-- 4) Coverage matrix (protocol variants -> producer/consumer wiring)
-- ============================================================

local RegionRegistry = {
    drive = drive,

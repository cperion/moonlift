    llpvm_handle: ptr(u8),
    node_store: @{T.UiNodeStore},
    content_store: @{T.UiContentStore},
    text_layout_store: @{T.UiTextLayoutStore},
    paint_store: @{T.UiPaintStore},
    image_store: @{T.UiImageStore},
    font_store: @{T.UiFontStore},
    value_store: @{T.UiValueStore},
    theme_store: @{T.UiThemeStore},
    scroll_store: @{T.UiScrollStore},
    model: @{T.UiModel},
    scene_buffer: @{T.UiSceneBuffer},
    measure_buffer: @{T.UiMeasureBuffer},
    solve_buffer: @{T.UiSolveBuffer},
    view_buffer: @{T.UiViewBuffer},
    report_buffer: @{T.UiReportBuffer},
    event_buffer: @{T.UiEventBuffer},
    epochs: @{T.UiEpochs},
    flags: u32
end

-- -----------------------------------------------------------------------------
-- Kernel and store protocols.
-- -----------------------------------------------------------------------------

R.ui_kernel_create = region ui_kernel_create(config: ptr(@{T.UiConfig});
    created(kernel: owned @{T.UiKernelRef})
  | oom(needed: index)) end

R.ui_kernel_borrow = region ui_kernel_borrow(kernel: @{T.UiKernelRef};
    borrowed(ui: lease ptr(@{T.UiKernel}))
  | missing(kernel: @{T.UiKernelRef})
  | stale(kernel: @{T.UiKernelRef})) end

R.ui_kernel_close_ref = region ui_kernel_close_ref(kernel: owned @{T.UiKernelRef};
    closed
  | busy(kernel: owned @{T.UiKernelRef})
  | missing(kernel: owned @{T.UiKernelRef})
  | stale(kernel: owned @{T.UiKernelRef})) end

R.ui_kernel_init_ptr = region ui_kernel_init_ptr(config: ptr(@{T.UiConfig});
    created(ui: ptr(@{T.UiKernel}))
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_kernel_close_ptr = region ui_kernel_close_ptr(ui: ptr(@{T.UiKernel});
    closed
  | busy
  | bad_argument(code: i32)) end

R.ui_reset_auth = region ui_reset_auth(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_scene = region ui_reset_scene(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_solve = region ui_reset_solve(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_view = region ui_reset_view(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_frame_events = region ui_reset_frame_events(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

-- -----------------------------------------------------------------------------
-- Program validation, import, and compiler pipeline protocols.
-- -----------------------------------------------------------------------------

R.ui_validate_program = region ui_validate_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram});
    valid(root_kind: u8, root_index: u32)
  | invalid_header(code: i32)
  | invalid_section(section: u8)
  | invalid_opcode(at: index, kind: u16)
  | invalid_range(section: u8, first: u32, count: u32)
  | invalid_arity(at: index, expected: u32, got: u32)
  | duplicate_id(id: u64)
  | missing_resource(section: u8, index_: u32)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_validate_llpv_program = region ui_validate_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index;
    valid(root_stream: u32)
  | invalid_header(code: i32)
  | invalid_section(section: u8)
  | invalid_opcode(at: index, kind: u16)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_import_auth = region ui_import_auth(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram}), root_kind: u8, root_index: u32;
    imported(root: @{T.UiNodeRef})
  | invalid_child(parent: u64, child_index: u32)
  | duplicate_id(id: u64)
  | missing_resource(section: u8, index_: u32)
  | unsupported_node(kind: u16)
  | oom(needed: index)) end

R.ui_import_auth_buffer = region ui_import_auth_buffer(ui: ptr(@{T.UiKernel}), readonly nodes: view(@{T.UiAuthNode}), readonly children: view(u32);
    imported(root: @{T.UiNodeRef})
  | invalid_child(parent: u64, child_index: u32)
  | duplicate_id(id: u64)
  | unsupported_node(kind: u16)
  | oom(needed: index)) end

R.ui_import_llpv_program = region ui_import_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index;
    imported(root: @{T.UiNodeRef})
  | invalid_header(code: i32)
  | invalid_opcode(at: index, kind: u16)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_expand_compose = region ui_expand_compose(ui: ptr(@{T.UiKernel}), readonly compose: view(@{T.UiComposeNode});
    expanded(auth: @{T.UiAuthBuffer})

M.ModelState.Scroll = { id = T.Id, x = moon.f32, y = moon.f32, content_w = moon.f32, content_h = moon.f32, viewport_w = moon.f32, viewport_h = moon.f32, epoch = T.Epoch }
M.ModelState.TextEdit = { id = T.Id, cursor = moon.u32, selection_start = moon.u32, selection_end = moon.u32, composing_start = moon.u32, composing_len = moon.u32, flags = moon.u32, epoch = T.Epoch }

M.EventEvent = M.Event "Event"
M.EventEvent.HoverChanged = { id = T.Id, hovered = moon.bool }
M.EventEvent.Pressed = { id = T.Id, button = moon.u16 }
M.EventEvent.Released = { id = T.Id, button = moon.u16 }
M.EventEvent.Activated = { id = T.Id }
M.EventEvent.FocusChanged = { old_id = T.Id, new_id = T.Id }
M.EventEvent.ScrollChanged = { id = T.Id, x = moon.f32, y = moon.f32 }
M.EventEvent.DragStarted = { id = T.Id, x = moon.f32, y = moon.f32 }
M.EventEvent.DragMoved = { id = T.Id, x = moon.f32, y = moon.f32, dx = moon.f32, dy = moon.f32 }
M.EventEvent.DragEnded = { id = T.Id, x = moon.f32, y = moon.f32 }
M.EventEvent.DragCancelled = { id = T.Id }
M.EventEvent.Dropped = { source_id = T.Id, target_id = T.Id, slot_id = T.Id }
M.EventEvent.TextInput = { id = T.Id, text_ref = T.Ref }
M.EventEvent.TextEditing = { id = T.Id, text_ref = T.Ref, start = moon.u32, length = moon.u32 }
M.EventEvent.TextInputWithoutFocus = { text_ref = T.Ref }
M.EventEvent.Cancelled = { id = T.Id }
M.EventEvent.CaptureChanged = { old_id = T.Id, new_id = T.Id }

-- -----------------------------------------------------------------------------
-- Worlds.
-- -----------------------------------------------------------------------------

M.worlds = {}
M.worlds.env           = M.Env:world "env"
M.worlds.theme         = M.Theme:world "theme"
M.worlds.style         = M.Style:world "style"
M.worlds.style_resolved = M.Style:world "style_resolved"
M.worlds.resource      = M.Resource:world "resource"
M.worlds.compose       = M.Compose:world "compose"
M.worlds.auth          = M.Auth:world "auth"
M.worlds.auth_checked  = M.Auth:world "auth_checked"
M.worlds.imported      = M.Imported:world "imported"
M.worlds.scene         = M.Scene:world "scene"
M.worlds.measure       = M.Measure:world "measure"
M.worlds.solve         = M.Solve:world "solve"
M.worlds.view          = M.View:world "view"
M.worlds.report        = M.Report:world "report"
M.worlds.input         = M.Input:world "input"
M.worlds.model         = M.Model:world "model"
M.worlds.event         = M.Event:world "event"

-- -----------------------------------------------------------------------------
-- Cached phases.  This is where MLUI becomes naturally retained:
-- app/frontends may rebuild streams immediately; LLPVM phase keys reuse stable
-- phase products when streams, explicit args, and resource generations match.
-- -----------------------------------------------------------------------------

M.phases = {}

M.phases.expand_compose = M.vm.phase "mlui_expand_compose" {
    from = M.worlds.compose,
    to = M.worlds.auth,
    entry = "ui_expand_compose",
    cache = "full",
}

M.phases.validate_auth = M.vm.phase "mlui_validate_auth" {
    from = M.worlds.auth,
    to = M.worlds.auth_checked,
    entry = "ui_validate_auth",
    cache = "record",
}

M.phases.import_auth = M.vm.phase "mlui_import_auth" {
    from = M.worlds.auth_checked,
    to = M.worlds.imported,
    entry = "ui_import_auth",
    cache = "full",
}

M.phases.resolve_style = M.vm.phase "mlui_resolve_style" {
    from = M.worlds.style,
    to = M.worlds.style_resolved,
    entry = "ui_resolve_style",
    cache = "full",
}

M.phases.lower_scene = M.vm.phase "mlui_lower_scene" {
    from = M.worlds.imported,
    to = M.worlds.scene,
    entry = "ui_lower_scene",
    cache = "full",
}

M.phases.measure_scene = M.vm.phase "mlui_measure_scene" {
    from = M.worlds.scene,
    to = M.worlds.measure,
    entry = "ui_measure_scene",
    cache = "full",
}

M.phases.solve_scene = M.vm.phase "mlui_solve_scene" {
    from = M.worlds.measure,
    to = M.worlds.solve,
    entry = "ui_solve_scene",
    cache = "full",
}

M.phases.render_view = M.vm.phase "mlui_render_view" {
    from = M.worlds.solve,
    to = M.worlds.view,
    entry = "ui_render_ops",
    cache = "record",
}

M.phases.build_report = M.vm.phase "mlui_build_report" {
    from = M.worlds.view,
    to = M.worlds.report,
    entry = "ui_runtime_report",
    cache = "record",
}

M.phases.interact_step = M.vm.phase "mlui_interact_step" {
    from = M.worlds.input,
    to = M.worlds.event,
    entry = "ui_interact_step",
    cache = nil,
}

M.phase_order = {
    "expand_compose",
    "validate_auth",
    "import_auth",
    "resolve_style",
    "lower_scene",
    "measure_scene",
    "solve_scene",
    "render_view",
    "build_report",
    "interact_step",
}

M.phase_args = {
    expand_compose = {},
    validate_auth = { "resource_args" },
    import_auth = { "resource_args" },
    resolve_style = { "env_args", "theme_args", "interaction_args" },
    lower_scene = { "env_args", "theme_args", "resource_args", "interaction_args" },
    measure_scene = { "env_args", "resource_args" },
    solve_scene = { "solve_args" },
    render_view = { "render_args" },
    build_report = { "report_args" },
    interact_step = { "env_args", "interaction_args" },
}


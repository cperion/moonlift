M.SceneDecor.Overlay = { id = T.Id, anchor_id = T.Id, placement = moon.u8 }
M.SceneDecor.ModalBarrier = { id = T.Id, policy = T.Policy }

M.MeasureNode = M.Measure "Node"
M.MeasureNode.Measured = { id = T.Id, layout_index = moon.u32, intrinsic = T.IntrinsicSize, text_layout_ref = T.Ref, epoch = T.Epoch }
M.MeasureNode.Missing = { id = T.Id, layout_index = moon.u32, reason = moon.u16 }


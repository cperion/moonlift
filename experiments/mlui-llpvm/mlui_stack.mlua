  | unsupported_compose(kind: u16)
  | oom(needed: index)) end

R.ui_resolve_style = region ui_resolve_style(ui: ptr(@{T.UiKernel}), token_range: @{T.UiRange}, env: @{T.UiEnvClass}, state: @{T.UiStateFacts};
    resolved(layout: @{T.UiLayoutStyle}, decor: @{T.UiDecorStyle}, interact: @{T.UiInteractionStyle})

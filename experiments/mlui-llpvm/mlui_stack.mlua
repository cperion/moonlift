-- -----------------------------------------------------------------------------
-- Header aliases for hosted Lua generators.
-- -----------------------------------------------------------------------------

T.MLUI_ABI_VERSION = M.constants.MLUI_ABI_VERSION
T.MLUI_MAGIC_U32 = M.constants.MLUI_MAGIC_U32
T.MLUI_LLPV_MAGIC_U32 = M.constants.MLUI_LLPV_MAGIC_U32
T.StatusCode = M.enums.status
T.RootKind = M.enums.root_kind
T.AxisKind = M.enums.axis
T.Direction = M.enums.direction
T.InputRole = M.enums.input_role
T.StateMask = M.enums.state_mask
T.AuthKind = M.enums.auth_kind
T.ComposeKind = M.enums.compose_kind
T.LayoutKind = M.enums.layout_kind
T.DecorKind = M.enums.decor_kind
T.ViewKind = M.enums.view_kind
T.RawInputKind = M.enums.raw_input_kind
T.EventKind = M.enums.event_kind
T.PaintKind = M.enums.paint_kind
T.ValueKind = M.enums.value_kind

-- -----------------------------------------------------------------------------
-- Scalar aliases for hosted Lua generators.
-- -----------------------------------------------------------------------------

T.UiId = moon.u64
T.UiRefBits = moon.u32
T.UiEpoch = moon.u64
T.UiKind = moon.u16
T.UiFlags = moon.u32
T.UiIndex32 = moon.u32
T.UiScalar = moon.f32

-- -----------------------------------------------------------------------------
-- Handles.  C encodes these as uint32_t in the v1 fast-row profile.
-- -----------------------------------------------------------------------------

T.UiKernelRef = handle UiKernelRef : u32 invalid 0
    domain UiKernelStore
    target UiKernel
end

T.UiNodeRef = handle UiNodeRef : u32 invalid 0
    domain UiNodeStore
    target UiNodeRecord
end

T.UiContentRef = handle UiContentRef : u32 invalid 0
    domain UiContentStore
    target UiContent
end

T.UiTextLayoutRef = handle UiTextLayoutRef : u32 invalid 0
    domain UiTextLayoutStore
    target UiTextLayout
end

T.UiPaintRef = handle UiPaintRef : u32 invalid 0
    domain UiPaintStore
    target UiPaintProgramSet
end

T.UiImageRef = handle UiImageRef : u32 invalid 0
    domain UiImageStore
    target UiImageRecord
end

T.UiFontRef = handle UiFontRef : u32 invalid 0
    domain UiFontStore
    target UiFontRecord
end

T.UiValueRef = handle UiValueRef : u32 invalid 0
    domain UiValueStore
    target UiValueRecord
end

T.UiThemeRef = handle UiThemeRef : u32 invalid 0
    domain UiThemeStore
    target UiTheme
end

T.UiScrollRef = handle UiScrollRef : u32 invalid 0
    domain UiScrollStore
    target UiScrollState
end

-- -----------------------------------------------------------------------------
-- Common products.
-- -----------------------------------------------------------------------------

T.UiStatus = struct UiStatus
    code: i32,
    detail: i32,
    at: index,
    needed: index
end

T.UiVec2 = struct UiVec2
    x: f32,
    y: f32
end

T.UiRect = struct UiRect
    x: f32,
    y: f32,
    w: f32,
    h: f32
end

T.UiInsets = struct UiInsets
    left: f32,
    top: f32,
    right: f32,
    bottom: f32
end

T.UiColor = struct UiColor
    r: f32,
    g: f32,
    b: f32,
    a: f32
end

T.UiRange = struct UiRange
    first: u32,
    count: u32
end

T.UiSize = struct UiSize
    w: f32,
    h: f32
end

T.UiViewport = struct UiViewport
    x: f32,
    y: f32,
    w: f32,
    h: f32,
    device_scale: f32
end

T.UiEpochs = struct UiEpochs
    program_epoch: u64,
    content_epoch: u64,
    paint_epoch: u64,
    image_epoch: u64,
    font_epoch: u64,
    value_epoch: u64,
    theme_epoch: u64,
    text_layout_epoch: u64,
    scene_epoch: u64,
    measure_epoch: u64,
    solve_epoch: u64,
    view_epoch: u64,
    report_epoch: u64,
    model_epoch: u64,
    scroll_epoch: u64
end

-- -----------------------------------------------------------------------------
-- Environment, theme, style, and phase argument products.
-- -----------------------------------------------------------------------------

T.UiEnvClass = struct UiEnvClass
    breakpoint: u8,
    color_scheme: u8,
    motion: u8,
    density: u8,
    pointer: u8,
    platform: u8,
    flags: u32
end

T.UiStateFacts = struct UiStateFacts
    id: u64,
    state_mask: u32,
    hover_id: u64,
    focus_id: u64,
    capture_id: u64,
    drag_id: u64,
    active_id: u64,
    model_epoch: u64
end

T.UiEnvArgs = struct UiEnvArgs
    env_class: @{T.UiEnvClass},
    viewport: @{T.UiViewport},
    time_ms: u64,
    flags: u32
end

T.UiThemeArgs = struct UiThemeArgs
    theme_ref: @{T.UiThemeRef},
    theme_epoch: u64
end

T.UiResourceArgs = struct UiResourceArgs
    content_epoch: u64,
    paint_epoch: u64,
    image_epoch: u64,
    font_epoch: u64,
    value_epoch: u64,
    text_layout_epoch: u64
end

T.UiInteractionArgs = struct UiInteractionArgs
    model_epoch: u64,
    hover_id: u64,
    focus_id: u64,
    capture_id: u64,
    drag_id: u64,
    scroll_epoch: u64
end

T.UiSolveArgs = struct UiSolveArgs
    viewport_w: f32,
    viewport_h: f32,
    scroll_epoch: u64,
    text_layout_epoch: u64
end

T.UiRenderArgs = struct UiRenderArgs
    solve_epoch: u64,
    decor_epoch: u64,
    paint_epoch: u64,
    text_epoch: u64
end

T.UiReportArgs = struct UiReportArgs
    view_epoch: u64,
    model_epoch: u64
end

T.UiLength = struct UiLength
    kind: u8,
    value: f32,
    min: f32,
    max: f32
end

T.UiTrack = struct UiTrack
    min: @{T.UiLength},
    max: @{T.UiLength},
    repeat_count: u32,
    flags: u32
end

T.UiStyleToken = struct UiStyleToken
    id: u64,
    first_cond: u32,
    cond_count: u32,
    first_atom: u32,
    atom_count: u32,
    order: u32,
    flags: u32
end

T.UiStyleCond = struct UiStyleCond

M.SceneLayout.Scroll = { id = T.Id, axis = T.Axis, child = moon.u32, style_index = moon.u32 }
M.SceneLayout.InputSurface = { id = T.Id, role = T.Role, child = moon.u32, style_index = moon.u32 }
M.SceneLayout.Wrapper = { id = T.Id, kind = T.Kind, child = moon.u32, style_index = moon.u32 }

M.SceneDecor = M.Scene "Decor"
M.SceneDecor.None = { id = T.Id }

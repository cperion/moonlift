}

M.validation = {
    program = {
        "non_null_program",
        "magic",
        "abi_version",
        "endian",
        "pointer_size",
        "root_kind",
        "root_index",
        "section_pointer_count_pairs",
        "auth_kind_range",
        "compose_kind_range",
        "child_ranges",
        "auth_arity",
        "style_ranges",
        "track_ranges",
        "paint_ranges",
        "required_resource_refs",
        "duplicate_nonzero_ids",
        "feature_flags",
    },
    view_stream = {
        "kind_range",
        "transform_stack_balanced",
        "clip_stack_balanced",
        "scroll_stack_balanced",
        "focus_scope_stack_balanced",
        "layer_stack_balanced",
    },
    text = {
        "borrowed_input_text_dispatch_only",
        "durable_text_copied_into_content_store",
        "render_consumes_text_layout_ref_only",
    },
}

M.abi = {
    header = "mlui_header.mlua",
    c_header = "mlui_c_api.h",
    c_prefix = "mlui_",
    functions = {
        "mlui_abi_version",
        "mlui_kernel_init",
        "mlui_kernel_init_ex",
        "mlui_kernel_close",
        "mlui_kernel_reset_frame",
        "mlui_validate_program",
        "mlui_load_program",
        "mlui_load_llpv_program",
        "mlui_import_auth_buffer",
        "mlui_lower_solve_render",
        "mlui_frame",
        "mlui_runtime_report",
        "mlui_interact_step",
        "mlui_view_ops",
        "mlui_events",
        "mlui_report_get",
        "mlui_clear_events",
        "mlui_content_retain_copy",
        "mlui_content_release",
        "mlui_paint_retain",
        "mlui_paint_release",
        "mlui_image_register",
        "mlui_image_release",
        "mlui_font_register",
        "mlui_font_release",
        "mlui_value_set",
        "mlui_value_retain",
        "mlui_value_release",
    },
}

function M.program(roots)
    return M.vm.program(roots)
end

function M.bytecode(roots)
    return M.program(roots):bytecode()
end



-- mlui_stack.mlua
-- Canonical LLPVM stack declaration for MLUI.
--
-- This file is the semantic source of truth.  It declares the MLUI operation
-- languages, typed constructors, worlds, machines, phases, cache policy, row
-- projections, ABI names, and validation tables.  mlui_header.mlua,
-- mlui_bytecode.md and mlui_c_api.h should be generated from or
-- mechanically checked against this file.

package.path = "./lua/?.lua;./lua/?/init.lua;" .. package.path

local moon = require "moonlift"
local ll = require "llpvm"

local M = {}

M.constants = {
    MLUI_ABI_VERSION = 1,
    MLUI_MAGIC_U32 = 0x49554c4d,       -- 'M''L''U''I' little-endian
    MLUI_LLPV_MAGIC_U32 = 0x56504c4c,  -- 'L''L''P''V' little-endian
}

M.vm = ll.vm {
    cache_bytes = 64 * 1024,
}

-- -----------------------------------------------------------------------------
-- Shared LLPVM type products.
-- -----------------------------------------------------------------------------

M.T = {}
M.R = {}
M.F = {}
local T = M.T
local R = M.R
local F = M.F

T.Id      = moon.u64
T.Ref     = moon.u32
T.Epoch   = moon.u64
T.Kind    = moon.u16
T.Flags   = moon.u32
T.Index32 = moon.u32
T.Axis    = moon.u8
T.Role    = moon.u8
T.Policy  = moon.u16

T.Vec2 = struct MluiCore_Vec2 x: f32, y: f32 end

T.Rect = struct MluiCore_Rect x: f32, y: f32, w: f32, h: f32 end

T.Insets = struct MluiCore_Insets left: f32, top: f32, right: f32, bottom: f32 end

T.Color = struct MluiCore_Color r: f32, g: f32, b: f32, a: f32 end

T.Range = struct MluiCore_Range first: u32, count: u32 end

T.Size = struct MluiCore_Size w: f32, h: f32 end

T.Viewport = struct MluiCore_Viewport x: f32, y: f32, w: f32, h: f32, device_scale: f32 end

T.Length = struct MluiStyle_Length kind: u8, value: f32, min: f32, max: f32 end

T.Track = struct MluiStyle_Track min: @{T.Length}, max: @{T.Length}, repeat_count: u32, flags: u32 end

T.EnvClass = struct MluiEnv_ClassRecord
    breakpoint: u8,
    color_scheme: u8,
    motion: u8,
    density: u8,
    pointer: u8,
    platform: u8,
    flags: u32
end

T.StateFacts = struct MluiModel_StateFacts
    id: u64,
    state_mask: u32,
    hover_id: u64,
    focus_id: u64,
    capture_id: u64,
    drag_id: u64,
    active_id: u64,
    model_epoch: u64
end

T.EnvArgs = struct MluiPhase_EnvArgs
    env_class: @{T.EnvClass},
    viewport: @{T.Viewport},
    time_ms: u64,
    flags: u32
end

T.ThemeArgs = struct MluiPhase_ThemeArgs theme_ref: u32, theme_epoch: u64 end

T.ResourceArgs = struct MluiPhase_ResourceArgs
    content_epoch: u64,
    paint_epoch: u64,
    image_epoch: u64,
    font_epoch: u64,
    value_epoch: u64,
    text_layout_epoch: u64
end

T.InteractionArgs = struct MluiPhase_InteractionArgs
    model_epoch: u64,
    hover_id: u64,
    focus_id: u64,
    capture_id: u64,
    drag_id: u64,
    scroll_epoch: u64
end

T.SolveArgs = struct MluiPhase_SolveArgs
    viewport_w: f32,
    viewport_h: f32,
    scroll_epoch: u64,
    text_layout_epoch: u64
end

T.RenderArgs = struct MluiPhase_RenderArgs
    solve_epoch: u64,
    decor_epoch: u64,
    paint_epoch: u64,
    text_epoch: u64
end

T.ReportArgs = struct MluiPhase_ReportArgs view_epoch: u64, model_epoch: u64 end

T.IntrinsicSize = struct MluiMeasure_IntrinsicSize
    min_w: f32,
    min_h: f32,
    pref_w: f32,
    pref_h: f32,
    max_w: f32,
    max_h: f32,
    baseline: f32,
    flags: u32
end

-- -----------------------------------------------------------------------------
-- Languages.
-- -----------------------------------------------------------------------------

M.Core     = M.vm.language "MluiCore"
M.Env      = M.vm.language "MluiEnv"
M.Theme    = M.vm.language "MluiTheme"
M.Style    = M.vm.language "MluiStyle"
M.Resource = M.vm.language "MluiResource"
M.Auth     = M.vm.language "MluiAuth"
M.Compose  = M.vm.language "MluiCompose"
M.Imported = M.vm.language "MluiImported"
M.Scene    = M.vm.language "MluiScene"
M.Measure  = M.vm.language "MluiMeasure"
M.Solve    = M.vm.language "MluiSolve"
M.View     = M.vm.language "MluiView"
M.Report   = M.vm.language "MluiReport"
M.Input    = M.vm.language "MluiInput"
M.Event    = M.vm.language "MluiEvent"
M.Model    = M.vm.language "MluiModel"

-- -----------------------------------------------------------------------------
-- Core / env / theme / style languages.
-- -----------------------------------------------------------------------------

M.EnvClass = M.Env "Class"
M.EnvClass.Default = {}
M.EnvClass.Custom = {
    breakpoint = moon.u8,
    color_scheme = moon.u8,
    motion = moon.u8,
    density = moon.u8,
    pointer = moon.u8,
    platform = moon.u8,
    flags = moon.u32,
}

M.EnvViewport = M.Env "Viewport"
M.EnvViewport.Viewport = {
    width = moon.f32,
    height = moon.f32,
    device_scale = moon.f32,
}

M.ThemeRecord = M.Theme "Record"
M.ThemeRecord.Palette = { name = T.Id, color = T.Color }
M.ThemeRecord.Spacing = { name = T.Id, value = moon.f32 }
M.ThemeRecord.Font = { name = T.Id, content_ref = T.Ref, font_ref = T.Ref, size = moon.f32, weight = moon.u32, flags = moon.u32 }
M.ThemeRecord.Radius = { name = T.Id, value = moon.f32 }
M.ThemeRecord.Border = { name = T.Id, width = moon.f32, color = T.Color }
M.ThemeRecord.Opacity = { name = T.Id, value = moon.f32 }
M.ThemeRecord.Theme = {
    id = T.Ref,
    epoch = T.Epoch,
    palette = T.Range,
    spacing = T.Range,
    font = T.Range,
    radius = T.Range,
    border = T.Range,
    opacity = T.Range,
}

M.StyleToken = M.Style "Token"
M.StyleToken.Token = {
    id = T.Id,
    conds = T.Range,
    atoms = T.Range,
    order = moon.u32,
    flags = moon.u32,
}

M.StyleCond = M.Style "Cond"
M.StyleCond.State = { mask = moon.u32, op = moon.u8, flags = moon.u32 }
M.StyleCond.Env = { key = moon.u32, op = moon.u8, rhs_i = moon.i32, rhs_f = moon.f32, rhs_id = T.Id, flags = moon.u32 }
M.StyleCond.Resource = { section = moon.u8, ref = T.Ref, epoch = T.Epoch, flags = moon.u32 }

M.StyleAtom = M.Style "Atom"
M.StyleAtom.Display = { kind = moon.u16 }
M.StyleAtom.Position = { kind = moon.u16 }
M.StyleAtom.Width = { length = T.Length }
M.StyleAtom.Height = { length = T.Length }
M.StyleAtom.MinWidth = { length = T.Length }
M.StyleAtom.MinHeight = { length = T.Length }
M.StyleAtom.MaxWidth = { length = T.Length }
M.StyleAtom.MaxHeight = { length = T.Length }
M.StyleAtom.Margin = { insets = T.Insets }
M.StyleAtom.Padding = { insets = T.Insets }
M.StyleAtom.Gap = { x = moon.f32, y = moon.f32 }
M.StyleAtom.FlexDirection = { direction = moon.u8 }
M.StyleAtom.FlexGrow = { value = moon.f32 }
M.StyleAtom.FlexShrink = { value = moon.f32 }
M.StyleAtom.FlexBasis = { length = T.Length }
M.StyleAtom.AlignItems = { value = moon.u16 }
M.StyleAtom.JustifyContent = { value = moon.u16 }
M.StyleAtom.GridTracks = { axis = T.Axis, tracks = T.Range }
M.StyleAtom.Overflow = { axis = T.Axis, policy = T.Policy }
M.StyleAtom.BackgroundColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.ForegroundColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.BorderColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.BorderWidth = { width = moon.f32 }
M.StyleAtom.Radius = { radius = moon.f32 }
M.StyleAtom.Opacity = { value = moon.f32 }
M.StyleAtom.Font = { font_ref = T.Ref, theme_name = T.Id }
M.StyleAtom.FontSize = { size = moon.f32 }
M.StyleAtom.FontWeight = { weight = moon.u32 }
M.StyleAtom.TextAlign = { align = moon.u16 }
M.StyleAtom.LineHeight = { value = moon.f32 }
M.StyleAtom.Cursor = { cursor = moon.u16 }
M.StyleAtom.LayerOrder = { order = moon.i32 }
M.StyleAtom.UserFlag = { flag = moon.u32 }

M.StyleResolved = M.Style "Resolved"
M.StyleResolved.Layout = { id = T.Id, style_index = moon.u32, flags = moon.u32 }
M.StyleResolved.Decor = { id = T.Id, style_index = moon.u32, flags = moon.u32 }
M.StyleResolved.Interaction = { id = T.Id, role = T.Role, policy = T.Policy, flags = moon.u32 }

-- -----------------------------------------------------------------------------
-- Resource language.
-- -----------------------------------------------------------------------------

M.ResourceRecord = M.Resource "Record"
M.ResourceRecord.Content = { ref = T.Ref, byte_len = moon.u32, encoding = moon.u32, layout_affecting = moon.bool, epoch = T.Epoch }
M.ResourceRecord.TextLayout = { ref = T.Ref, content_ref = T.Ref, font_ref = T.Ref, width_constraint = moon.f32, epoch = T.Epoch }
M.ResourceRecord.PaintProgram = { ref = T.Ref, ops = T.Range, epoch = T.Epoch }
M.ResourceRecord.Image = { ref = T.Ref, host_key = moon.u64, width = moon.f32, height = moon.f32, format = moon.u32, epoch = T.Epoch }
M.ResourceRecord.Font = { ref = T.Ref, host_key = moon.u64, family_content_ref = T.Ref, size = moon.f32, weight = moon.u32, style = moon.u32, epoch = T.Epoch }
M.ResourceRecord.Value = { ref = T.Ref, kind = moon.u16, payload_a = moon.u64, payload_b = moon.u64, epoch = T.Epoch }

M.Value = M.Resource "Value"
M.Value.None = {}
M.Value.Bool = { value = moon.bool }
M.Value.I32 = { value = moon.i32 }
M.Value.U32 = { value = moon.u32 }
M.Value.F32 = { value = moon.f32 }
M.Value.F64 = { value = moon.f64 }
M.Value.Id = { value = T.Id }
M.Value.Ref = { value = T.Ref }
M.Value.Range = { min = moon.f32, max = moon.f32, value = moon.f32 }
M.Value.Color = { color = T.Color }
M.Value.Text = { content_ref = T.Ref }
M.Value.Custom = { kind = moon.u16, data_ref = T.Ref }

-- -----------------------------------------------------------------------------
-- Auth and compose languages.  Auth nodes are authored semantic opcodes, not
-- draw commands.  Ranges are row-profile compatible; id/ref 0 means absent.
-- -----------------------------------------------------------------------------

M.AuthNode = M.Auth "Node"
M.AuthNode.Empty = { id = T.Id, state = T.StateFacts, styles = T.Range }
M.AuthNode.Fragment = { id = T.Id, children = T.Range }
M.AuthNode.Box = { id = T.Id, styles = T.Range, children = T.Range, state = T.StateFacts }
M.AuthNode.Text = { id = T.Id, content_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextInline = { id = T.Id, content_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextRef = { id = T.Id, text_layout_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Paint = { id = T.Id, paint_ref = T.Ref, paint_range = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Canvas = { id = T.Id, value_ref = T.Ref, paint_ref = T.Ref, paint_range = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Image = { id = T.Id, image_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Scroll = { id = T.Id, axis = T.Axis, policy = T.Policy, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.InputSurface = { id = T.Id, role = T.Role, policy = T.Policy, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.DragSource = { id = T.Id, policy = T.Policy, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.DropTarget = { id = T.Id, policy = T.Policy, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.FocusScope = { id = T.Id, policy = T.Policy, children = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Layer = { id = T.Id, layer_kind = moon.u8, order = moon.i32, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.Overlay = { id = T.Id, anchor_id = T.Id, placement = moon.u8, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.Modal = { id = T.Id, barrier_policy = T.Policy, child = moon.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextField = { id = T.Id, content_ref = T.Ref, text_field_state_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Slot = { id = T.Id, slot_kind = moon.u16, value_ref = T.Ref, child = moon.u32, styles = T.Range, state = T.StateFacts }

M.ComposeNode = M.Compose "Node"
M.ComposeNode.Panel = { id = T.Id, header = moon.u32, body = moon.u32, footer = moon.u32, styles = T.Range, state = T.StateFacts }
M.ComposeNode.ScrollPanel = { id = T.Id, header = moon.u32, body = moon.u32, footer = moon.u32, axis = T.Axis, styles = T.Range, state = T.StateFacts }
M.ComposeNode.HSplit = { id = T.Id, panes = T.Range, ratios = T.Range, styles = T.Range, state = T.StateFacts }
M.ComposeNode.VSplit = { id = T.Id, panes = T.Range, ratios = T.Range, styles = T.Range, state = T.StateFacts }
M.ComposeNode.Workbench = { id = T.Id, toolbar = moon.u32, sidebar = moon.u32, main = moon.u32, bottom = moon.u32, styles = T.Range, state = T.StateFacts }

M.ImportedNode = M.Imported "Node"
M.ImportedNode.Record = {
    ref = T.Ref,
    kind = T.Kind,
    id = T.Id,
    children = T.Range,
    styles = T.Range,
    content_ref = T.Ref,
    text_layout_ref = T.Ref,
    image_ref = T.Ref,
    paint_ref = T.Ref,
    value_ref = T.Ref,
    other_id = T.Id,
    axis = T.Axis,
    role = T.Role,
    policy = T.Policy,
    state_mask = moon.u32,
    flags = moon.u32,
    epoch = T.Epoch,
}


    EMPTY = { min = 0, max = 0 },
    FRAGMENT = { min = 0, max = false },
    BOX = { min = 0, max = false },
    TEXT = { min = 0, max = 0 },
    TEXT_INLINE = { min = 0, max = 0 },
    TEXT_REF = { min = 0, max = 0 },
    PAINT = { min = 0, max = 0 },
    CANVAS = { min = 0, max = 0 },
    IMAGE = { min = 0, max = 0 },
    SCROLL = { min = 1, max = 1 },
    INPUT_SURFACE = { min = 1, max = 1 },
    DRAG_SOURCE = { min = 1, max = 1 },
    DROP_TARGET = { min = 1, max = 1 },
    FOCUS_SCOPE = { min = 0, max = false },
    LAYER = { min = 1, max = 1 },
    OVERLAY = { min = 1, max = 1 },
    MODAL = { min = 1, max = 1 },
    TEXT_FIELD = { min = 0, max = 0 },
    SLOT = { min = 0, max = 1 },
}


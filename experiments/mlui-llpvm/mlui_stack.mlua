-- -----------------------------------------------------------------------------
-- Public C ABI seals.  These are product-to-product.  They convert region
-- protocols to UiStatus exactly once and do not duplicate region logic.
-- -----------------------------------------------------------------------------

F.mlui_abi_version = func mlui_abi_version(): u32 end

F.mlui_kernel_init = func mlui_kernel_init(out: ptr(ptr(@{T.UiKernel}))): @{T.UiStatus} end

F.mlui_kernel_init_ex = func mlui_kernel_init_ex(readonly config: ptr(@{T.UiConfig}), out: ptr(ptr(@{T.UiKernel}))): @{T.UiStatus} end

F.mlui_kernel_close = func mlui_kernel_close(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_kernel_reset_frame = func mlui_kernel_reset_frame(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_validate_program = func mlui_validate_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram})): @{T.UiStatus} end

F.mlui_load_program = func mlui_load_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram}), out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_load_llpv_program = func mlui_load_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index, out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_import_auth_buffer = func mlui_import_auth_buffer(ui: ptr(@{T.UiKernel}), readonly nodes: ptr(@{T.UiAuthNode}), node_count: index, readonly children: ptr(u32), child_count: index, out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_lower_solve_render = func mlui_lower_solve_render(ui: ptr(@{T.UiKernel}), root: @{T.UiNodeRef}, width: f32, height: f32): @{T.UiStatus} end

F.mlui_frame = func mlui_frame(ui: ptr(@{T.UiKernel}), root: @{T.UiNodeRef}, width: f32, height: f32, readonly raw: ptr(@{T.UiRawInputBuffer})): @{T.UiStatus} end

F.mlui_runtime_report = func mlui_runtime_report(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end


-- GEOLIFT_HEADER_DIRECT.mlua
--
-- Apache DataFusion-like geospatial engine design header for Moonlift.
--
-- This file is intentionally a header:
--   - type declarations
--   - handle declarations
--   - region protocol declarations
--   - function seal declarations
--   - extern C declarations
--
-- No bodies live here.
--
-- Important correction:
--   Moonlift emits C. That is all the AOT design needs to know.
--   C-to-WASM is performed by the user's chosen C compiler/toolchain.
--   Therefore this header does not contain CEmissionPolicy, WasmArtifact,
--   WasmBackend, emit_wasm, or any similar policy layer.
--
-- Syntax:
--   This file uses real hosted .mlua islands:
--
--       G.T.Point = struct
--           x: f64
--           y: f64
--       end
--
--   not moon.struct[[...]] quoting.
--
-- Doctrine:
--   products        = facts that exist together
--   protocols      = choices consumed by control
--   regions        = machines from input product to output protocol
--   handles        = durable identity
--   leases         = temporary access granted by resolving regions
--   Arrow/GeoArrow = memory layout
--   C emission     = portable AOT path
--   Cranelift      = JIT path
--
-- Stored kind/tag bytes are encodings, not design.
-- Each stored encoding has exactly one visit_* owner region.

local moon = require("moonlift")

local G = {
    T = {},      -- type/product forest
    H = {},      -- durable handles
    R = {},      -- region/protocol forest
    F = {},      -- function seals / ABI boundaries
    X = {},      -- extern C boundary declarations
    Const = {},  -- Lua-side documentation for encoding ownership
}

--------------------------------------------------------------------------------
-- 0. Encoding ownership doctrine
--------------------------------------------------------------------------------
-- These are Lua-side facts for linting, documentation, and code generation.
-- They are not runtime semantics.
--
-- If a field is named kind/tag/encoding/layout/op, it must have one owner
-- region. Everywhere else goes through that owner region's protocol.
--------------------------------------------------------------------------------

G.Const.encoding_owner = {
    TypeKind              = "visit_type",
    ScalarKind            = "visit_scalar_type",

    SourceKind            = "visit_source",
    ArrayKind             = "visit_array_record",
    GeoTypeKind           = "visit_geo_type",
    GeoEncodingKind       = "visit_geo_encoding",
    CoordLayoutKind       = "visit_coord_layout",
    EdgeModelKind         = "visit_edge_model",

    SurfacePlanKind       = "visit_surface_plan",
    SurfaceExprKind       = "visit_surface_expr",
    BoundPlanKind         = "visit_bound_plan",
    BoundExprKind         = "visit_bound_expr",
    GeoLogicalPlanKind    = "visit_geo_logical_plan",
    OptimizedPlanKind     = "visit_optimized_plan",
    PhysicalOpKind        = "visit_physical_op",
    ExprKind              = "visit_expr",
    GeoPredicateKind      = "visit_geo_predicate",
    GeoTransformKind      = "visit_geo_transform",

    RuleKind              = "visit_optimizer_rule",
    FactKind              = "visit_fact",
    JoinKind              = "visit_join_kind",
    SpatialJoinKind       = "visit_spatial_join_strategy",

    KernelOpKind          = "visit_kernel_op",
    KernelArtifactKind    = "visit_kernel_artifact",
    TargetKind            = "visit_target",
    MemoryPolicyKind      = "visit_memory_policy",
    StreamStateKind       = "visit_stream_state",
}

--------------------------------------------------------------------------------
-- 1. Foundational products
--------------------------------------------------------------------------------

G.T.ByteRange = struct
    off: index
    len: index
end

G.T.RowRange = struct
    start: index
    len: index
end

G.T.BoxXY = struct
    xmin: f64
    ymin: f64
    xmax: f64
    ymax: f64
end

G.T.BoxXYZ = struct
    xmin: f64
    ymin: f64
    zmin: f64
    xmax: f64
    ymax: f64
    zmax: f64
end

G.T.SymbolRecord = struct
    hash: u64
    bytes_off: index
    bytes_len: index
end

G.T.DiagnosticRecord = struct
    code: i32
    primary_pos: index
    aux_pos: index
    message: u32
end

G.T.MetadataRecord = struct
    keys: ptr(u32)
    values: ptr(u32)
    len: index
    cap: index
end

G.T.UnitRecord = struct
    kind: u8                 -- owner: visit_unit
    scale_to_meter: f64
end

G.T.EdgeModel = struct
    kind: u8                 -- owner: visit_edge_model
end

G.T.CrsRecord = struct
    auth_name: u32
    code: u32
    wkt: u32
    is_projected: bool
    is_geographic: bool
end

G.T.Target = struct
    kind: u8                 -- owner: visit_target
    pointer_bits: u8
    simd_features: u64
    freestanding_c: bool
    wasm_friendly_c: bool    -- means generated C avoids hostile constructs;
                             -- the C-to-WASM compiler is outside Moonlift.
end

G.T.MemoryPolicy = struct
    kind: u8                 -- owner: visit_memory_policy
    batch_size: index
    spill_threshold_bytes: index
    reserve_slack_bytes: index
end

--------------------------------------------------------------------------------
-- 2. Records that handles point to
--------------------------------------------------------------------------------

G.T.TableRecord = struct
    name: u32
    schema: u32
    source: u32
    stats: u32
end

G.T.SchemaRecord = struct
    fields: ptr(u32)
    fields_len: index
    metadata: u32
end

G.T.FieldRecord = struct
    name: u32
    type: u32
    nullable: bool
    metadata: u32
end

G.T.TypeRecord = struct
    kind: u8                 -- owner: visit_type
    scalar_kind: u8          -- owner: visit_scalar_type
    child_type: u32
    metadata: u32
end

G.T.ColumnRecord = struct
    table: u32
    field: u32
    ordinal: index
end

G.T.SourceRecord = struct
    kind: u8                 -- owner: visit_source
    schema: u32
    metadata: u32
end

G.T.ArrayRecord = struct
    kind: u8                 -- owner: visit_array_record
    payload_index: u32
    len: index
    null_count: index
end

G.T.BatchRecord = struct
    schema: u32
    columns: ptr(u32)
    columns_len: index
    n_rows: index
end

G.T.SurfacePlanRecord = struct
    kind: u8                 -- owner: visit_surface_plan
    payload_index: u32
end

G.T.SurfaceExprRecord = struct
    kind: u8                 -- owner: visit_surface_expr
    payload_index: u32
end

G.T.BoundPlanRecord = struct
    kind: u8                 -- owner: visit_bound_plan
    payload_index: u32
end

G.T.BoundExprRecord = struct
    kind: u8                 -- owner: visit_bound_expr
    payload_index: u32
end

G.T.GeoLogicalPlanRecord = struct
    kind: u8                 -- owner: visit_geo_logical_plan
    payload_index: u32
end

G.T.OptimizedPlanRecord = struct
    kind: u8                 -- owner: visit_optimized_plan
    payload_index: u32
end

G.T.PhysicalPlanRecord = struct
    kind: u8                 -- owner: visit_physical_op
    payload_index: u32
end

G.T.ExprRecord = struct
    kind: u8                 -- owner: visit_expr
    payload_index: u32
end

G.T.GeoPredicateRecord = struct
    kind: u8                 -- owner: visit_geo_predicate
    payload_index: u32
end

G.T.GeoTransformRecord = struct
    kind: u8                 -- owner: visit_geo_transform
    payload_index: u32
end

G.T.RuleRecord = struct
    kind: u8                 -- owner: visit_optimizer_rule
    payload_index: u32
end

G.T.FactRecord = struct
    kind: u8                 -- owner: visit_fact
    payload_index: u32
end

G.T.StreamRecord = struct
    kind: u8                 -- owner: visit_stream_state
    state_index: u32
    schema: u32
end

G.T.KernelPlanRecord = struct
    op: u8                   -- owner: visit_kernel_op
    geom_kind: u8            -- owner: visit_geo_type
    coord_layout: u8         -- owner: visit_coord_layout
    dims: u8
    null_policy: u8
    target: Target
    memory_policy: MemoryPolicy
end

G.T.KernelRecord = struct
    plan: u32
    artifact: u32
    symbol: u32
    generation: u64
end

G.T.KernelArtifactRecord = struct
    kind: u8                 -- owner: visit_kernel_artifact
    bytes_off: index
    bytes_len: index
    c_source: u32
    object: u32
end

G.T.CSourceRecord = struct
    symbol_prefix: u32
    bytes_off: index
    bytes_len: index
end

G.T.ObjectRecord = struct
    format_kind: u8
    bytes_off: index
    bytes_len: index
end

G.T.SpatialIndexRecord = struct
    kind: u8                 -- owner: visit_spatial_index
    source: u32
    column: u32
    payload_index: u32
end

G.T.OwnedBytesRecord = struct
    data: ptr(u8)
    len: index
    cap: index
    generation: u64
end

G.T.CrsTransformRecord = struct
    raw: ptr(u8)
    src: u32
    dst: u32
    generation: u64
end

--------------------------------------------------------------------------------
-- 3. Handles
--------------------------------------------------------------------------------
-- Handles are durable identity. They do not grant pointer access.
-- Resolving regions grant leases.
--------------------------------------------------------------------------------

G.H.SymbolRef = handle : u32 invalid 0
    target SymbolRecord
end

G.H.DiagnosticRef = handle : u32 invalid 0
    target DiagnosticRecord
end

G.H.MetadataRef = handle : u32 invalid 0
    target MetadataRecord
end

G.H.UnitRef = handle : u32 invalid 0
    target UnitRecord
end

G.H.CrsRef = handle : u32 invalid 0
    target CrsRecord
end

G.H.TableRef = handle : u32 invalid 0
    target TableRecord
end

G.H.SchemaRef = handle : u32 invalid 0
    target SchemaRecord
end

G.H.FieldRef = handle : u32 invalid 0
    target FieldRecord
end

G.H.TypeRef = handle : u32 invalid 0
    target TypeRecord
end

G.H.ColumnRef = handle : u32 invalid 0
    target ColumnRecord
end

G.H.SourceRef = handle : u32 invalid 0
    target SourceRecord
end

G.H.ArrayRef = handle : u32 invalid 0
    target ArrayRecord
end

G.H.BatchRef = handle : u32 invalid 0
    target BatchRecord
end

G.H.SurfacePlanRef = handle : u32 invalid 0
    target SurfacePlanRecord
end

G.H.SurfaceExprRef = handle : u32 invalid 0
    target SurfaceExprRecord
end

G.H.BoundPlanRef = handle : u32 invalid 0
    target BoundPlanRecord
end

G.H.BoundExprRef = handle : u32 invalid 0
    target BoundExprRecord
end

G.H.GeoLogicalPlanRef = handle : u32 invalid 0
    target GeoLogicalPlanRecord
end

G.H.OptimizedPlanRef = handle : u32 invalid 0
    target OptimizedPlanRecord
end

G.H.PhysicalPlanRef = handle : u32 invalid 0
    target PhysicalPlanRecord
end

G.H.ExprRef = handle : u32 invalid 0
    target ExprRecord
end

G.H.GeoPredicateRef = handle : u32 invalid 0
    target GeoPredicateRecord
end

G.H.GeoTransformRef = handle : u32 invalid 0
    target GeoTransformRecord
end

G.H.RuleRef = handle : u32 invalid 0
    target RuleRecord
end

G.H.FactRef = handle : u32 invalid 0
    target FactRecord
end

G.H.StreamRef = handle : u32 invalid 0
    target StreamRecord
end

G.H.KernelPlanRef = handle : u32 invalid 0
    target KernelPlanRecord
end

G.H.KernelRef = handle : u32 invalid 0
    target KernelRecord
end

G.H.KernelArtifactRef = handle : u32 invalid 0
    target KernelArtifactRecord
end

G.H.CSourceRef = handle : u32 invalid 0
    target CSourceRecord
end

G.H.ObjectRef = handle : u32 invalid 0
    target ObjectRecord
end

G.H.SpatialIndexRef = handle : u32 invalid 0
    target SpatialIndexRecord
end

G.H.OwnedBytesRef = handle : u32 invalid 0
    target OwnedBytesRecord
end

G.H.CrsTransformRef = handle : u32 invalid 0
    target CrsTransformRecord
end

--------------------------------------------------------------------------------
-- 4. Stores and engine product
--------------------------------------------------------------------------------

G.T.SymbolStore = struct
    records: ptr(SymbolRecord)
    records_len: index
    records_cap: index
    bytes: ptr(u8)
    bytes_len: index
    bytes_cap: index
    generation: u64
end

G.T.MetadataStore = struct
    records: ptr(MetadataRecord)
    records_len: index
    records_cap: index
    generation: u64
end

G.T.CatalogStore = struct
    tables: ptr(TableRecord)
    tables_len: index
    tables_cap: index
    generation: u64
end

G.T.SchemaStore = struct
    schemas: ptr(SchemaRecord)
    schemas_len: index
    schemas_cap: index
    fields: ptr(FieldRecord)
    fields_len: index
    fields_cap: index
    types: ptr(TypeRecord)
    types_len: index
    types_cap: index
    columns: ptr(ColumnRecord)
    columns_len: index
    columns_cap: index
    generation: u64
end

G.T.CrsRegistry = struct
    records: ptr(CrsRecord)
    records_len: index
    records_cap: index
    generation: u64
end

G.T.SourceStore = struct
    sources: ptr(SourceRecord)
    sources_len: index
    sources_cap: index
    generation: u64
end

G.T.ArrayStore = struct
    arrays: ptr(ArrayRecord)
    arrays_len: index
    arrays_cap: index
    batches: ptr(BatchRecord)
    batches_len: index
    batches_cap: index
    generation: u64
end

G.T.PlanStore = struct
    surface_plans: ptr(SurfacePlanRecord)
    surface_plans_len: index
    surface_plans_cap: index
    surface_exprs: ptr(SurfaceExprRecord)
    surface_exprs_len: index
    surface_exprs_cap: index
    bound_plans: ptr(BoundPlanRecord)
    bound_plans_len: index
    bound_plans_cap: index
    bound_exprs: ptr(BoundExprRecord)
    bound_exprs_len: index
    bound_exprs_cap: index
    geo_plans: ptr(GeoLogicalPlanRecord)
    geo_plans_len: index
    geo_plans_cap: index
    optimized_plans: ptr(OptimizedPlanRecord)
    optimized_plans_len: index
    optimized_plans_cap: index
    physical_plans: ptr(PhysicalPlanRecord)
    physical_plans_len: index
    physical_plans_cap: index
    exprs: ptr(ExprRecord)
    exprs_len: index
    exprs_cap: index
    generation: u64
end

G.T.FactStore = struct
    facts: ptr(FactRecord)
    facts_len: index
    facts_cap: index
    generation: u64
end

G.T.KernelStore = struct
    kernel_plans: ptr(KernelPlanRecord)
    kernel_plans_len: index
    kernel_plans_cap: index
    kernels: ptr(KernelRecord)
    kernels_len: index
    kernels_cap: index
    artifacts: ptr(KernelArtifactRecord)
    artifacts_len: index
    artifacts_cap: index
    c_sources: ptr(CSourceRecord)
    c_sources_len: index
    c_sources_cap: index
    objects: ptr(ObjectRecord)
    objects_len: index
    objects_cap: index
    generation: u64
end

G.T.StreamStore = struct
    streams: ptr(StreamRecord)
    streams_len: index
    streams_cap: index
    generation: u64
end

G.T.IndexStore = struct
    indexes: ptr(SpatialIndexRecord)
    indexes_len: index
    indexes_cap: index
    generation: u64
end

G.T.MemoryPool = struct
    bytes: ptr(OwnedBytesRecord)
    bytes_len: index
    bytes_cap: index
    live_leases: index
    bytes_reserved: index
    bytes_committed: index
    generation: u64
end

G.T.GeoEngine = struct
    symbols: SymbolStore
    metadata: MetadataStore
    catalog: CatalogStore
    schemas: SchemaStore
    crs: CrsRegistry
    sources: SourceStore
    arrays: ArrayStore
    plans: PlanStore
    facts: FactStore
    kernels: KernelStore
    streams: StreamStore
    indexes: IndexStore
    memory: MemoryPool
end

--------------------------------------------------------------------------------
-- 5. Arrow and GeoArrow memory products
--------------------------------------------------------------------------------
-- Arrow/GeoArrow is the memory story.
-- Kernels receive these layouts after validation and borrowing.
--------------------------------------------------------------------------------

G.T.ArrowBitmap = struct
    data: ptr(u8)
    len_bits: index
end

G.T.ArrowBuffer = struct
    data: ptr(u8)
    len_bytes: index
    capacity_bytes: index
end

G.T.ArrowArrayHeader = struct
    len: index
    null_count: index
    offset: index
    validity: ptr(ArrowBitmap)
end

G.T.ArrowI32Offsets = struct
    data: ptr(i32)
    len: index             -- logical array length + 1
end

G.T.ArrowI64Offsets = struct
    data: ptr(i64)
    len: index             -- logical array length + 1
end

G.T.CoordXYSeparated = struct
    x: view(f64)
    y: view(f64)
end

G.T.CoordXYZSeparated = struct
    x: view(f64)
    y: view(f64)
    z: view(f64)
end

G.T.CoordXYInterleaved = struct
    xy: view(f64)          -- len = 2 * coordinate_count
end

G.T.GeoTypeFact = struct
    geom_kind: u8          -- owner: visit_geo_type
    coord_layout: u8       -- owner: visit_coord_layout
    coord_dims: u8
    encoding: u8           -- owner: visit_geo_encoding
    crs: CrsRef
    edges: EdgeModel
    nullable: bool
end

G.T.GeoPointXYArray = struct
    header: ArrowArrayHeader
    coords: CoordXYSeparated
    crs: CrsRef
    edges: EdgeModel
end

G.T.GeoLineStringXYArray = struct
    header: ArrowArrayHeader
    geom_offsets: ArrowI32Offsets
    coords: CoordXYSeparated
    crs: CrsRef
    edges: EdgeModel
end

G.T.GeoPolygonXYArray = struct
    header: ArrowArrayHeader
    polygon_offsets: ArrowI32Offsets
    ring_offsets: ArrowI32Offsets
    coords: CoordXYSeparated
    crs: CrsRef
    edges: EdgeModel
end

G.T.GeoMultiPolygonXYArray = struct
    header: ArrowArrayHeader
    multipolygon_offsets: ArrowI32Offsets
    polygon_offsets: ArrowI32Offsets
    ring_offsets: ArrowI32Offsets
    coords: CoordXYSeparated
    crs: CrsRef
    edges: EdgeModel
end

G.T.GeoBoxXYArray = struct
    header: ArrowArrayHeader
    xmin: view(f64)
    ymin: view(f64)
    xmax: view(f64)
    ymax: view(f64)
    crs: CrsRef
end

G.T.WkbArray = struct
    header: ArrowArrayHeader
    offsets: ArrowI32Offsets
    bytes: view(u8)
    crs: CrsRef
end

G.T.WktArray = struct
    header: ArrowArrayHeader
    offsets: ArrowI32Offsets
    bytes: view(u8)
    crs: CrsRef
end

G.T.RecordBatch = struct
    schema: SchemaRef
    columns: ptr(ArrayRef)
    n_columns: index
    n_rows: index
end

G.T.ExternalArrowOwner = struct
    ctx: ptr(u8)
    release: func(ptr(u8)): void
    retained_by_host: bool
end

G.T.ImportedArrayRecord = struct
    owner_ctx: ptr(u8)
    release: func(ptr(u8)): void
    array: ArrayRef
end


-- CFG TREE: owner visitors for stored choices
-- ============================================================

struct VisitScoreRegionContentInput
    project: ptr(ScoreProject),
    ref: ScoreRegionContentRef,
end

union VisitScoreRegionContentOutput
    audio(audio_asset_id: u32)
  | note(note_asset_id: u32)
  | invalid(code: i32)
end

region visit_score_region_content(VisitScoreRegionContentInput; VisitScoreRegionContentOutput) end


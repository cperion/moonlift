-- daw_moonlift_type_cfg_design_v2.moonlift
-- Bible-pass design: DAW type forest + control/CFG forest.
-- Signature-only. No bodies. Implementation must transcribe these declarations.


-- ============================================================
-- BIBLE PASS V2: THE DAW AS A LIVE COMPILER
-- ============================================================
-- Compiler sentence:
--   This DAW compiles a user-authored project language (arrangement,
--   launcher, mixer, devices, modulation, assets, and edits) into flat
--   scheduled audio/control/kernel facts consumed by sealed UI, host,
--   plugin, and audio-callback loops.
--
-- Design laws applied here:
--   1. Source products are saved/undoable user intent, not caches.
--   2. Events are source edits, not callbacks.
--   3. Every stored kind has exactly one owning visit_* region.
--   4. Phases answer knowledge questions and expose iterator protocols.
--   5. Every region has a named input product and a named output protocol:
--        region r(RInput; ROutput) end
--      This is the DAW control ASDL, not an ad-hoc callback/status surface.
--   6. The audio callback consumes planned facts; it never traverses Score.
--   7. Status integers exist only at sealed ABI functions.
--   8. Lua factories generate monomorphic family members; no source generics.
--
-- This section is an architectural overlay. The ASDL-derived Score/Semantic/
-- Rated/Planned/Runtime/Kernel forest follows below and remains the canonical
-- coverage of the uploaded DAW ontology. Names in this overlay are prefixed
-- with Daw, Source, Edit, Phase, Fact, or Live to avoid colliding with the
-- lower forest.

-- ------------------------------------------------------------
-- Identity roots and source store
-- ------------------------------------------------------------

struct DawRootRef
    index: u32,
    generation: u64,
end

struct DawEntityRef
    kind: u32,      -- owned by visit_daw_entity
    index: u32,
    generation: u64,
end

struct DawTrackRef
    index: u32,
    generation: u64,
end

struct DawClipRef
    kind: u32,      -- owned by visit_daw_clip
    index: u32,
    generation: u64,
end

struct DawDeviceRef
    kind: u32,      -- owned by visit_daw_device
    index: u32,
    generation: u64,
end

struct DawChainRef
    index: u32,
    generation: u64,
end

struct DawSceneRef
    index: u32,
    generation: u64,
end

struct DawSlotRef
    track: DawTrackRef,
    scene: DawSceneRef,
    generation: u64,
end

struct DawAssetRef
    kind: u32,      -- owned by visit_daw_asset
    index: u32,
    generation: u64,
end

struct DawTargetRef2
    kind: u32,      -- owned by visit_daw_target
    index: u32,
    arg0: u32,
    arg1: u32,
    generation: u64,
end

struct DawSourceRef2
    kind: u32,      -- owned by visit_daw_source
    index: u32,
    generation: u64,
end

struct DawAutomationRef
    index: u32,
    generation: u64,
end

struct DawNoteClipRef
    index: u32,
    generation: u64,
end

struct DawAudioClipRef
    index: u32,
    generation: u64,
end

struct DawSourceRoot
    project: DawRootRef,
    selected_entity: DawEntityRef,
    focused_track: DawTrackRef,
    focused_scene: DawSceneRef,
    edit_revision: u64,
end

struct DawSourceStore
    roots: view(ScoreProject),
    root_ids: view(DawRootRef),
    undo_roots: view(DawRootRef),
    redo_roots: view(DawRootRef),
    current: DawSourceRoot,
end

-- ------------------------------------------------------------
-- High-level authored additions missing from the raw ASDL tree
-- ------------------------------------------------------------
-- The uploaded ASDL already covers arrangement regions and launcher slots.
-- These products name the Bitwig-like concepts that survive save/load at the
-- UI/source-language level and then lower into Score/Semantic facts.

struct DawClipHeader
    id: DawClipRef,
    name: TextRef,
    color: MaybeTextRef,
    duration_beats: f64,
    loop_enabled: bool,
    loop: BeatRange,
    start_offset_beats: f64,
    gain_target_id: u32,
end

struct DawNoteClip
    header: DawClipHeader,
    note_asset_id: u32,
    expressions: view(ScoreNoteEvent),
    clip_automation: view(ScoreAutomationLane),
end

struct DawAudioClip
    header: DawClipHeader,
    audio_asset_id: u32,
    warp_mode_code: u32,        -- owned by visit_daw_warp_mode
    stretch_markers: view(DawStretchMarker),
    clip_automation: view(ScoreAutomationLane),
end

struct DawStretchMarker
    source_sample: i64,
    target_tick: i64,
end

struct DawLauncherCell
    slot: DawSlotRef,
    content: DawClipRef,
    policy: ScoreLaunchPolicy,
    enabled: bool,
end

struct DawArrangerPlacement
    region_id: u32,
    track: DawTrackRef,
    clip: DawClipRef,
    range: BeatRange,
    source_offset_beats: f64,
    lane_index: u32,
    muted: bool,
end

struct DawProjectSource
    root: DawRootRef,
    score: ScoreProject,
    note_clips: view(DawNoteClip),
    audio_clips: view(DawAudioClip),
    placements: view(DawArrangerPlacement),
    launcher_cells: view(DawLauncherCell),
end

-- ------------------------------------------------------------
-- Source edit language: input facts, not callbacks
-- ------------------------------------------------------------

struct EditEventRef
    kind: u32,      -- owned by dispatch_edit_event
    index: u32,
    generation: u64,
end

struct EditEnvelope
    event: EditEventRef,
    at_host_time_ns: i64,
    user_id: u32,
    transaction_id: u64,
end

struct EditTransport
    bpm: MaybeF64,
    swing: MaybeF64,
    sample_rate: MaybeF64,
    buffer_size: MaybeU32,
    loop_enabled: bool,
    loop: MaybeBeatRange,
end

struct EditTempoMap
    points: view(ScoreTempoEvent),
    replace_all: bool,
end

struct EditSignatureMap
    points: view(ScoreSignatureEvent),
    replace_all: bool,
end

struct EditTrackCreate
    after_track: MaybeU32,
    role_code: u32,
    name: TextRef,
    channels: ChannelLayout,
end

struct EditTrackRemove
    track_id: u32,
    delete_clips: bool,
end

struct EditTrackMove
    track_id: u32,
    before_track: MaybeU32,
    parent_group_id: MaybeU32,
end

struct EditTrackProperties
    track_id: u32,
    name: MaybeTextRef,
    muted: bool,
    soloed: bool,
    armed: bool,
    monitor_input: bool,
    phase_invert: bool,
    output_track_id: MaybeU32,
end

struct EditClipCreate
    track_id: u32,
    scene_id: MaybeU32,
    arrangement_start_beats: MaybeF64,
    kind: u32,              -- owned by visit_edit_clip_create_kind
    asset_id: u32,
    duration_beats: f64,
end

struct EditClipDelete
    clip: DawClipRef,
end

struct EditClipMove
    clip: DawClipRef,
    target_track_id: u32,
    target_scene_id: MaybeU32,
    arrangement_start_beats: MaybeF64,
end

struct EditClipLoop
    clip: DawClipRef,
    enabled: bool,
    loop: BeatRange,
end

struct EditNoteEvent
    clip: DawNoteClipRef,
    note: ScoreNoteEvent,
    operation_code: u32,    -- owned by visit_edit_operation
end

struct EditAutomation
    target: DawTargetRef2,
    curve: ScoreCurve,
    operation_code: u32,    -- owned by visit_edit_operation
end

struct EditDeviceInsert
    track_id: u32,
    chain_id: u32,
    before_device_id: MaybeU32,
    device: ScoreDevice,
end

struct EditDeviceRemove
    device_id: u32,
end

struct EditDeviceMove
    device_id: u32,
    target_chain_id: u32,
    before_device_id: MaybeU32,
end

struct EditDeviceParam
    device_id: u32,
    param_index: u32,
    value: f64,
end

struct EditMapping
    mapping: ScoreMapping,
    operation_code: u32,
end

struct EditAssetImport
    kind: u32,              -- owned by visit_daw_asset
    path: TextRef,
    decode_policy_code: u32,
end

struct EditScene
    scene_id: u32,
    name: MaybeTextRef,
    quantization: MaybeU32,
    tempo_override: MaybeF64,
end

struct EditSelection
    entity: DawEntityRef,
    extend: bool,
end

struct EditStore
    envelopes: view(EditEnvelope),
    transport_edits: view(EditTransport),
    tempo_map_edits: view(EditTempoMap),
    signature_map_edits: view(EditSignatureMap),
    track_creates: view(EditTrackCreate),
    track_removes: view(EditTrackRemove),
    track_moves: view(EditTrackMove),
    track_properties: view(EditTrackProperties),
    clip_creates: view(EditClipCreate),
    clip_deletes: view(EditClipDelete),
    clip_moves: view(EditClipMove),
    clip_loops: view(EditClipLoop),
    note_events: view(EditNoteEvent),
    automation_edits: view(EditAutomation),
    device_inserts: view(EditDeviceInsert),
    device_removes: view(EditDeviceRemove),
    device_moves: view(EditDeviceMove),
    device_params: view(EditDeviceParam),
    mappings: view(EditMapping),
    asset_imports: view(EditAssetImport),
    scene_edits: view(EditScene),
    selections: view(EditSelection),
end

-- ------------------------------------------------------------
-- Phase keys, caches, and fact-stream products
-- ------------------------------------------------------------

struct PhaseId
    value: u32,
end

struct PhaseKey
    phase: PhaseId,
    root: DawRootRef,
    ctx_hash0: u64,
    ctx_hash1: u64,
end

struct PhaseReport
    phase: PhaseId,
    calls: u64,
    hits: u64,
    misses: u64,
    recorded_facts: u64,
    retained_bytes: u64,
    abandoned_recordings: u64,
end

struct PhaseCache
    keys: view(PhaseKey),
    fact_offsets: view(u64),
    fact_counts: view(u32),
    reports: view(PhaseReport),
end

struct ResolveFactRef
    kind: u32,      -- owned by visit_resolve_fact
    index: u32,
end

struct RateFactRef
    kind: u32,      -- owned by visit_rate_fact
    index: u32,
end

struct PlanFactRef
    kind: u32,      -- owned by visit_plan_fact
    index: u32,
end

struct KernelFactRef
    kind: u32,      -- owned by visit_kernel_fact
    index: u32,
end

struct ResolveIter
    root: DawRootRef,
    cursor: u32,
    stack_top: u32,
    cache_recording_id: u32,
end

struct RateIter
    project_index: u32,
    cursor: u32,
    binding_cursor: u32,
    cache_recording_id: u32,
end

struct PlanIter
    project_index: u32,
    cursor: u32,
    step_cursor: u32,
    cache_recording_id: u32,
end

struct KernelIter
    project_index: u32,
    cursor: u32,
    quote_cursor: u32,
    cache_recording_id: u32,
end

struct ResolveFactStore
    normalized_transports: view(SemanticTransport),
    normalized_tracks: view(SemanticTrack),
    normalized_regions: view(SemanticRegion),
    normalized_slots: view(SemanticSlot),
    normalized_devices: view(SemanticDevice),
    normalized_targets: view(SemanticTarget),
    normalized_sources: view(SemanticSource),
    normalized_assets: view(SemanticAssets),
    issues: view(Issue),
end

struct RateFactStore
    literals: view(RatedLiteralBinding),
    init_bindings: view(RatedInitBinding),
    block_bindings: view(RatedBlockBinding),
    sample_bindings: view(RatedSampleBinding),
    event_bindings: view(RatedEventBinding),
    voice_bindings: view(RatedVoiceBinding),
    issues: view(Issue),
end

struct PlanFactStore
    buffers: view(PlannedBufferSlot),
    steps: view(PlannedStep),
    regions: view(PlannedRegionJob),
    device_jobs: view(PlannedDeviceJob),
    sends: view(PlannedSendJob),
    mixes: view(PlannedMixJob),
    outputs: view(PlannedOutputJob),
    launch_tables: view(PlannedLaunchTable),
    targets: view(PlannedTargetSlot),
    issues: view(Issue),
end

struct KernelFactStore
    quotes: view(BlobRef),
    functions: view(BlobRef),
    types: view(BlobRef),
    issues: view(Issue),
end

-- ------------------------------------------------------------
-- Live command facts consumed by runtime seals
-- ------------------------------------------------------------

struct LiveCommandRef
    kind: u32,      -- owned by visit_live_command
    index: u32,
    generation: u64,
end

struct LivePlayCommand
    start_tick: i64,
end

struct LiveStopCommand
    stop_tick: i64,
    flush_notes: bool,
end

struct LiveRecordCommand
    track_id: u32,
    start_tick: i64,
end

struct LiveLaunchCommand
    track_id: u32,
    slot_index: u32,
    quantization_code: u32,
end

struct LiveSceneCommand
    scene_id: u32,
    quantization_code: u32,
end

struct LiveParamCommand
    target: DawTargetRef2,
    value: f64,
    sample_offset: u32,
end

struct LiveMidiCommand
    track_id: u32,
    event: ScoreNoteEvent,
    sample_offset: u32,
end

struct LiveStore
    play: view(LivePlayCommand),
    stop: view(LiveStopCommand),
    record: view(LiveRecordCommand),
    launch: view(LiveLaunchCommand),
    scenes: view(LiveSceneCommand),
    params: view(LiveParamCommand),
    midi: view(LiveMidiCommand),
end

-- ------------------------------------------------------------
-- Owner regions for encoded source/edit/fact/live kinds
-- ------------------------------------------------------------

struct VisitDawEntityInput
    store: ptr(DawSourceStore),
    e: DawEntityRef,
end

union VisitDawEntityOutput
    project(root: DawRootRef)
  | track(track: DawTrackRef)
  | clip(clip: DawClipRef)
  | device(device: DawDeviceRef)
  | chain(chain: DawChainRef)
  | scene(scene: DawSceneRef)
  | slot(slot: DawSlotRef)
  | asset(asset: DawAssetRef)
  | target(target: DawTargetRef2)
  | source(source: DawSourceRef2)
  | automation(lane: DawAutomationRef)
  | invalid(code: i32)
end

region visit_daw_entity(VisitDawEntityInput; VisitDawEntityOutput) end

struct VisitDawClipInput
    source: ptr(DawProjectSource),
    clip: DawClipRef,
end

union VisitDawClipOutput
    note(clip: ptr(DawNoteClip))
  | audio(clip: ptr(DawAudioClip))
  | invalid(code: i32)
end

region visit_daw_clip(VisitDawClipInput; VisitDawClipOutput) end

struct VisitDawDeviceInput
    project: ptr(ScoreProject),
    device: DawDeviceRef,
end

union VisitDawDeviceOutput
    note_fx(device_id: u32)
  | instrument(device_id: u32)
  | audio_fx(device_id: u32)
  | router(device_id: u32)
  | plugin(device_id: u32)
  | invalid(code: i32)
end

region visit_daw_device(VisitDawDeviceInput; VisitDawDeviceOutput) end

struct VisitDawAssetInput
    project: ptr(ScoreProject),
    asset: DawAssetRef,
end

union VisitDawAssetOutput
    audio(asset_id: u32)
  | note(asset_id: u32)
  | plugin(asset_id: u32)
  | preset(asset_id: u32)
  | zone_bank(asset_id: u32)
  | invalid(code: i32)
end

region visit_daw_asset(VisitDawAssetInput; VisitDawAssetOutput) end

struct VisitDawTargetInput
    project: ptr(ScoreProject),
    target: DawTargetRef2,
end

union VisitDawTargetOutput
    mixer_fader(track_id: u32)
  | mixer_pan(track_id: u32)
  | send_level(send_id: u32)
  | device_param(device_id: u32, param_index: u32)
  | clip_gain(clip: DawClipRef)
  | transport_param(kind: u32)
  | invalid(code: i32)
end

region visit_daw_target(VisitDawTargetInput; VisitDawTargetOutput) end

struct VisitDawSourceInput
    project: ptr(ScoreProject),
    source: DawSourceRef2,
end

union VisitDawSourceOutput
    macro(source_id: u32)
  | lfo(source_id: u32)
  | envelope(source_id: u32)
  | sidechain(source_id: u32)
  | midi_cc(source_id: u32)
  | random(source_id: u32)
  | note_expression(source_id: u32)
  | invalid(code: i32)
end

region visit_daw_source(VisitDawSourceInput; VisitDawSourceOutput) end

struct DispatchEditEventInput
    events: ptr(EditStore),
    e: EditEventRef,
end

union DispatchEditEventOutput
    transport(e: ptr(EditTransport))
  | tempo_map(e: ptr(EditTempoMap))
  | signature_map(e: ptr(EditSignatureMap))
  | track_create(e: ptr(EditTrackCreate))
  | track_remove(e: ptr(EditTrackRemove))
  | track_move(e: ptr(EditTrackMove))
  | track_properties(e: ptr(EditTrackProperties))
  | clip_create(e: ptr(EditClipCreate))
  | clip_delete(e: ptr(EditClipDelete))
  | clip_move(e: ptr(EditClipMove))
  | clip_loop(e: ptr(EditClipLoop))
  | note_event(e: ptr(EditNoteEvent))
  | automation(e: ptr(EditAutomation))
  | device_insert(e: ptr(EditDeviceInsert))
  | device_remove(e: ptr(EditDeviceRemove))
  | device_move(e: ptr(EditDeviceMove))
  | device_param(e: ptr(EditDeviceParam))
  | mapping(e: ptr(EditMapping))
  | asset_import(e: ptr(EditAssetImport))
  | scene(e: ptr(EditScene))
  | selection(e: ptr(EditSelection))
  | invalid(code: i32)
end

region dispatch_edit_event(DispatchEditEventInput; DispatchEditEventOutput) end

struct VisitResolveFactInput
    store: ptr(ResolveFactStore),
    f: ResolveFactRef,
end

union VisitResolveFactOutput
    transport(t: ptr(SemanticTransport))
  | track(t: ptr(SemanticTrack))
  | region(r: ptr(SemanticRegion))
  | slot(s: ptr(SemanticSlot))
  | device(d: ptr(SemanticDevice))
  | target(t: ptr(SemanticTarget))
  | source(s: ptr(SemanticSource))
  | asset_group(a: ptr(SemanticAssets))
  | issue(issue: ptr(Issue))
  | invalid(code: i32)
end

region visit_resolve_fact(VisitResolveFactInput; VisitResolveFactOutput) end

struct VisitRateFactInput
    store: ptr(RateFactStore),
    f: RateFactRef,
end

union VisitRateFactOutput
    literal(b: ptr(RatedLiteralBinding))
  | init(b: ptr(RatedInitBinding))
  | block(b: ptr(RatedBlockBinding))
  | sample(b: ptr(RatedSampleBinding))
  | event(b: ptr(RatedEventBinding))
  | voice(b: ptr(RatedVoiceBinding))
  | issue(issue: ptr(Issue))
  | invalid(code: i32)
end

region visit_rate_fact(VisitRateFactInput; VisitRateFactOutput) end

struct VisitPlanFactInput
    store: ptr(PlanFactStore),
    f: PlanFactRef,
end

union VisitPlanFactOutput
    buffer(b: ptr(PlannedBufferSlot))
  | step(s: ptr(PlannedStep))
  | region_job(j: ptr(PlannedRegionJob))
  | device_job(j: ptr(PlannedDeviceJob))
  | send(j: ptr(PlannedSendJob))
  | mix(j: ptr(PlannedMixJob))
  | output(j: ptr(PlannedOutputJob))
  | launch_table(t: ptr(PlannedLaunchTable))
  | target(t: ptr(PlannedTargetSlot))
  | issue(issue: ptr(Issue))
  | invalid(code: i32)
end

region visit_plan_fact(VisitPlanFactInput; VisitPlanFactOutput) end

struct VisitKernelFactInput
    store: ptr(KernelFactStore),
    f: KernelFactRef,
end

union VisitKernelFactOutput
    quote(bytes: BlobRef)
  | function_symbol(bytes: BlobRef)
  | type_blob(bytes: BlobRef)
  | issue(issue: ptr(Issue))
  | invalid(code: i32)
end

region visit_kernel_fact(VisitKernelFactInput; VisitKernelFactOutput) end

struct VisitLiveCommandInput
    store: ptr(LiveStore),
    cmd: LiveCommandRef,
end

union VisitLiveCommandOutput
    play(c: ptr(LivePlayCommand))
  | stop(c: ptr(LiveStopCommand))
  | record(c: ptr(LiveRecordCommand))
  | launch(c: ptr(LiveLaunchCommand))
  | scene(c: ptr(LiveSceneCommand))
  | param(c: ptr(LiveParamCommand))
  | midi(c: ptr(LiveMidiCommand))
  | invalid(code: i32)
end

region visit_live_command(VisitLiveCommandInput; VisitLiveCommandOutput) end

-- ------------------------------------------------------------
-- Pure source application CFG
-- ------------------------------------------------------------

struct ApplyEditEventInput
    store: ptr(DawSourceStore),
    events: ptr(EditStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyEditEventOutput
    changed(next: DawRootRef, revision: u64)
  | unchanged
  | rejected(issue: Issue)
  | invalid_event(code: i32)
end

region apply_edit_event(ApplyEditEventInput; ApplyEditEventOutput) end

struct ApplyEditTransactionInput
    store: ptr(DawSourceStore),
    events: ptr(EditStore),
    root: DawRootRef,
    first_event: u32,
    event_count: u32,
end

union ApplyEditTransactionOutput
    committed(next: DawRootRef, revision: u64)
  | rolled_back(issue: Issue)
  | unchanged
  | invalid_event(code: i32)
end

region apply_edit_transaction(ApplyEditTransactionInput; ApplyEditTransactionOutput) end

struct ApplyTransportEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: ptr(EditTransport),
end

union ApplyTransportEditOutput
    changed(next: DawRootRef)
  | unchanged
  | rejected(issue: Issue)
end

region apply_transport_edit(ApplyTransportEditInput; ApplyTransportEditOutput) end

struct ApplyTrackEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyTrackEditOutput
    changed(next: DawRootRef, track: DawTrackRef)
  | unchanged
  | rejected(issue: Issue)
  | invalid_event(code: i32)
end

region apply_track_edit(ApplyTrackEditInput; ApplyTrackEditOutput) end

struct ApplyClipEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyClipEditOutput
    changed(next: DawRootRef, clip: DawClipRef)
  | unchanged
  | rejected(issue: Issue)
  | invalid_event(code: i32)
end

region apply_clip_edit(ApplyClipEditInput; ApplyClipEditOutput) end

struct ApplyDeviceEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyDeviceEditOutput
    changed(next: DawRootRef, device: DawDeviceRef)
  | unchanged
  | rejected(issue: Issue)
  | invalid_event(code: i32)
end

region apply_device_edit(ApplyDeviceEditInput; ApplyDeviceEditOutput) end

struct ApplyControlEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyControlEditOutput
    changed(next: DawRootRef, target: DawTargetRef2)
  | unchanged
  | rejected(issue: Issue)
  | invalid_event(code: i32)
end

region apply_control_edit(ApplyControlEditInput; ApplyControlEditOutput) end

struct ApplyAssetEditInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
    e: EditEventRef,
end

union ApplyAssetEditOutput
    imported(next: DawRootRef, asset: DawAssetRef)
  | unchanged
  | rejected(issue: Issue)
  | decode_required(path: TextRef, kind: u32)
end

region apply_asset_edit(ApplyAssetEditInput; ApplyAssetEditOutput) end

-- ------------------------------------------------------------
-- Phase cache protocol
-- ------------------------------------------------------------

struct PhaseCacheLookupInput
    cache: ptr(PhaseCache),
    key: PhaseKey,
end

union PhaseCacheLookupOutput
    hit(first_fact: u64, fact_count: u32)
  | miss(recording_id: u32)
  | stale(old_first_fact: u64, old_fact_count: u32)
  | invalid(code: i32)
end

region phase_cache_lookup(PhaseCacheLookupInput; PhaseCacheLookupOutput) end

struct PhaseCacheCommitInput
    cache: ptr(PhaseCache),
    recording_id: u32,
    key: PhaseKey,
    first_fact: u64,
    fact_count: u32,
end

union PhaseCacheCommitOutput
    committed
  | abandoned
  | invalid(code: i32)
end

region phase_cache_commit(PhaseCacheCommitInput; PhaseCacheCommitOutput) end

struct PhaseCacheReportInput
    cache: ptr(PhaseCache),
    phase: PhaseId,
end

union PhaseCacheReportOutput
    report(r: PhaseReport)
  | missing
end

region phase_cache_report(PhaseCacheReportInput; PhaseCacheReportOutput) end

-- ------------------------------------------------------------
-- Iterator phase CFGs: knowledge boundaries
-- ------------------------------------------------------------

struct ValidateSourceProjectInput
    store: ptr(DawSourceStore),
    root: DawRootRef,
end

union ValidateSourceProjectOutput
    valid
  | invalid(issues: IssueList)
  | unsupported(issue: Issue)
end

region validate_source_project(ValidateSourceProjectInput; ValidateSourceProjectOutput) end

struct ResolveStartInput
    ctx: ResolveCtx,
    cache: ptr(PhaseCache),
    store: ptr(DawSourceStore),
    root: DawRootRef,
end

union ResolveStartOutput
    ready(it: ResolveIter)
  | cache_hit(first_fact: u64, fact_count: u32)
  | invalid(issues: IssueList)
end

region resolve_start(ResolveStartInput; ResolveStartOutput) end

struct ResolveNextInput
    ctx: ResolveCtx,
    facts: ptr(ResolveFactStore),
    it: ResolveIter,
end

union ResolveNextOutput
    fact(f: ResolveFactRef, next: ResolveIter)
  | done(project: ptr(SemanticProject))
  | invalid(issue: Issue)
end

region resolve_next(ResolveNextInput; ResolveNextOutput) end

struct RateStartInput
    ctx: RateCtx,
    cache: ptr(PhaseCache),
    project: ptr(SemanticProject),
end

union RateStartOutput
    ready(it: RateIter)
  | cache_hit(first_fact: u64, fact_count: u32)
  | invalid(issues: IssueList)
end

region rate_start(RateStartInput; RateStartOutput) end

struct RateNextInput
    ctx: RateCtx,
    facts: ptr(RateFactStore),
    it: RateIter,
end

union RateNextOutput
    fact(f: RateFactRef, next: RateIter)
  | done(project: ptr(RatedProject))
  | invalid(issue: Issue)
end

region rate_next(RateNextInput; RateNextOutput) end

struct PlanStartInput
    ctx: PlanCtx,
    cache: ptr(PhaseCache),
    project: ptr(RatedProject),
end

union PlanStartOutput
    ready(it: PlanIter)
  | cache_hit(first_fact: u64, fact_count: u32)
  | cycle(track_id: u32, chain_id: u32)
  | unsupported(issue: Issue)
  | invalid(issues: IssueList)
end

region plan_start(PlanStartInput; PlanStartOutput) end

struct PlanNextInput
    ctx: PlanCtx,
    facts: ptr(PlanFactStore),
    it: PlanIter,
end

union PlanNextOutput
    fact(f: PlanFactRef, next: PlanIter)
  | done(project: ptr(PlannedProject))
  | invalid(issue: Issue)
end

region plan_next(PlanNextInput; PlanNextOutput) end

struct KernelStartInput
    ctx: CompileCtx,
    cache: ptr(PhaseCache),
    project: ptr(PlannedProject),
end

union KernelStartOutput
    ready(it: KernelIter)
  | cache_hit(first_fact: u64, fact_count: u32)
  | unsupported(issue: Issue)
  | backend_error(code: i32)
  | invalid(issues: IssueList)
end

region kernel_start(KernelStartInput; KernelStartOutput) end

struct KernelNextInput
    ctx: CompileCtx,
    facts: ptr(KernelFactStore),
    it: KernelIter,
end

union KernelNextOutput
    fact(f: KernelFactRef, next: KernelIter)
  | done(kernel: ptr(KernelProject))
  | backend_error(code: i32)
  | invalid(issue: Issue)
end

region kernel_next(KernelNextInput; KernelNextOutput) end

-- ------------------------------------------------------------
-- Runtime statecharts: explicit final protocols, no status soup
-- ------------------------------------------------------------

struct TransportLifecycleInput
    state: ptr(RuntimeRenderState),
    cmd: LiveCommandRef,
end

union TransportLifecycleOutput
    playing(start_tick: i64)
  | stopped(stop_tick: i64)
  | recording(track_id: u32, start_tick: i64)
  | unchanged
  | rejected(issue: Issue)
end

region transport_lifecycle(TransportLifecycleInput; TransportLifecycleOutput) end

struct LauncherLifecycleInput
    planned: ptr(PlannedProject),
    state: ptr(RuntimeRenderState),
    cmd: LiveCommandRef,
end

union LauncherLifecycleOutput
    queued(track_id: u32, slot_index: u32, launch_at_tick: i64)
  | launched(track_id: u32, slot_index: u32)
  | stopped(track_id: u32, stop_at_tick: i64)
  | unchanged
  | rejected(issue: Issue)
end

region launcher_lifecycle(LauncherLifecycleInput; LauncherLifecycleOutput) end

struct ClipPlaybackLifecycleInput
    planned: ptr(PlannedProject),
    state: ptr(RuntimeRenderState),
    clip: DawClipRef,
    audio_block: AudioBlock,
end

union ClipPlaybackLifecycleOutput
    active(region_job: ptr(PlannedRegionJob), local_tick: i64)
  | silent
  | loop_wrapped(iteration: u32, local_tick: i64)
  | ended
  | invalid(issue: Issue)
end

region clip_playback_lifecycle(ClipPlaybackLifecycleInput; ClipPlaybackLifecycleOutput) end

struct VoiceLifecycleInput
    planned: ptr(PlannedProject),
    state: ptr(RuntimeRenderState),
    track_id: u32,
    event: ScoreNoteEvent,
end

union VoiceLifecycleOutput
    started(voice_id: u32)
  | released(voice_id: u32)
  | stolen(old_voice_id: u32, new_voice_id: u32)
  | orphan_note_off
  | rejected(issue: Issue)
end

region voice_lifecycle(VoiceLifecycleInput; VoiceLifecycleOutput) end

struct PluginLifecycleInput
    planned: ptr(PlannedProject),
    state: ptr(RuntimeRenderState),
    device_id: u32,
    audio_block: AudioBlock,
end

union PluginLifecycleOutput
    processed(latency_samples: u32)
  | bypassed
  | suspended
  | plugin_error(code: i32)
  | invalid(issue: Issue)
end

region plugin_lifecycle(PluginLifecycleInput; PluginLifecycleOutput) end

struct ConsumeLiveCommandInput
    planned: ptr(PlannedProject),
    state: ptr(RuntimeRenderState),
    live: ptr(LiveStore),
    cmd: LiveCommandRef,
end

union ConsumeLiveCommandOutput
    consumed
  | deferred(next_tick: i64)
  | rejected(issue: Issue)
  | invalid(code: i32)
end

region consume_live_command(ConsumeLiveCommandInput; ConsumeLiveCommandOutput) end

-- ------------------------------------------------------------
-- Deep sealed ABI functions: encode protocols only at the boundary
-- ------------------------------------------------------------

func daw_source_apply_event(store: ptr(DawSourceStore), events: ptr(EditStore), root: ptr(DawRootRef), event: EditEventRef): i32 end
func daw_source_apply_transaction(store: ptr(DawSourceStore), events: ptr(EditStore), root: ptr(DawRootRef), first_event: u32, event_count: u32): i32 end
func daw_rebuild_incremental(store: ptr(DawSourceStore), cache: ptr(PhaseCache), root: DawRootRef, out_kernel: ptr(KernelProject)): i32 end
func daw_audio_callback(kernel: ptr(KernelProject), planned: ptr(PlannedProject), state: ptr(RuntimeRenderState), live: ptr(LiveStore), audio_block: ptr(AudioBlock)): i32 end
func daw_host_command(kernel: ptr(KernelProject), planned: ptr(PlannedProject), state: ptr(RuntimeRenderState), live: ptr(LiveStore), cmd: LiveCommandRef): i32 end
func daw_cache_report(cache: ptr(PhaseCache), phase_id: u32, out_report: ptr(PhaseReport)): i32 end

-- ============================================================
-- ASDL-DERIVED FOREST: complete structural coverage from upload
-- ============================================================

-- ============================================================
-- COMMON: scalars, handles, option products, diagnostics
-- ============================================================

struct TextRef
    data: ptr(u8),
    len: index,
end

struct BlobRef
    data: ptr(u8),
    len: index,
end

struct MaybeTextRef
    present: bool,
    value: TextRef,
end

struct MaybeU32
    present: bool,
    value: u32,
end

struct MaybeI64
    present: bool,
    value: i64,
end

struct MaybeF64
    present: bool,
    value: f64,
end

struct MaybePtr
    present: bool,
    value: ptr(u8),
end

struct BeatRange
    start_beats: f64,
    end_beats: f64,
end

struct TickRange
    start_tick: i64,
    end_tick: i64,
end

struct SampleRange
    start_sample: i64,
    end_sample: i64,
end

struct SourceSpan
    file_id: u32,
    start_byte: index,
    len: index,
end

struct GenerationRef
    index: u32,
    generation: u64,
end

struct Issue
    code: i32,
    subject_kind: u32,
    subject_id: u32,
    span: SourceSpan,
end

struct IssueList
    issues: view(Issue),
end

struct ResolveCtx
    tick_ppq: i64,
    strict: bool,
    asset_root: TextRef,
end

struct RateCtx
    sample_rate: f64,
    block_size: u32,
    tick_ppq: i64,
end

struct PlanCtx
    sample_rate: f64,
    block_size: u32,
    max_tracks: u32,
    max_buffers: u32,
    latency_compensation: bool,
end

struct CompileCtx
    target_id: u32,
    sample_type_code: u32,
    vector_width: u32,
    plugin_host: ptr(u8),
end

union Checked
    ok
  | invalid(issues: IssueList)
end

-- ============================================================
-- COMMON CODEBOOKS
-- Codes are stored facts. Their meaning is owned by visit_* regions below.
-- ============================================================

struct QuantizationCode value: u32 end
-- 0 none, 1 1/64, 2 1/32, 3 1/16, 4 1/8, 5 1/4, 6 1/2,
-- 7 1bar, 8 2bars, 9 4bars, 10 8bars

struct InterpModeCode value: u32 end
-- 0 linear, 1 smoothstep, 2 hold

struct LaunchModeCode value: u32 end
-- 0 trigger, 1 gate, 2 toggle, 3 repeat

struct StopPolicyCode value: u32 end
-- 0 immediate, 1 quantized, 2 at_clip_end

struct FollowKindCode value: u32 end
-- 0 none, 1 next, 2 prev, 3 first, 4 last, 5 other, 6 random, 7 stop

struct TrackRoleCode value: u32 end
-- 0 audio, 1 instrument, 2 hybrid, 3 group, 4 return, 5 master

struct RateClassCode value: u32 end
-- 0 literal, 1 init, 2 block, 3 sample, 4 event, 5 voice

struct TargetRefKindCode value: u32 end
-- 0 mixer_fader, 1 mixer_pan, 2 send_level, 3 device_param, 4 clip_gain, 5 transport_param

struct SourceKindCode value: u32 end
-- 0 macro, 1 lfo, 2 envelope, 3 sidechain, 4 midi_cc, 5 random, 6 note_expression

struct DeviceDomainCode value: u32 end
-- 0 note_fx, 1 instrument, 2 audio_fx, 3 router, 4 plugin

struct DeviceKindCode value: u32 end
-- Domain-local; interpreted by visit_score_device_kind / visit_semantic_device_kind.

struct NoteEventKindCode value: u32 end
-- 0 note_on, 1 note_off, 2 cc, 3 pitch_bend, 4 note_expression

struct ChannelLayout
    channels: u32,
    ambisonic_order: u32,
    speaker_set_code: u32,
end

-- ============================================================
-- SCORE: authored/source project language
-- Saved, undoable, user-authored facts only.
-- ============================================================

struct ScoreProject
    meta: ScoreMeta,
    transport: ScoreTransport,
    arrangement: ScoreArrangement,
    launcher: ScoreLauncher,
    mixer: ScoreMixer,
    devices: ScoreDevices,
    control: ScoreControl,
    assets: ScoreAssets,
end

struct ScoreMeta
    name: TextRef,
    author: MaybeTextRef,
    format_version: u32,
end

struct ScoreTransport
    sample_rate: f64,
    buffer_size: u32,
    bpm: f64,
    swing: f64,
    time_sig_num: u32,
    time_sig_den: u32,
    global_launch_quantization: QuantizationCode,
    tempo_map: view(ScoreTempoEvent),
    signature_map: view(ScoreSignatureEvent),
    looping_enabled: bool,
    loop_range: MaybeBeatRange,
end

struct MaybeBeatRange
    present: bool,
    value: BeatRange,
end

struct ScoreTempoEvent
    at_beats: f64,
    bpm: f64,
end

struct ScoreSignatureEvent
    at_beats: f64,
    num: u32,
    den: u32,
end

struct ScoreArrangement
    tracks: view(ScoreArrangementTrack),
    markers: view(ScoreMarker),
    sections: view(ScoreSection),
end

struct ScoreArrangementTrack
    track_id: u32,
    regions: view(ScoreRegion),
    automation_lanes: view(ScoreAutomationLane),
end

struct ScoreRegion
    region_id: u32,
    content: ScoreRegionContentRef,
    start_beats: f64,
    duration_beats: f64,
    source_offset_beats: f64,
    muted: bool,
    lane_index: u32,
    gain_target_id: u32,
end

struct ScoreRegionContentRef
    kind: u32,      -- 0 audio_asset, 1 note_asset
    slot: u32,
end

struct ScoreAutomationLane
    lane_id: u32,
    target_id: u32,
    curve: ScoreCurve,
end

struct ScoreCurve
    points: view(ScorePoint),
    mode: InterpModeCode,
end

struct ScorePoint
    time_beats: f64,
    value: f64,
end

struct ScoreMarker
    marker_id: u32,
    name: TextRef,
    at_beats: f64,
end

struct ScoreSection
    section_id: u32,
    name: TextRef,
    start_beats: f64,
    end_beats: f64,
    color: MaybeTextRef,
end

struct ScoreLauncher
    tracks: view(ScoreLaunchTrack),
    scenes: view(ScoreScene),
end

struct ScoreLaunchTrack
    track_id: u32,
    slots: view(ScoreSlot),
    exclusive_playing: bool,
    stop_policy: StopPolicyCode,
end

struct ScoreSlot
    slot_index: u32,
    content: ScoreSlotContentRef,
    launch_policy: ScoreLaunchPolicy,
    enabled: bool,
end

struct ScoreSlotContentRef
    kind: u32,      -- 0 empty, 1 clip/region, 2 stop
    clip_id: u32,
end

struct ScoreLaunchPolicy
    mode: LaunchModeCode,
    quantization_override: MaybeU32,
    legato: bool,
    retrigger: bool,
    follow_policy: ScoreMaybeFollowPolicy,
end

struct ScoreMaybeFollowPolicy
    present: bool,
    value: ScoreFollowPolicy,
end

struct ScoreFollowPolicy
    kind: FollowKindCode,
    amount0: f64,
    amount1: f64,
    next_scene_id: MaybeU32,
end

struct ScoreScene
    scene_id: u32,
    name: TextRef,
    actions: view(ScoreSceneAction),
    quantization_override: MaybeU32,
    tempo_override_bpm: MaybeF64,
end

struct ScoreSceneAction
    track_id: u32,
    slot_index: u32,
    stop_others: bool,
end

struct ScoreMixer
    tracks: view(ScoreTrack),
    master_track_id: u32,
end

struct ScoreTrack
    name: TextRef,
    track_id: u32,
    role: TrackRoleCode,
    channel_layout: ChannelLayout,
    chain_id: u32,
    output_track_id: u32,
    sends: view(ScoreSend),
    fader_target_id: u32,
    pan_target_id: u32,
    muted: bool,
    soloed: bool,
    armed: bool,
    monitor_input: bool,
    phase_invert: bool,
    parent_group_id: MaybeU32,
    latency_hint_samples: u32,
end

struct ScoreSend
    send_id: u32,
    target_track_id: u32,
    level_target_id: u32,
    pre_fader: bool,
    enabled: bool,
end

struct ScoreDevices
    chains: view(ScoreChain),
    devices: view(ScoreDevice),
    note_fx: view(ScoreNoteFX),
    note_fx_arps: view(ScoreNoteFXArpeggiator),
    note_fx_chords: view(ScoreNoteFXChord),
    note_fx_filters: view(ScoreNoteFXNoteFilter),
    chord_notes: view(ScoreChordNote),
    instruments: view(ScoreInstrument),
    samplers: view(ScoreSampler),
    basic_synths: view(ScoreBasicSynth),
    audio_fx: view(ScoreAudioFX),
    eqs: view(ScoreEQFX),
    eq_bands: view(ScoreEQBand),
    compressors: view(ScoreCompressorFX),
    delays: view(ScoreDelayFX),
    reverbs: view(ScoreReverbFX),
    choruses: view(ScoreChorusFX),
    saturators: view(ScoreSaturatorFX),
    routers: view(ScoreRouter),
    splitters: view(ScoreSplitter),
    split_rules: view(ScoreSplitRule),
    layers: view(ScoreLayer),
    layer_rules: view(ScoreLayerRule),
    selectors: view(ScoreSelector),
    plugins: view(ScorePluginDevice),
    plugin_params: view(ScorePluginParam),
end

struct ScoreChain
    chain_id: u32,
    device_ids: view(u32),
    note_domain: bool,
    audio_domain: bool,
    input_channels: u32,
    output_channels: u32,
end

struct ScoreDevice
    device_id: u32,
    domain: DeviceDomainCode,
    kind: DeviceKindCode,
    payload_slot: u32,
    bypass_target_id: u32,
    enabled: bool,
    channels: u32,
end

struct ScoreNoteFX
    note_fx_id: u32,
    kind: DeviceKindCode,    -- 0 arp, 1 chord, 2 note_filter
    payload_slot: u32,
end

struct ScoreNoteFXArpeggiator
    pattern_id: u32,
    gate_target_id: u32,
    rate_target_id: u32,
end

struct ScoreNoteFXChord
    first_note: u32,
    note_count: u32,
end

struct ScoreNoteFXNoteFilter
    lo_note: u32,
    hi_note: u32,
    lo_vel: u32,
    hi_vel: u32,
end

struct ScoreChordNote
    semitone: i32,
    velocity_scale: f64,
end

struct ScoreInstrument
    instrument_id: u32,
    kind: DeviceKindCode,    -- 0 sampler, 1 basic_synth
    payload_slot: u32,
end

struct ScoreSampler
    zone_bank_id: u32,
    gain_target_id: u32,
    pitch_target_id: u32,
end

struct ScoreBasicSynth
    voice_count: u32,
    osc_type_code: u32,      -- 0 sine, 1 saw, 2 square, 3 triangle, 4 noise
    tune_target_id: u32,
    cutoff_target_id: u32,
    resonance_target_id: u32,
    env_amount_target_id: u32,
end

struct ScoreAudioFX
    audio_fx_id: u32,
    kind: DeviceKindCode,    -- 0 gain, 1 pan, 2 eq, 3 comp, 4 delay, 5 reverb, 6 chorus, 7 saturator
    payload_slot: u32,
end

struct ScoreEQFX
    first_band: u32,
    band_count: u32,
end

struct ScoreEQBand
    eq_type_code: u32,       -- 0 low_shelf, 1 high_shelf, 2 peak, 3 low_cut, 4 high_cut
    freq_target_id: u32,
    gain_target_id: u32,
    q_target_id: u32,
end

struct ScoreCompressorFX
    threshold_target_id: u32,
    ratio_target_id: u32,
    attack_target_id: u32,
    release_target_id: u32,
    makeup_target_id: u32,
    sidechain_amount_target_id: MaybeU32,
end

struct ScoreDelayFX
    time_target_id: u32,
    feedback_target_id: u32,
    mix_target_id: u32,
    tempo_sync: bool,
end

struct ScoreReverbFX
    decay_target_id: u32,
    damping_target_id: u32,
    mix_target_id: u32,
    predelay_target_id: u32,
end

struct ScoreChorusFX
    rate_target_id: u32,
    depth_target_id: u32,
    mix_target_id: u32,
end

struct ScoreSaturatorFX
    drive_target_id: u32,
    curve_code: u32,         -- 0 tanh, 1 soft_clip, 2 hard_clip, 3 tube
end

struct ScoreRouter
    router_id: u32,
    kind: DeviceKindCode,    -- 0 splitter, 1 layer, 2 selector
    payload_slot: u32,
end

struct ScoreSplitter
    first_rule: u32,
    rule_count: u32,
end

struct ScoreSplitRule
    chain_id: u32,
    low_note: u32,
    high_note: u32,
    low_freq_hz: f64,
    high_freq_hz: f64,
end

struct ScoreLayer
    first_rule: u32,
    rule_count: u32,
end

struct ScoreLayerRule
    chain_id: u32,
    gain_target_id: u32,
    enabled_target_id: u32,
end

struct ScoreSelector
    selector_target_id: u32,
    chain_ids: view(u32),
end

struct ScorePluginDevice
    plugin_handle: ptr(u8),
    format: TextRef,
    channels: u32,
    params: view(ScorePluginParam),
end

struct ScorePluginParam
    index: u32,
    name: TextRef,
    target_id: u32,
end

struct ScoreControl
    targets: view(ScoreTarget),
    sources: view(ScoreSource),
    mappings: view(ScoreMapping),
end

struct ScoreTarget
    target_id: u32,
    ref: ScoreTargetRef,
    default_value: f64,
    min_value: f64,
    max_value: f64,
    combine_mode_code: u32,      -- 0 replace, 1 add, 2 multiply, 3 min, 4 max
    smoothing_mode_code: u32,    -- 0 none, 1 lag
    smoothing_ms: f64,
    preferred_rate: RateClassCode,
end

struct ScoreTargetRef
    kind: TargetRefKindCode,
    arg0: u32,
    arg1: u32,
    arg2: u32,
end

struct ScoreSource
    source_id: u32,
    kind: SourceKindCode,
    payload_slot: u32,
end

struct ScoreMacroSource
    name: TextRef,
    default_value: f64,
end

struct ScoreLFOSource
    shape_code: u32,         -- 0 sine, 1 triangle, 2 square, 3 saw, 4 sample_hold
    rate_target_id: u32,
    depth_target_id: u32,
    phase_offset: f64,
end

struct ScoreEnvelopeSource
    envelope_kind_code: u32, -- 0 ar, 1 follower, 2 adsr
    attack_target_id: u32,
    release_target_id: u32,
end

struct ScoreSidechainSource
    source_track_id: u32,
    attack_ms: f64,
    release_ms: f64,
end

struct ScoreMIDICCSource
    cc_number: u32,
    min_value: f64,
    max_value: f64,
end

struct ScoreRandomSource
    seed: u64,
    rate_target_id: u32,
end

struct ScoreNoteExpressionSource
    kind_code: u32,          -- 0 pressure, 1 timbre, 2 pitch_bend, 3 velocity
end

struct ScoreMapping
    mapping_id: u32,
    source_id: u32,
    target_id: u32,
    depth: f64,
    offset: f64,
    bipolar: bool,
end

struct ScoreAssets
    audio_assets: view(ScoreAudioAsset),
    note_assets: view(ScoreNoteAsset),
    plugin_assets: view(ScorePluginAsset),
    preset_assets: view(ScorePresetAsset),
    zone_banks: view(ScoreZoneBank),
end

struct ScoreAudioAsset
    asset_id: u32,
    path: TextRef,
    sample_rate: f64,
    channels: u32,
    length_samples: i64,
end

struct ScoreNoteAsset
    asset_id: u32,
    events: view(ScoreNoteEvent),
    loop_start_beats: f64,
    loop_end_beats: f64,
end

struct ScoreNoteEvent
    kind: NoteEventKindCode,
    at_beats: f64,
    data0: f64,
    data1: f64,
end

struct ScorePluginAsset
    asset_id: u32,
    format: TextRef,
    identifier: TextRef,
    version: TextRef,
end

struct ScorePresetAsset
    asset_id: u32,
    plugin_asset_id: u32,
    path: TextRef,
end

struct ScoreZoneBank
    bank_id: u32,
    zones: view(ScoreSampleZone),
end

struct ScoreSampleZone
    path: TextRef,
    root_note: u32,
    lo_note: u32,
    hi_note: u32,
    lo_vel: u32,
    hi_vel: u32,
end

-- ============================================================
-- SEMANTIC: resolved model
-- IDs fixed, refs flattened, beats normalized to ticks.
-- ============================================================

struct SemanticProject
    meta: SemanticMeta,
    transport: SemanticTransport,
    arrangement: SemanticArrangement,
    launcher: SemanticLauncher,
    mixer: SemanticMixer,
    devices: SemanticDevices,
    control: SemanticControl,
    assets: SemanticAssets,
end

struct SemanticMeta
    name: TextRef,
    author: MaybeTextRef,
    format_version: u32,
end

struct SemanticTransport
    sample_rate: f64,
    buffer_size: u32,
    bpm: f64,
    swing: f64,
    time_sig_num: u32,
    time_sig_den: u32,
    global_launch_quant_code: u32,
    tempo_points: view(SemanticTempoPoint),
    signature_points: view(SemanticSignaturePoint),
    looping_enabled: bool,
    loop_start_tick: i64,
    loop_end_tick: i64,
end

struct SemanticTempoPoint tick: i64, bpm: f64 end
struct SemanticSignaturePoint tick: i64, num: u32, den: u32 end

struct SemanticArrangement
    tracks: view(SemanticArrangementTrack),
    regions: view(SemanticRegion),
    automation_lanes: view(SemanticAutomationLane),
    curves: view(SemanticCurve),
    markers: view(SemanticMarker),
    sections: view(SemanticSection),
end

struct SemanticArrangementTrack
    track_id: u32,
    first_region: u32,
    region_count: u32,
    first_automation_lane: u32,
    automation_lane_count: u32,
end

struct SemanticRegion
    region_id: u32,
    content: SemanticRegionContentRef,
    start_tick: i64,
    end_tick: i64,
    source_offset_tick: i64,
    muted: bool,
    lane_index: u32,
    gain_target_id: u32,
end

struct SemanticRegionContentRef
    kind: u32,      -- 0 audio, 1 note
    slot: u32,
end

struct SemanticAutomationLane lane_id: u32, target_id: u32, curve_slot: u32 end
struct SemanticCurve points: view(SemanticCurvePoint), interp_mode_code: u32 end
struct SemanticCurvePoint tick: i64, value: f64 end
struct SemanticMarker marker_id: u32, name: TextRef, tick: i64 end
struct SemanticSection section_id: u32, name: TextRef, start_tick: i64, end_tick: i64, color: MaybeTextRef end

struct SemanticLauncher
    tracks: view(SemanticLaunchTrack),
    scenes: view(SemanticScene),
end

struct SemanticLaunchTrack
    track_id: u32,
    slots: view(SemanticSlot),
    exclusive_playing: bool,
    stop_policy_code: u32,
end

struct SemanticSlot
    slot_index: u32,
    content: SemanticSlotContentRef,
    launch_policy: SemanticLaunchPolicy,
    enabled: bool,
end

struct SemanticSlotContentRef
    kind: u32,      -- 0 empty, 1 clip, 2 stop
    clip_id: u32,
end

struct SemanticLaunchPolicy
    launch_mode_code: u32,
    quantization_code: u32,
    legato: bool,
    retrigger: bool,
    follow_policy: SemanticMaybeFollowPolicy,
end

struct SemanticMaybeFollowPolicy present: bool, value: SemanticFollowPolicy end
struct SemanticFollowPolicy follow_kind_code: u32, amount0: f64, amount1: f64, next_scene_id: MaybeU32 end
struct SemanticScene scene_id: u32, name: TextRef, actions: view(SemanticSceneAction), quantization_code: u32, tempo_override_bpm: MaybeF64 end
struct SemanticSceneAction track_id: u32, slot_index: u32, stop_others: bool end

struct SemanticMixer
    tracks: view(SemanticTrack),
    sends: view(SemanticSend),
    master_track_id: u32,
end

struct SemanticTrack
    name: TextRef,
    track_id: u32,
    role_code: u32,
    channels: u32,
    chain_id: u32,
    output_track_id: u32,
    send_ids: view(u32),
    fader_target_id: u32,
    pan_target_id: u32,
    muted: bool,
    soloed: bool,
    armed: bool,
    monitor_input: bool,
    phase_invert: bool,
    parent_group_id: MaybeU32,
    latency_hint_samples: u32,
end

struct SemanticSend send_id: u32, target_track_id: u32, level_target_id: u32, pre_fader: bool, enabled: bool end

struct SemanticDevices
    chains: view(SemanticChain),
    devices: view(SemanticDevice),
    params: view(SemanticDeviceParam),
    eq_bands: view(SemanticEQBand),
end

struct SemanticChain
    chain_id: u32,
    device_ids: view(u32),
    note_domain: bool,
    audio_domain: bool,
    input_channels: u32,
    output_channels: u32,
end

struct SemanticDevice
    device_id: u32,
    domain_code: u32,
    kind: SemanticDeviceKind,
    channels: u32,
    first_param: u32,
    param_count: u32,
end

struct SemanticDeviceKind
    kind_code: u32,
    plugin_handle: MaybePtr,
    plugin_format: MaybeTextRef,
    first_child_chain: u32,
    child_chain_count: u32,
    arg0: u32,
    arg1: u32,
    arg2: u32,
    arg3: u32,
end

struct SemanticDeviceParam device_id: u32, index: u32, name: TextRef, target_id: u32 end
struct SemanticEQBand eq_type_code: u32, freq_target_id: u32, gain_target_id: u32, q_target_id: u32 end

struct SemanticControl
    targets: view(SemanticTarget),
    sources: view(SemanticSource),
    mappings: view(SemanticMapping),
end

struct SemanticTarget
    target_id: u32,
    ref: SemanticTargetRef,
    default_value: f64,
    min_value: f64,
    max_value: f64,
    combine_mode_code: u32,
    smoothing_mode_code: u32,
    smoothing_ms: f64,
    preferred_rate_code: u32,
end

struct SemanticTargetRef kind: u32, arg0: u32, arg1: u32, arg2: u32 end
struct SemanticSource source_id: u32, kind: u32, arg0: u32, arg1: u32, arg2: u32, arg3: u32 end
struct SemanticMapping mapping_id: u32, source_id: u32, target_id: u32, depth: f64, offset: f64, bipolar: bool end

struct SemanticAssets
    audio_assets: view(SemanticAudioAsset),
    note_assets: view(SemanticNoteAsset),
    plugin_assets: view(SemanticPluginAsset),
    preset_assets: view(SemanticPresetAsset),
    zone_banks: view(SemanticZoneBank),
end

struct SemanticAudioAsset asset_id: u32, path: TextRef, sample_rate: f64, channels: u32, length_samples: i64 end
struct SemanticNoteAsset asset_id: u32, events: view(SemanticNoteEvent), loop_start_tick: i64, loop_end_tick: i64 end
struct SemanticNoteEvent kind: u32, tick: i64, data0: f64, data1: f64 end
struct SemanticPluginAsset asset_id: u32, format: TextRef, identifier: TextRef, version: TextRef end
struct SemanticPresetAsset asset_id: u32, plugin_asset_id: u32, path: TextRef end
struct SemanticZoneBank bank_id: u32, zones: view(SemanticSampleZone) end
struct SemanticSampleZone path: TextRef, root_note: u32, lo_note: u32, hi_note: u32, lo_vel: u32, hi_vel: u32 end

-- ============================================================
-- RATED: dynamic targets classified by runtime rate
-- ============================================================

struct RatedProject
    transport: RatedTransport,
    arrangement: RatedArrangement,
    launcher: RatedLauncher,
    mixer: RatedMixer,
    devices: RatedDevices,
    control: RatedControl,
    literals: view(RatedLiteralBinding),
    inits: view(RatedInitBinding),
    blocks: view(RatedBlockBinding),
    block_points: view(RatedBlockPoint),
    samples: view(RatedSampleBinding),
    events: view(RatedEventBinding),
    voices: view(RatedVoiceBinding),
end

struct RatedTransport
    sample_rate: f64,
    buffer_size: u32,
    bpm: f64,
    swing: f64,
    time_sig_num: u32,
    time_sig_den: u32,
    global_launch_quant_code: u32,
    looping_enabled: bool,
    loop_start_tick: i64,
    loop_end_tick: i64,
end

struct RatedArrangement tracks: view(RatedArrangementTrack), regions: view(RatedRegion), automation_lanes: view(RatedAutomationLane), curves: view(RatedBlockCurve) end
struct RatedArrangementTrack track_id: u32, first_region: u32, region_count: u32, first_automation_lane: u32, automation_lane_count: u32 end
struct RatedRegion region_id: u32, content_kind: u32, content_slot: u32, start_tick: i64, end_tick: i64, source_offset_tick: i64, muted: bool, lane_index: u32, gain: RatedBindingRef end
struct RatedAutomationLane lane_id: u32, target_id: u32, block_binding_slot: u32 end
struct RatedBlockCurve first_point: u32, point_count: u32, interp_mode_code: u32 end
struct RatedLauncher tracks: view(RatedLaunchTrack), scenes: view(RatedScene) end
struct RatedLaunchTrack track_id: u32, slots: view(RatedSlot), exclusive_playing: bool, stop_policy_code: u32 end
struct RatedSlot slot_index: u32, kind: u32, clip_id: u32, launch_mode_code: u32, quantization_code: u32, legato: bool, retrigger: bool, follow_kind_code: u32, amount0: f64, amount1: f64, next_scene_id: MaybeU32, enabled: bool end
struct RatedScene scene_id: u32, first_action: u32, action_count: u32, quantization_code: u32, tempo_override_bpm: MaybeF64 end
struct RatedMixer tracks: view(RatedTrack), sends: view(RatedSend), master_track_id: u32 end
struct RatedTrack track_id: u32, role_code: u32, channels: u32, chain_id: u32, output_track_id: u32, send_ids: view(u32), fader: RatedBindingRef, pan: RatedBindingRef, muted_structural: bool, solo_structural: bool, armed: bool, monitor_input: bool, latency_hint_samples: u32 end
struct RatedSend send_id: u32, target_track_id: u32, level: RatedBindingRef, pre_fader: bool, enabled: bool end
struct RatedDevices chains: view(RatedChain), devices: view(RatedDevice), params: view(RatedDeviceParam), eq_bands: view(RatedEQBand) end
struct RatedChain chain_id: u32, device_ids: view(u32), note_domain: bool, audio_domain: bool, input_channels: u32, output_channels: u32 end
struct RatedDevice device_id: u32, domain_code: u32, kind_code: u32, plugin_handle: MaybePtr, plugin_format: MaybeTextRef, channels: u32, first_param: u32, param_count: u32, first_child_chain: u32, child_chain_count: u32, arg0: u32, arg1: u32, arg2: u32, arg3: u32 end
struct RatedDeviceParam device_id: u32, index: u32, binding: RatedBindingRef end
struct RatedEQBand eq_type_code: u32, freq: RatedBindingRef, gain: RatedBindingRef, q: RatedBindingRef end
struct RatedControl targets: view(RatedTarget), sources: view(RatedSource), mappings: view(RatedMapping) end
struct RatedTarget target_id: u32, ref: SemanticTargetRef, default_value: f64, min_value: f64, max_value: f64, combine_mode_code: u32, smoothing_mode_code: u32, smoothing_ms: f64, binding: RatedBindingRef, runtime_state_slot: u32 end
struct RatedSource source_id: u32, kind: u32, preferred_rate_class: u32, binding_slot: u32, runtime_state_slot: u32, arg0: u32, arg1: u32, arg2: u32, arg3: u32 end
struct RatedMapping mapping_id: u32, source_id: u32, target_id: u32, depth: f64, offset: f64, bipolar: bool end
struct RatedBindingRef rate_class: u32, slot: u32 end
struct RatedMaybeBindingRef present: bool, value: RatedBindingRef end
struct RatedLiteralBinding value: f64 end
struct RatedInitBinding kind: u32, arg0: u32, arg1: u32, arg2: u32, input0: RatedBindingRef, input1: RatedMaybeBindingRef, state_slot: u32 end
struct RatedBlockBinding kind: u32, first_point: u32, point_count: u32, interp_mode_code: u32, arg0: u32, arg1: u32, input0: RatedBindingRef, input1: RatedMaybeBindingRef end
struct RatedBlockPoint tick: i64, value: f64 end
struct RatedSampleBinding kind: u32, input0: RatedBindingRef, input1: RatedMaybeBindingRef, source_track_id: u32, arg0: u32, arg1: u32, arg2: u32, state_slot: u32 end
struct RatedEventBinding kind: u32, event_code: u32, min_value: f64, max_value: f64, state_slot: u32 end
struct RatedVoiceBinding kind: u32, input0: RatedBindingRef, input1: RatedMaybeBindingRef, arg0: u32, arg1: u32, arg2: u32, state_slot: u32 end

-- ============================================================
-- PLANNED: explicit schedules and buffer/runtime slots
-- ============================================================

struct PlannedProject
    transport: PlannedTransport,
    arrangement: PlannedArrangement,
    launcher: PlannedLauncher,
    mixer: PlannedMixer,
    devices: PlannedDevices,
    control: PlannedControl,
    buffers: view(PlannedBufferSlot),
    tracks: view(PlannedTrackPlan),
    steps: view(PlannedStep),
    regions: view(PlannedRegionJob),
    device_jobs: view(PlannedDeviceJob),
    device_params: view(PlannedDeviceParamJob),
    sends: view(PlannedSendJob),
    mixes: view(PlannedMixJob),
    outputs: view(PlannedOutputJob),
    targets: view(PlannedTargetSlot),
    inits: view(PlannedInitBinding),
    blocks: view(PlannedBlockBinding),
    block_points: view(PlannedBlockPoint),
    samples: view(PlannedSampleBinding),
    events: view(PlannedEventBinding),
    voices: view(PlannedVoiceBinding),
    total_buffer_slots: u32,
    master_left_buf: u32,
    master_right_buf: u32,
end

struct PlannedTransport sample_rate: f64, buffer_size: u32, bpm: f64, swing: f64, time_sig_num: u32, time_sig_den: u32, global_launch_quant_code: u32, looping_enabled: bool, loop_start_tick: i64, loop_end_tick: i64 end
struct PlannedArrangement regions: view(PlannedRegionJob) end
struct PlannedLauncher tables: view(PlannedLaunchTable), scenes: view(PlannedSceneTransition) end
struct PlannedMixer master_track_id: u32 end
struct PlannedDevices jobs: view(PlannedDeviceJob), params: view(PlannedDeviceParamJob) end
struct PlannedControl targets: view(PlannedTargetSlot) end
struct PlannedBufferSlot index: u32, channels: u32, interleaved: bool, persistent: bool end
struct PlannedTrackPlan track_id: u32, role_code: u32, work_buf: u32, aux_buf: u32, mix_in_buf: u32, out_left_buf: u32, out_right_buf: u32, first_step: u32, step_count: u32 end
struct PlannedStep index: u32, clear_buf: u32, region_job: u32, device_job: u32, send_job: u32, mix_job: u32, output_job: u32, launcher_eval_slot: u32, scene_transition_slot: u32 end
struct PlannedRegionJob region_id: u32, content_kind: u32, content_slot: u32, out_buf: u32, start_tick: i64, end_tick: i64, source_offset_tick: i64, gain: PlannedBindingRef, reversed: bool, pitch_shift_semitones: MaybeF64, time_stretch_ratio: MaybeF64 end
struct PlannedDeviceJob device_id: u32, domain_code: u32, kind_code: u32, plugin_handle: MaybePtr, in_buf: u32, out_buf: u32, first_param: u32, param_count: u32, first_child_chain: u32, child_chain_count: u32, runtime_state_slot: u32, arg0: u32, arg1: u32, arg2: u32, arg3: u32 end
struct PlannedDeviceParamJob device_id: u32, index: u32, binding: PlannedBindingRef end
struct PlannedSendJob source_buf: u32, target_buf: u32, level: PlannedBindingRef, pre_fader: bool, enabled: bool end
struct PlannedMixJob source_buf: u32, target_buf: u32, gain: PlannedBindingRef end
struct PlannedOutputJob source_buf: u32, out_left_buf: u32, out_right_buf: u32, gain: PlannedBindingRef, pan: PlannedBindingRef end
struct PlannedLaunchTable track_id: u32, slot_index: u32, kind: u32, clip_id: u32, launch_mode_code: u32, quantization_code: u32, legato: bool, retrigger: bool, stop_policy_code: u32, follow_kind_code: u32, amount0: f64, amount1: f64, next_scene_id: MaybeU32, enabled: bool end
struct PlannedSceneTransition scene_id: u32, first_action: u32, action_count: u32, quantization_code: u32, tempo_override_bpm: MaybeF64 end
struct PlannedTargetSlot target_id: u32, ref: SemanticTargetRef, default_value: f64, min_value: f64, max_value: f64, combine_mode_code: u32, smoothing_mode_code: u32, smoothing_ms: f64, binding: PlannedBindingRef, runtime_state_slot: u32 end
struct PlannedBindingRef rate_class: u32, slot: u32 end
struct PlannedMaybeBindingRef present: bool, value: PlannedBindingRef end
struct PlannedInitBinding kind: u32, arg0: u32, arg1: u32, arg2: u32, input0: PlannedBindingRef, input1: PlannedMaybeBindingRef, state_slot: u32 end
struct PlannedBlockBinding kind: u32, first_point: u32, point_count: u32, interp_mode_code: u32, arg0: u32, arg1: u32, input0: PlannedBindingRef, input1: PlannedMaybeBindingRef end
struct PlannedBlockPoint tick: i64, value: f64 end
struct PlannedSampleBinding kind: u32, input0: PlannedBindingRef, input1: PlannedMaybeBindingRef, source_track_id: u32, arg0: u32, arg1: u32, arg2: u32, state_slot: u32 end
struct PlannedEventBinding kind: u32, event_code: u32, min_value: f64, max_value: f64, state_slot: u32 end
struct PlannedVoiceBinding kind: u32, input0: PlannedBindingRef, input1: PlannedMaybeBindingRef, arg0: u32, arg1: u32, arg2: u32, state_slot: u32 end

-- Iterators/fact streams used by the final loop.
struct PlannedStepIter project_generation: u64, track_index: u32, step_index: u32 end
struct PlannedJobIter project_generation: u64, job_kind: u32, index: u32 end
struct PlannedLaunchIter project_generation: u64, index: u32 end
struct PlannedControlIter project_generation: u64, rate_class: u32, index: u32 end

-- ============================================================
-- RUNTIME: live machine state, not saved project data
-- ============================================================

struct RuntimeTransportState
    playing: bool,
    recording: bool,
    current_tick: i64,
    current_sample: i64,
    block_start_tick: i64,
    loop_iteration: u64,
end

struct RuntimeLaunchState tracks: view(RuntimeTrackLaunchState), scenes: view(RuntimeSceneQueueState) end
struct RuntimeTrackLaunchState track_id: u32, active_slot: u32, queued_slot: u32, stop_pending: bool, launch_pending: bool, launch_at_tick: i64, stop_at_tick: i64, legato_mode: bool end
struct RuntimeSceneQueueState scene_id: u32, queued: bool, launch_at_tick: i64 end
struct RuntimeControlState target_values: view(f64), smoothed_values: view(f64), macro_values: view(f64), event_values: view(f64), block_values: view(f64), sample_values: view(f64), voice_values: view(f64) end
struct RuntimeDSPState lfo_phases: view(f64), follower_values: view(f64), comp_envs: view(f64), delay_positions: view(f64), delay_lengths: view(f64), voice_states: view(f64), plugin_state_indices: view(u32) end
struct RuntimeBufferState buffer_count: u32, sample_t: ptr(u8), buffers: view(ptr(f32)) end
struct RuntimeRenderState transport: RuntimeTransportState, launcher: RuntimeLaunchState, control: RuntimeControlState, dsp: RuntimeDSPState, buffers: RuntimeBufferState end

-- Runtime input facts.
struct DawEventRef kind: u32, index: u32, generation: u64 end
struct PointerEvent x: f32, y: f32, buttons: u32, mods: u32 end
struct KeyEvent key: u32, mods: u32, pressed: bool end
struct TransportEvent kind: u32, value0: f64, value1: f64 end
struct ClipLaunchEvent track_id: u32, slot_index: u32, scene_id: MaybeU32 end
struct SceneLaunchEvent scene_id: u32 end
struct ParameterEditEvent target_id: u32, value: f64, normalized: bool end
struct MidiEvent port_id: u32, status: u32, data0: u32, data1: u32, sample_offset: u32 end
struct AudioBlock block_index: u64, nframes: u32, inputs: view(ptr(f32)), outputs: view(ptr(f32)) end

-- ============================================================
-- KERNEL: final compiled artifact and ABI surface
-- ============================================================

struct KernelBufferTypes
    mono_buf_t: ptr(u8),
    stereo_buf_t: ptr(u8),
    note_buf_t: ptr(u8),
    bus_array_t: ptr(u8),
end

struct KernelStateTypes
    transport_state_t: ptr(u8),
    launch_state_t: ptr(u8),
    control_state_t: ptr(u8),
    dsp_state_t: ptr(u8),
    render_state_t: ptr(u8),
end

struct KernelFunctions
    init_state_fn: ptr(u8),
    begin_block_fn: ptr(u8),
    eval_launcher_fn: ptr(u8),
    eval_control_fn: ptr(u8),
    render_block_fn: ptr(u8),
    queue_launch_fn: ptr(u8),
    queue_scene_fn: ptr(u8),
    stop_track_fn: ptr(u8),
    set_macro_fn: ptr(u8),
    set_cc_fn: ptr(u8),
    note_on_fn: ptr(u8),
    note_off_fn: ptr(u8),
end

struct KernelProject
    buffer_types: KernelBufferTypes,
    state_types: KernelStateTypes,
    fns: KernelFunctions,
end


-- ── Dispatch helpers ──────────────────────────────────────────────

-- Lower a binary operation to the appropriate Cmd variant.
-- overflow: 0=Wrap, 1=NoSignedWrap, 2=NoUnsignedWrap, 3=NoWrap.
-- exact: 0=MayLose, 1=Exact.
local mb_lower_binary = func(op: i32, scalar: i32, dst: i32, lhs: i32, rhs: i32, overflow: i32, exact: i32, out: ptr(@{CmdEntry}))
    let is_float: bool = mb_is_float(scalar)
    switch op do
    case @{T.BinAdd} then
        if is_float then
            mb_cmd_float_binary(out, dst, @{T.BackFloatAdd}, scalar, 1, lhs, rhs)
            return
        end
        mb_cmd_int_binary(out, dst, @{T.BackIntAdd}, scalar, overflow, exact, lhs, rhs)
    case @{T.BinSub} then
        if is_float then
            mb_cmd_float_binary(out, dst, @{T.BackFloatSub}, scalar, 1, lhs, rhs)
            return
        end
        mb_cmd_int_binary(out, dst, @{T.BackIntSub}, scalar, overflow, exact, lhs, rhs)
    case @{T.BinMul} then
        if is_float then
            mb_cmd_float_binary(out, dst, @{T.BackFloatMul}, scalar, 1, lhs, rhs)
            return
        end
        mb_cmd_int_binary(out, dst, @{T.BackIntMul}, scalar, overflow, exact, lhs, rhs)
    case @{T.BinDiv} then
        if is_float then
            mb_cmd_float_binary(out, dst, @{T.BackFloatDiv}, scalar, 1, lhs, rhs)
            return
        end
        mb_cmd_int_binary(out, dst, @{T.BackIntSDiv}, scalar, overflow, exact, lhs, rhs)
    case @{T.BinRem} then
        mb_cmd_int_binary(out, dst, @{T.BackIntSRem}, scalar, overflow, exact, lhs, rhs)
    case @{T.BinBitAnd} then
        mb_cmd_bit_binary(out, dst, @{T.BackBitAnd}, scalar, lhs, rhs)
    case @{T.BinBitOr} then
        mb_cmd_bit_binary(out, dst, @{T.BackBitOr}, scalar, lhs, rhs)
    case @{T.BinBitXor} then
        mb_cmd_bit_binary(out, dst, @{T.BackBitXor}, scalar, lhs, rhs)
    case @{T.BinShl} then
        mb_cmd_shift(out, dst, @{T.BackShiftLeft}, scalar, lhs, rhs)
    case @{T.BinLShr} then
        mb_cmd_shift(out, dst, @{T.BackShiftLogicalRight}, scalar, lhs, rhs)
    case @{T.BinAShr} then
        mb_cmd_shift(out, dst, @{T.BackShiftArithmeticRight}, scalar, lhs, rhs)
    default then
        mb_cmd_trap(out)
    end
end

-- Lower a unary operation to CmdUnary.
-- shape_tag: 1 for scalar shape. lanes: 0 for scalar.
local mb_lower_unary_cmd = func(op: i32, scalar: i32, dst: i32, value: i32, shape_tag: i32, out: ptr(@{CmdEntry}))
    switch op do
    case @{T.UnaryNeg} then
        let back_op: i32 = select(mb_is_float(scalar), @{T.BackUnaryFneg}, @{T.BackUnaryIneg})
        mb_cmd_unary(out, dst, back_op, shape_tag, scalar, 0, value)
    case @{T.UnaryNot} then
        mb_cmd_unary(out, dst, @{T.BackUnaryBoolNot}, shape_tag, scalar, 0, value)
    case @{T.UnaryBitNot} then
        mb_cmd_bit_not(out, dst, scalar, value)
    default then
        mb_cmd_trap(out)
    end
end

-- Lower a compare operation to CmdCompare.
local mb_lower_compare = func(op: i32, scalar: i32, dst: i32, lhs: i32, rhs: i32, shape_tag: i32, out: ptr(@{CmdEntry}))
    let is_float: bool = mb_is_float(scalar)
    let is_signed: bool = mb_is_signed(scalar)
    switch op do
    case @{T.CmpEq} then
        let back_op: i32 = select(is_float, @{T.BackFCmpEq}, @{T.BackIcmpEq})
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    case @{T.CmpNe} then
        let back_op: i32 = select(is_float, @{T.BackFCmpNe}, @{T.BackIcmpNe})
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    case @{T.CmpLt} then
        let back_op: i32 = select(is_float, @{T.BackFCmpLt}, select(is_signed, @{T.BackSIcmpLt}, @{T.BackUIcmpLt}))
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    case @{T.CmpLe} then
        let back_op: i32 = select(is_float, @{T.BackFCmpLe}, select(is_signed, @{T.BackSIcmpLe}, @{T.BackUIcmpLe}))
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    case @{T.CmpGt} then
        let back_op: i32 = select(is_float, @{T.BackFCmpGt}, select(is_signed, @{T.BackSIcmpGt}, @{T.BackUIcmpGt}))
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    case @{T.CmpGe} then
        let back_op: i32 = select(is_float, @{T.BackFCmpGe}, select(is_signed, @{T.BackSIcmpGe}, @{T.BackUIcmpGe}))
        mb_cmd_compare(out, dst, back_op, shape_tag, scalar, 0, lhs, rhs)
    default then
        mb_cmd_trap(out)
    end
end

-- Lower a MachineCastOp to CmdCast. cast_op is MachineCastOp tag.
local mb_lower_cast_cmd = func(cast_op: i32, scalar: i32, dst: i32, value: i32, out: ptr(@{CmdEntry}))
    switch cast_op do
    case @{T.MC_BITCAST} then mb_cmd_cast(out, dst, @{T.BackBitcast}, scalar, value)
    case @{T.MC_IREDUCE} then mb_cmd_cast(out, dst, @{T.BackIreduce}, scalar, value)
    case @{T.MC_SEXTEND} then mb_cmd_cast(out, dst, @{T.BackSextend}, scalar, value)
    case @{T.MC_UEXTEND} then mb_cmd_cast(out, dst, @{T.BackUextend}, scalar, value)
    case @{T.MC_FPROMOTE} then mb_cmd_cast(out, dst, @{T.BackFpromote}, scalar, value)
    case @{T.MC_FDEMOTE} then mb_cmd_cast(out, dst, @{T.BackFdemote}, scalar, value)
    case @{T.MC_STOF} then mb_cmd_cast(out, dst, @{T.BackSToF}, scalar, value)
    case @{T.MC_UTOF} then mb_cmd_cast(out, dst, @{T.BackUToF}, scalar, value)
    case @{T.MC_FTOS} then mb_cmd_cast(out, dst, @{T.BackFToS}, scalar, value)
    case @{T.MC_FTOU} then mb_cmd_cast(out, dst, @{T.BackFToU}, scalar, value)
    default then mb_cmd_trap(out)
    end
end


-- ── Memory commands ────────────────────────────────────────────────

-- CmdLoadInfo: [dst, shape_tag, scalar, lanes, base_tag, base_id, byte_offset,
--   access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k] = 15 slots
local mb_cmd_load_info = func(out: ptr(@{CmdEntry}), dst: i32, shape_tag: i32, scalar: i32, lanes: i32,
    base_tag: i32, base_id: i32, byte_offset: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdLoadInfo}
    out.w0 = dst; out.w1 = shape_tag; out.w2 = scalar; out.w3 = lanes; out.w4 = base_tag
    out.w5 = base_id; out.w6 = byte_offset; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k; out.w14 = mode_k
end

-- CmdStoreInfo: [shape_tag, scalar, lanes, base_tag, base_id, byte_offset, value,
--   access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k] = 14 slots
local mb_cmd_store_info = func(out: ptr(@{CmdEntry}), shape_tag: i32, scalar: i32, lanes: i32,
    base_tag: i32, base_id: i32, byte_offset: i32, value: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdStoreInfo}
    out.w0 = shape_tag; out.w1 = scalar; out.w2 = lanes; out.w3 = base_tag; out.w4 = base_id
    out.w5 = byte_offset; out.w6 = value; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k
    out.w14 = mode_k
end

-- CmdAliasFact: [kind, a, b, c] = 3 slots
local mb_cmd_alias_fact = func(out: ptr(@{CmdEntry}), kind: i32, a: i32, b: i32, c: i32)
    mb_cmd_clear(out)

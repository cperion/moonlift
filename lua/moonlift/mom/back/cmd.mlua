local mb_cmd_vec_load_info = func(out: ptr(@{CmdEntry}), dst: i32, elem_scalar: i32, lanes: i32,
    base_tag: i32, base_id: i32, byte_offset: i32, access: i32, align_k: i32, align_b: i32,

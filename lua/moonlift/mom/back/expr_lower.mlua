M:add_func(mb_token_to_binary_op)
M:add_func(mb_token_to_cmp_op)
M:add_func(mb_lower_surface_cast)
M:add_func(mb_lower_lit)
M:add_func(mb_lower_ref)
M:add_func(mb_lower_unary_expr)
M:add_func(mb_lower_binary_expr)
M:add_func(mb_lower_compare_expr)
M:add_func(mb_lower_select_expr)
M:add_func(mb_lower_logic_expr)
M:add_func(mb_lower_cast_expr)
M:add_func(mb_lower_call_expr)
M:add_func(mb_lower_dot_expr)
M:add_func(mb_lower_index_expr)
M:add_func(mb_lower_deref_expr)
M:add_func(mb_lower_addr_expr)
M:add_func(mb_lower_len_expr)
M:add_func(mb_lower_view_expr)
M:add_func(mb_lower_if_expr)
M:add_func(mb_lower_hole_expr)
M:add_func(mb_lower_switch_expr)
M:add_func(mb_lower_control_expr)
M:add_func(mb_lower_expr)

return M
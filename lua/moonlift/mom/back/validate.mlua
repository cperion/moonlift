-- MOM backend validation — structural validator.
--
-- Walks Cmd tape, reads data fields (a-f) per variant, and maintains
-- declaration tables for symbol classes.  This is a function boundary because
-- driver/compile_source.mlua calls it directly and expects an issue count.

local T = require("moonlift.mom.tags.mom_tags")

return function(M)
local mb_push = func(tag: i32, a: i32, b: i32, c: i32,
                      it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32),
                      cnt: ptr(i32), cap: i32)
    let i: i32 = cnt[0]
    if i < cap then it[i] = tag; ia[i] = a; ib[i] = b; ic[i] = c end
    cnt[0] = i + 1
end

local mb_has = func(st: ptr(i32), key: ptr(i32), k: i32, cap: i32) -> i32
    block sc(i: i32 = 0)
        if i >= cap then return 0 end
        if st[i] == 1 and key[i] == k then return 1 end
        jump sc(i = i + 1)
    end
    return 0
end

local mb_add = func(st: ptr(i32), key: ptr(i32), k: i32, cap: i32) -> i32
    if mb_has(st, key, k, cap) ~= 0 then return 1 end
    block ins(i: i32 = 0)
        if i >= cap then return 1 end
        if st[i] == 0 then st[i] = 1; key[i] = k; return 0 end
        jump ins(i = i + 1)
    end
    return 1
end

-- Maps: 0=sig 1=data 2=func 3=extern 4=block 5=slot 6=value 7=access.
local mb_validate = func(tagp: ptr(i32), a_arr: ptr(i32), b_arr: ptr(i32), c_arr: ptr(i32),
                          d_arr: ptr(i32), e_arr: ptr(i32), f_arr: ptr(i32), n: i32,
                          it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32),
                          icnt: ptr(i32), icap: i32,
                          ms: ptr(i32), mk: ptr(i32), mcap: i32) -> i32
    let MS: i32 = 0; let MD: i32 = 1; let MF: i32 = 2; let ME: i32 = 3
    let MB: i32 = 4; let MSL: i32 = 5; let MV: i32 = 6; let MA: i32 = 7

    if n == 0 then
        mb_push(@{T.BackIssueEmptyProgram}, 0, 0, 0, it, ia, ib, ic, icnt, icap)
        mb_push(@{T.BackIssueMissingFinalize}, 0, 0, 0, it, ia, ib, ic, icnt, icap)
        return icnt[0]
    end

    block lp(i: i32 = 0, act: i32 = -1, fin: i32 = 0)
        if i >= n then
            if act >= 0 then mb_push(@{T.BackIssueUnfinishedFunction}, act, 0, 0, it, ia, ib, ic, icnt, icap) end
            if fin == 0 then mb_push(@{T.BackIssueMissingFinalize}, 0, 0, 0, it, ia, ib, ic, icnt, icap) end
            return icnt[0]
        end
        if fin ~= 0 then
            mb_push(@{T.BackIssueCommandAfterFinalize}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            jump lp(i = i + 1, act = act, fin = fin)
        end

        let tg: i32 = tagp[i]
        let a: i32 = a_arr[i]; let b: i32 = b_arr[i]; let c: i32 = c_arr[i]
        let d: i32 = d_arr[i]; let e: i32 = e_arr[i]; let f: i32 = f_arr[i]

        if tg == @{T.CmdFinalizeModule} then jump lp(i = i + 1, act = act, fin = 1) end

        if tg == @{T.CmdCreateSig} then
            if mb_add(ms + MS * mcap, mk + MS * mcap, a, mcap) ~= 0 then
                mb_push(@{T.BackIssueDuplicateSig}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdDeclareFunc} then
            if mb_has(ms + MS * mcap, mk + MS * mcap, c, mcap) == 0 then
                mb_push(@{T.BackIssueMissingSig}, i, c, 0, it, ia, ib, ic, icnt, icap)
            end
            if mb_add(ms + MF * mcap, mk + MF * mcap, b, mcap) ~= 0 then
                mb_push(@{T.BackIssueDuplicateFunc}, i, b, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdDeclareExtern} then
            if mb_has(ms + MS * mcap, mk + MS * mcap, c, mcap) == 0 then
                mb_push(@{T.BackIssueMissingSig}, i, c, 0, it, ia, ib, ic, icnt, icap)
            end
            if mb_add(ms + ME * mcap, mk + ME * mcap, a, mcap) ~= 0 then
                mb_push(@{T.BackIssueDuplicateExtern}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdDeclareData} then
            if mb_add(ms + MD * mcap, mk + MD * mcap, a, mcap) ~= 0 then
                mb_push(@{T.BackIssueDuplicateData}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdDataAddr} or tg == @{T.CmdDataInitZero} or tg == @{T.CmdDataInit} then
            let did: i32 = select(tg == @{T.CmdDataAddr}, b, a)
            if mb_has(ms + MD * mcap, mk + MD * mcap, did, mcap) == 0 then
                mb_push(@{T.BackIssueMissingData}, i, did, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdFuncAddr} then
            if mb_has(ms + MF * mcap, mk + MF * mcap, b, mcap) == 0 then
                mb_push(@{T.BackIssueMissingFunc}, i, b, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdExternAddr} then
            if mb_has(ms + ME * mcap, mk + ME * mcap, b, mcap) == 0 then
                mb_push(@{T.BackIssueMissingExtern}, i, b, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdBeginFunc} then
            if act >= 0 then mb_push(@{T.BackIssueNestedFunction}, i, act, a, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = a, fin = fin)
        end
        if tg == @{T.CmdFinishFunc} then
            if act < 0 then
                mb_push(@{T.BackIssueFinishWithoutBegin}, i, a, 0, it, ia, ib, ic, icnt, icap)
            elseif act ~= a then
                mb_push(@{T.BackIssueFinishWrongFunction}, i, act, a, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = -1, fin = fin)
        end

        if tg == @{T.CmdCreateBlock} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_add(ms + MB * mcap, mk + MB * mcap, a, mcap) ~= 0 then
                mb_push(@{T.BackIssueDuplicateBlock}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdSwitchToBlock} or tg == @{T.CmdSealBlock} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MB * mcap, mk + MB * mcap, a, mcap) == 0 then
                mb_push(@{T.BackIssueMissingBlock}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdJump} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MB * mcap, mk + MB * mcap, a, mcap) == 0 then
                mb_push(@{T.BackIssueMissingBlock}, i, a, 0, it, ia, ib, ic, icnt, icap)
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdBrIf} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            else
                if mb_has(ms + MB * mcap, mk + MB * mcap, b, mcap) == 0 then mb_push(@{T.BackIssueMissingBlock}, i, b, 0, it, ia, ib, ic, icnt, icap) end
                if mb_has(ms + MB * mcap, mk + MB * mcap, d, mcap) == 0 then mb_push(@{T.BackIssueMissingBlock}, i, d, 0, it, ia, ib, ic, icnt, icap) end
            end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdSwitchInt} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MB * mcap, mk + MB * mcap, d, mcap) == 0 then mb_push(@{T.BackIssueMissingBlock}, i, d, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdCreateStackSlot} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_add(ms + MSL * mcap, mk + MSL * mcap, a, mcap) ~= 0 then mb_push(@{T.BackIssueDuplicateStackSlot}, i, a, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdStackAddr} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MSL * mcap, mk + MSL * mcap, b, mcap) == 0 then mb_push(@{T.BackIssueMissingStackSlot}, i, b, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdConst} or tg == @{T.CmdIntrinsic} or tg == @{T.CmdUnary} or tg == @{T.CmdPtrOffset}
            or tg == @{T.CmdCompare} or tg == @{T.CmdIntBinary} or tg == @{T.CmdBitBinary} or tg == @{T.CmdBitNot}
            or tg == @{T.CmdShift} or tg == @{T.CmdRotate} or tg == @{T.CmdFloatBinary} or tg == @{T.CmdSelect}
            or tg == @{T.CmdFma} or tg == @{T.CmdVecSplat} or tg == @{T.CmdVecBinary} or tg == @{T.CmdVecCompare}
            or tg == @{T.CmdVecSelect} or tg == @{T.CmdVecInsertLane} or tg == @{T.CmdVecExtractLane}
            or tg == @{T.CmdAlias} or tg == @{T.CmdLoadInfo} or tg == @{T.CmdAtomicLoad} or tg == @{T.CmdAtomicRmw}
            or tg == @{T.CmdAtomicCas}
        then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_add(ms + MV * mcap, mk + MV * mcap, a, mcap) ~= 0 then mb_push(@{T.BackIssueDuplicateValue}, i, a, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdReturnValue} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MV * mcap, mk + MV * mcap, a, mcap) == 0 then mb_push(@{T.BackIssueMissingValue}, i, a, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdBindEntryParams} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdCall} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_has(ms + MS * mcap, mk + MS * mcap, c, mcap) == 0 then mb_push(@{T.BackIssueMissingSig}, i, c, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdStoreInfo} or tg == @{T.CmdAtomicStore} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        if tg == @{T.CmdTargetModel} then jump lp(i = i + 1, act = act, fin = fin) end
        if tg == @{T.CmdReturnVoid} or tg == @{T.CmdTrap} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdAppendBlockParam} then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap)
            elseif mb_add(ms + MV * mcap, mk + MV * mcap, b, mcap) ~= 0 then mb_push(@{T.BackIssueDuplicateValue}, i, b, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end
        if tg == @{T.CmdAliasFact} or tg == @{T.CmdMemcpy} or tg == @{T.CmdMemset}
            or tg == @{T.CmdAtomicFence}
        then
            if act < 0 then mb_push(@{T.BackIssueCommandOutsideFunction}, i, 0, 0, it, ia, ib, ic, icnt, icap) end
            jump lp(i = i + 1, act = act, fin = fin)
        end

        jump lp(i = i + 1, act = act, fin = fin)
    end
end

local mb_validate_region = region(ct: ptr(i32), ca: ptr(i32), cb: ptr(i32), cc: ptr(i32),
                                  cd: ptr(i32), ce: ptr(i32), cf: ptr(i32), n: i32,
                                  it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32),
                                  icnt: ptr(i32), icap: i32,
                                  ms: ptr(i32), mk: ptr(i32), mcap: i32;
                                  done: cont(result: MomValidateResult))
entry start()
    let issue_count: i32 = mb_validate(ct, ca, cb, cc, cd, ce, cf, n,
                                       it, ia, ib, ic, icnt, icap,
                                       ms, mk, mcap)
    jump done(result = MomValidateResult{issue_count = issue_count})
end
end

M.mb_push = mb_push
M.mb_has = mb_has
M.mb_add = mb_add
M.mb_validate = mb_validate
M.mb_validate_region = mb_validate_region
return M
end

-- MOM open validation — port of open_validate.lua to Moonlift region pattern.
--
-- 3 phases:
-- 1. slot_issue: Maps 16 Slot types deterministically to Issue types
-- 2. fact_issue: Maps 21 MetaFact types to Issue types (with delegation to slot_issue)
-- 3. validate_open_set: Deduplicates issues from facts array
--
-- Uses region/continuation pattern for proper data flow and state threading.

local T = require("moonlift.mom.tags.mom_tags")

return function(M)

-- PART 1: Helper functions for issue type mapping

-- Maps a slot tag to its corresponding issue tag.
-- Input: slot_tag (as loaded from union discriminator)
-- Output: corresponding issue type tag, or 0 if none
local mb_issue_tag_for_slot = func(tag: i32) -> i32
    -- SlotType (0) -> IssueUnfilledTypeSlot
    if tag == @{T.SlotType} then return @{T.IssueUnfilledTypeSlot} end
    -- SlotValue (1) -> IssueOpenSlot
    if tag == @{T.SlotValue} then return @{T.IssueOpenSlot} end
    -- SlotExpr (2) -> IssueUnfilledExprSlot
    if tag == @{T.SlotExpr} then return @{T.IssueUnfilledExprSlot} end
    -- SlotPlace (3) -> IssueUnfilledPlaceSlot
    if tag == @{T.SlotPlace} then return @{T.IssueUnfilledPlaceSlot} end
    -- SlotDomain (4) -> IssueUnfilledDomainSlot
    if tag == @{T.SlotDomain} then return @{T.IssueUnfilledDomainSlot} end
    -- SlotRegion (5) -> IssueUnfilledRegionSlot
    if tag == @{T.SlotRegion} then return @{T.IssueUnfilledRegionSlot} end
    -- SlotCont (6) -> IssueUnfilledContSlot
    if tag == @{T.SlotCont} then return @{T.IssueUnfilledContSlot} end
    -- SlotFunc (7) -> IssueUnfilledFuncSlot
    if tag == @{T.SlotFunc} then return @{T.IssueUnfilledFuncSlot} end
    -- SlotConst (8) -> IssueUnfilledConstSlot
    if tag == @{T.SlotConst} then return @{T.IssueUnfilledConstSlot} end
    -- SlotStatic (9) -> IssueUnfilledStaticSlot
    if tag == @{T.SlotStatic} then return @{T.IssueUnfilledStaticSlot} end
    -- SlotTypeDecl (10) -> IssueUnfilledTypeDeclSlot
    if tag == @{T.SlotTypeDecl} then return @{T.IssueUnfilledTypeDeclSlot} end
    -- SlotItems (11) -> IssueUnfilledItemsSlot
    if tag == @{T.SlotItems} then return @{T.IssueUnfilledItemsSlot} end
    -- SlotModule (12) -> IssueUnfilledModuleSlot
    if tag == @{T.SlotModule} then return @{T.IssueUnfilledModuleSlot} end
    -- SlotRegionFrag (13) -> IssueUnfilledRegionFragSlot
    if tag == @{T.SlotRegionFrag} then return @{T.IssueUnfilledRegionFragSlot} end
    -- SlotExprFrag (14) -> IssueUnfilledExprFragSlot
    if tag == @{T.SlotExprFrag} then return @{T.IssueUnfilledExprFragSlot} end
    -- SlotName (15) -> IssueUnfilledNameSlot
    if tag == @{T.SlotName} then return @{T.IssueUnfilledNameSlot} end
    return 0
end

-- Maps a MetaFact tag to its corresponding issue tag.
-- Input: fact_tag (as loaded from union discriminator)
-- Output: corresponding issue type tag, or 0 if no issue generated
local mb_issue_tag_for_fact = func(tag: i32) -> i32
    -- MetaFactValueImportUse (2) -> IssueGenericValueImport
    if tag == @{T.MetaFactValueImportUse} then return @{T.IssueGenericValueImport} end
    -- MetaFactExprFragUse (11) -> IssueUnexpandedExprFragUse
    if tag == @{T.MetaFactExprFragUse} then return @{T.IssueUnexpandedExprFragUse} end
    -- MetaFactRegionFragUse (12) -> IssueUnexpandedRegionFragUse
    if tag == @{T.MetaFactRegionFragUse} then return @{T.IssueUnexpandedRegionFragUse} end
    -- MetaFactRegionFragSlotUse (13) -> IssueUnfilledRegionFragSlot
    if tag == @{T.MetaFactRegionFragSlotUse} then return @{T.IssueUnfilledRegionFragSlot} end
    -- MetaFactExprFragSlotUse (14) -> IssueUnfilledExprFragSlot
    if tag == @{T.MetaFactExprFragSlotUse} then return @{T.IssueUnfilledExprFragSlot} end
    -- MetaFactModuleUse (15) -> IssueUnexpandedModuleUse
    if tag == @{T.MetaFactModuleUse} then return @{T.IssueUnexpandedModuleUse} end
    -- MetaFactOpenModuleName (17) -> IssueOpenModuleName
    if tag == @{T.MetaFactOpenModuleName} then return @{T.IssueOpenModuleName} end
    -- All others: no issue
    return 0
end

-- PART 2: Regions

-- slot_issue region: Dispatch on slot tag and emit corresponding issue.
-- Signature: region(slot_id: i32; done: cont(...))
-- Loads slot at position slot_id, dispatches on tag, emits issue or empty.
local mb_slot_issue = region(slot_id: i32;
                              done: cont(it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32), cnt: i32),
                              slots_ptr: ptr(i32), slots_a: ptr(i32), slots_b: ptr(i32), slots_c: ptr(i32))
entry start()
    -- Load slot tag from slots array (first field is tag)
    let tag: i32 = slots_ptr[slot_id]

    -- Get the corresponding issue tag
    let issue_tag: i32 = mb_issue_tag_for_slot(tag)

    -- If no issue, return empty
    if issue_tag == 0 then
        jump done(it = it, ia = ia, ib = ib, ic = ic, cnt = 0)
    end

    -- Otherwise emit single issue with slot data from union payload
    it[0] = issue_tag
    ia[0] = slots_a[slot_id]
    ib[0] = slots_b[slot_id]
    ic[0] = slots_c[slot_id]
    jump done(it = it, ia = ia, ib = ib, ic = ic, cnt = 1)
end
end

-- fact_issue region: Dispatch on fact tag and emit corresponding issue or delegate.
-- Signature: region(fact_id: i32; done: cont(...))
-- Loads fact at position fact_id, dispatches on tag, emits issue or delegates to slot_issue.
local mb_fact_issue = region(fact_id: i32;
                              done: cont(it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32), cnt: i32),
                              facts_ptr: ptr(i32), facts_a: ptr(i32), facts_b: ptr(i32), facts_c: ptr(i32),
                              slots_ptr: ptr(i32), slots_a: ptr(i32), slots_b: ptr(i32), slots_c: ptr(i32),
                              it_out: ptr(i32), ia_out: ptr(i32), ib_out: ptr(i32), ic_out: ptr(i32))
entry start()
    -- Load fact tag
    let tag: i32 = facts_ptr[fact_id]

    -- MetaFactSlot (0) -> delegate to slot_issue with slot_id in facts_a[fact_id]
    if tag == @{T.MetaFactSlot} then
        let slot_id: i32 = facts_a[fact_id]
        jump slot_delegation(slot_id = slot_id)
    end

    -- MetaFactValueImportUse (2) -> IssueGenericValueImport with import in facts_a
    if tag == @{T.MetaFactValueImportUse} then
        it_out[0] = @{T.IssueGenericValueImport}
        ia_out[0] = facts_a[fact_id]
        ib_out[0] = 0
        ic_out[0] = 0
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = 1)
    end

    -- MetaFactExprFragUse (11) -> IssueUnexpandedExprFragUse with use_id in facts_a
    if tag == @{T.MetaFactExprFragUse} then
        it_out[0] = @{T.IssueUnexpandedExprFragUse}
        ia_out[0] = facts_a[fact_id]
        ib_out[0] = 0
        ic_out[0] = 0
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = 1)
    end

    -- MetaFactRegionFragUse (12) -> IssueUnexpandedRegionFragUse with use_id in facts_a
    if tag == @{T.MetaFactRegionFragUse} then
        it_out[0] = @{T.IssueUnexpandedRegionFragUse}
        ia_out[0] = facts_a[fact_id]
        ib_out[0] = 0
        ic_out[0] = 0
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = 1)
    end

    -- MetaFactRegionFragSlotUse (13) -> IssueUnfilledRegionFragSlot with slot in facts_a
    if tag == @{T.MetaFactRegionFragSlotUse} then
        let slot_id: i32 = facts_a[fact_id]
        jump slot_delegation_for_frag(slot_id = slot_id)
    end

    -- MetaFactExprFragSlotUse (14) -> IssueUnfilledExprFragSlot with slot in facts_a
    if tag == @{T.MetaFactExprFragSlotUse} then
        let slot_id: i32 = facts_a[fact_id]
        jump slot_delegation_for_frag(slot_id = slot_id)
    end

    -- MetaFactModuleUse (15) -> IssueUnexpandedModuleUse with use_id in facts_a
    if tag == @{T.MetaFactModuleUse} then
        it_out[0] = @{T.IssueUnexpandedModuleUse}
        ia_out[0] = facts_a[fact_id]
        ib_out[0] = 0
        ic_out[0] = 0
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = 1)
    end

    -- MetaFactOpenModuleName (17) -> IssueOpenModuleName (no data)
    if tag == @{T.MetaFactOpenModuleName} then
        it_out[0] = @{T.IssueOpenModuleName}
        ia_out[0] = 0
        ib_out[0] = 0
        ic_out[0] = 0
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = 1)
    end

    -- All other facts: no issue
    jump done(it = it, ia = ia, ib = ib, ic = ic, cnt = 0)
end

block slot_delegation(slot_id: i32)
    -- Delegate to slot_issue with empty issue buffer (will write to it_out)
    let local_it: i32 = 0
    let local_ia: i32 = 0
    let local_ib: i32 = 0
    let local_ic: i32 = 0
    jump mb_slot_issue(slot_id = slot_id,
                       done = after_slot_issue(it_out = it_out, ia_out = ia_out, ib_out = ib_out, ic_out = ic_out))
end

block slot_delegation_for_frag(slot_id: i32)
    -- Same as slot_delegation
    jump mb_slot_issue(slot_id = slot_id,
                       done = after_slot_issue(it_out = it_out, ia_out = ia_out, ib_out = ib_out, ic_out = ic_out))
end

block after_slot_issue(it_out: ptr(i32), ia_out: ptr(i32), ib_out: ptr(i32), ic_out: ptr(i32),
                       it_result: ptr(i32), ia_result: ptr(i32), ib_result: ptr(i32), ic_result: ptr(i32), cnt_result: i32)
    -- Return result from slot_issue through done continuation
    jump done(it = it_result, ia = ia_result, ib = ib_result, ic = ic_result, cnt = cnt_result)
end

end

-- validate_open_set region: Iterate facts array, deduplicate issues.
-- Signature: region(fact_set: view(i32); done: cont(..., issues: view(i32)))
-- Iterates through all facts, calls fact_issue on each, deduplicates by checking seen set.
local mb_validate_open_set = region(facts_ptr: ptr(i32), facts_len: i32;
                                     done: cont(it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32), cnt: i32),
                                     facts_a: ptr(i32), facts_b: ptr(i32), facts_c: ptr(i32),
                                     slots_ptr: ptr(i32), slots_a: ptr(i32), slots_b: ptr(i32), slots_c: ptr(i32),
                                     it_tmp: ptr(i32), ia_tmp: ptr(i32), ib_tmp: ptr(i32), ic_tmp: ptr(i32),
                                     it_out: ptr(i32), ia_out: ptr(i32), ib_out: ptr(i32), ic_out: ptr(i32),
                                     seen_keys: ptr(i32), seen_vals: ptr(i32), seen_cap: i32)
entry start()
    -- Initialize issue collection
    let issue_cnt: i32 = 0

    -- Iterate through facts
    jump collect_issues(i = 0, issue_cnt = issue_cnt)
end

block collect_issues(i: i32, issue_cnt: i32)
    if i >= facts_len then
        -- Done collecting, return deduplicated issues
        jump done(it = it_out, ia = ia_out, ib = ib_out, ic = ic_out, cnt = issue_cnt)
    end

    -- Call fact_issue for facts[i]
    -- This will write to it_tmp, ia_tmp, ib_tmp, ic_tmp arrays
    jump mb_fact_issue(fact_id = i,
                       done = after_fact_issue(i = i, issue_cnt = issue_cnt))
end

block after_fact_issue(i: i32, issue_cnt: i32,
                       it_result: ptr(i32), ia_result: ptr(i32), ib_result: ptr(i32), ic_result: ptr(i32), cnt_result: i32)
    -- Check if issue was generated (cnt_result > 0)
    if cnt_result == 0 then
        jump collect_issues(i = i + 1, issue_cnt = issue_cnt)
    end

    -- Load the issue
    let issue_tag: i32 = it_result[0]
    let issue_a: i32 = ia_result[0]
    let issue_b: i32 = ib_result[0]
    let issue_c: i32 = ic_result[0]

    -- Create a hash key (simple: tag xor a xor b xor c)
    let key: i32 = issue_tag
    key = key ^ issue_a
    key = key ^ issue_b
    key = key ^ issue_c

    -- Check if we've seen this issue before
    let is_seen: i32 = 0
    block check_seen(j: i32 = 0)
        if j >= issue_cnt then jump check_seen_done(is_seen = 0) end
        if seen_keys[j] == key then jump check_seen_done(is_seen = 1) end
        jump check_seen(j = j + 1)
    end

    block check_seen_done(is_seen: i32)
        if is_seen ~= 0 then
            -- Skip duplicate
            jump collect_issues(i = i + 1, issue_cnt = issue_cnt)
        end

        -- Add to output
        it_out[issue_cnt] = issue_tag
        ia_out[issue_cnt] = issue_a
        ib_out[issue_cnt] = issue_b
        ic_out[issue_cnt] = issue_c
        seen_keys[issue_cnt] = key

        jump collect_issues(i = i + 1, issue_cnt = issue_cnt + 1)
    end
end

end

-- PART 3: Public API

M.mb_issue_tag_for_slot = mb_issue_tag_for_slot
M.mb_issue_tag_for_fact = mb_issue_tag_for_fact
M.mb_slot_issue = mb_slot_issue
M.mb_fact_issue = mb_fact_issue
M.mb_validate_open_set = mb_validate_open_set

return M
end

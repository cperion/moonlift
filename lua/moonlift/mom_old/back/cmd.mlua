-- ── Memory commands ────────────────────────────────────────────────

-- CmdLoadInfo: [dst, shape_tag, scalar, lanes, base_tag, base_id, byte_offset,
--   access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k] = 15 slots
local mb_cmd_load_info = func(out: ptr(@{CmdEntry}), dst: i32, shape_tag: i32, scalar: i32, lanes: i32,
    base_tag: i32, base_id: i32, byte_offset: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdLoadInfo}
    out.w0 = dst; out.w1 = shape_tag; out.w2 = scalar; out.w3 = lanes; out.w4 = base_tag
    out.w5 = base_id; out.w6 = byte_offset; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k; out.w14 = mode_k
end

-- CmdStoreInfo: [shape_tag, scalar, lanes, base_tag, base_id, byte_offset, value,
--   access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k] = 14 slots
local mb_cmd_store_info = func(out: ptr(@{CmdEntry}), shape_tag: i32, scalar: i32, lanes: i32,
    base_tag: i32, base_id: i32, byte_offset: i32, value: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdStoreInfo}
    out.w0 = shape_tag; out.w1 = scalar; out.w2 = lanes; out.w3 = base_tag; out.w4 = base_id
    out.w5 = byte_offset; out.w6 = value; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k
    out.w14 = mode_k
end

-- CmdAliasFact: [kind, a, b, c] = 3 slots
local mb_cmd_alias_fact = func(out: ptr(@{CmdEntry}), kind: i32, a: i32, b: i32, c: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAliasFact}
    out.w0 = kind; out.w1 = a; out.w2 = b; out.w3 = c
end

-- CmdMemcpy: [dst, src, len] = 3 slots
local mb_cmd_memcpy = func(out: ptr(@{CmdEntry}), dst: i32, src: i32, len: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdMemcpy}
    out.w0 = dst; out.w1 = src; out.w2 = len
end

-- CmdMemset: [dst, byte, len] = 3 slots
local mb_cmd_memset = func(out: ptr(@{CmdEntry}), dst: i32, byte: i32, len: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdMemset}
    out.w0 = dst; out.w1 = byte; out.w2 = len
end

-- ── Select and FMA ────────────────────────────────────────────────

-- CmdSelect: [dst, shape_tag, scalar, lanes, cond, then_val, else_val] = 7 slots
local mb_cmd_select = func(out: ptr(@{CmdEntry}), dst: i32, shape_tag: i32, scalar: i32, lanes: i32, cond: i32, then_val: i32, else_val: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdSelect}
    out.w0 = dst; out.w1 = shape_tag; out.w2 = scalar; out.w3 = lanes; out.w4 = cond; out.w5 = then_val; out.w6 = else_val
end

-- CmdFma: [dst, scalar, semantics, a, b, c] = 6 slots
local mb_cmd_fma = func(out: ptr(@{CmdEntry}), dst: i32, scalar: i32, semantics: i32, a: i32, b: i32, c: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdFma}
    out.w0 = dst; out.w1 = scalar; out.w2 = semantics; out.w3 = a; out.w4 = b; out.w5 = c
end

-- ── Control flow commands ──────────────────────────────────────────

-- CmdCall: [result_tag, result_dst, result_scalar, target_tag, target_id, sig, args_aux, count] = 8 slots
local mb_cmd_call = func(out: ptr(@{CmdEntry}), result_tag: i32, result_dst: i32, result_scalar: i32,
    target_tag: i32, target_id: i32, sig: i32, args_aux: i32, count: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCall}
    out.w0 = result_tag; out.w1 = result_dst; out.w2 = result_scalar; out.w3 = target_tag
    out.w4 = target_id; out.w5 = sig; out.w6 = args_aux; out.w7 = count
end

-- CmdJump: [dest, args_aux, count] = 3 slots
local mb_cmd_jump = func(out: ptr(@{CmdEntry}), dest: i32, args_aux: i32, count: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdJump}
    out.w0 = dest; out.w1 = args_aux; out.w2 = count
end

-- CmdBrIf: [cond, then_block, then_aux, then_count, else_block, else_aux, else_count] = 7 slots
local mb_cmd_br_if = func(out: ptr(@{CmdEntry}), cond: i32, then_block: i32, then_aux: i32, then_count: i32, else_block: i32, else_aux: i32, else_count: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdBrIf}
    out.w0 = cond; out.w1 = then_block; out.w2 = then_aux; out.w3 = then_count
    out.w4 = else_block; out.w5 = else_aux; out.w6 = else_count
end

-- CmdSwitchInt: [value, scalar, cases_aux, n_cases, default] = 5 slots
local mb_cmd_switch_int = func(out: ptr(@{CmdEntry}), value: i32, scalar: i32, cases_aux: i32, n_cases: i32, default_blk: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdSwitchInt}
    out.w0 = value; out.w1 = scalar; out.w2 = cases_aux; out.w3 = n_cases; out.w4 = default_blk
end

-- CmdReturnVoid: [] = 0 slots
local mb_cmd_return_void = func(out: ptr(@{CmdEntry}))
    mb_cmd_clear(out)
    out.tag = @{T.CmdReturnVoid}
end

-- CmdReturnValue: [value] = 1 slot
local mb_cmd_return_value = func(out: ptr(@{CmdEntry}), value: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdReturnValue}
    out.w0 = value
end

-- CmdFinishFunc: [func] = 1 slot
local mb_cmd_finish_func = func(out: ptr(@{CmdEntry}), func_id: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdFinishFunc}
    out.w0 = func_id

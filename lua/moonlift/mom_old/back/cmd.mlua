-- CmdRotate: [dst, op, scalar, lhs, rhs] = 5 slots
local mb_cmd_rotate = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, scalar: i32, lhs: i32, rhs: i32)
    mb_cmd_clear(out)

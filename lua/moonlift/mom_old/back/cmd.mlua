-- ── Atomic commands ─────────────────────────────────────────────────

-- CmdAtomicLoad: [dst, scalar, base_tag, base_id, byte_offset, access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k, ordering, _pad] = 15 slots
local mb_cmd_atomic_load = func(out: ptr(@{CmdEntry}), dst: i32, scalar: i32, base_tag: i32, base_id: i32,
    byte_offset: i32, access: i32, align_k: i32, align_b: i32, deref_k: i32, deref_b: i32,
    trap_k: i32, motion_k: i32, mode_k: i32, ordering: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAtomicLoad}
    out.w0 = dst; out.w1 = scalar; out.w2 = base_tag; out.w3 = base_id; out.w4 = byte_offset
    out.w5 = access; out.w6 = align_k; out.w7 = align_b; out.w8 = deref_k; out.w9 = deref_b
    out.w10 = trap_k; out.w11 = motion_k; out.w12 = mode_k; out.w13 = ordering
end

-- CmdAtomicStore: [scalar, base_tag, base_id, byte_offset, value, access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k, ordering] = 14 slots
local mb_cmd_atomic_store = func(out: ptr(@{CmdEntry}), scalar: i32, base_tag: i32, base_id: i32,
    byte_offset: i32, value: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32, ordering: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAtomicStore}
    out.w0 = scalar; out.w1 = base_tag; out.w2 = base_id; out.w3 = byte_offset; out.w4 = value
    out.w5 = access; out.w6 = align_k; out.w7 = align_b; out.w8 = deref_k; out.w9 = deref_b
    out.w10 = trap_k; out.w11 = motion_k; out.w12 = mode_k; out.w13 = ordering
end

-- CmdAtomicRmw: [dst, op, scalar, base_tag, base_id, byte_offset, value, access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k, ordering] = 16 slots
local mb_cmd_atomic_rmw = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, scalar: i32, base_tag: i32, base_id: i32,
    byte_offset: i32, value: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32, ordering: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAtomicRmw}
    out.w0 = dst; out.w1 = op; out.w2 = scalar; out.w3 = base_tag; out.w4 = base_id
    out.w5 = byte_offset; out.w6 = value; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k
    out.w14 = mode_k; out.w15 = ordering
end

-- CmdAtomicCas: [dst, scalar, base_tag, base_id, byte_offset, expected, replacement, access, align_k, align_b, deref_k, deref_b, trap_k, motion_k, mode_k, ordering, _pad] = 17 slots
local mb_cmd_atomic_cas = func(out: ptr(@{CmdEntry}), dst: i32, scalar: i32, base_tag: i32, base_id: i32,
    byte_offset: i32, expected: i32, replacement: i32, access: i32, align_k: i32, align_b: i32,
    deref_k: i32, deref_b: i32, trap_k: i32, motion_k: i32, mode_k: i32, ordering: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAtomicCas}
    out.w0 = dst; out.w1 = scalar; out.w2 = base_tag; out.w3 = base_id; out.w4 = byte_offset
    out.w5 = expected; out.w6 = replacement; out.w7 = access; out.w8 = align_k; out.w9 = align_b
    out.w10 = deref_k; out.w11 = deref_b; out.w12 = trap_k; out.w13 = motion_k
    out.w14 = mode_k; out.w15 = ordering
end

-- CmdAtomicFence: [ordering] = 1 slot
local mb_cmd_atomic_fence = func(out: ptr(@{CmdEntry}), ordering: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAtomicFence}
    out.w0 = ordering
end


local mb_cmd_unary = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, shape_tag: i32, scalar: i32, lanes: i32, value: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdUnary}
    out.w0 = dst; out.w1 = op; out.w2 = shape_tag; out.w3 = scalar; out.w4 = lanes; out.w5 = value

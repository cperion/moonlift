-- MOM backend command-producing functions.
--
-- Phase 3: pure functions that construct Cmd variant entries. Each takes raw
-- op/scalar/value ID parameters and fills a CmdEntry output struct.
--
-- CmdEntry layout matches MLBT v3 wire format (see BACK_WIRE_FORMAT.md):
--   18 i32 words per entry: tag + w0..w16
--   Only the prefix defined by slot_count(tag) is serialized; unused words are 0.
--
-- Field mapping per command variant uses slot names from BACK_WIRE_FORMAT.md §7.

local T = require("moonlift.mom.tags.mom_tags")

return function(M)
local i32p = moon.ptr(moon.i32)

local MomBackLowerCtx = M.MomBackLowerCtx
local MomCmdBuffer = M.MomCmdBuffer
local MomSwitchCaseTable = M.MomSwitchCaseTable
local mr_cmd_buffer_push = M.mr_cmd_buffer_push

M.CmdEntry = struct CmdEntry
    tag: i32
    w0: i32
    w1: i32
    w2: i32
    w3: i32
    w4: i32
    w5: i32
    w6: i32
    w7: i32
    w8: i32
    w9: i32
    w10: i32
    w11: i32
    w12: i32
    w13: i32
    w14: i32
    w15: i32
    w16: i32
end
local CmdEntry = M.CmdEntry

-- Zero all fields and set tag to CMD_TRAP.
local mb_cmd_clear = func(out: ptr(@{CmdEntry}))
    out.tag = 0
    out.w0 = 0; out.w1 = 0; out.w2 = 0; out.w3 = 0
    out.w4 = 0; out.w5 = 0; out.w6 = 0; out.w7 = 0
    out.w8 = 0; out.w9 = 0; out.w10 = 0; out.w11 = 0
    out.w12 = 0; out.w13 = 0; out.w14 = 0; out.w15 = 0
    out.w16 = 0
end

-- Zero all fields and set tag to CMD_TRAP.
local mb_cmd_trap = func(out: ptr(@{CmdEntry}))
    mb_cmd_clear(out)
    out.tag = @{T.CmdTrap}
end

-- Scalar predicates live in back/ops.mlua and are shared by backend modules.

-- ── Structural commands ────────────────────────────────────────────

-- CmdCreateSig: [sig, params_aux, n_params, results_aux, n_results] = 5 slots
local mb_cmd_create_sig = func(out: ptr(@{CmdEntry}), sig: i32, params_aux: i32, n_params: i32, results_aux: i32, n_results: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCreateSig}
    out.w0 = sig; out.w1 = params_aux; out.w2 = n_params; out.w3 = results_aux; out.w4 = n_results
end

-- CmdDeclareData: [data, size, align] = 3 slots
local mb_cmd_declare_data = func(out: ptr(@{CmdEntry}), data: i32, size: i32, align: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDeclareData}
    out.w0 = data; out.w1 = size; out.w2 = align
end

-- CmdDataInitZero: [data, offset, size] = 3 slots
local mb_cmd_data_init_zero = func(out: ptr(@{CmdEntry}), data: i32, offset: i32, size: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDataInitZero}
    out.w0 = data; out.w1 = offset; out.w2 = size
end

-- CmdDataInit: [data, offset, scalar, lit_tag, lit_lo, lit_hi] = 6 slots
local mb_cmd_data_init = func(out: ptr(@{CmdEntry}), data: i32, offset: i32, scalar: i32, lit_tag: i32, lit_lo: i32, lit_hi: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDataInit}
    out.w0 = data; out.w1 = offset; out.w2 = scalar; out.w3 = lit_tag; out.w4 = lit_lo; out.w5 = lit_hi
end

-- CmdDataAddr: [dst, data] = 2 slots
local mb_cmd_data_addr = func(out: ptr(@{CmdEntry}), dst: i32, data: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDataAddr}
    out.w0 = dst; out.w1 = data
end

-- CmdFuncAddr: [dst, func] = 2 slots
local mb_cmd_func_addr = func(out: ptr(@{CmdEntry}), dst: i32, func_id: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdFuncAddr}
    out.w0 = dst; out.w1 = func_id
end

-- CmdExternAddr: [dst, extern_id] = 2 slots
local mb_cmd_extern_addr = func(out: ptr(@{CmdEntry}), dst: i32, extern_id: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdExternAddr}
    out.w0 = dst; out.w1 = extern_id
end

-- CmdDeclareFunc: [visibility, func, sig] = 3 slots
local mb_cmd_declare_func = func(out: ptr(@{CmdEntry}), visibility: i32, func_id: i32, sig: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDeclareFunc}
    out.w0 = visibility; out.w1 = func_id; out.w2 = sig
end

-- CmdDeclareExtern: [extern_id, symbol, sig] = 3 slots
local mb_cmd_declare_extern = func(out: ptr(@{CmdEntry}), extern_id: i32, symbol: i32, sig: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdDeclareExtern}
    out.w0 = extern_id; out.w1 = symbol; out.w2 = sig
end

-- CmdBeginFunc: [func] = 1 slot
local mb_cmd_begin_func = func(out: ptr(@{CmdEntry}), func_id: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdBeginFunc}
    out.w0 = func_id
end

-- CmdCreateBlock: [block] = 1 slot
local mb_cmd_create_block = func(out: ptr(@{CmdEntry}), blk: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCreateBlock}
    out.w0 = blk
end

-- CmdSwitchToBlock: [block] = 1 slot
local mb_cmd_switch_to_block = func(out: ptr(@{CmdEntry}), blk: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdSwitchToBlock}
    out.w0 = blk
end

-- CmdSealBlock: [block] = 1 slot
local mb_cmd_seal_block = func(out: ptr(@{CmdEntry}), blk: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdSealBlock}
    out.w0 = blk
end

-- CmdBindEntryParams: [block, vals_aux, count] = 3 slots
local mb_cmd_bind_entry_params = func(out: ptr(@{CmdEntry}), blk: i32, vals_aux: i32, n_vals: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdBindEntryParams}
    out.w0 = blk; out.w1 = vals_aux; out.w2 = n_vals
end

-- CmdAppendBlockParam: [block, value, shape_tag, scalar, lanes] = 5 slots
local mb_cmd_append_block_param = func(out: ptr(@{CmdEntry}), blk: i32, value: i32, shape_tag: i32, scalar: i32, lanes: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAppendBlockParam}
    out.w0 = blk; out.w1 = value; out.w2 = shape_tag; out.w3 = scalar; out.w4 = lanes
end

-- CmdCreateStackSlot: [slot, size, align] = 3 slots
local mb_cmd_create_stack_slot = func(out: ptr(@{CmdEntry}), slot: i32, size: i32, align: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCreateStackSlot}
    out.w0 = slot; out.w1 = size; out.w2 = align
end

-- ── Value commands ─────────────────────────────────────────────────

-- CmdAlias: [dst, src] = 2 slots
local mb_cmd_alias = func(out: ptr(@{CmdEntry}), dst: i32, src: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdAlias}
    out.w0 = dst; out.w1 = src
end

-- CmdStackAddr: [dst, slot] = 2 slots
local mb_cmd_stack_addr = func(out: ptr(@{CmdEntry}), dst: i32, slot: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdStackAddr}
    out.w0 = dst; out.w1 = slot
end

-- CmdConst: [dst, scalar, lit_tag, lit_lo, lit_hi] = 5 slots
local mb_cmd_const = func(out: ptr(@{CmdEntry}), dst: i32, scalar: i32, lit_tag: i32, lit_lo: i32, lit_hi: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdConst}
    out.w0 = dst; out.w1 = scalar; out.w2 = lit_tag; out.w3 = lit_lo; out.w4 = lit_hi
end

-- CmdIntrinsic: [dst, op, shape_tag, scalar, lanes, args_aux, count] = 7 slots
local mb_cmd_intrinsic = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, shape_tag: i32, scalar: i32, lanes: i32, args_aux: i32, count: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdIntrinsic}
    out.w0 = dst; out.w1 = op; out.w2 = shape_tag; out.w3 = scalar; out.w4 = lanes; out.w5 = args_aux; out.w6 = count
end

-- CmdPtrOffset: [dst, base_tag, base_id, index, elem_size, offset_lo, offset_hi] = 7 slots
local mb_cmd_ptr_offset = func(out: ptr(@{CmdEntry}), dst: i32, base_tag: i32, base_id: i32, index: i32, elem_size: i32, offset_lo: i32, offset_hi: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdPtrOffset}
    out.w0 = dst; out.w1 = base_tag; out.w2 = base_id; out.w3 = index; out.w4 = elem_size; out.w5 = offset_lo; out.w6 = offset_hi
end

-- ── Arithmetic commands ────────────────────────────────────────────

-- CmdIntBinary: [dst, op, scalar, overflow, exact, lhs, rhs] = 7 slots
local mb_cmd_int_binary = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, scalar: i32, overflow: i32, exact: i32, lhs: i32, rhs: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdIntBinary}
    out.w0 = dst; out.w1 = op; out.w2 = scalar; out.w3 = overflow; out.w4 = exact; out.w5 = lhs; out.w6 = rhs
end


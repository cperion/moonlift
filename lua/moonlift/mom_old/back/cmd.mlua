local mb_cmd_compare = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, shape_tag: i32, scalar: i32, lanes: i32, lhs: i32, rhs: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCompare}
    out.w0 = dst; out.w1 = op; out.w2 = shape_tag; out.w3 = scalar; out.w4 = lanes; out.w5 = lhs; out.w6 = rhs
end

-- CmdCast: [dst, op, scalar, value] = 4 slots
local mb_cmd_cast = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, scalar: i32, value: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdCast}
    out.w0 = dst; out.w1 = op; out.w2 = scalar; out.w3 = value

-- CmdFinalizeModule: [] = 0 slots
local mb_cmd_finalize_module = func(out: ptr(@{CmdEntry}))
    mb_cmd_clear(out)
    out.tag = @{T.CmdFinalizeModule}
end

-- CmdTargetModel: [] = 0 slots (reserved)
local mb_cmd_target_model = func(out: ptr(@{CmdEntry}))
    mb_cmd_clear(out)

local mb_cmd_shift = func(out: ptr(@{CmdEntry}), dst: i32, op: i32, scalar: i32, lhs: i32, rhs: i32)
    mb_cmd_clear(out)
    out.tag = @{T.CmdShift}
    out.w0 = dst; out.w1 = op; out.w2 = scalar; out.w3 = lhs; out.w4 = rhs

-- pvm_ll_validate.mlua — Native PVM-LL back_validate.
--
-- Works on a packed i32 array ctx: ptr(i32) produced by back_validate_pack.lua.
--
-- ctx[0] = N  cmd count
-- ctx[1] = I  intern count
-- ctx[2..]   intern data (lengths + chars, 1 i32 per char)
-- after intern: length-prefixed command entries
-- after commands: issue buffer (native code writes issues here)
-- after issue buffer: bit-sets for tracking facts
--
-- Export: validate_commands(ctx: ptr(i32)) -> i32   (0 = clean, 1 = issues)
--
-- The native code calls `append_issue_code(ctx, code)` to emit issues.
-- Issue codes are: [issue_kind, cmd_index, ...payload] packed as i32 sequence
-- starting at the issue buffer start.

local pvmll = require("moonlift.pvm_ll")

-- Command tags and issue codes (numeric constants for use in @{} splices)
local T_TARGET_MODEL       = 0
local T_CREATE_SIG         = 1
local T_DECLARE_DATA       = 2
local T_DATA_INIT_ZERO     = 3
local T_DATA_INIT          = 4
local T_DATA_ADDR          = 5
local T_FUNC_ADDR          = 6
local T_EXTERN_ADDR        = 7
local T_DECLARE_FUNC       = 8
local T_DECLARE_EXTERN     = 9
local T_BEGIN_FUNC         = 10
local T_FINISH_FUNC        = 11
local T_CREATE_BLOCK       = 12
local T_SWITCH_TO_BLOCK    = 13
local T_SEAL_BLOCK         = 14
local T_BIND_ENTRY_PARAMS  = 15
local T_APPEND_BLOCK_PARAM = 16
local T_CREATE_STACK_SLOT  = 17
local T_ALIAS              = 18
local T_STACK_ADDR         = 19
local T_CONST              = 20
local T_UNARY              = 21
local T_INTRINSIC          = 22
local T_COMPARE            = 23
local T_CAST               = 24
local T_PTR_OFFSET         = 25
local T_LOAD_INFO          = 26
local T_STORE_INFO         = 27
local T_INT_BINARY         = 28
local T_BIT_BINARY         = 29
local T_BIT_NOT            = 30
local T_SHIFT              = 31
local T_ROTATE             = 32
local T_FLOAT_BINARY       = 33
local T_ALIAS_FACT         = 34
local T_MEMCPY             = 35
local T_MEMSET             = 36
local T_SELECT_CMD         = 37
local T_FMA                = 38
local T_VEC_SPLAT          = 39
local T_VEC_BINARY         = 40
local T_VEC_COMPARE        = 41
local T_VEC_SELECT         = 42
local T_VEC_MASK           = 43
local T_VEC_INSERT_LANE    = 44
local T_VEC_EXTRACT_LANE   = 45
local T_CALL               = 46
local T_JUMP               = 47
local T_BR_IF              = 48
local T_SWITCH_INT         = 49
local T_RETURN_VOID        = 50
local T_RETURN_VALUE       = 51
local T_TRAP               = 52
local T_FINALIZE_MODULE    = 53

local I_DUPLICATE_SIG            = 1
local I_DUPLICATE_DATA           = 2
local I_DUPLICATE_FUNC           = 3
local I_DUPLICATE_EXTERN         = 4
local I_DUPLICATE_BLOCK          = 5
local I_DUPLICATE_STACK_SLOT     = 6
local I_DUPLICATE_VALUE          = 7
local I_DUPLICATE_ACCESS         = 8
local I_MISSING_SIG              = 9
local I_MISSING_DATA             = 10
local I_MISSING_FUNC             = 11
local I_MISSING_EXTERN           = 12
local I_MISSING_BLOCK            = 13
local I_MISSING_STACK_SLOT       = 14
local I_MISSING_VALUE            = 15
local I_MISSING_ACCESS           = 16
local I_NESTED_FUNCTION           = 17
local I_COMMAND_OUTSIDE_FUNCTION  = 18
local I_MISSING_FINALIZE          = 19
local I_COMMAND_AFTER_FINALIZE    = 20
local I_EMPTY_PROGRAM             = 21
local I_UNFINISHED_FUNCTION       = 22

-- Sink that writes i32 issue codes into the ctx buffer
local issue_sink = pvmll.append_sink {
    name = "emit_issue_code",
    ctx_ty = pvmll.ptr(pvmll.i32),
    value_ty = pvmll.i32,
    append = "append_issue_i32",
}

-- Main validation module
local validate_mod = module PvmLlValidate

-- Append a single i32 to the issue buffer (stored at issue_pos index)
func append_issue_i32(ctx: ptr(i32), value: i32)
    let pos: i32 = ctx[1]
    ctx[pos] = value
    ctx[1] = pos + 1
end

-- Two-pass validation: collect facts, then check
--
-- The data layout after the commands array:
--   issue_start (computed by caller) = start of issue buffer
--   ctx[issue_start + 0] = bit-set base offset  (set by this code)
--   ctx[issue_start + 1] = issue count placeholder -> written at end
--   ctx[issue_start + 2] = current issue write position
--
-- The bit-sets start at issue_start + 3.
-- Each bit-set has ceil(intern_count/32) words.
-- Bit-sets: sigs, data, funcs, externs, blocks, slots, values, accesses
-- 8 bit-sets total.

-- ============================================================
-- Entry point: packed array validation
-- ============================================================
export func validate_commands(ctx: ptr(i32), intern_end: i32, cmds_start: i32, cmds_end: i32, issue_start: i32, bitset_words: i32) -> i32
    return region -> i32
    entry do_validate()
        let cmd_count: i32 = ctx[0]
        if cmd_count <= 0 then
            yield 1
        end
        -- Initialize issue buffer
        ctx[issue_start + 1] = 0   -- issue count = 0
        ctx[issue_start + 2] = issue_start + 3 + bitset_words * 8  -- issue write pos, after bit-sets
        -- Zero all bit-sets
        emit zero_bit_sets(ctx, issue_start + 3, bitset_words, 8; done = scan_cmds)
    end

    block scan_cmds()
        -- First pass: collect facts
        emit collect_facts(ctx, cmds_start, cmds_end, issue_start, bitset_words; done = check_cmds)
    end

    block check_cmds()
        -- Second pass: validate commands
        emit check_commands(ctx, cmds_start, cmds_end, issue_start, bitset_words; done = finish)
    end

    block finish()
        -- Write issue count
        let count: i32 = ctx[issue_start + 1]
        ctx[issue_start] = count
        if count ~= 0 then
            yield 1
        else
            yield 0
        end
    end
    end
end

-- ============================================================
-- Bit-set helpers
-- ============================================================

-- Zero N bit-sets each of `words` words
zero_bit_sets = region zero_bit_sets(ctx: ptr(i32), base: i32, words: i32, sets: i32;
    done: cont())
entry start()
    jump zero_loop(set = 0, w = 0)
end
block zero_loop(set: i32, w: i32)
    if set >= sets then jump done() end
    if w >= words then jump zero_loop(set = set + 1, w = 0) end
    ctx[base + set * words + w] = 0
    jump zero_loop(set = set, w = w + 1)
end
end

-- Test a bit in bit-set `set_idx`.  Returns 0 or 1.
bitset_test = region bitset_test(ctx: ptr(i32), base: i32, words: i32, set_idx: i32, bit: i32;
    result: cont(v: i32))
entry start()
    let word_off: i32 = bit >> 5  -- bit / 32
    let bit_mask: i32 = 1 << (bit & 31)  -- 1 << (bit % 32)
    let val: i32 = ctx[base + set_idx * words + word_off]
    let r: i32 = val & bit_mask
    if r ~= 0 then
        jump result(v = 1)
    else
        jump result(v = 0)
    end
end
end

-- Set a bit in bit-set `set_idx`.  Returns 1 if already set, 0 if newly set.
bitset_set = region bitset_set(ctx: ptr(i32), base: i32, words: i32, set_idx: i32, bit: i32;
    result: cont(v: i32))
entry start()
    let word_off: i32 = bit >> 5
    let bit_mask: i32 = 1 << (bit & 31)
    let val: i32 = ctx[base + set_idx * words + word_off]
    let was_set: i32 = val & bit_mask
    if was_set ~= 0 then
        jump result(v = 1)
    end
    ctx[base + set_idx * words + word_off] = val | bit_mask
    jump result(v = 0)
end
end

-- Read a command field: ctx[off + field_idx]
-- This is just ctx indexing, but wrapped for clarity
cmd_field = region cmd_field(ctx: ptr(i32), off: i32, field: i32;
    value: cont(v: i32))
entry start()
    jump value(v = ctx[off + field])
end
end

-- ============================================================
-- First pass: collect facts (defined entities)
-- ============================================================
collect_facts = region collect_facts(ctx: ptr(i32), cmds_start: i32, cmds_end: i32, issue_start: i32, bitset_words: i32;
    done: cont())
entry start()
    jump fact_loop(pos = cmds_start)
end
block fact_loop(pos: i32)
    if pos >= cmds_end then jump done() end
    let len: i32 = ctx[pos]
    if len <= 0 then jump fact_loop(pos = pos + 1) end
    let tag: i32 = ctx[pos + 1]

    -- Collect defined entities by tag
    switch tag do
    case @{T_CREATE_SIG} then
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 0, id; result = fact_next_0)
    case @{T_DECLARE_DATA} then
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 1, id; result = fact_next_1)
    case @{T_DECLARE_FUNC} then
        let id: i32 = ctx[pos + 3]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 2, id; result = fact_next_2)
    case @{T_DECLARE_EXTERN} then
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 3, id; result = fact_next_3)
    case @{T_CREATE_BLOCK} then
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 4, id; result = fact_next_4)
    case @{T_CREATE_STACK_SLOT} then
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 5, id; result = fact_next_5)
    default then
        jump fact_loop(pos = pos + len)
    end
end

block fact_next_0(was_set: i32)
    jump fact_loop(pos = pos + len)
end
block fact_next_1(was_set: i32)
    jump fact_loop(pos = pos + len)
end
block fact_next_2(was_set: i32)
    jump fact_loop(pos = pos + len)
end
block fact_next_3(was_set: i32)
    jump fact_loop(pos = pos + len)
end
block fact_next_4(was_set: i32)
    jump fact_loop(pos = pos + len)
end
block fact_next_5(was_set: i32)
    jump fact_loop(pos = pos + len)
end
end

-- ============================================================
-- Second pass: validate commands
-- ============================================================
check_commands = region check_commands(ctx: ptr(i32), cmds_start: i32, cmds_end: i32, issue_start: i32, bitset_words: i32;
    done: cont())
entry start()
    jump check_loop(pos = cmds_start, active_func = 0, saw_finalize = 0)
end
block check_loop(pos: i32, active_func: i32, saw_finalize: i32)
    if pos >= cmds_end then
        -- Check end state
        if active_func ~= 0 then
            -- Unfinished function
            let write_pos: i32 = ctx[issue_start + 2]
            ctx[write_pos] = @{I_UNFINISHED_FUNCTION}
            ctx[write_pos + 1] = pos
            ctx[write_pos + 2] = active_func
            ctx[issue_start + 2] = write_pos + 3
            let cnt: i32 = ctx[issue_start + 1]
            ctx[issue_start + 1] = cnt + 1
        end
        if saw_finalize == 0 then
            let write_pos: i32 = ctx[issue_start + 2]
            ctx[write_pos] = @{I_MISSING_FINALIZE}
            ctx[write_pos + 1] = pos
            ctx[issue_start + 2] = write_pos + 2
            let cnt: i32 = ctx[issue_start + 1]
            ctx[issue_start + 1] = cnt + 1
        end
        jump done()
    end
    let len: i32 = ctx[pos]
    if len <= 0 then jump check_loop(pos = pos + 1, active_func = active_func, saw_finalize = saw_finalize) end
    let tag: i32 = ctx[pos + 1]

    -- Check command-after-finalize
    if saw_finalize ~= 0 then
        let write_pos: i32 = ctx[issue_start + 2]
        ctx[write_pos] = @{I_COMMAND_AFTER_FINALIZE}
        ctx[write_pos + 1] = pos
        ctx[issue_start + 2] = write_pos + 2
        let cnt: i32 = ctx[issue_start + 1]
        ctx[issue_start + 1] = cnt + 1
        jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = saw_finalize)
    end

    -- Check command-outside-function
    if active_func == 0 then
        if tag ~= @{T_TARGET_MODEL} and tag ~= @{T_CREATE_SIG} and
           tag ~= @{T_DECLARE_DATA} and tag ~= @{T_DECLARE_FUNC} and
           tag ~= @{T_DECLARE_EXTERN} and tag ~= @{T_BEGIN_FUNC} and
           tag ~= @{T_FINALIZE_MODULE} then
            let write_pos: i32 = ctx[issue_start + 2]
            ctx[write_pos] = @{I_COMMAND_OUTSIDE_FUNCTION}
            ctx[write_pos + 1] = pos
            ctx[issue_start + 2] = write_pos + 2
            let cnt: i32 = ctx[issue_start + 1]
            ctx[issue_start + 1] = cnt + 1
            jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = saw_finalize)
        end
    end

    -- Process command by tag
    switch tag do
    case @{T_CREATE_SIG} then
        -- Check duplicate
        let id: i32 = ctx[pos + 2]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 0, id; result = check_sig_dup)
    case @{T_DECLARE_FUNC} then
        let id: i32 = ctx[pos + 3]
        emit @{bitset_set}(ctx, issue_start + 3, bitset_words, 2, id; result = check_func_dup)
    case @{T_BEGIN_FUNC} then
        if active_func ~= 0 then
            -- Nested function
            let write_pos: i32 = ctx[issue_start + 2]
            ctx[write_pos] = @{I_NESTED_FUNCTION}
            ctx[write_pos + 1] = pos
            ctx[write_pos + 2] = active_func
            ctx[write_pos + 3] = ctx[pos + 2]
            ctx[issue_start + 2] = write_pos + 4
            let cnt: i32 = ctx[issue_start + 1]
            ctx[issue_start + 1] = cnt + 1
        end
        let func_id: i32 = ctx[pos + 2]
        jump check_loop(pos = pos + len, active_func = func_id, saw_finalize = saw_finalize)
    case @{T_FINISH_FUNC} then
        jump check_loop(pos = pos + len, active_func = 0, saw_finalize = saw_finalize)
    case @{T_FINALIZE_MODULE} then
        jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = 1)
    default then
        jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = saw_finalize)
    end
end

-- Duplicate handlers
block check_sig_dup(was_set: i32)
    if was_set ~= 0 then
        let id: i32 = ctx[pos + 2]
        let write_pos: i32 = ctx[issue_start + 2]
        ctx[write_pos] = @{I_DUPLICATE_SIG}
        ctx[write_pos + 1] = pos
        ctx[write_pos + 2] = id
        ctx[issue_start + 2] = write_pos + 3
        let cnt: i32 = ctx[issue_start + 1]
        ctx[issue_start + 1] = cnt + 1
    end
    jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = saw_finalize)
end

block check_func_dup(was_set: i32)
    if was_set ~= 0 then
        let id: i32 = ctx[pos + 3]
        let write_pos: i32 = ctx[issue_start + 2]
        ctx[write_pos] = @{I_DUPLICATE_FUNC}
        ctx[write_pos + 1] = pos
        ctx[write_pos + 2] = id
        ctx[issue_start + 2] = write_pos + 3
        let cnt: i32 = ctx[issue_start + 1]
        ctx[issue_start + 1] = cnt + 1
    end
    jump check_loop(pos = pos + len, active_func = active_func, saw_finalize = saw_finalize)
end
end

end

return validate_mod

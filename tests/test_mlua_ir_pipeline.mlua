-- test_mlua_ir_pipeline.mlua — end-to-end: Moonlift .mlua → LuaJIT mcode

package.path = "./?.lua;./?/init.lua;./lua/?.lua;./lua/?/init.lua;" .. package.path

local Host = require("moonlift.mlua_run")
local pvm  = require("moonlift.pvm")
local A    = require("moonlift.asdl")
local Lower = require("moonlift.ir_lower")

-- 1. Evaluate a Moonlift function via the .mlua runner
local add_fn = Host.eval [[
return func add(x: i32, y: i32) -> i32
    return x + y
end
]]

-- 2. Compile it through the existing Moonlift pipeline as a baseline
local compiled = add_fn:compile()
print("baseline add(41, 1) = " .. compiled(41, 1))
assert(compiled(41, 1) == 42, "baseline failed")
compiled:free()

-- 3. Now lower the same function to LuaJIT IR
-- We need the type-checked MoonTree. Use the Host.eval's internal runtime.
local T   = add_fn.T
local Tr  = T.MoonTree
local fn  = add_fn.func
local buf = Lower.lower_func(T, fn)

print("\n--- Lowered IR ---")
print(Lower.dump(buf))

-- 4. Feed IR through luajit_host for optimization + asm
local parts = {}
for i = 1, buf.nk do
    local ins = buf.ks[i]
    parts[#parts + 1] = ("{%d,%d,%d,%d,%d}"):format(ins.o, ins.t, ins.op1, ins.op2, ins.i)
end
for i = 1, buf.ni do
    local ins = buf.is_[i]
    parts[#parts + 1] = ("{%d,%d,%d,%d,%d}"):format(ins.o, ins.t, ins.op1, ins.op2, ins.i)
end

local cmd = "./luajit_host/luajit_host -e '"
    .. "jit.init();"
    .. "local r=jit.compile({" .. table.concat(parts, ",") .. "}," .. buf.nk .. ");"
    .. "print(r.mcode, r.size, r.nins)'"

local h = io.popen(cmd)
local out = h:read("*a")
h:close()

local mcode_ptr, sz, nins = out:match("userdata: (%S+)%s+(%d+)%s+(%d+)")
print("\n--- Compiled ---")
print("instructions: " .. nins)
print("mcode size:   " .. sz .. " bytes")
print("mcode ptr:    0x" .. mcode_ptr)

-- 5. Also test a slightly more complex function
print("\n=== Test 2: branch ===")
local max_fn = Host.eval [[
return func max(x: i32, y: i32) -> i32
    if x > y then
        return x
    else
        return y
    end
end
]]
local max_compiled = max_fn:compile()
print("baseline max(3, 7) = " .. max_compiled(3, 7))
assert(max_compiled(3, 7) == 7, "max baseline failed")
max_compiled:free()

local max_buf = Lower.lower_func(max_fn.T, max_fn.func)
print("\n--- Lowered IR (max) ---")
print(Lower.dump(max_buf))

local max_parts = {}
for i = 1, max_buf.nk do
    local ins = max_buf.ks[i]
    max_parts[#max_parts + 1] = ("{%d,%d,%d,%d,%d}"):format(ins.o, ins.t, ins.op1, ins.op2, ins.i)
end
for i = 1, max_buf.ni do
    local ins = max_buf.is_[i]
    max_parts[#max_parts + 1] = ("{%d,%d,%d,%d,%d}"):format(ins.o, ins.t, ins.op1, ins.op2, ins.i)
end

local max_cmd = "./luajit_host/luajit_host -e '"
    .. "jit.init();"
    .. "local r=jit.compile({" .. table.concat(max_parts, ",") .. "}," .. max_buf.nk .. ");"
    .. "print(r.mcode, r.size, r.nins)'"

local max_h = io.popen(max_cmd)
local max_out = max_h:read("*a")
max_h:close()

local max_mcode, max_sz, max_nins = max_out:match("userdata: (%S+)%s+(%d+)%s+(%d+)")
print("\n--- Compiled (max) ---")
print("instructions: " .. max_nins)
print("mcode size:   " .. max_sz .. " bytes")

print("\n✓ Moonlift → IR → optimizer → asm pipeline works!")

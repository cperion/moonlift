-- Verify tokenizer fragments compose through the explicit parser-composition API.
local Host = require("moonlift.mlua_run")
local Tok = Host.dofile("lib/tokenizer.mlua")
local pvm = require("moonlift.pvm")

local ws    = Tok.skip_ws("test_ws")
local digit = Tok.scan_range("test_digit", 48, 57)
local comma = Tok.match_byte("test_comma", 44)   -- ','
local lb    = Tok.match_byte("test_lb", 91)      -- '['
local rb    = Tok.match_byte("test_rb", 93)      -- ']'

local C = require("moonlift.parser_compose").new(ws.session, { prefix = "test" })
local comma_digit = C:seq({ comma, ws, digit }, { name = "test_comma_digit" })
local more_digits = C:star(comma_digit, { name = "test_more_digits" })
local array = C:seq({ lb, ws, digit, more_digits, ws, rb }, { name = "test_array" })

assert(array.kind == "region_frag")
assert(array.name == "test_array")
assert(array.source == nil, "composition must not generate source strings")
assert(pvm.classof(array.frag) == ws.session.T.MoonOpen.RegionFrag)
assert(array.deps.region_frags.test_lb == lb)
assert(array.deps.region_frags.test_rb == rb)
assert(array.deps.region_frags.test_digit == digit)
assert(array.deps.region_frags.test_comma_digit == comma_digit)
assert(array.deps.region_frags.test_more_digits == more_digits)
assert(#more_digits.frag.blocks[3].params == 1 and more_digits.frag.blocks[3].params[1].name == "at")

print("tokenizer + compose ok")
return "tokenizer compose ok"

-- Pointer-to-struct field access test using Lua-first .mlua

local Pair = struct a: i32; b: i32 end

local get_a = func(p: ptr(Pair)) -> i32
    return (*p).a
end

local get_b = func(p: ptr(Pair)) -> i32
    return (*p).b
end

local set_a = func(p: ptr(Pair), v: i32)
    (*p).a = v
end

return { get_a = get_a, get_b = get_b, set_a = set_a }

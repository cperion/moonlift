-- Closed symbol/memory semantics: consts inline, statics are data, pointer * and & lower cleanly.

local ffi = require("ffi")

local m = module SymbolMemoryClean

const ANSWER: i32 = 40 + 2
static CELL: i32 = 7

export func get_answer() -> i32
    return ANSWER
end

export func get_cell() -> i32
    return CELL
end

export func set_cell(v: i32)
    CELL = v
end

export func cell_addr_load() -> i32
    return *&CELL
end

export func ptr_load(p: ptr(i32)) -> i32
    return *p
end

export func ptr_store(p: ptr(i32), v: i32)
    *p = v
end

end

local c = m:compile()
assert(c:get("get_answer")() == 42)
assert(c:get("get_cell")() == 7)
assert(c:get("cell_addr_load")() == 7)
c:get("set_cell")(99)
assert(c:get("get_cell")() == 99)
assert(c:get("cell_addr_load")() == 99)

local cell = ffi.new("int32_t[1]", 3)
assert(c:get("ptr_load")(cell) == 3)
c:get("ptr_store")(cell, 11)
assert(cell[0] == 11)

c:free()
return "symbol memory clean ok"

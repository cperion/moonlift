-- Region Normal Form tests using Lua-first .mlua

local inc = region(x: i32; next: cont(v: i32))
entry start()
    jump next(v = x + 1)
end
end

local run_inc = func(x: i32): i32
    return region: i32
    entry start()
        emit @{inc}(x; next = done)
    end
    block done(v: i32)
        yield v
    end
    end
end

return run_inc

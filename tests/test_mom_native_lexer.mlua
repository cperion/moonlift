package.path = "./?.lua;./?/init.lua;./lua/?.lua;./lua/?/init.lua;" .. package.path

local ffi = require("ffi")
local Host = require("moonlift.mlua_run")

local mod = Host.dofile("lua/moonlift/mom/parser/native_lexer.mlua")
local unit = mod:compile()
local lex = unit:get("mom_lex_into")
local parse_events = unit:get("mom_parse_module_events")
local parse_full_events = unit:get("mom_parse_full_events")

local function bytes(s)
    local a = ffi.new("uint8_t[?]", #s)
    ffi.copy(a, s, #s)
    return a, #s
end

local function lex_all(src)
    local p, n = bytes(src)
    local cap = 256
    local kinds = ffi.new("int32_t[?]", cap)
    local starts = ffi.new("int32_t[?]", cap)
    local stops = ffi.new("int32_t[?]", cap)
    local lines = ffi.new("int32_t[?]", cap)
    local cols = ffi.new("int32_t[?]", cap)
    local count = tonumber(lex(p, n, kinds, starts, stops, lines, cols, cap))
    assert(count <= cap, "increase test token cap")
    local out = {}
    for i = 0, count - 1 do
        out[#out + 1] = {
            kind = kinds[i],
            text = src:sub(starts[i] + 1, stops[i]),
            start = starts[i],
            stop = stops[i],
            line = lines[i],
            col = cols[i],
        }
    end
    return out
end

local TK = {
    eof = 0, name = 1, int = 2, float = 3, string = 4, nl = 5, hole = 6,
    lparen = 10, rparen = 11, comma = 16, colon = 17, plus = 20, arrow = 26,
    func = 102, let = 110, return_kw = 134, as_kw = 170,
}

local toks = lex_all("func add(x: i32, y: i32) -> i32\n    return x + y\nend")
local kinds = {}
for i, t in ipairs(toks) do kinds[i] = t.kind end
assert(kinds[1] == TK.func)
assert(kinds[2] == TK.name and toks[2].text == "add")
assert(kinds[3] == TK.lparen)
assert(kinds[5] == TK.colon)
assert(kinds[12] == TK.arrow)
assert(kinds[#kinds] == TK.eof)

local nums = lex_all("0 123 0xff 1.5 2e10 3.0e-2")
assert(nums[1].kind == TK.int and nums[1].text == "0")
assert(nums[2].kind == TK.int and nums[2].text == "123")
assert(nums[3].kind == TK.int and nums[3].text == "0xff")
assert(nums[4].kind == TK.float and nums[4].text == "1.5")
assert(nums[5].kind == TK.float and nums[5].text == "2e10")
assert(nums[6].kind == TK.float and nums[6].text == "3.0e-2")

local holes = lex_all("let x: @{T} = @{expr...}")
local hole_count = 0
for _, t in ipairs(holes) do if t.kind == TK.hole then hole_count = hole_count + 1 end end
assert(hole_count == 2)

local function parse_event_kinds(src)
    local p, n = bytes(src)
    local cap = 256
    local kinds = ffi.new("int32_t[?]", cap)
    local starts = ffi.new("int32_t[?]", cap)
    local stops = ffi.new("int32_t[?]", cap)
    local lines = ffi.new("int32_t[?]", cap)
    local cols = ffi.new("int32_t[?]", cap)
    local ntok = tonumber(lex(p, n, kinds, starts, stops, lines, cols, cap))
    local ek = ffi.new("int32_t[?]", cap)
    local et = ffi.new("int32_t[?]", cap)
    local ea = ffi.new("int32_t[?]", cap)
    local nev = tonumber(parse_events(kinds, ntok, ek, et, ea, cap))
    local out = {}
    for i = 0, nev - 1 do
        out[#out + 1] = { kind = ek[i], token = et[i], aux = ea[i] }
    end
    return out
end

local evs = parse_event_kinds([[struct Pair
  a: i32
  b: i32
end
func add(x: i32, y: i32) -> i32
  return x + y
end]])
local seen = {}
for _, e in ipairs(evs) do seen[e.kind] = (seen[e.kind] or 0) + 1 end
assert(seen[1] == 1)   -- module begin
assert(seen[2] == 1)   -- module end
assert(seen[14] == 1)  -- struct begin
assert(seen[15] == 1)  -- struct end
assert(seen[31] == 2)  -- fields
assert(seen[10] == 1)  -- func begin
assert(seen[11] == 1)  -- func end
assert(seen[30] == 2)  -- params

local function parse_full_event_kinds(src)
    local p, n = bytes(src)
    local cap = 512
    local kinds = ffi.new("int32_t[?]", cap)
    local starts = ffi.new("int32_t[?]", cap)
    local stops = ffi.new("int32_t[?]", cap)
    local lines = ffi.new("int32_t[?]", cap)
    local cols = ffi.new("int32_t[?]", cap)
    local ntok = tonumber(lex(p, n, kinds, starts, stops, lines, cols, cap))
    local state = ffi.new("int32_t[2]")
    local ek = ffi.new("int32_t[?]", cap)
    local et = ffi.new("int32_t[?]", cap)
    local ea = ffi.new("int32_t[?]", cap)
    local nev = tonumber(parse_full_events(kinds, ntok, state, ek, et, ea, cap))
    local out = {}
    for i = 0, nev - 1 do out[#out + 1] = { kind = ek[i], token = et[i], aux = ea[i] } end
    return out
end

local full = parse_full_event_kinds([[func abs_i32(x: i32) -> i32
    if x < 0 then
        return 0 - x
    else
        return x
    end
end]])
local fseen = {}
for _, e in ipairs(full) do fseen[e.kind] = (fseen[e.kind] or 0) + 1 end
assert(fseen[10] == 1 and fseen[11] == 1) -- func begin/end
assert(fseen[30] == 1)                    -- parameter
assert((fseen[33] or 0) >= 2)             -- param/result types
assert((fseen[35] or 0) >= 3)             -- if + returns
assert((fseen[34] or 0) >= 4)             -- expressions

unit.artifact:free()
print("mom native lexer ok")
return "mom native lexer ok"

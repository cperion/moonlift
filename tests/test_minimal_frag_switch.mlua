-- Minimal repro: fragment with switch + block jump, emitted inside if in return region
local inner = region inner(c: i32; ok: cont(v: i32), bad: cont(pos: i32))
entry start()
    if c < 0 then jump bad(pos = 0 - c) end
    jump dispatch(c = c)
end
block dispatch(c: i32)
    switch c do
    case 1 then jump handle_one()
    case 2 then jump handle_two()
    default then jump bad(pos = c)
    end
end
block handle_one()
    jump ok(v = 1)
end
block handle_two()
    jump ok(v = 2)
end
end

local test = module TestFragSwitch
export func run(x: i32) -> i32
    return region -> i32
    entry start()
        if x >= 0 then
            emit @{inner}(x; ok = done, bad = fail)
        end
        yield -100
    end
    block done(v: i32)
        yield v
    end
    block fail(pos: i32)
        yield 0 - pos
    end
    end
end
end

local compiled = test:compile()
local run = compiled:get("run")
assert(run(1) == 1)
assert(run(2) == 2)
assert(run(99) == -99)
compiled:free()
return "minimal frag switch ok"

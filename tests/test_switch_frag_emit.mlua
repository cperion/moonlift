-- Reproduction: fragment with switch + internal block jump, emitted in if-then
local inner = region inner(x: i32; ok: cont(v: i32), bad: cont(pos: i32))
entry start()
    if x == 0 then jump ok(v = 0) end
    if x < 0 then jump dispatch(c = 0 - x) end
    jump dispatch(c = x)
end
block dispatch(c: i32)
    switch c do
    case 1 then jump handle_one()
    case 2 then jump handle_two()
    default then jump bad(pos = c)
    end
end
block handle_one()
    jump ok(v = 1)
end
block handle_two()
    jump ok(v = 2)
end
end

local test = module TestSwitchFrag
export func run(x: i32) -> i32
    return region -> i32
    entry start()
        -- emit inside if-then
        if x >= 0 then
            emit @{inner}(x; ok = done, bad = fail)
        end
        yield -100
    end
    block done(v: i32)
        yield v
    end
    block fail(pos: i32)
        yield 0 - pos
    end
    end
end
end

local compiled = test:compile()
local run = compiled:get("run")
print("run(1)=", run(1))
print("run(2)=", run(2))
print("run(0)=", run(0))
print("run(-5)=", run(-5))
print("run(99)=", run(99))
-- assert(run(1) == 1)
assert(run(2) == 2)
assert(run(0) == 0)
assert(run(-5) == 100)
assert(run(99) == -99)
compiled:free()
print("switch frag emit ok")
return "switch frag emit ok"

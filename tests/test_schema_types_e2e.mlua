-- End-to-end: ASDL types injected into Moonlift module via @{...}
local Types = require("moonlift.schema_types")

return module
    @{Types.declarations}

    -- Use a type from the blob: MoonCore_Name is struct { text: ptr(u8) }
    export func make_name(t: ptr(u8)) -> ptr(MoonCore_Name)
        return region -> ptr(MoonCore_Name)
        entry start()
            let name: MoonCore_Name
            name.text = t
            yield &name
        end
        end
    end
end

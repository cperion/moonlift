-- Region fragment composition test using .mlua eval
local Host = require("moonlift.mlua_run")

-- Region fragment with multiple continuation exits
local fn = Host.eval [[
local scan_byte = region(p: ptr(u8), n: i32, pos: i32;
    ok: cont(next: i32, value: i32),
    err: cont(pos: i32))
entry start()
    if pos >= n then jump err(pos = pos) end
    jump ok(next = pos + 1, value = as(i32, p[pos]))
end
end

return func use_scan(p: ptr(u8), n: i32, pos: i32) -> i32
    return region -> i32
    entry start()
        emit @{scan_byte}(p, n, pos; ok = got, err = failed)
    end
    block got(next: i32, value: i32)
        yield value
    end
    block failed(pos: i32)
        yield -1
    end
    end
end
]]
assert(fn.name == "use_scan")

-- Test the fragment has the expected structure
local compiled = fn:compile()
-- Verify with known input
local ffi = require("ffi")
local data = ffi.new("uint8_t[3]", 10, 20, 30)
assert(compiled(data, 3, 0) == 10)
assert(compiled(data, 3, 1) == 20)
assert(compiled(data, 3, 2) == 30)
assert(compiled(data, 3, 3) == -1)  -- out of bounds
compiled:free()

print("moonlift region compose ASDL ok")
return "moonlift region compose ASDL ok"

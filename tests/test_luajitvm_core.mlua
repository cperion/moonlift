-- tests/test_luajitvm_core.mlua
-- Exercises core/value, core/object, core/bytecode, core/state.

local ffi = require("ffi")
local Run = require("moonlift.mlua_run")

-- Each module returns its ModuleValue. Compile, test, collect.
local function load_compiled(path)
    local mv = Run.dofile(path)
    -- Module files return `m` (the ModuleValue)
    if type(mv) ~= "table" or not mv.compile then
        error(path .. " did not return a ModuleValue, got " .. type(mv))
    end
    local compiled = mv:compile()
    return function(name)
        local fn = compiled:get(name)
        if not fn then error(path .. " has no export: " .. name) end
        return fn
    end, compiled
end

local tv_get, tv_compiled = load_compiled("mlua/luajitvm/core/value.mlua")
local obj_get, obj_compiled = load_compiled("mlua/luajitvm/core/object.mlua")
local bc_get, bc_compiled = load_compiled("mlua/luajitvm/core/bytecode.mlua")
local st_get, st_compiled = load_compiled("mlua/luajitvm/core/state.mlua")

-- =========================================================================
-- TValue tests
-- =========================================================================

local buf_tv = ffi.new("int32_t[?]", 16)
local p32 = ffi.cast("int32_t*", buf_tv)
local p64 = ffi.cast("int64_t*", buf_tv)

-- Tag constants are module constants, not exported functions.
-- value_const_check proves constants resolve inside compiled Moonlift code.
assert(tv_get("value_const_check")() == 44)

-- Write + read
tv_get("tv_set")(p32, p64, 0, 0, 0)
assert(tv_get("tv_tag")(p32, 0) == 0)
assert(tv_get("tv_is_nil")(p32, 0) == true)

tv_get("tv_set_int")(p32, p64, 0, 42)
assert(tv_get("tv_tag")(p32, 0) == 3)
assert(tv_get("tv_is_int")(p32, 0) == true)
assert(tonumber(tv_get("tv_payload")(p64, 0)) == 42)

-- Type predicates
tv_get("tv_set")(p32, p64, 2, 5, 0)
assert(tv_get("tv_is_str")(p32, 2) == true)
assert(tv_get("tv_is_gcv")(p32, 2) == true)

tv_get("tv_set")(p32, p64, 2, 4, 0)
assert(tv_get("tv_is_num")(p32, 2) == true)
assert(tv_get("tv_is_number")(p32, 2) == true)

-- Copy
tv_get("tv_set_int")(p32, p64, 0, 99)
tv_get("tv_copy")(p32, p64, 0, 3)
assert(tv_get("tv_tag")(p32, 3) == 3)
assert(tonumber(tv_get("tv_payload")(p64, 3)) == 99)

-- Partial writes
tv_get("tv_set_int")(p32, p64, 0, 100)
tv_get("tv_set_tag")(p32, 0, 5)
assert(tv_get("tv_tag")(p32, 0) == 5)
assert(tonumber(tv_get("tv_payload")(p64, 0)) == 100)

-- =========================================================================
-- GC object tests
-- =========================================================================

local buf_obj = ffi.new("uint8_t[?]", 32)
local p_obj = ffi.cast("uint8_t*", buf_obj)

assert(obj_get("object_const_check")() == 37)

obj_get("gc_set_gct")(p_obj, 7)
assert(obj_get("gc_gct")(p_obj) == 7)

obj_get("gc_set_marked")(p_obj, 3)
assert(obj_get("gc_is_black")(p_obj) == true)

obj_get("gc_set_marked")(p_obj, 0)
assert(obj_get("gc_is_white")(p_obj, 0) == true)

-- =========================================================================
-- Bytecode tests
-- =========================================================================

assert(bc_get("bytecode_const_check")() == 183)

-- Bitfield: BC_ADDVV A=10, B=20, C=5
local ins = 32 + (10 * 256) + (5 * 65536) + (20 * 16777216)
assert(bc_get("bc_op")(ins) == 32)
assert(bc_get("bc_a")(ins)  == 10)
assert(bc_get("bc_b")(ins)  == 20)
assert(bc_get("bc_c")(ins)  == 5)

-- D-format: BC_KNIL(44), A=3, D=10
local ins_d = 44 + (3 * 256) + (10 * 65536)
assert(bc_get("bc_op")(ins_d) == 44)
assert(bc_get("bc_a")(ins_d)  == 3)
assert(bc_get("bc_d")(ins_d)  == 10)

-- =========================================================================
-- State tests
-- =========================================================================

assert(st_get("state_const_check")() == 42)

-- =========================================================================
-- Cleanup
-- =========================================================================

tv_compiled:free()
obj_compiled:free()
bc_compiled:free()
st_compiled:free()
return "luajitvm core ok"

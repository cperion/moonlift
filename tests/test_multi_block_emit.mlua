-- Minimal reproduction: multi-block region fragment emit inside return region
local inner = region inner(x: i32; ok: cont(v: i32), bad: cont(pos: i32))
entry start()
    if x < 0 then jump bad(pos = 0 - x) end
    jump increment(i = x)
end
block increment(i: i32)
    if i > 100 then jump ok(v = i) end
    jump increment(i = i + 1)
end
end

local test = module TestMultiBlock
export func run(x: i32) -> i32
    return region -> i32
    entry start()
        emit @{inner}(x; ok = done, bad = fail)
    end
    block done(v: i32)
        yield v
    end
    block fail(pos: i32)
        yield 0 - pos
    end
    end
end
end

local compiled = test:compile()
local run = compiled:get("run")
assert(run(5) == 101)
assert(run(-3) == -3)
assert(run(200) == 200)
compiled:free()
return "multi-block emit ok"

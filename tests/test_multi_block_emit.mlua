-- Minimal reproduction: multi-block region fragment emit inside return region
local inner = region(x: i32; ok: cont(v: i32), bad: cont(pos: i32))
entry start()
    if x < 0 then jump bad(pos = 0 - x) end
    jump increment(i = x)
end
block increment(i: i32)
    if i > 100 then jump ok(v = i) end
    jump increment(i = i + 1)
end
end

local run = func(x: i32): i32
    return region: i32
    entry start()
        emit @{inner}(x; ok = done, bad = fail)
    end
    block done(v: i32)
        yield v
    end
    block fail(pos: i32)
        yield 0 - pos
    end
    end
end

local compiled = run:compile()
assert(compiled(5) == 101)
assert(compiled(-3) == -3)
assert(compiled(200) == 200)
compiled:free()
return "multi-block emit ok"

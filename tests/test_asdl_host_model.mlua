-- Test document scanning + parsing pipeline (replaces old host model tests)
local pvm = require("moonlift.pvm")
local A = require("moonlift.asdl")
local Parse = require("moonlift.parse")

local T = pvm.context(); A.Define(T)
local P = Parse.Define(T)

-- Scan a document with an island containing a splice
local src = [[
local x = 1
local r = region R()
entry start()
    let y: i32 = @{x}
end
end
return r
]]
local scan = Parse.scan_document(src)
assert(#scan.islands >= 1, "expected at least one island")
local island = scan.islands[1]
assert(island.kind == "region", "expected region kind, got " .. island.kind)
assert(#island.holes >= 1, "expected at least one hole")
assert(island.holes[1]:match("splice"), "hole should be a splice id")

-- Parse the island
local parsed = P.parse_island(scan, 1)
assert(#parsed.issues == 0, "parse should succeed: " .. tostring(parsed.issues[1]))
assert(parsed.value ~= nil)
assert(#parsed.splice_slots == 1, "expected 1 splice slot")

print("moonlift ASDL host model ok")
return "moonlift ASDL host model ok"

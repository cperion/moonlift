                set { tags[meta[0]], 7 },
                set { a[meta[0]], 0 },
                set { b[meta[0]], 0 },
                set { nums[meta[0]], value },
                set { meta[0], meta[0] + 1 },
                yield { next_i },
            },
            block .lit_true { i [i32] } {
                when { (i + 4):gt(n) } {
                    jump .fail_at { at = i + 1 },

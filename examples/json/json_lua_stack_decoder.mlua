                when { c:eq(91) } {
                    let .array_next_i [i32] { json_parse_array_events(p, n, i, tags, a, b, nums, event_cap, strbuf, str_cap, meta) },
                    when { array_next_i:lt(0) } {
                        yield { array_next_i },
                    },
                    yield { array_next_i },
                },
                when { c:eq(123) } {
                    let .object_next_i [i32] { json_parse_object_events(p, n, i, tags, a, b, nums, event_cap, strbuf, str_cap, meta) },
                    when { object_next_i:lt(0) } {

    fn .json_parse_value_events
        { p [ptr [u8]], n [i32], pos [i32], tags [ptr [i32]], a [ptr [i32]], b [ptr [i32]], nums [ptr [f64]], event_cap [i32], strbuf [ptr [u8]], str_cap [i32], meta [ptr [i32]] }
        [i32]
        {
            entry .start { } {

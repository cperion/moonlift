local module_defs = json_module.body or {}
local bundle = moon.bundle("json_library_showcase")
for i = 1, #module_defs do
    bundle:pack(module_defs[i])
end

local c_artifact = bundle:emit_c_artifact({ module_name = "moonlift_json_showcase" })
local c_blob = c_artifact.combined
local c_header = c_artifact.header

local compiled_module
local value_fn
local c_backend
do
    local ok, compiled, backend
    ok, compiled = pcall(function()
        return bundle:compile({ backend = "c", runner = "libtcc", cflags = "-O3" })
    end)
    if ok and compiled then
        backend = "libtcc"
        compiled_module = compiled
        value_fn = compiled_module:get("json_decode_value_events")
        c_backend = backend
    else
        ok, compiled = pcall(function()
            return bundle:compile({ backend = "c", runner = "shared", cflags = "-std=c99 -fPIC -shared -O3" })
        end)
        if ok and compiled then
            backend = "gcc-o3"
            compiled_module = compiled
            value_fn = compiled_module:get("json_decode_value_events")
            c_backend = backend
        else
            ok, compiled = pcall(function()
                return bundle:compile({ backend = "cranelift-jit" })
            end)
            if not ok or not compiled then error("failed to compile json parser artifact", 2) end
            backend = "cranelift-jit"
            compiled_module = compiled
            value_fn = compiled_module:get("json_decode_value_events")
            c_backend = backend
        end
    end
end

local Json = {
    tags = {
        ARRAY_OPEN = 1,
        ARRAY_CLOSE = 2,
        OBJECT_OPEN = 3,
        OBJECT_CLOSE = 4,
        OBJECT_KEY = 5,
        STRING = 6,
        NUMBER = 7,
        TRUE = 8,
        FALSE = 9,
        NULL = 10,
    },
    c_blob = c_blob,
    c_header = c_header,
    c_backend = c_backend,
}

Json.c_api = {
    backend = c_backend,
    decode = "json_decode_value_events",
    typed_arrays = {
        tags = "Int32Array",
        nums = "Float64Array",
        strings = "Uint8Array",
    },
}

Json.emcc_args = {
    "-O3",
    "-s", "EXPORTED_FUNCTIONS=['_json_decode_value_events']",
}

Json.object_mt = {}
Json.array_mt = {}
Json.null = {}
Json.tags.NULL = 10

local NULL_SENTINEL = Json.null

local function new_decoder_state()
    return {
        event_cap = 2048,
        str_cap = 1024,
        tags = ffi.new("int32_t[2048]"),
        a = ffi.new("int32_t[2048]"),
        b = ffi.new("int32_t[2048]"),
        nums = ffi.new("double[2048]"),
        strbuf = ffi.new("uint8_t[1024]"),
        meta = ffi.new("int32_t[2]"),
    }
end

local function ensure_state(state, n)
    local need_events = n * 6 + 256
    if state.event_cap < need_events then
        local cap = state.event_cap
        while cap < need_events do cap = cap * 2 end
        state.event_cap = cap
        state.tags = ffi.new("int32_t[?]", cap)
        state.a = ffi.new("int32_t[?]", cap)
        state.b = ffi.new("int32_t[?]", cap)
        state.nums = ffi.new("double[?]", cap)
    end

    local need_str = n + 128
    if state.str_cap < need_str then
        local cap = state.str_cap
        while cap < need_str do cap = cap * 2 end
        state.str_cap = cap
        state.strbuf = ffi.new("uint8_t[?]", cap)
    end
end

local function syntax_error(offset)
    return nil, { kind = "syntax", offset = offset }
end

local function decode_events_to_value(state, event_count)
    local stack = {}
    local root

    local function append_value(v)
        local frame = stack[#stack]
        if not frame then
            root = v
            return true
        end
        if frame.kind == "array" then
            frame.value[#frame.value + 1] = v
            return true
        end
        local key = frame.pending_key
        frame.pending_key = nil
        if key == nil then return false, { kind = "syntax", offset = 1 } end
        frame.value[key] = v
        return true
    end

    local function close_frame(kind)
        local frame = table.remove(stack)
        if not frame then return false, { kind = "syntax", offset = 1 } end
        if frame.kind ~= kind then return false, { kind = "syntax", offset = 1 } end
        local v = frame.value
        local parent = stack[#stack]
        if not parent then
            root = v
            return true
        end
        if parent.kind == "array" then
            parent.value[#parent.value + 1] = v
            return true
        end
        local key = frame.key
        if key == nil then return false, { kind = "syntax", offset = 1 } end
        parent.value[key] = v
        return true
    end

    local function push_object()
        local parent = stack[#stack]
        local key
        if parent and parent.kind == "object" and parent.pending_key ~= nil then
            key = parent.pending_key
            parent.pending_key = nil
        end
        stack[#stack + 1] = {
            kind = "object",
            value = setmetatable({}, Json.object_mt),
            pending_key = nil,
            key = key,
        }
    end

    local function push_array()
        local parent = stack[#stack]
        local key
        if parent and parent.kind == "object" and parent.pending_key ~= nil then
            key = parent.pending_key
            parent.pending_key = nil
        end
        stack[#stack + 1] = {
            kind = "array",
            value = setmetatable({}, Json.array_mt),
            key = key,
        }
    end

    for i = 0, event_count - 1 do
        local tag = tonumber(state.tags[i])
        if tag == Json.tags.ARRAY_OPEN then
            push_array()
        elseif tag == Json.tags.ARRAY_CLOSE then
            local ok, err = close_frame("array")
            if not ok then return nil, err end
        elseif tag == Json.tags.OBJECT_OPEN then
            push_object()
        elseif tag == Json.tags.OBJECT_CLOSE then
            local ok, err = close_frame("object")
            if not ok then return nil, err end
        elseif tag == Json.tags.OBJECT_KEY then
            local parent = stack[#stack]
            if not parent or parent.kind ~= "object" then return syntax_error(1) end
            parent.pending_key = ffi.string(state.strbuf + tonumber(state.a[i]), tonumber(state.b[i]))
        elseif tag == Json.tags.STRING then
            local ok = append_value(ffi.string(state.strbuf + tonumber(state.a[i]), tonumber(state.b[i])))
            if not ok then return syntax_error(1) end
        elseif tag == Json.tags.NUMBER then
            local ok = append_value(tonumber(state.nums[i]))
            if not ok then return syntax_error(1) end
        elseif tag == Json.tags.TRUE then
            local ok = append_value(true)
            if not ok then return syntax_error(1) end
        elseif tag == Json.tags.FALSE then
            local ok = append_value(false)
            if not ok then return syntax_error(1) end
        elseif tag == Json.tags.NULL then
            local ok = append_value(NULL_SENTINEL)
            if not ok then return syntax_error(1) end
        else
            return syntax_error(1)
        end
    end

    if #stack ~= 0 then return syntax_error(1) end
    return root
end

local function decode_with_state(state, src)
    src = tostring(src)
    local n = #src
    if not value_fn then error("json parser was closed", 2) end
    ensure_state(state, n)
    local parsed = value_fn(
        ffi.cast("uint8_t *", src),
        n,
        state.tags, state.a, state.b, state.nums,
        state.event_cap,
        state.strbuf, state.str_cap,
        state.meta
    )
    if parsed < 0 then return syntax_error(-parsed) end
    if parsed ~= n then return syntax_error(parsed) end
    local count = tonumber(state.meta[0] or 0)
    if count <= 0 then return syntax_error(parsed) end
    return decode_events_to_value(state, count)
end

local shared_state = new_decoder_state()

local function decode_or_nil(src)
    return decode_with_state(shared_state, src)
end

local function decode(src)
    local value, err = decode_or_nil(src)
    if value ~= nil then return value end
    error(("json decode failed at offset %d"):format(err and err.offset or 0), 2)
end

local function valid(src)
    return decode_or_nil(src) ~= nil
end

local function json_string_escape(s)
    local escapes = {
        ["\\"] = "\\\\",
        ["\""] = "\\\"",
        ["\b"] = "\\b",
        ["\f"] = "\\f",
        ["\n"] = "\\n",
        ["\r"] = "\\r",
        ["\t"] = "\\t",
    }
    return "\"" .. s:gsub("[\\\"%c]", function(c)
            if escapes[c] then return escapes[c] end
            local byte = c:byte()
            return string.format("\\u%04x", byte)
        end) .. "\""
end

local function encode_value(v)
    local tv = type(v)
    if v == NULL_SENTINEL then return "null" end
    if tv == "string" then return json_string_escape(v) end
    if tv == "number" then return tostring(v) end
    if tv == "boolean" then return v and "true" or "false" end
    if tv == "nil" then return "null" end
    if tv == "table" then
        local mt = getmetatable(v)
        if mt == Json.array_mt then
            local out = {}
            for i = 1, #v do out[i] = encode_value(v[i]) end
            return "[" .. table.concat(out, ",") .. "]"
        end
        if mt == Json.object_mt then
            local keys = {}
            for k in pairs(v) do
                keys[#keys + 1] = tostring(k)
            end
            table.sort(keys)
            local out = {}
            for i = 1, #keys do
                local k = keys[i]
                out[#out + 1] = json_string_escape(k) .. ":" .. encode_value(v[k])
            end
            return "{" .. table.concat(out, ",") .. "}"
        end
    end
    error("cannot encode value for JSON", 2)
end

local function encode(v)
    return encode_value(v)
end

local function write_file(path, text)
    local f = assert(io.open(path, "wb"))
    f:write(text or "")
    f:close()
    return path, #(text or "")
end

local function write_c(path)
    return write_file(path, Json.c_blob)
end

local function write_header(path)
    return write_file(path, Json.c_header)
end

local function new_decoder()
    local state = new_decoder_state()
    return {
        decode = function(self, src)
            local value, err = decode_with_state(state, src)
            if value ~= nil then return value end
            error(("json decode failed at offset %d"):format(err and err.offset or 0), 2)
        end,
        decode_or_nil = function(self, src)
            return decode_with_state(state, src)
        end,
        close = function() end,
    }
end

local function close()
    if compiled_module and compiled_module.free then compiled_module:free() end
    compiled_module = nil
    value_fn = nil
end

Json.value_fn = value_fn
Json.decode = decode
Json.decode_or_nil = decode_or_nil
Json.valid = valid
Json.encode = encode
Json.new_decoder = new_decoder
Json.write_c = write_c
Json.write_header = write_header
Json.close = close

return Json

-- zyn_moonlift_synth_impl.mlua
--
-- Implementation module for zyn_moonlift_synth_headers.mlua.
-- The header owns the product forest, protocol graph, and ABI seal signatures;
-- this file supplies bodies by calling those signature closures with body-only
-- Moonlift source, per LANGUAGE_REFERENCE.md §15.1-15.3.
--
-- Use moon.dofile, not Lua's standard dofile: .mlua files must pass through the
-- Moonlift island transform before Lua execution.

local H = moon.dofile("examples/synth/zyn_moonlift_synth_headers.mlua")

local M = H
local E = M.enc
local T = M.T
local R = M.R
local F = M.F

-------------------------------------------------------------------------------
-- Shared Lua-side constants and body bindings
-------------------------------------------------------------------------------

local MAGIC_ZYNM = 0x5a594e4d
local PATCH_FORMAT_VERSION = 1
local EMPTY_U32 = 0xffffffff

-- Binding table for future body strings. It contains only compile-time Lua
-- values used for Moonlift splices/dependency registration; it is not synth
-- runtime state.
local BODY = {
    E = E,
    T = T,
    R = R,
    F = F,

    MAGIC_ZYNM = MAGIC_ZYNM,
    PATCH_FORMAT_VERSION = PATCH_FORMAT_VERSION,
    EMPTY_U32 = EMPTY_U32,
}

-------------------------------------------------------------------------------
-- Primitive helper fragments
-------------------------------------------------------------------------------

local HLP = {}
M.HLP = HLP
BODY.HLP = HLP

HLP.min_f32 = expr(a: f32, b: f32): f32
    select(a < b, a, b)
end

HLP.max_f32 = expr(a: f32, b: f32): f32
    select(a > b, a, b)
end

HLP.abs_f32 = expr(x: f32): f32
    select(x < as(f32, 0.0), -x, x)
end

HLP.clamp_f32 = expr(x: f32, lo: f32, hi: f32): f32
    select(x < lo, lo, select(x > hi, hi, x))
end

HLP.denormal_clamp = expr(x: f32, floor: f32): f32
    select(emit @{HLP.abs_f32}(x) < floor, as(f32, 0.0), x)
end

HLP.is_finite_f32 = region(x: f32;
    finite
    | not_finite)
entry start()
    if x ~= x then jump not_finite() end
    if x > 3.402823e38 then jump not_finite() end
    if x < -3.402823e38 then jump not_finite() end
    jump finite()
end
end

HLP.checked_add_index = region(a: index, b: index;
    ok(value: index)
    | overflow)
entry start()
    let sum: index = a + b
    if sum < a then jump overflow() end
    jump ok(value = sum)
end
end

HLP.checked_mul_index = region(a: index, b: index;
    ok(value: index)
    | overflow)
entry start()
    if a < 0 then jump overflow() end
    if b < 0 then jump overflow() end
    if a == 0 then jump ok(value = as(index, 0)) end
    if b == 0 then jump ok(value = as(index, 0)) end
    let product_f: f64 = as(f64, a) * as(f64, b)
    if product_f > 9223372036854775807.0 then jump overflow() end
    let product: index = a * b
    if product < a then jump overflow() end
    if product < b then jump overflow() end
    jump ok(value = product)
end
end

HLP.align_up_index = region(value: index, align: index;
    ok(value: index)
    | bad_align
    | overflow)
entry start()
    if align <= 0 then jump bad_align() end
    let mask: index = align - 1
    if (align & mask) ~= 0 then jump bad_align() end
    emit @{HLP.checked_add_index}(value, mask; ok = added, overflow = too_big)
end
block added(value: index)
    let mask: index = align - 1
    jump ok(value = value & ~mask)
end
block too_big()
    jump overflow()
end
end

HLP.checked_byte_range = region(pos: index, size: index, total: index;
    ok
    | overflow
    | out_of_bounds)
entry start()
    if pos < 0 then jump out_of_bounds() end
    if size < 0 then jump out_of_bounds() end
    emit @{HLP.checked_add_index}(pos, size; ok = bounded, overflow = too_big)
end
block bounded(value: index)
    if value > total then jump out_of_bounds() end
    jump ok()
end
block too_big()
    jump overflow()
end
end

HLP.validate_byte_slice = region(bytes: ByteSlice, min_len: index;
    ok
    | bad_buffer)
entry start()
    if min_len < 0 then jump bad_buffer() end
    if bytes.data == nil then jump bad_buffer() end
    if bytes.len < min_len then jump bad_buffer() end
    jump ok()
end
end

HLP.validate_f32_view = region(samples: view(f32), required_len: index;
    ok
    | bad_buffer)
entry start()
    if required_len < 0 then jump bad_buffer() end
    if len(samples) < required_len then jump bad_buffer() end
    jump ok()
end
end

HLP.validate_stereo_block = region(stereo: StereoBlock, frame_count: index;
    ok
    | bad_buffer)
entry start()
    emit @{HLP.validate_f32_view}(stereo.left, frame_count; ok = left_ok, bad_buffer = bad)
end
block left_ok()
    emit @{HLP.validate_f32_view}(stereo.right, frame_count; ok = right_ok, bad_buffer = bad)
end
block right_ok()
    jump ok()
end
block bad()
    jump bad_buffer()
end
end

HLP.arena_alloc_bytes = region(arena: ptr(ByteArena), size: index, align: index;
    allocated(data: ptr(u8), offset: index)
    | bad_align
    | overflow
    | exhausted
    | bad_buffer)
entry start()
    if arena == nil then jump bad_buffer() end
    if (*arena).data == nil then jump bad_buffer() end
    if size < 0 then jump overflow() end
    if (*arena).used > (*arena).cap then jump bad_buffer() end
    emit @{HLP.align_up_index}((*arena).used, align; ok = aligned, bad_align = bad_alignment, overflow = too_big)
end
block aligned(value: index)
    emit @{HLP.checked_add_index}(value, size; ok = finished, overflow = too_big)
end
block finished(value: index)
    if value > (*arena).cap then jump exhausted() end
    let start: index = (*arena).used
    emit @{HLP.align_up_index}(start, align; ok = commit, bad_align = bad_alignment, overflow = too_big)
end
block commit(value: index)
    let new_used: index = value + size;
    (*arena).used = new_used
    jump allocated(data = (*arena).data + value, offset = value)
end
block bad_alignment()
    jump bad_align()
end
block too_big()
    jump overflow()
end
end

HLP.read_u16_le = region(bytes: ByteSlice, pos: index;
    ok(value: u16)
    | malformed(pos: index, code: i32))
entry start()
    if bytes.data == nil then jump malformed(pos = pos, code = 1) end
    emit @{HLP.checked_byte_range}(pos, as(index, 2), bytes.len; ok = in_range, overflow = bad_overflow, out_of_bounds = bad_range)
end
block in_range()
    let b0: u16 = as(u16, bytes.data[pos])
    let b1: u16 = as(u16, bytes.data[pos + as(index, 1)])
    jump ok(value = b0 | (b1 << 8))
end
block bad_overflow()
    jump malformed(pos = pos, code = 2)
end
block bad_range()
    jump malformed(pos = pos, code = 3)
end
end

HLP.read_u32_le = region(bytes: ByteSlice, pos: index;
    ok(value: u32)
    | malformed(pos: index, code: i32))
entry start()
    if bytes.data == nil then jump malformed(pos = pos, code = 1) end
    emit @{HLP.checked_byte_range}(pos, as(index, 4), bytes.len; ok = in_range, overflow = bad_overflow, out_of_bounds = bad_range)
end
block in_range()
    let b0: u32 = as(u32, bytes.data[pos])
    let b1: u32 = as(u32, bytes.data[pos + as(index, 1)])
    let b2: u32 = as(u32, bytes.data[pos + as(index, 2)])
    let b3: u32 = as(u32, bytes.data[pos + as(index, 3)])
    jump ok(value = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24))
end
block bad_overflow()
    jump malformed(pos = pos, code = 2)
end
block bad_range()
    jump malformed(pos = pos, code = 3)
end
end

HLP.read_f32_le = region(bytes: ByteSlice, pos: index;
    ok(value: f32)
    | malformed(pos: index, code: i32))
entry start()
    emit @{HLP.read_u32_le}(bytes, pos; ok = got_bits, malformed = bad)
end
block got_bits(value: u32)
    jump ok(value = bitcast(f32, value))
end
block bad(pos: index, code: i32)
    jump malformed(pos = pos, code = code)
end
end

HLP.deterministic_noise_step = region(seed: u64;
    ok(next_seed: u64, sample: f32))
entry start()
    let nonzero: u64 = select(seed == 0, as(u64, 1), seed)
    let next: u64 = nonzero * as(u64, 1664525) + as(u64, 1013904223)
    let mant: u32 = as(u32, next & as(u64, 16777215))
    let unit: f32 = as(f32, mant) * as(f32, 0.00000011920928955078125)
    jump ok(next_seed = next, sample = unit - as(f32, 1.0))
end
end

BODY.validate_byte_slice = HLP.validate_byte_slice
BODY.read_u16_le = HLP.read_u16_le
BODY.read_u32_le = HLP.read_u32_le
BODY.read_f32_le = HLP.read_f32_le
BODY.checked_mul_index = HLP.checked_mul_index
BODY.checked_add_index = HLP.checked_add_index
BODY.checked_byte_range = HLP.checked_byte_range
BODY.arena_alloc_bytes = HLP.arena_alloc_bytes
BODY.is_finite_f32 = HLP.is_finite_f32

BODY.K_SECTION_HEADER = E.PatchSectionKind.header
BODY.K_SECTION_TUNING = E.PatchSectionKind.tuning
BODY.K_SECTION_PART = E.PatchSectionKind.part
BODY.K_SECTION_LAYER = E.PatchSectionKind.layer
BODY.K_SECTION_MODULATION = E.PatchSectionKind.modulation
BODY.K_SECTION_ADDITIVE = E.PatchSectionKind.additive
BODY.K_SECTION_SUBTRACTIVE = E.PatchSectionKind.subtractive
BODY.K_SECTION_PAD = E.PatchSectionKind.pad
BODY.K_SECTION_EFFECT_BUS = E.PatchSectionKind.effect_bus
BODY.K_SECTION_END_MARKER = E.PatchSectionKind.end_marker
BODY.VOICE_STAGE_FREE = E.VoiceStage.free
BODY.VOICE_STAGE_ATTACK = E.VoiceStage.attack
BODY.VOICE_STAGE_DECAY = E.VoiceStage.decay
BODY.VOICE_STAGE_SUSTAIN = E.VoiceStage.sustain
BODY.VOICE_STAGE_RELEASE = E.VoiceStage.release
BODY.VOICE_STAGE_FADEOUT = E.VoiceStage.fadeout
BODY.VOICE_STAGE_RETIRING = E.VoiceStage.retiring
BODY.EMPTY_U32_VALUE = EMPTY_U32
BODY.HOST_EVENT_MIDI = E.HostEventKind.midi
BODY.HOST_EVENT_PARAMETER = E.HostEventKind.parameter
BODY.HOST_EVENT_PROGRAM_CHANGE = E.HostEventKind.program_change
BODY.HOST_EVENT_TRANSPORT = E.HostEventKind.transport
BODY.HOST_EVENT_ALL_NOTES_OFF = E.HostEventKind.all_notes_off
BODY.HOST_EVENT_PANIC = E.HostEventKind.panic
BODY.MIDI_NOTE_OFF = E.MidiKind.note_off
BODY.MIDI_NOTE_ON = E.MidiKind.note_on
BODY.MIDI_POLY_PRESSURE = E.MidiKind.poly_pressure
BODY.MIDI_CONTROL_CHANGE = E.MidiKind.control_change
BODY.MIDI_PROGRAM_CHANGE = E.MidiKind.program_change
BODY.MIDI_CHANNEL_PRESSURE = E.MidiKind.channel_press
BODY.MIDI_PITCH_BEND = E.MidiKind.pitch_bend
BODY.PARAM_SCOPE_GLOBAL = E.ParamScope.global
BODY.PARAM_SCOPE_PART = E.ParamScope.part
BODY.PARAM_SCOPE_LAYER = E.ParamScope.layer
BODY.PARAM_SCOPE_MODULATION = E.ParamScope.modulation
BODY.PARAM_SCOPE_INSERT_FX = E.ParamScope.insert_fx
BODY.PARAM_SCOPE_SEND_FX = E.ParamScope.send_fx
BODY.PARAM_SCOPE_MASTER_FX = E.ParamScope.master_fx
BODY.TONE_MASK_ALL = E.ToneMask.additive + E.ToneMask.subtractive + E.ToneMask.pad
BODY.TONE_MASK_ADDITIVE = E.ToneMask.additive
BODY.TONE_MASK_SUBTRACTIVE = E.ToneMask.subtractive
BODY.TONE_MASK_PAD = E.ToneMask.pad
BODY.VOICE_STEAL_OLDEST = E.VoiceStealMode.oldest
BODY.VOICE_STEAL_QUIETEST = E.VoiceStealMode.quietest
BODY.VOICE_STEAL_RELEASE_FIRST = E.VoiceStealMode.release_first
BODY.VOICE_STEAL_SAME_NOTE = E.VoiceStealMode.same_note

-------------------------------------------------------------------------------
-- Storage sizing and initialization ABI seals
-------------------------------------------------------------------------------

F.synth_required_storage = F.synth_required_storage({})[[
    if config.max_voices <= 0 then return 0 end
    if config.max_parts <= 0 then return 0 end
    if config.max_layers <= 0 then return 0 end
    if config.max_mod_routes <= 0 then return 0 end
    if config.max_additive_partials <= 0 then return 0 end
    if config.max_noise_bands <= 0 then return 0 end
    if config.max_block_frames <= 0 then return 0 end
    if config.program_banks == 0 then return 0 end
    if config.programs_per_bank == 0 then return 0 end
    if config.channel_count <= 0 then return 0 end
    if config.pad_table_count == 0 and config.pad_total_frames > 0 then return 0 end
    if config.pad_table_count > 0 and config.pad_total_frames <= 0 then return 0 end
    if config.effect_bus_count == 0 and config.effect_slots_per_bus > 0 then return 0 end
    if config.effect_bus_count > 0 and config.effect_slots_per_bus <= 0 then return 0 end

    let program_count: index = as(index, config.program_banks) * as(index, config.programs_per_bank)
    let effect_count: index = config.effect_bus_count * config.effect_slots_per_bus
    if program_count < 0 then return 0 end
    if effect_count < 0 then return 0 end

    let t00: index = as(index, 0)
    let t01: index = t00 + program_count * as(index, 16)
    if t01 < t00 then return 0 end
    let t02: index = t01 + config.max_voices * as(index, 224)
    if t02 < t01 then return 0 end
    let t03: index = t02 + config.max_voices * as(index, 2)
    if t03 < t02 then return 0 end
    let t04: index = (t03 + as(index, 3)) & ~as(index, 3)
    if t04 < t03 then return 0 end
    let t05: index = t04 + config.max_voices * as(index, 8)
    if t05 < t04 then return 0 end
    let t06: index = t05 + config.max_voices * as(index, 4)
    if t06 < t05 then return 0 end
    let t07: index = t06 + config.channel_count * as(index, 28)
    if t07 < t06 then return 0 end
    let t08: index = t07 + config.channel_count * as(index, 128)
    if t08 < t07 then return 0 end
    let t09: index = (t08 + as(index, 3)) & ~as(index, 3)
    if t09 < t08 then return 0 end
    let t10: index = t09 + config.macro_count * as(index, 4)
    if t10 < t09 then return 0 end
    let t11: index = t10 + config.pad_total_frames * as(index, 4)
    if t11 < t10 then return 0 end
    let t12: index = (t11 + as(index, 7)) & ~as(index, 7)
    if t12 < t11 then return 0 end
    let t13: index = t12 + config.pad_table_count * as(index, 8)
    if t13 < t12 then return 0 end
    let t14: index = t13 + config.pad_table_count * as(index, 8)
    if t14 < t13 then return 0 end
    let t15: index = t14 + config.pad_table_count * as(index, 2)
    if t15 < t14 then return 0 end
    let t16: index = (t15 + as(index, 7)) & ~as(index, 7)
    if t16 < t15 then return 0 end
    let t17: index = t16 + effect_count * as(index, 32)
    if t17 < t16 then return 0 end
    let t18: index = t17 + config.effect_bus_count * as(index, 8)
    if t18 < t17 then return 0 end
    let t19: index = t18 + config.effect_bus_count * as(index, 8)
    if t19 < t18 then return 0 end
    let t20: index = (t19 + as(index, 15)) & ~as(index, 15)
    if t20 < t19 then return 0 end
    return t20
]]

local STORAGE_BODY = {
    synth_required_storage = F.synth_required_storage,
}

F.synth_init = F.synth_init(STORAGE_BODY)[[
    if s == nil then return 2 end
    if storage.arena.data == nil then return 2 end
    if sample_rate_hz <= as(f32, 0.0) then return 1 end

    let required: index = @{synth_required_storage}(config)
    if required == 0 then return 1 end
    if storage.arena.cap < required then return 5 end

    var st: SynthStorage = storage;
    st.arena.used = 0

    var cursor: index = 0
    var count: index = 0
    var mask: index = 0

    count = as(index, config.program_banks) * as(index, config.programs_per_bank)
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.programs.slots = as(ptr(ProgramSlot), st.arena.data + cursor); cursor = cursor + count * as(index, 16)
    st.programs.bank_count = config.program_banks
    st.programs.programs_per_bank = config.programs_per_bank

    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.voices.states = as(ptr(VoiceState), st.arena.data + cursor); cursor = cursor + config.max_voices * as(index, 224)
    mask = as(index, 2) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.voices.generations = as(ptr(u16), st.arena.data + cursor); cursor = cursor + config.max_voices * as(index, 2)
    mask = as(index, 4) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.voices.active = as(ptr(VoiceRef), st.arena.data + cursor); cursor = cursor + config.max_voices * as(index, 8)
    mask = as(index, 4) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.voices.next_free = as(ptr(u32), st.arena.data + cursor); cursor = cursor + config.max_voices * as(index, 4)
    st.voices.cap = config.max_voices
    st.voices.active_count = 0
    st.voices.free_head = select(config.max_voices == 0, as(u32, 4294967295), as(u32, 0))

    mask = as(index, 4) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.controls.states = as(ptr(ControlState), st.arena.data + cursor); cursor = cursor + config.channel_count * as(index, 28)
    mask = as(index, 1) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.controls.cc_values = as(ptr(u8), st.arena.data + cursor); cursor = cursor + config.channel_count * as(index, 128) * as(index, 1)
    mask = as(index, 4) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.controls.macro_values = as(ptr(f32), st.arena.data + cursor); cursor = cursor + config.macro_count * as(index, 4)
    st.controls.channel_count = config.channel_count
    st.controls.macro_count = config.macro_count

    mask = as(index, 4) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.pad_cache.table_data = as(ptr(f32), st.arena.data + cursor); cursor = cursor + config.pad_total_frames * as(index, 4)
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.pad_cache.table_offsets = as(ptr(index), st.arena.data + cursor); cursor = cursor + config.pad_table_count * as(index, 8)
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.pad_cache.table_lengths = as(ptr(index), st.arena.data + cursor); cursor = cursor + config.pad_table_count * as(index, 8)
    mask = as(index, 2) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.pad_cache.table_generations = as(ptr(u16), st.arena.data + cursor); cursor = cursor + config.pad_table_count * as(index, 2)
    st.pad_cache.table_count = config.pad_table_count
    st.pad_cache.total_frames = config.pad_total_frames
    st.pad_cache.used_frames = 0
    st.pad_cache.generation = 1

    count = config.effect_bus_count * config.effect_slots_per_bus
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.effects.states = as(ptr(EffectState), st.arena.data + cursor); cursor = cursor + count * as(index, 32)
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.effects.bus_offsets = as(ptr(index), st.arena.data + cursor); cursor = cursor + config.effect_bus_count * as(index, 8)
    mask = as(index, 8) - as(index, 1); cursor = (cursor + mask) & ~mask
    st.effects.bus_slot_counts = as(ptr(index), st.arena.data + cursor); cursor = cursor + config.effect_bus_count * as(index, 8)
    st.effects.bus_count = config.effect_bus_count
    st.effects.cap = count
    st.effects.generation = 1

    mask = as(index, 15); cursor = (cursor + mask) & ~mask
    st.arena.used = cursor

    block init_programs(i: index = 0)
        if i >= as(index, config.program_banks) * as(index, config.programs_per_bank) then yield end
        st.programs.slots[i].program = nil
        st.programs.slots[i].generation = 1
        st.programs.slots[i].occupied = false
        jump init_programs(i = i + as(index, 1))
    end

    block init_voices(i: index = 0)
        if i >= config.max_voices then yield end
        st.voices.generations[i] = 1
        st.voices.next_free[i] = select(i + as(index, 1) >= config.max_voices, as(u32, 4294967295), as(u32, i + as(index, 1)))
        st.voices.states[i].stage = 0
        st.voices.states[i].gate = false
        st.voices.states[i].age_frames = 0
        st.voices.states[i].release_frame = 0
        jump init_voices(i = i + as(index, 1))
    end

    block init_controls(i: index = 0)
        if i >= config.channel_count then yield end
        st.controls.states[i].pitch_bend = as(f32, 0.0)
        st.controls.states[i].channel_pressure = as(f32, 0.0)
        st.controls.states[i].sustain = false
        st.controls.states[i].expression = as(f32, 1.0)
        st.controls.states[i].mod_wheel = as(f32, 0.0)
        st.controls.states[i].volume = as(f32, 1.0)
        st.controls.states[i].pan = as(f32, 0.0)
        jump init_controls(i = i + as(index, 1))
    end

    block init_cc(i: index = 0)
        if i >= config.channel_count * as(index, 128) then yield end
        st.controls.cc_values[i] = 0
        jump init_cc(i = i + as(index, 1))
    end

    block init_macros(i: index = 0)
        if i >= config.macro_count then yield end
        st.controls.macro_values[i] = as(f32, 0.0)
        jump init_macros(i = i + as(index, 1))
    end

    block init_pad_tables(i: index = 0)
        if i >= config.pad_table_count then yield end
        st.pad_cache.table_offsets[i] = 0
        st.pad_cache.table_lengths[i] = 0
        st.pad_cache.table_generations[i] = 1
        jump init_pad_tables(i = i + as(index, 1))
    end

    block init_pad_data(i: index = 0)
        if i >= config.pad_total_frames then yield end
        st.pad_cache.table_data[i] = as(f32, 0.0)
        jump init_pad_data(i = i + as(index, 1))
    end

    block init_effects(i: index = 0)
        if i >= count then yield end
        st.effects.states[i].kind = 0
        st.effects.states[i].generation = 1
        st.effects.states[i].z0 = as(f32, 0.0)
        st.effects.states[i].z1 = as(f32, 0.0)
        st.effects.states[i].z2 = as(f32, 0.0)
        st.effects.states[i].z3 = as(f32, 0.0)
        st.effects.states[i].rng = 0
        jump init_effects(i = i + as(index, 1))
    end

    block init_buses(i: index = 0)
        if i >= config.effect_bus_count then yield end
        st.effects.bus_offsets[i] = i * config.effect_slots_per_bus
        st.effects.bus_slot_counts[i] = config.effect_slots_per_bus
        jump init_buses(i = i + as(index, 1))
    end

    (*s) = {
        current_program = { bank = as(u16, 0), program = as(u16, 0), generation = as(u16, 0) },
        storage = st,
        policy = policy,
        transport = { playing = false, beat_pos = 0.0, bar_pos = 0.0, time_sig_num = as(u8, 4), time_sig_den = as(u8, 4) },
        last_meter = { peak_l = as(f32, 0.0), peak_r = as(f32, 0.0), rms_l = as(f32, 0.0), rms_r = as(f32, 0.0), clipped = false },
        generation = as(u64, 1),
    }
    return 0
]]

-------------------------------------------------------------------------------
-- Memory, borrow, lifetime, and cleanup regions
-------------------------------------------------------------------------------

R.borrow_published_program = R.borrow_published_program({})[[
entry start()
    if synth == nil then jump bad_state(code = 1) end
    let current: ProgramRef = (*synth).current_program
    if current.generation == 0 then jump no_program() end
    if current.bank >= (*synth).storage.programs.bank_count then jump bad_state(code = 2) end
    if current.program >= (*synth).storage.programs.programs_per_bank then jump bad_state(code = 3) end
    if (*synth).storage.programs.slots == nil then jump bad_state(code = 4) end
    let slot_index: index = as(index, current.bank) * as(index, (*synth).storage.programs.programs_per_bank) + as(index, current.program)
    let slot: ptr(ProgramSlot) = (*synth).storage.programs.slots + slot_index
    if not slot[0].occupied then jump no_program() end
    if slot[0].program == nil then jump bad_state(code = 5) end
    if slot[0].generation ~= current.generation then jump bad_state(code = 6) end
    jump borrowed(program_ref = current, program = slot[0].program, generation = slot[0].generation)
end
]]

R.publish_prepared_program = R.publish_prepared_program({})[[
entry start()
    if synth == nil then jump invalid(code = 1) end
    if program == nil then jump invalid(code = 2) end
    if (*synth).storage.programs.slots == nil then jump invalid(code = 3) end
    if target.bank >= (*synth).storage.programs.bank_count then jump invalid(code = 4) end
    if target.program >= (*synth).storage.programs.programs_per_bank then jump invalid(code = 5) end
    let slot_index: index = as(index, target.bank) * as(index, (*synth).storage.programs.programs_per_bank) + as(index, target.program)
    let slot: ptr(ProgramSlot) = (*synth).storage.programs.slots + slot_index
    if target.generation ~= 0 and target.generation ~= slot[0].generation then jump stale_ref(program = target) end
    let next_generation: u16 = as(u16, slot[0].generation + as(u16, 1))
    slot[0].program = program
    slot[0].occupied = true
    slot[0].generation = select(next_generation == 0, as(u16, 1), next_generation)
    let published_ref: ProgramRef = { bank = target.bank, program = target.program, generation = slot[0].generation }
    jump published(program = published_ref, generation = slot[0].generation)
end
]]

R.retire_prepared_program = R.retire_prepared_program({})[[
entry start()
    let p_ref: ProgramRef = program
    if synth == nil then jump missing(program = p_ref) end
    if (*synth).storage.programs.slots == nil then jump missing(program = p_ref) end
    if p_ref.bank >= (*synth).storage.programs.bank_count then jump missing(program = p_ref) end
    if p_ref.program >= (*synth).storage.programs.programs_per_bank then jump missing(program = p_ref) end
    if (*synth).current_program.bank == p_ref.bank and (*synth).current_program.program == p_ref.program and (*synth).current_program.generation == p_ref.generation then jump current_program(program = p_ref) end
    let slot_index: index = as(index, p_ref.bank) * as(index, (*synth).storage.programs.programs_per_bank) + as(index, p_ref.program)
    let slot: ptr(ProgramSlot) = (*synth).storage.programs.slots + slot_index
    if not slot[0].occupied then jump missing(program = p_ref) end
    if slot[0].generation ~= p_ref.generation then jump stale_ref(program = p_ref) end
    let next_generation: u16 = as(u16, slot[0].generation + as(u16, 1))
    slot[0].program = nil
    slot[0].occupied = false
    slot[0].generation = select(next_generation == 0, as(u16, 1), next_generation)
    jump retired(generation = slot[0].generation)
end
]]

R.borrow_voice_state = R.borrow_voice_state({ VOICE_STAGE_FREE = E.VoiceStage.free })[[
entry start()
    if pool == nil then jump already_free(voice = voice) end
    if (*pool).states == nil then jump already_free(voice = voice) end
    if (*pool).generations == nil then jump already_free(voice = voice) end
    if as(index, voice.index) >= (*pool).cap then jump stale_ref(voice = voice) end
    if (*pool).generations[as(index, voice.index)] ~= voice.generation then jump stale_ref(voice = voice) end
    let state: ptr(VoiceState) = (*pool).states + as(index, voice.index)
    if (*state).stage == @{VOICE_STAGE_FREE} then jump already_free(voice = voice) end
    jump borrowed(state = state)
end
]]

R.borrow_effect_state = R.borrow_effect_state({})[[
entry start()
    if rack == nil then jump missing(effect = effect) end
    if (*rack).states == nil then jump missing(effect = effect) end
    if (*rack).bus_offsets == nil then jump missing(effect = effect) end
    if (*rack).bus_slot_counts == nil then jump missing(effect = effect) end
    if as(index, effect.bus) >= (*rack).bus_count then jump missing(effect = effect) end
    let slot_count: index = (*rack).bus_slot_counts[as(index, effect.bus)]
    if as(index, effect.slot) >= slot_count then jump missing(effect = effect) end
    let offset: index = (*rack).bus_offsets[as(index, effect.bus)] + as(index, effect.slot)
    if offset >= (*rack).cap then jump missing(effect = effect) end
    let state: ptr(EffectState) = (*rack).states + offset
    if (*state).generation ~= effect.generation then jump stale_ref(effect = effect) end
    jump borrowed(state = state)
end
]]

R.borrow_pad_table = R.borrow_pad_table({})[[
entry start()
    if cache == nil then jump missing_cache(table = table) end
    if (*cache).table_data == nil then jump missing_cache(table = table) end
    if (*cache).table_offsets == nil then jump missing_cache(table = table) end
    if (*cache).table_lengths == nil then jump missing_cache(table = table) end
    if (*cache).table_generations == nil then jump missing_cache(table = table) end
    if as(index, table.index) >= (*cache).table_count then jump missing_cache(table = table) end
    if (*cache).table_generations[as(index, table.index)] ~= table.generation then jump stale_ref(table = table) end
    let offset: index = (*cache).table_offsets[as(index, table.index)]
    let n: index = (*cache).table_lengths[as(index, table.index)]
    if n <= 0 then jump rebuilding(table = table) end
    if offset < 0 then jump missing_cache(table = table) end
    if offset + n > (*cache).used_frames then jump missing_cache(table = table) end
    jump borrowed(samples = view((*cache).table_data + offset, n))
end
]]

R.reset_render_scratch = R.reset_render_scratch({})[[
entry start()
    if scratch == nil then jump bad_buffer() end
    if (*scratch).arena.data == nil then jump bad_buffer() end
    if shape.frame_count < 0 then jump bad_buffer() end
    if len((*scratch).voice.left) < shape.frame_count then jump bad_buffer() end
    if len((*scratch).voice.right) < shape.frame_count then jump bad_buffer() end
    if len((*scratch).part.left) < shape.frame_count then jump bad_buffer() end
    if len((*scratch).part.right) < shape.frame_count then jump bad_buffer() end
    if len((*scratch).send.left) < shape.frame_count then jump bad_buffer() end
    if len((*scratch).send.right) < shape.frame_count then jump bad_buffer() end
    scratch[0].arena.used = 0
    jump reset()
end
]]

R.enter_render_memory = R.enter_render_memory({ borrow_published_program = R.borrow_published_program })[[
entry start()
    if synth == nil then jump bad_buffer() end
    if scratch == nil then jump bad_buffer() end
    if (*synth).storage.arena.data == nil then jump bad_state(code = 1) end
    emit @{borrow_published_program}(synth; borrowed = got_program, no_program = no_current, bad_state = bad)
end
block got_program(program_ref: ProgramRef, program: ptr(PreparedProgram), generation: u16)
    jump ready(program = program, storage = &(*synth).storage, scratch = scratch, events = events, out = { left = out_l, right = out_r })
end
block no_current()
    jump no_program()
end
block bad(code: i32)
    jump bad_state(code = code)
end
]]

R.close_synth_storage = R.close_synth_storage({})[[
entry start()
    if synth == nil then jump already_closed() end
    if (*synth).generation == 0 then jump already_closed() end
    synth[0].generation = synth[0].generation + as(u64, 1)
    synth[0].storage.voices.active_count = 0
    synth[0].storage.voices.free_head = as(u32, 4294967295)
    synth[0].current_program.bank = as(u16, 0)
    synth[0].current_program.program = as(u16, 0)
    synth[0].current_program.generation = as(u16, 0)
    if synth[0].generation == 0 then
        synth[0].generation = as(u64, 1)
    end
    jump closed()
end
]]

-------------------------------------------------------------------------------
-- Patch section decoding
-------------------------------------------------------------------------------

R.decode_patch_source = R.decode_patch_source(BODY)[[
entry start()
    if src.format_id ~= @{MAGIC_ZYNM} then jump unsupported_format(format_id = src.format_id, version = src.version) end
    if src.version ~= @{PATCH_FORMAT_VERSION} then jump unsupported_format(format_id = src.format_id, version = src.version) end
    emit @{validate_byte_slice}(src.bytes, as(index, 16); ok = bytes_ok, bad_buffer = short_header)
end
block bytes_ok()
    emit @{read_u32_le}(src.bytes, as(index, 0); ok = got_magic, malformed = bad)
end
block got_magic(value: u32)
    if value ~= @{MAGIC_ZYNM} then jump unsupported_format(format_id = value, version = src.version) end
    emit @{read_u32_le}(src.bytes, as(index, 4); ok = got_version, malformed = bad)
end
block got_version(value: u32)
    if value ~= @{PATCH_FORMAT_VERSION} then jump unsupported_format(format_id = src.format_id, version = value) end
    emit @{read_u32_le}(src.bytes, as(index, 8); ok = got_flags, malformed = bad)
end
block got_flags(value: u32)
    if value ~= 0 then jump malformed(pos = as(index, 8), code = 10) end
    emit @{read_u32_le}(src.bytes, as(index, 12); ok = got_count, malformed = bad)
end
block got_count(value: u32)
    let count: index = as(index, value)
    if count < 0 then jump malformed(pos = as(index, 12), code = 11) end
    emit @{checked_mul_index}(count, as(index, 12); ok = dir_bytes, overflow = dir_overflow)
end
block dir_bytes(value: index)
    emit @{checked_add_index}(as(index, 16), value; ok = dir_end, overflow = dir_overflow)
end
block dir_end(value: index)
    if value > src.bytes.len then jump malformed(pos = src.bytes.len, code = 12) end
    let h: PatchHeader = { format_id = src.format_id, version = src.version, flags = 0, section_count = (value - as(index, 16)) / as(index, 12) }
    jump decoded(header = h)
end
block short_header()
    jump malformed(pos = as(index, 0), code = 1)
end
block dir_overflow()
    jump malformed(pos = as(index, 12), code = 2)
end
block bad(pos: index, code: i32)
    jump malformed(pos = pos, code = code)
end
]]

R.next_patch_section = R.next_patch_section(BODY)[[
entry start()
    if src.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if cursor < 0 then jump malformed(pos = cursor, code = 2) end
    if header.format_id ~= @{MAGIC_ZYNM} then jump unsupported_section(kind = as(u8, 0), index = cursor) end
    if header.version ~= @{PATCH_FORMAT_VERSION} then jump unsupported_section(kind = as(u8, 0), index = cursor) end
    if header.section_count < 0 then jump malformed(pos = as(index, 12), code = 3) end
    emit @{checked_mul_index}(header.section_count, as(index, 12); ok = dir_bytes, overflow = dir_overflow)
end
block dir_bytes(value: index)
    emit @{checked_add_index}(as(index, 16), value; ok = dir_end, overflow = dir_overflow)
end
block dir_end(value: index)
    if value > src.bytes.len then jump malformed(pos = src.bytes.len, code = 4) end
    if cursor >= header.section_count then jump done(count = header.section_count) end
    jump validate_sorted(i = as(index, 0), dir_end = value)
end
block validate_sorted(i: index, dir_end: index)
    if i >= header.section_count then jump validate_ranges(i = as(index, 0), dir_end = dir_end) end
    let pos: index = as(index, 16) + i * as(index, 12)
    let kind: u8 = src.bytes.data[pos]
    if kind == @{K_SECTION_HEADER} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_TUNING} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_PART} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_LAYER} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_MODULATION} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_ADDITIVE} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_SUBTRACTIVE} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_PAD} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_EFFECT_BUS} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    if kind == @{K_SECTION_END_MARKER} then jump kind_ok(i = i, dir_end = dir_end, pos = pos, kind = kind) end
    jump unsupported_section(kind = kind, index = i)
end
block kind_ok(i: index, dir_end: index, pos: index, kind: u8)
    if src.bytes.data[pos + as(index, 1)] ~= 0 then jump malformed(pos = pos + as(index, 1), code = 5) end
    let idx_u16: u16 = as(u16, src.bytes.data[pos + as(index, 2)]) | (as(u16, src.bytes.data[pos + as(index, 3)]) << 8)
    let idx: index = as(index, idx_u16)
    if kind == @{K_SECTION_HEADER} and idx ~= 0 then jump malformed(pos = pos + as(index, 2), code = 6) end
    if kind == @{K_SECTION_TUNING} and idx ~= 0 then jump malformed(pos = pos + as(index, 2), code = 7) end
    if kind == @{K_SECTION_END_MARKER} and idx ~= 0 then jump malformed(pos = pos + as(index, 2), code = 8) end
    if i == 0 then jump sorted_next(i = i + as(index, 1), dir_end = dir_end) end
    let prev_pos: index = as(index, 16) + (i - as(index, 1)) * as(index, 12)
    let prev_kind: u8 = src.bytes.data[prev_pos]
    let prev_idx_u16: u16 = as(u16, src.bytes.data[prev_pos + as(index, 2)]) | (as(u16, src.bytes.data[prev_pos + as(index, 3)]) << 8)
    let prev_idx: index = as(index, prev_idx_u16)
    if kind < prev_kind then jump malformed(pos = pos, code = 9) end
    if kind == prev_kind and idx <= prev_idx then jump malformed(pos = pos, code = 10) end
    jump sorted_next(i = i + as(index, 1), dir_end = dir_end)
end
block sorted_next(i: index, dir_end: index)
    jump validate_sorted(i = i, dir_end = dir_end)
end
block validate_ranges(i: index, dir_end: index)
    if i >= header.section_count then jump read_cursor() end
    let pos: index = as(index, 16) + i * as(index, 12)
    let kind: u8 = src.bytes.data[pos]
    let idx_u16: u16 = as(u16, src.bytes.data[pos + as(index, 2)]) | (as(u16, src.bytes.data[pos + as(index, 3)]) << 8)
    let idx: index = as(index, idx_u16)
    let off_u32: u32 = as(u32, src.bytes.data[pos + as(index, 4)]) | (as(u32, src.bytes.data[pos + as(index, 5)]) << 8) | (as(u32, src.bytes.data[pos + as(index, 6)]) << 16) | (as(u32, src.bytes.data[pos + as(index, 7)]) << 24)
    let n_u32: u32 = as(u32, src.bytes.data[pos + as(index, 8)]) | (as(u32, src.bytes.data[pos + as(index, 9)]) << 8) | (as(u32, src.bytes.data[pos + as(index, 10)]) << 16) | (as(u32, src.bytes.data[pos + as(index, 11)]) << 24)
    let off: index = as(index, off_u32)
    let n: index = as(index, n_u32)
    if (off & as(index, 3)) ~= 0 then jump malformed(pos = off, code = 11) end
    if off < dir_end then jump malformed(pos = off, code = 12) end
    let payload_end: index = off + n
    if payload_end < off then jump malformed(pos = off, code = 13) end
    if payload_end > src.bytes.len then jump malformed(pos = off, code = 14) end
    if kind == @{K_SECTION_END_MARKER} and n ~= 0 then jump malformed(pos = pos + as(index, 8), code = 15) end
    jump validate_no_overlap(i = i, j = as(index, 0), dir_end = dir_end, off = off, n = n)
end
block validate_no_overlap(i: index, j: index, dir_end: index, off: index, n: index)
    if j >= i then jump range_next(i = i + as(index, 1), dir_end = dir_end) end
    let other_pos: index = as(index, 16) + j * as(index, 12)
    let other_off_u32: u32 = as(u32, src.bytes.data[other_pos + as(index, 4)]) | (as(u32, src.bytes.data[other_pos + as(index, 5)]) << 8) | (as(u32, src.bytes.data[other_pos + as(index, 6)]) << 16) | (as(u32, src.bytes.data[other_pos + as(index, 7)]) << 24)
    let other_n_u32: u32 = as(u32, src.bytes.data[other_pos + as(index, 8)]) | (as(u32, src.bytes.data[other_pos + as(index, 9)]) << 8) | (as(u32, src.bytes.data[other_pos + as(index, 10)]) << 16) | (as(u32, src.bytes.data[other_pos + as(index, 11)]) << 24)
    let other_off: index = as(index, other_off_u32)
    let other_n: index = as(index, other_n_u32)
    let end_a: index = off + n
    let end_b: index = other_off + other_n
    if n ~= 0 and other_n ~= 0 and off < end_b and other_off < end_a then jump malformed(pos = off, code = 16) end
    jump validate_no_overlap(i = i, j = j + as(index, 1), dir_end = dir_end, off = off, n = n)
end
block range_next(i: index, dir_end: index)
    jump validate_ranges(i = i, dir_end = dir_end)
end
block read_cursor()
    let pos: index = as(index, 16) + cursor * as(index, 12)
    let kind: u8 = src.bytes.data[pos]
    let idx_u16: u16 = as(u16, src.bytes.data[pos + as(index, 2)]) | (as(u16, src.bytes.data[pos + as(index, 3)]) << 8)
    let off_u32: u32 = as(u32, src.bytes.data[pos + as(index, 4)]) | (as(u32, src.bytes.data[pos + as(index, 5)]) << 8) | (as(u32, src.bytes.data[pos + as(index, 6)]) << 16) | (as(u32, src.bytes.data[pos + as(index, 7)]) << 24)
    let n_u32: u32 = as(u32, src.bytes.data[pos + as(index, 8)]) | (as(u32, src.bytes.data[pos + as(index, 9)]) << 8) | (as(u32, src.bytes.data[pos + as(index, 10)]) << 16) | (as(u32, src.bytes.data[pos + as(index, 11)]) << 24)
    let sec: PatchSection = { kind = kind, index = as(index, idx_u16), bytes = { data = src.bytes.data + as(index, off_u32), len = as(index, n_u32) } }
    jump section(section = sec, next = cursor + as(index, 1))
end
block dir_overflow()
    jump malformed(pos = as(index, 12), code = 17)
end
]]
-------------------------------------------------------------------------------
-- Primitive patch plan preparation
-------------------------------------------------------------------------------

R.prepare_tuning = R.prepare_tuning(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let t: TuningTable = { ratios = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0), root_midi_note = 69, root_hz = as(f32, 440.0) }
        jump defaulted(tuning = t)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 8) then jump malformed(pos = as(index, 0), code = 2) end
    if section.bytes.data[as(index, 1)] ~= 0 then jump malformed(pos = as(index, 1), code = 3) end
    let count_u16: u16 = as(u16, section.bytes.data[as(index, 2)]) | (as(u16, section.bytes.data[as(index, 3)]) << 8)
    let count: index = as(index, count_u16)
    let root_bits: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let root_hz: f32 = bitcast(f32, root_bits)
    if root_hz ~= root_hz or root_hz < as(f32, 0.0) or root_hz == as(f32, 0.0) or root_hz > as(f32, 3.402823e38) then jump malformed(pos = as(index, 4), code = 4) end
    let need: index = as(index, 8) + count * as(index, 4)
    if need < as(index, 8) then jump malformed(pos = as(index, 2), code = 5) end
    if section.bytes.len < need then jump malformed(pos = section.bytes.len, code = 6) end
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = count * as(index, 4)
    let start: index = ((*arena).used + as(index, 3)) & ~as(index, 3)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let ratios: ptr(f32) = as(ptr(f32), (*arena).data + start)
    arena[0].used = finish
    jump copy_ratio(i = as(index, 0), ratios = ratios, count = count, root_hz = root_hz)
end
block copy_ratio(i: index, ratios: ptr(f32), count: index, root_hz: f32)
    if i >= count then jump tuning_done(ratios = ratios, count = count, root_hz = root_hz) end
    let pos: index = as(index, 8) + i * as(index, 4)
    let bits: u32 = as(u32, section.bytes.data[pos]) | (as(u32, section.bytes.data[pos + as(index, 1)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 2)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 3)]) << 24)
    let x: f32 = bitcast(f32, bits)
    if x ~= x or x < as(f32, 0.0) or x == as(f32, 0.0) or x > as(f32, 3.402823e38) then jump malformed(pos = pos, code = 7) end
    ratios[i] = x
    jump copy_ratio(i = i + as(index, 1), ratios = ratios, count = count, root_hz = root_hz)
end
block tuning_done(ratios: ptr(f32), count: index, root_hz: f32)
    let t: TuningTable = { ratios = view(ratios, count), count = count, root_midi_note = section.bytes.data[as(index, 0)], root_hz = root_hz }
    jump ready(tuning = t)
end
]]

R.prepare_envelope = R.prepare_envelope(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let p: EnvelopePlan = { delay_s = as(f32, 0.0), attack_s = as(f32, 0.0), hold_s = as(f32, 0.0), decay_s = as(f32, 0.0), sustain_level = as(f32, 1.0), release_s = as(f32, 0.0), curve = 0 }
        jump defaulted(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 28) then jump malformed(pos = section.bytes.len, code = 2) end
    let b0: u32 = as(u32, section.bytes.data[as(index, 0)]) | (as(u32, section.bytes.data[as(index, 1)]) << 8) | (as(u32, section.bytes.data[as(index, 2)]) << 16) | (as(u32, section.bytes.data[as(index, 3)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let b4: u32 = as(u32, section.bytes.data[as(index, 16)]) | (as(u32, section.bytes.data[as(index, 17)]) << 8) | (as(u32, section.bytes.data[as(index, 18)]) << 16) | (as(u32, section.bytes.data[as(index, 19)]) << 24)
    let b5: u32 = as(u32, section.bytes.data[as(index, 20)]) | (as(u32, section.bytes.data[as(index, 21)]) << 8) | (as(u32, section.bytes.data[as(index, 22)]) << 16) | (as(u32, section.bytes.data[as(index, 23)]) << 24)
    let d: f32 = bitcast(f32, b0)
    let a: f32 = bitcast(f32, b1)
    let h: f32 = bitcast(f32, b2)
    let dc: f32 = bitcast(f32, b3)
    let s: f32 = bitcast(f32, b4)
    let r: f32 = bitcast(f32, b5)
    let curve: u8 = section.bytes.data[as(index, 24)]
    if curve > 4 then jump malformed(pos = as(index, 24), code = 3) end
    if d ~= d or a ~= a or h ~= h or dc ~= dc or s ~= s or r ~= r then jump malformed(pos = as(index, 0), code = 4) end
    let p: EnvelopePlan = { delay_s = d, attack_s = a, hold_s = h, decay_s = dc, sustain_level = s, release_s = r, curve = curve }
    jump ready(plan = p)
end
]]

R.prepare_lfo = R.prepare_lfo(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let p: LfoPlan = { shape = 0, rate_hz = as(f32, 0.0), depth = as(f32, 0.0), phase_offset = as(f32, 0.0), tempo_sync = false }
        jump defaulted(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 20) then jump malformed(pos = section.bytes.len, code = 2) end
    let shape: u8 = section.bytes.data[as(index, 0)]
    if shape > 6 then jump malformed(pos = as(index, 0), code = 3) end
    let rbits: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let dbits: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let pbits: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let rate: f32 = bitcast(f32, rbits)
    let depth: f32 = bitcast(f32, dbits)
    let phase: f32 = bitcast(f32, pbits)
    if rate ~= rate or depth ~= depth or phase ~= phase then jump malformed(pos = as(index, 4), code = 4) end
    let p: LfoPlan = { shape = shape, rate_hz = rate, depth = depth, phase_offset = phase, tempo_sync = section.bytes.data[as(index, 16)] ~= 0 }
    jump ready(plan = p)
end
]]

R.prepare_filter = R.prepare_filter(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let p: FilterPlan = { model = 0, cutoff_hz = as(f32, 0.0), resonance = as(f32, 0.0), drive = as(f32, 0.0), keytrack = as(f32, 0.0) }
        jump bypass(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 20) then jump malformed(pos = section.bytes.len, code = 2) end
    let model: u8 = section.bytes.data[as(index, 0)]
    if model > 7 then jump malformed(pos = as(index, 0), code = 3) end
    let b0: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[as(index, 16)]) | (as(u32, section.bytes.data[as(index, 17)]) << 8) | (as(u32, section.bytes.data[as(index, 18)]) << 16) | (as(u32, section.bytes.data[as(index, 19)]) << 24)
    let c: f32 = bitcast(f32, b0)
    let q: f32 = bitcast(f32, b1)
    let d: f32 = bitcast(f32, b2)
    let k: f32 = bitcast(f32, b3)
    if c ~= c or q ~= q or d ~= d or k ~= k then jump malformed(pos = as(index, 4), code = 4) end
    let p: FilterPlan = { model = model, cutoff_hz = c, resonance = q, drive = d, keytrack = k }
    if model == 0 then jump bypass(plan = p) end
    jump ready(plan = p)
end
]]

R.prepare_modulation = R.prepare_modulation(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let p: ModulationPlan = { routes = view(as(ptr(ModRoute), nil), as(index, 0)) }
        jump empty(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 4) then jump malformed(pos = section.bytes.len, code = 2) end
    let count_u32: u32 = as(u32, section.bytes.data[as(index, 0)]) | (as(u32, section.bytes.data[as(index, 1)]) << 8) | (as(u32, section.bytes.data[as(index, 2)]) << 16) | (as(u32, section.bytes.data[as(index, 3)]) << 24)
    let count: index = as(index, count_u32)
    let need: index = as(index, 4) + count * as(index, 12)
    if need < as(index, 4) then jump malformed(pos = as(index, 0), code = 3) end
    if section.bytes.len < need then jump malformed(pos = section.bytes.len, code = 4) end
    if count == 0 then
        let p: ModulationPlan = { routes = view(as(ptr(ModRoute), nil), as(index, 0)) }
        jump empty(plan = p)
    end
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = count * as(index, 12)
    let start: index = ((*arena).used + as(index, 3)) & ~as(index, 3)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let routes: ptr(ModRoute) = as(ptr(ModRoute), (*arena).data + start)
    arena[0].used = finish
    jump copy_route(i = as(index, 0), routes = routes, count = count)
end
block copy_route(i: index, routes: ptr(ModRoute), count: index)
    if i >= count then jump routes_done(routes = routes, count = count) end
    let pos: index = as(index, 4) + i * as(index, 12)
    let source: u8 = section.bytes.data[pos]
    let dest: u8 = section.bytes.data[pos + as(index, 1)]
    if source > 9 then jump malformed(pos = pos, code = 5) end
    if dest < 1 or dest > 9 then jump malformed(pos = pos + as(index, 1), code = 6) end
    let abits: u32 = as(u32, section.bytes.data[pos + as(index, 8)]) | (as(u32, section.bytes.data[pos + as(index, 9)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 10)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 11)]) << 24)
    let amount: f32 = bitcast(f32, abits)
    if amount ~= amount then jump malformed(pos = pos + as(index, 8), code = 7) end
    routes[i].source = source; routes[i].dest = dest; routes[i].source_index = section.bytes.data[pos + as(index, 2)]; routes[i].dest_index = section.bytes.data[pos + as(index, 3)]; routes[i].cc_number = section.bytes.data[pos + as(index, 4)]; routes[i].amount = amount
    jump copy_route(i = i + as(index, 1), routes = routes, count = count)
end
block routes_done(routes: ptr(ModRoute), count: index)
    let p: ModulationPlan = { routes = view(routes, count) }
    jump ready(plan = p)
end
]]

R.prepare_additive_plan = R.prepare_additive_plan(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let parts: AdditivePartialPlan = { ratios = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), phase_offsets = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
        let p: AdditivePlan = { partials = parts, detune_cents = as(f32, 0.0), stereo_spread = as(f32, 0.0), phase_random = as(f32, 0.0) }
        jump disabled(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 16) then jump malformed(pos = section.bytes.len, code = 2) end
    if section.bytes.data[as(index, 2)] ~= 0 or section.bytes.data[as(index, 3)] ~= 0 then jump malformed(pos = as(index, 2), code = 3) end
    let count_u16: u16 = as(u16, section.bytes.data[as(index, 0)]) | (as(u16, section.bytes.data[as(index, 1)]) << 8)
    let count: index = as(index, count_u16)
    let need: index = as(index, 16) + count * as(index, 16)
    if need < as(index, 16) then jump malformed(pos = as(index, 0), code = 4) end
    if section.bytes.len < need then jump malformed(pos = section.bytes.len, code = 5) end
    let d_bits: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let s_bits: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let p_bits: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let detune: f32 = bitcast(f32, d_bits)
    let spread: f32 = bitcast(f32, s_bits)
    let phase_random: f32 = bitcast(f32, p_bits)
    if detune ~= detune or spread ~= spread or phase_random ~= phase_random then jump malformed(pos = as(index, 4), code = 6) end
    if count == 0 then
        let parts: AdditivePartialPlan = { ratios = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), phase_offsets = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
        let p: AdditivePlan = { partials = parts, detune_cents = detune, stereo_spread = spread, phase_random = phase_random }
        jump disabled(plan = p)
    end
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = count * as(index, 16)
    let start: index = ((*arena).used + as(index, 3)) & ~as(index, 3)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let ratios: ptr(f32) = as(ptr(f32), (*arena).data + start)
    let gains: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 4))
    let phases: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 8))
    let pans: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 12))
    arena[0].used = finish
    jump copy_additive(i = as(index, 0), count = count, ratios = ratios, gains = gains, phases = phases, pans = pans, detune = detune, spread = spread, phase_random = phase_random)
end
block copy_additive(i: index, count: index, ratios: ptr(f32), gains: ptr(f32), phases: ptr(f32), pans: ptr(f32), detune: f32, spread: f32, phase_random: f32)
    if i >= count then jump additive_done(count = count, ratios = ratios, gains = gains, phases = phases, pans = pans, detune = detune, spread = spread, phase_random = phase_random) end
    let p0: index = as(index, 16) + i * as(index, 4)
    let p1: index = as(index, 16) + count * as(index, 4) + i * as(index, 4)
    let p2: index = as(index, 16) + count * as(index, 8) + i * as(index, 4)
    let p3: index = as(index, 16) + count * as(index, 12) + i * as(index, 4)
    let b0: u32 = as(u32, section.bytes.data[p0]) | (as(u32, section.bytes.data[p0 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p0 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p0 + as(index, 3)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[p1]) | (as(u32, section.bytes.data[p1 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p1 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p1 + as(index, 3)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[p2]) | (as(u32, section.bytes.data[p2 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p2 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p2 + as(index, 3)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[p3]) | (as(u32, section.bytes.data[p3 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p3 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p3 + as(index, 3)]) << 24)
    let x0: f32 = bitcast(f32, b0)
    let x1: f32 = bitcast(f32, b1)
    let x2: f32 = bitcast(f32, b2)
    let x3: f32 = bitcast(f32, b3)
    if x0 ~= x0 or x1 ~= x1 or x2 ~= x2 or x3 ~= x3 then jump malformed(pos = p0, code = 7) end
    ratios[i] = x0; gains[i] = x1; phases[i] = x2; pans[i] = x3
    jump copy_additive(i = i + as(index, 1), count = count, ratios = ratios, gains = gains, phases = phases, pans = pans, detune = detune, spread = spread, phase_random = phase_random)
end
block additive_done(count: index, ratios: ptr(f32), gains: ptr(f32), phases: ptr(f32), pans: ptr(f32), detune: f32, spread: f32, phase_random: f32)
    let parts: AdditivePartialPlan = { ratios = view(ratios, count), gains = view(gains, count), phase_offsets = view(phases, count), pan = view(pans, count), count = count }
    let p: AdditivePlan = { partials = parts, detune_cents = detune, stereo_spread = spread, phase_random = phase_random }
    jump ready(plan = p)
end
]]

R.prepare_subtractive_plan = R.prepare_subtractive_plan(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let bands: NoiseBandPlan = { center_hz = view(as(ptr(f32), nil), as(index, 0)), bandwidth_hz = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
        let p: SubtractivePlan = { bands = bands, source_color = as(f32, 0.0), stereo_width = as(f32, 0.0) }
        jump disabled(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 12) then jump malformed(pos = section.bytes.len, code = 2) end
    if section.bytes.data[as(index, 2)] ~= 0 or section.bytes.data[as(index, 3)] ~= 0 then jump malformed(pos = as(index, 2), code = 3) end
    let count_u16: u16 = as(u16, section.bytes.data[as(index, 0)]) | (as(u16, section.bytes.data[as(index, 1)]) << 8)
    let count: index = as(index, count_u16)
    let need: index = as(index, 12) + count * as(index, 16)
    if need < as(index, 12) then jump malformed(pos = as(index, 0), code = 4) end
    if section.bytes.len < need then jump malformed(pos = section.bytes.len, code = 5) end
    let c_bits: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let w_bits: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let color: f32 = bitcast(f32, c_bits)
    let width: f32 = bitcast(f32, w_bits)
    if color ~= color or width ~= width then jump malformed(pos = as(index, 4), code = 6) end
    if count == 0 then
        let bands: NoiseBandPlan = { center_hz = view(as(ptr(f32), nil), as(index, 0)), bandwidth_hz = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
        let p: SubtractivePlan = { bands = bands, source_color = color, stereo_width = width }
        jump disabled(plan = p)
    end
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = count * as(index, 16)
    let start: index = ((*arena).used + as(index, 3)) & ~as(index, 3)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let centers: ptr(f32) = as(ptr(f32), (*arena).data + start)
    let widths: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 4))
    let gains: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 8))
    let pans: ptr(f32) = as(ptr(f32), (*arena).data + start + count * as(index, 12))
    arena[0].used = finish
    jump copy_subtractive(i = as(index, 0), count = count, centers = centers, widths = widths, gains = gains, pans = pans, color = color, stereo_width = width)
end
block copy_subtractive(i: index, count: index, centers: ptr(f32), widths: ptr(f32), gains: ptr(f32), pans: ptr(f32), color: f32, stereo_width: f32)
    if i >= count then jump subtractive_done(count = count, centers = centers, widths = widths, gains = gains, pans = pans, color = color, stereo_width = stereo_width) end
    let p0: index = as(index, 12) + i * as(index, 4)
    let p1: index = as(index, 12) + count * as(index, 4) + i * as(index, 4)
    let p2: index = as(index, 12) + count * as(index, 8) + i * as(index, 4)
    let p3: index = as(index, 12) + count * as(index, 12) + i * as(index, 4)
    let b0: u32 = as(u32, section.bytes.data[p0]) | (as(u32, section.bytes.data[p0 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p0 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p0 + as(index, 3)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[p1]) | (as(u32, section.bytes.data[p1 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p1 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p1 + as(index, 3)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[p2]) | (as(u32, section.bytes.data[p2 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p2 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p2 + as(index, 3)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[p3]) | (as(u32, section.bytes.data[p3 + as(index, 1)]) << 8) | (as(u32, section.bytes.data[p3 + as(index, 2)]) << 16) | (as(u32, section.bytes.data[p3 + as(index, 3)]) << 24)
    let x0: f32 = bitcast(f32, b0)
    let x1: f32 = bitcast(f32, b1)
    let x2: f32 = bitcast(f32, b2)
    let x3: f32 = bitcast(f32, b3)
    if x0 ~= x0 or x1 ~= x1 or x2 ~= x2 or x3 ~= x3 then jump malformed(pos = p0, code = 7) end
    centers[i] = x0; widths[i] = x1; gains[i] = x2; pans[i] = x3
    jump copy_subtractive(i = i + as(index, 1), count = count, centers = centers, widths = widths, gains = gains, pans = pans, color = color, stereo_width = stereo_width)
end
block subtractive_done(count: index, centers: ptr(f32), widths: ptr(f32), gains: ptr(f32), pans: ptr(f32), color: f32, stereo_width: f32)
    let bands: NoiseBandPlan = { center_hz = view(centers, count), bandwidth_hz = view(widths, count), gains = view(gains, count), pan = view(pans, count), count = count }
    let p: SubtractivePlan = { bands = bands, source_color = color, stereo_width = stereo_width }
    jump ready(plan = p)
end
]]

R.prepare_effect_bus = R.prepare_effect_bus(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let p: EffectBusPlan = { slots = view(as(ptr(EffectSlotPlan), nil), as(index, 0)), slot_count = as(index, 0), send_gain = as(f32, 0.0) }
        jump empty(bus = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 8) then jump malformed(pos = section.bytes.len, code = 2) end
    if section.bytes.data[as(index, 2)] ~= 0 or section.bytes.data[as(index, 3)] ~= 0 then jump malformed(pos = as(index, 2), code = 3) end
    let count_u16: u16 = as(u16, section.bytes.data[as(index, 0)]) | (as(u16, section.bytes.data[as(index, 1)]) << 8)
    let count: index = as(index, count_u16)
    let need: index = as(index, 8) + count * as(index, 28)
    if need < as(index, 8) then jump malformed(pos = as(index, 0), code = 4) end
    if section.bytes.len < need then jump malformed(pos = section.bytes.len, code = 5) end
    let g_bits: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let send_gain: f32 = bitcast(f32, g_bits)
    if send_gain ~= send_gain then jump malformed(pos = as(index, 4), code = 6) end
    if count == 0 then
        let p: EffectBusPlan = { slots = view(as(ptr(EffectSlotPlan), nil), as(index, 0)), slot_count = as(index, 0), send_gain = send_gain }
        jump empty(bus = p)
    end
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = count * as(index, 28)
    let start: index = ((*arena).used + as(index, 3)) & ~as(index, 3)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let slots: ptr(EffectSlotPlan) = as(ptr(EffectSlotPlan), (*arena).data + start)
    arena[0].used = finish
    jump copy_slot(i = as(index, 0), count = count, slots = slots, send_gain = send_gain)
end
block copy_slot(i: index, count: index, slots: ptr(EffectSlotPlan), send_gain: f32)
    if i >= count then jump bus_done(count = count, slots = slots, send_gain = send_gain) end
    let pos: index = as(index, 8) + i * as(index, 28)
    let kind: u8 = section.bytes.data[pos]
    if kind > 7 then jump malformed(pos = pos, code = 7) end
    let b0: u32 = as(u32, section.bytes.data[pos + as(index, 4)]) | (as(u32, section.bytes.data[pos + as(index, 5)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 6)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 7)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[pos + as(index, 8)]) | (as(u32, section.bytes.data[pos + as(index, 9)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 10)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 11)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[pos + as(index, 12)]) | (as(u32, section.bytes.data[pos + as(index, 13)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 14)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 15)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[pos + as(index, 16)]) | (as(u32, section.bytes.data[pos + as(index, 17)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 18)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 19)]) << 24)
    let b4: u32 = as(u32, section.bytes.data[pos + as(index, 20)]) | (as(u32, section.bytes.data[pos + as(index, 21)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 22)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 23)]) << 24)
    let b5: u32 = as(u32, section.bytes.data[pos + as(index, 24)]) | (as(u32, section.bytes.data[pos + as(index, 25)]) << 8) | (as(u32, section.bytes.data[pos + as(index, 26)]) << 16) | (as(u32, section.bytes.data[pos + as(index, 27)]) << 24)
    let mix: f32 = bitcast(f32, b0)
    let gain: f32 = bitcast(f32, b1)
    let p0: f32 = bitcast(f32, b2)
    let p1: f32 = bitcast(f32, b3)
    let p2: f32 = bitcast(f32, b4)
    let p3: f32 = bitcast(f32, b5)
    if mix ~= mix or gain ~= gain or p0 ~= p0 or p1 ~= p1 or p2 ~= p2 or p3 ~= p3 then jump malformed(pos = pos + as(index, 4), code = 8) end
    slots[i].kind = kind; slots[i].mix = mix; slots[i].gain = gain; slots[i].p0 = p0; slots[i].p1 = p1; slots[i].p2 = p2; slots[i].p3 = p3
    jump copy_slot(i = i + as(index, 1), count = count, slots = slots, send_gain = send_gain)
end
block bus_done(count: index, slots: ptr(EffectSlotPlan), send_gain: f32)
    let p: EffectBusPlan = { slots = view(slots, count), slot_count = count, send_gain = send_gain }
    jump ready(bus = p)
end
]]


R.prepare_effect_slot = R.prepare_effect_slot(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let s: EffectSlotPlan = { kind = 0, mix = as(f32, 0.0), gain = as(f32, 1.0), p0 = as(f32, 0.0), p1 = as(f32, 0.0), p2 = as(f32, 0.0), p3 = as(f32, 0.0) }
        jump bypass(slot = s)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 28) then jump malformed(pos = section.bytes.len, code = 2) end
    let kind: u8 = section.bytes.data[as(index, 0)]
    if kind > 7 then jump unsupported_effect(kind = kind) end
    let b0: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let b3: u32 = as(u32, section.bytes.data[as(index, 16)]) | (as(u32, section.bytes.data[as(index, 17)]) << 8) | (as(u32, section.bytes.data[as(index, 18)]) << 16) | (as(u32, section.bytes.data[as(index, 19)]) << 24)
    let b4: u32 = as(u32, section.bytes.data[as(index, 20)]) | (as(u32, section.bytes.data[as(index, 21)]) << 8) | (as(u32, section.bytes.data[as(index, 22)]) << 16) | (as(u32, section.bytes.data[as(index, 23)]) << 24)
    let b5: u32 = as(u32, section.bytes.data[as(index, 24)]) | (as(u32, section.bytes.data[as(index, 25)]) << 8) | (as(u32, section.bytes.data[as(index, 26)]) << 16) | (as(u32, section.bytes.data[as(index, 27)]) << 24)
    let mix: f32 = bitcast(f32, b0)
    let gain: f32 = bitcast(f32, b1)
    let p0: f32 = bitcast(f32, b2)
    let p1: f32 = bitcast(f32, b3)
    let p2: f32 = bitcast(f32, b4)
    let p3: f32 = bitcast(f32, b5)
    if mix ~= mix or gain ~= gain or p0 ~= p0 or p1 ~= p1 or p2 ~= p2 or p3 ~= p3 then jump malformed(pos = as(index, 4), code = 3) end
    let s: EffectSlotPlan = { kind = kind, mix = mix, gain = gain, p0 = p0, p1 = p1, p2 = p2, p3 = p3 }
    if kind == 0 then jump bypass(slot = s) end
    jump ready(slot = s)
end
]]

R.prepare_pad_plan = R.prepare_pad_plan(BODY)[[
entry start()
    if section.bytes.len == 0 then
        let ref: PadTableRef = { index = 0, generation = 0 }
        let spec: PadSpectralPlan = { table_ref = ref, table_length = as(index, 0), table_count = as(index, 0), base_frequency_hz = as(f32, 0.0), morph = as(f32, 0.0) }
        let p: PadPlan = { spectral = spec, position_lfo_amount = as(f32, 0.0) }
        jump disabled(plan = p)
    end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 24) then jump malformed(pos = section.bytes.len, code = 2) end
    if cache == nil then jump malformed(pos = as(index, 0), code = 3) end
    let table_u32: u32 = as(u32, section.bytes.data[as(index, 0)]) | (as(u32, section.bytes.data[as(index, 1)]) << 8) | (as(u32, section.bytes.data[as(index, 2)]) << 16) | (as(u32, section.bytes.data[as(index, 3)]) << 24)
    let len_u32: u32 = as(u32, section.bytes.data[as(index, 4)]) | (as(u32, section.bytes.data[as(index, 5)]) << 8) | (as(u32, section.bytes.data[as(index, 6)]) << 16) | (as(u32, section.bytes.data[as(index, 7)]) << 24)
    let count_u32: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let table_i: index = as(index, table_u32)
    if table_i >= (*cache).table_count then jump malformed(pos = as(index, 0), code = 4) end
    let b0: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let b1: u32 = as(u32, section.bytes.data[as(index, 16)]) | (as(u32, section.bytes.data[as(index, 17)]) << 8) | (as(u32, section.bytes.data[as(index, 18)]) << 16) | (as(u32, section.bytes.data[as(index, 19)]) << 24)
    let b2: u32 = as(u32, section.bytes.data[as(index, 20)]) | (as(u32, section.bytes.data[as(index, 21)]) << 8) | (as(u32, section.bytes.data[as(index, 22)]) << 16) | (as(u32, section.bytes.data[as(index, 23)]) << 24)
    let base: f32 = bitcast(f32, b0)
    let morph: f32 = bitcast(f32, b1)
    let pos_lfo: f32 = bitcast(f32, b2)
    if base ~= base or morph ~= morph or pos_lfo ~= pos_lfo then jump malformed(pos = as(index, 12), code = 5) end
    let ref: PadTableRef = { index = table_u32, generation = (*cache).table_generations[table_i] }
    let spec: PadSpectralPlan = { table_ref = ref, table_length = as(index, len_u32), table_count = as(index, count_u32), base_frequency_hz = base, morph = morph }
    let p: PadPlan = { spectral = spec, position_lfo_amount = pos_lfo }
    jump ready(plan = p)
end
]]


BODY.decode_patch_source = R.decode_patch_source
BODY.next_patch_section = R.next_patch_section
BODY.prepare_tuning = R.prepare_tuning
BODY.prepare_modulation = R.prepare_modulation
BODY.prepare_additive_plan = R.prepare_additive_plan
BODY.prepare_subtractive_plan = R.prepare_subtractive_plan
BODY.prepare_pad_plan = R.prepare_pad_plan

-------------------------------------------------------------------------------
-- Layer, part, and program preparation
-------------------------------------------------------------------------------

R.prepare_layer = R.prepare_layer(BODY)[[
entry start()
    if section.bytes.len == 0 then jump unsupported_feature(code = 1) end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 184) then jump malformed(pos = section.bytes.len, code = 2) end
    let first_note: u8 = section.bytes.data[as(index, 0)]
    let last_note: u8 = section.bytes.data[as(index, 1)]
    if first_note > last_note then jump malformed(pos = as(index, 0), code = 3) end
    let mono: bool = section.bytes.data[as(index, 2)] ~= 0
    let legato: bool = section.bytes.data[as(index, 3)] ~= 0
    let tr_bits: u16 = as(u16, section.bytes.data[as(index, 4)]) | (as(u16, section.bytes.data[as(index, 5)]) << 8)
    let tone_mask: u8 = section.bytes.data[as(index, 6)]
    if (tone_mask & ~as(u8, @{TONE_MASK_ALL})) ~= 0 then jump unsupported_feature(code = 2) end
    if tone_mask == 0 then jump unsupported_feature(code = 3) end
    let pb_bits: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let gain_bits: u32 = as(u32, section.bytes.data[as(index, 176)]) | (as(u32, section.bytes.data[as(index, 177)]) << 8) | (as(u32, section.bytes.data[as(index, 178)]) << 16) | (as(u32, section.bytes.data[as(index, 179)]) << 24)
    let pan_bits: u32 = as(u32, section.bytes.data[as(index, 180)]) | (as(u32, section.bytes.data[as(index, 181)]) << 8) | (as(u32, section.bytes.data[as(index, 182)]) << 16) | (as(u32, section.bytes.data[as(index, 183)]) << 24)
    let pb: f32 = bitcast(f32, pb_bits)
    let nominal_gain: f32 = bitcast(f32, gain_bits)
    let pan: f32 = bitcast(f32, pan_bits)
    if pb ~= pb or nominal_gain ~= nominal_gain or pan ~= pan then jump malformed(pos = as(index, 8), code = 4) end
    let keymap: KeyMapPlan = { first_note = first_note, last_note = last_note, transpose_semitones = bitcast(i16, tr_bits), pitch_bend_range_cents = pb, legato = legato, mono = mono }
    let amp_env: EnvelopePlan = as(ptr(EnvelopePlan), section.bytes.data + as(index, 12))[0]
    let pitch_env: EnvelopePlan = as(ptr(EnvelopePlan), section.bytes.data + as(index, 40))[0]
    let filter_env: EnvelopePlan = as(ptr(EnvelopePlan), section.bytes.data + as(index, 68))[0]
    let lfo1: LfoPlan = as(ptr(LfoPlan), section.bytes.data + as(index, 96))[0]
    let lfo2: LfoPlan = as(ptr(LfoPlan), section.bytes.data + as(index, 116))[0]
    let filter: FilterPlan = as(ptr(FilterPlan), section.bytes.data + as(index, 136))[0]
    let mods: ModulationPlan = { routes = view(as(ptr(ModRoute), nil), as(index, 0)) }
    let partials: AdditivePartialPlan = { ratios = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), phase_offsets = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
    let additive: AdditivePlan = { partials = partials, detune_cents = as(f32,0.0), stereo_spread = as(f32, 0.0), phase_random = as(f32, 0.0) }
    let bands: NoiseBandPlan = { center_hz = view(as(ptr(f32), nil), as(index, 0)), bandwidth_hz = view(as(ptr(f32), nil), as(index, 0)), gains = view(as(ptr(f32), nil), as(index, 0)), pan = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0) }
    let subtractive: SubtractivePlan = { bands = bands, source_color = as(f32, 0.0), stereo_width = as(f32, 0.0) }
    let pad_ref: PadTableRef = { index = as(u32, 0), generation = as(u16, 0) }
    let spectral: PadSpectralPlan = { table_ref = pad_ref, table_length = as(index, 0), table_count = as(index, 0), base_frequency_hz = as(f32, 0.0), morph = as(f32, 0.0) }
    let pad: PadPlan = { spectral = spectral, position_lfo_amount = as(f32, 0.0) }
    let layer: LayerPlan = { keymap = keymap, amp_env = amp_env, pitch_env = pitch_env, filter_env = filter_env, lfo1 = lfo1, lfo2 = lfo2, filter = filter, mods = mods, additive = additive, subtractive = subtractive, pad = pad, tone_mask = tone_mask, nominal_gain = nominal_gain, pan = pan }
    jump ready(layer = layer)
end
]]

R.prepare_part = R.prepare_part(BODY)[[
entry start()
    if section.bytes.len == 0 then jump disabled_empty() end
    if section.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if section.bytes.len < as(index, 32) then jump malformed(pos = section.bytes.len, code = 2) end
    let layer_count_u16: u16 = as(u16, section.bytes.data[as(index, 2)]) | (as(u16, section.bytes.data[as(index, 3)]) << 8)
    let layer_count: index = as(index, layer_count_u16)
    if arena == nil then jump exhausted() end
    if (*arena).data == nil then jump exhausted() end
    let bytes_needed: index = layer_count * as(index, 472)
    let start: index = ((*arena).used + as(index, 7)) & ~as(index, 7)
    let finish: index = start + bytes_needed
    if finish < start then jump exhausted() end
    if finish > (*arena).cap then jump exhausted() end
    let layers: ptr(LayerPlan) = as(ptr(LayerPlan), (*arena).data + start)
    arena[0].used = finish
    jump init_layers(i = as(index, 0), layers = layers, layer_count = layer_count)
end
block disabled_empty()
    let empty_layers: view(LayerPlan) = view(as(ptr(LayerPlan), nil), as(index, 0))
    let steal: VoiceStealPolicy = { mode = 0, same_note_bonus = as(f32, 0.0), release_bonus = as(f32, 0.0), age_weight = as(f32, 0.0), level_weight = as(f32, 0.0) }
    let part: PartPlan = { layers = empty_layers, layer_count = as(index, 0), midi_channel = 0, enabled = false, max_polyphony = as(index, 0), steal = steal, gain = as(f32, 0.0), pan = as(f32, 0.0) }
    jump disabled(part = part)
end
block init_layers(i: index, layers: ptr(LayerPlan), layer_count: index)
    if i >= layer_count then jump part_done(layers = layers, layer_count = layer_count) end
    layers[i].tone_mask = 0
    layers[i].nominal_gain = as(f32, 0.0)
    layers[i].pan = as(f32, 0.0)
    jump init_layers(i = i + as(index, 1), layers = layers, layer_count = layer_count)
end
block part_done(layers: ptr(LayerPlan), layer_count: index)
    let gbits: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    let pbits: u32 = as(u32, section.bytes.data[as(index, 12)]) | (as(u32, section.bytes.data[as(index, 13)]) << 8) | (as(u32, section.bytes.data[as(index, 14)]) << 16) | (as(u32, section.bytes.data[as(index, 15)]) << 24)
    let sbits: u32 = as(u32, section.bytes.data[as(index, 16)]) | (as(u32, section.bytes.data[as(index, 17)]) << 8) | (as(u32, section.bytes.data[as(index, 18)]) << 16) | (as(u32, section.bytes.data[as(index, 19)]) << 24)
    let rbits: u32 = as(u32, section.bytes.data[as(index, 20)]) | (as(u32, section.bytes.data[as(index, 21)]) << 8) | (as(u32, section.bytes.data[as(index, 22)]) << 16) | (as(u32, section.bytes.data[as(index, 23)]) << 24)
    let abits: u32 = as(u32, section.bytes.data[as(index, 24)]) | (as(u32, section.bytes.data[as(index, 25)]) << 8) | (as(u32, section.bytes.data[as(index, 26)]) << 16) | (as(u32, section.bytes.data[as(index, 27)]) << 24)
    let lbits: u32 = as(u32, section.bytes.data[as(index, 28)]) | (as(u32, section.bytes.data[as(index, 29)]) << 8) | (as(u32, section.bytes.data[as(index, 30)]) << 16) | (as(u32, section.bytes.data[as(index, 31)]) << 24)
    let gain: f32 = bitcast(f32, gbits)
    let pan: f32 = bitcast(f32, pbits)
    let steal: VoiceStealPolicy = { mode = section.bytes.data[as(index, 6)], same_note_bonus = bitcast(f32, sbits), release_bonus = bitcast(f32, rbits), age_weight = bitcast(f32, abits), level_weight = bitcast(f32, lbits) }
    if gain ~= gain or pan ~= pan or steal.same_note_bonus ~= steal.same_note_bonus or steal.release_bonus ~= steal.release_bonus or steal.age_weight ~= steal.age_weight or steal.level_weight ~= steal.level_weight then jump malformed(pos = as(index, 8), code = 3) end
    let part: PartPlan = { layers = view(layers, layer_count), layer_count = layer_count, midi_channel = section.bytes.data[as(index, 0)], enabled = section.bytes.data[as(index, 1)] ~= 0, max_polyphony = as(index, as(u16, section.bytes.data[as(index, 4)]) | (as(u16, section.bytes.data[as(index, 5)]) << 8)), steal = steal, gain = gain, pan = pan }
    if not part.enabled then jump disabled(part = part) end
    jump ready(part = part)
end
]]

R.validate_program = R.validate_program(BODY)[[
entry start()
    if program == nil then jump invalid(code = 1) end
    if (*program).part_count <= 0 then jump invalid(code = 2) end
    if len((*program).parts) < (*program).part_count then jump invalid(code = 3) end
    if len((*program).effects.insert_fx) < (*program).effects.insert_count then jump invalid(code = 40) end
    if len((*program).effects.send_fx) < (*program).effects.send_count then jump invalid(code = 41) end
    if len((*program).effects.send_routes) < (*program).effects.send_route_count then jump invalid(code = 42) end
    if (*program).tuning.root_hz ~= (*program).tuning.root_hz or (*program).tuning.root_hz <= as(f32, 0.0) or (*program).tuning.root_hz > as(f32, 3.402823e38) then jump invalid(code = 43) end
    if (*program).tuning.count > len((*program).tuning.ratios) then jump invalid(code = 44) end
    jump check_tuning(i = as(index, 0))
end
block check_tuning(i: index)
    if i >= (*program).tuning.count then jump check_part(i = as(index, 0)) end
    let ratio: f32 = (*program).tuning.ratios[i]
    if ratio ~= ratio or ratio <= as(f32, 0.0) or ratio > as(f32, 3.402823e38) then jump invalid(code = 45) end
    jump check_tuning(i = i + as(index, 1))
end
block check_part(i: index)
    if i >= (*program).part_count then jump check_insert_bus(i = as(index, 0)) end
    let part: PartPlan = (*program).parts[i]
    if part.layer_count < 0 then jump invalid(code = 4) end
    if len(part.layers) < part.layer_count then jump invalid(code = 5) end
    if part.gain ~= part.gain or part.pan ~= part.pan then jump invalid(code = 6) end
    if part.steal.same_note_bonus ~= part.steal.same_note_bonus or part.steal.release_bonus ~= part.steal.release_bonus or part.steal.age_weight ~= part.steal.age_weight or part.steal.level_weight ~= part.steal.level_weight then jump invalid(code = 20) end
    if part.enabled then
        if part.layer_count <= 0 then jump invalid(code = 21) end
        if part.steal.mode ~= @{VOICE_STEAL_OLDEST} and part.steal.mode ~= @{VOICE_STEAL_QUIETEST} and part.steal.mode ~= @{VOICE_STEAL_RELEASE_FIRST} and part.steal.mode ~= @{VOICE_STEAL_SAME_NOTE} then jump invalid(code = 22) end
    end
    jump check_layer(part = part, j = as(index, 0), next_part = i + as(index, 1))
end
block check_layer(part: PartPlan, j: index, next_part: index)
    if j >= part.layer_count then jump check_part(i = next_part) end
    let layer: LayerPlan = part.layers[j]
    if part.enabled then
        if layer.keymap.first_note > layer.keymap.last_note then jump invalid(code = 7) end
        if (layer.tone_mask & ~as(u8, @{TONE_MASK_ALL})) ~= 0 then jump invalid(code = 8) end
        if layer.tone_mask == 0 then jump invalid(code = 9) end
    end
    if layer.nominal_gain ~= layer.nominal_gain or layer.pan ~= layer.pan or layer.keymap.pitch_bend_range_cents ~= layer.keymap.pitch_bend_range_cents then jump invalid(code = 10) end
    if layer.amp_env.curve > 4 or layer.pitch_env.curve > 4 or layer.filter_env.curve > 4 then jump invalid(code = 11) end
    if layer.lfo1.shape > 6 or layer.lfo2.shape > 6 then jump invalid(code = 12) end
    if layer.filter.model > 7 then jump invalid(code = 13) end
    if layer.amp_env.delay_s ~= layer.amp_env.delay_s or layer.amp_env.attack_s ~= layer.amp_env.attack_s or layer.amp_env.hold_s ~= layer.amp_env.hold_s or layer.amp_env.decay_s ~= layer.amp_env.decay_s or layer.amp_env.sustain_level ~= layer.amp_env.sustain_level or layer.amp_env.release_s ~= layer.amp_env.release_s then jump invalid(code = 14) end
    if layer.pitch_env.delay_s ~= layer.pitch_env.delay_s or layer.pitch_env.attack_s ~= layer.pitch_env.attack_s or layer.pitch_env.hold_s ~= layer.pitch_env.hold_s or layer.pitch_env.decay_s ~= layer.pitch_env.decay_s or layer.pitch_env.sustain_level ~= layer.pitch_env.sustain_level or layer.pitch_env.release_s ~= layer.pitch_env.release_s then jump invalid(code = 15) end
    if layer.filter_env.delay_s ~= layer.filter_env.delay_s or layer.filter_env.attack_s ~= layer.filter_env.attack_s or layer.filter_env.hold_s ~= layer.filter_env.hold_s or layer.filter_env.decay_s ~= layer.filter_env.decay_s or layer.filter_env.sustain_level ~= layer.filter_env.sustain_level or layer.filter_env.release_s ~= layer.filter_env.release_s then jump invalid(code = 16) end
    if layer.lfo1.rate_hz ~= layer.lfo1.rate_hz or layer.lfo1.depth ~= layer.lfo1.depth or layer.lfo1.phase_offset ~= layer.lfo1.phase_offset or layer.lfo2.rate_hz ~= layer.lfo2.rate_hz or layer.lfo2.depth ~= layer.lfo2.depth or layer.lfo2.phase_offset ~= layer.lfo2.phase_offset then jump invalid(code = 17) end
    if layer.filter.cutoff_hz ~= layer.filter.cutoff_hz or layer.filter.resonance ~= layer.filter.resonance or layer.filter.drive ~= layer.filter.drive or layer.filter.keytrack ~= layer.filter.keytrack then jump invalid(code = 18) end
    if len(layer.mods.routes) < 0 then jump invalid(code = 19) end
    jump check_route(layer = layer, route_i = as(index, 0), part = part, j = j, next_part = next_part)
end
block check_route(layer: LayerPlan, route_i: index, part: PartPlan, j: index, next_part: index)
    if route_i >= len(layer.mods.routes) then jump check_additive(layer = layer, a_i = as(index, 0), part = part, j = j, next_part = next_part) end
    let r: ModRoute = layer.mods.routes[route_i]
    if r.source > 9 then jump invalid(code = 23) end
    if r.dest < 1 or r.dest > 9 then jump invalid(code = 24) end
    if r.amount ~= r.amount then jump invalid(code = 25) end
    jump check_route(layer = layer, route_i = route_i + as(index, 1), part = part, j = j, next_part = next_part)
end
block check_additive(layer: LayerPlan, a_i: index, part: PartPlan, j: index, next_part: index)
    let c: index = layer.additive.partials.count
    if c < 0 then jump invalid(code = 26) end
    if len(layer.additive.partials.ratios) < c or len(layer.additive.partials.gains) < c or len(layer.additive.partials.phase_offsets) < c or len(layer.additive.partials.pan) < c then jump invalid(code = 27) end
    if layer.additive.detune_cents ~= layer.additive.detune_cents or layer.additive.stereo_spread ~= layer.additive.stereo_spread or layer.additive.phase_random ~= layer.additive.phase_random then jump invalid(code = 28) end
    if a_i >= c then jump check_subtractive(layer = layer, s_i = as(index, 0), part = part, j = j, next_part = next_part) end
    let ar: f32 = layer.additive.partials.ratios[a_i]
    let ag: f32 = layer.additive.partials.gains[a_i]
    let ap: f32 = layer.additive.partials.phase_offsets[a_i]
    let apan: f32 = layer.additive.partials.pan[a_i]
    if ar ~= ar or ag ~= ag or ap ~= ap or apan ~= apan then jump invalid(code = 29) end
    jump check_additive(layer = layer, a_i = a_i + as(index, 1), part = part, j = j, next_part = next_part)
end
block check_subtractive(layer: LayerPlan, s_i: index, part: PartPlan, j: index, next_part: index)
    let c: index = layer.subtractive.bands.count
    if c < 0 then jump invalid(code = 30) end
    if len(layer.subtractive.bands.center_hz) < c or len(layer.subtractive.bands.bandwidth_hz) < c or len(layer.subtractive.bands.gains) < c or len(layer.subtractive.bands.pan) < c then jump invalid(code = 31) end
    if layer.subtractive.source_color ~= layer.subtractive.source_color or layer.subtractive.stereo_width ~= layer.subtractive.stereo_width then jump invalid(code = 32) end
    if s_i >= c then jump check_pad(layer = layer, part = part, j = j, next_part = next_part) end
    let sc: f32 = layer.subtractive.bands.center_hz[s_i]
    let sw: f32 = layer.subtractive.bands.bandwidth_hz[s_i]
    let sg: f32 = layer.subtractive.bands.gains[s_i]
    let span: f32 = layer.subtractive.bands.pan[s_i]
    if sc ~= sc or sw ~= sw or sg ~= sg or span ~= span then jump invalid(code = 33) end
    jump check_subtractive(layer = layer, s_i = s_i + as(index, 1), part = part, j = j, next_part = next_part)
end
block check_pad(layer: LayerPlan, part: PartPlan, j: index, next_part: index)
    if layer.pad.spectral.base_frequency_hz ~= layer.pad.spectral.base_frequency_hz or layer.pad.spectral.morph ~= layer.pad.spectral.morph or layer.pad.position_lfo_amount ~= layer.pad.position_lfo_amount then jump invalid(code = 34) end
    if layer.pad.spectral.table_length < 0 or layer.pad.spectral.table_count < 0 then jump invalid(code = 35) end
    jump check_layer(part = part, j = j + as(index, 1), next_part = next_part)
end
block check_insert_bus(i: index)
    if i >= (*program).effects.insert_count then jump check_send_bus(i = as(index, 0)) end
    let bus: EffectBusPlan = (*program).effects.insert_fx[i]
    if bus.slot_count < 0 then jump invalid(code = 46) end
    if len(bus.slots) < bus.slot_count then jump invalid(code = 47) end
    if bus.send_gain ~= bus.send_gain then jump invalid(code = 48) end
    jump check_insert_slot(bus_i = i, slot = as(index, 0))
end
block check_insert_slot(bus_i: index, slot: index)
    let bus: EffectBusPlan = (*program).effects.insert_fx[bus_i]
    if slot >= bus.slot_count then jump check_insert_bus(i = bus_i + as(index, 1)) end
    let s: EffectSlotPlan = bus.slots[slot]
    if s.kind > 7 then jump invalid(code = 49) end
    if s.mix ~= s.mix or s.gain ~= s.gain or s.p0 ~= s.p0 or s.p1 ~= s.p1 or s.p2 ~= s.p2 or s.p3 ~= s.p3 then jump invalid(code = 50) end
    jump check_insert_slot(bus_i = bus_i, slot = slot + as(index, 1))
end
block check_send_bus(i: index)
    if i >= (*program).effects.send_count then jump check_master_bus(slot = as(index, 0)) end
    let bus: EffectBusPlan = (*program).effects.send_fx[i]
    if bus.slot_count < 0 then jump invalid(code = 51) end
    if len(bus.slots) < bus.slot_count then jump invalid(code = 52) end
    if bus.send_gain ~= bus.send_gain then jump invalid(code = 53) end
    jump check_send_slot(bus_i = i, slot = as(index, 0))
end
block check_send_slot(bus_i: index, slot: index)
    let bus: EffectBusPlan = (*program).effects.send_fx[bus_i]
    if slot >= bus.slot_count then jump check_send_bus(i = bus_i + as(index, 1)) end
    let s: EffectSlotPlan = bus.slots[slot]
    if s.kind > 7 then jump invalid(code = 54) end
    if s.mix ~= s.mix or s.gain ~= s.gain or s.p0 ~= s.p0 or s.p1 ~= s.p1 or s.p2 ~= s.p2 or s.p3 ~= s.p3 then jump invalid(code = 55) end
    jump check_send_slot(bus_i = bus_i, slot = slot + as(index, 1))
end
block check_master_bus(slot: index)
    let bus: EffectBusPlan = (*program).effects.master_fx
    if bus.slot_count < 0 then jump invalid(code = 56) end
    if len(bus.slots) < bus.slot_count then jump invalid(code = 57) end
    if bus.send_gain ~= bus.send_gain then jump invalid(code = 58) end
    if slot >= bus.slot_count then jump valid() end
    let s: EffectSlotPlan = bus.slots[slot]
    if s.kind > 7 then jump invalid(code = 59) end
    if s.mix ~= s.mix or s.gain ~= s.gain or s.p0 ~= s.p0 or s.p1 ~= s.p1 or s.p2 ~= s.p2 or s.p3 ~= s.p3 then jump invalid(code = 60) end
    jump check_master_bus(slot = slot + as(index, 1))
end
]]

R.rebuild_pad_cache = R.rebuild_pad_cache(BODY)[[
entry start()
    if program == nil then jump invalid(code = 1) end
    if cache == nil then jump invalid(code = 2) end
    if arena == nil then jump invalid(code = 3) end
    if (*cache).table_count < 0 or (*cache).total_frames < 0 or (*cache).used_frames < 0 then jump invalid(code = 4) end
    if (*cache).used_frames > (*cache).total_frames then jump invalid(code = 5) end
    if (*cache).table_count > 0 then
        if (*cache).table_offsets == nil or (*cache).table_lengths == nil or (*cache).table_generations == nil then jump invalid(code = 6) end
    end
    jump scan_part(pi = as(index, 0), dirty = false)
end
block scan_part(pi: index, dirty: bool)
    if pi >= (*program).part_count then jump finish(dirty = dirty) end
    let part: PartPlan = (*program).parts[pi]
    jump scan_layer(pi = pi, li = as(index, 0), dirty = dirty)
end
block scan_layer(pi: index, li: index, dirty: bool)
    let part: PartPlan = (*program).parts[pi]
    if li >= part.layer_count then jump scan_part(pi = pi + as(index, 1), dirty = dirty) end
    let layer: LayerPlan = part.layers[li]
    if (layer.tone_mask & as(u8, @{TONE_MASK_PAD})) == 0 then jump scan_layer(pi = pi, li = li + as(index, 1), dirty = dirty) end
    let idx: index = as(index, layer.pad.spectral.table_ref.index)
    if idx < 0 or idx >= (*cache).table_count then jump invalid(code = 7) end
    if layer.pad.spectral.table_length < 0 or layer.pad.spectral.table_count < 0 then jump invalid(code = 8) end
    let needed: index = layer.pad.spectral.table_length * layer.pad.spectral.table_count
    if layer.pad.spectral.table_count ~= 0 and needed / layer.pad.spectral.table_count ~= layer.pad.spectral.table_length then jump invalid(code = 9) end
    if needed > (*cache).total_frames then jump invalid(code = 10) end
    if (*cache).table_lengths[idx] == needed and (*cache).table_generations[idx] == layer.pad.spectral.table_ref.generation then jump scan_layer(pi = pi, li = li + as(index, 1), dirty = dirty) end
    if needed == 0 then jump set_empty(pi = pi, li = li, idx = idx) end
    let finish: index = (*cache).used_frames + needed
    if finish < (*cache).used_frames then jump invalid(code = 11) end
    if finish > (*cache).total_frames then jump exhausted() end
    cache[0].table_offsets[idx] = (*cache).used_frames
    cache[0].table_lengths[idx] = needed
    cache[0].table_generations[idx] = layer.pad.spectral.table_ref.generation
    cache[0].used_frames = finish
    jump scan_layer(pi = pi, li = li + as(index, 1), dirty = true)
end
block set_empty(pi: index, li: index, idx: index)
    cache[0].table_offsets[idx] = 0
    cache[0].table_lengths[idx] = 0
    cache[0].table_generations[idx] = (*program).parts[pi].layers[li].pad.spectral.table_ref.generation
    jump scan_layer(pi = pi, li = li + as(index, 1), dirty = true)
end
block finish(dirty: bool)
    if dirty then
        cache[0].generation = cache[0].generation + as(u16, 1)
        if cache[0].generation == 0 then
            cache[0].generation = as(u16, 1)
        end
        jump rebuilt(generation = cache[0].generation)
    end
    jump clean()
end
]]

BODY.prepare_part = R.prepare_part
BODY.prepare_layer = R.prepare_layer
BODY.validate_program = R.validate_program
BODY.rebuild_pad_cache = R.rebuild_pad_cache
BODY.prepare_effect_bus = R.prepare_effect_bus

local next_patch_section = R.next_patch_section
local prepare_part_region = R.prepare_part
local prepare_layer_region = R.prepare_layer
local prepare_tuning_region = R.prepare_tuning
local prepare_modulation_region = R.prepare_modulation
local prepare_additive_plan_region = R.prepare_additive_plan
local prepare_subtractive_plan_region = R.prepare_subtractive_plan
local prepare_pad_plan_region = R.prepare_pad_plan
local prepare_effect_bus_region = R.prepare_effect_bus
local validate_program_region = R.validate_program
local rebuild_pad_cache_region = R.rebuild_pad_cache

-- Program-preparation helpers keep scan state in region parameters and
-- continuation payloads.  This avoids relying on block-local state being
-- visible from emit continuation fills.
HLP.validate_rebuild_prepared_program = region(program: ptr(PreparedProgram), storage: ptr(SynthStorage), saved: index;
    ready(program: ptr(PreparedProgram))
    | malformed(pos: index, code: i32)
    | exhausted)
entry start()
    emit @{validate_program_region}(program; valid = program_valid, invalid = invalid_program)
end
block program_valid()
    emit @{rebuild_pad_cache_region}(program, &(*storage).pad_cache, &(*storage).arena; clean = program_clean, rebuilt = program_rebuilt, exhausted = rebuild_exhausted, invalid = invalid_program)
end
block program_clean()
    jump ready(program = program)
end
block program_rebuilt(generation: u16)
    jump ready(program = program)
end
block invalid_program(code: i32)
    storage[0].arena.used = saved
    jump malformed(pos = as(index, 0), code = code)
end
block rebuild_exhausted()
    storage[0].arena.used = saved
    jump exhausted()
end
end

HLP.begin_program_preparation = region(src: PatchSource, storage: ptr(SynthStorage), header: PatchHeader;
    ready(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    | unsupported_feature(code: i32)
    | malformed(pos: index, code: i32)
    | exhausted)
entry start()
    emit @{next_patch_section}(src, header, as(index, 0); section = first_section, done = no_header, unsupported_section = unsupported_section_start, malformed = malformed_start)
end
block first_section(section: PatchSection, next: index)
    let saved_start: index = (*storage).arena.used
    if section.kind ~= @{BODY.K_SECTION_HEADER} then jump rollback_malformed(saved = saved_start, pos = as(index, 0), code = 2) end
    if section.bytes.len < as(index, 12) then jump rollback_malformed(saved = saved_start, pos = section.bytes.len, code = 3) end
    let part_count_u16: u16 = as(u16, section.bytes.data[as(index, 0)]) | (as(u16, section.bytes.data[as(index, 1)]) << 8)
    let insert_count_u16: u16 = as(u16, section.bytes.data[as(index, 2)]) | (as(u16, section.bytes.data[as(index, 3)]) << 8)
    let send_count_u16: u16 = as(u16, section.bytes.data[as(index, 4)]) | (as(u16, section.bytes.data[as(index, 5)]) << 8)
    let reserved_u16: u16 = as(u16, section.bytes.data[as(index, 6)]) | (as(u16, section.bytes.data[as(index, 7)]) << 8)
    let flags_u32: u32 = as(u32, section.bytes.data[as(index, 8)]) | (as(u32, section.bytes.data[as(index, 9)]) << 8) | (as(u32, section.bytes.data[as(index, 10)]) << 16) | (as(u32, section.bytes.data[as(index, 11)]) << 24)
    if reserved_u16 ~= 0 then jump rollback_malformed(saved = saved_start, pos = as(index, 6), code = 4) end
    if flags_u32 ~= 0 then jump rollback_malformed(saved = saved_start, pos = as(index, 8), code = 5) end
    let part_count: index = as(index, part_count_u16)
    let insert_count: index = as(index, insert_count_u16)
    let send_count: index = as(index, send_count_u16)
    if part_count <= 0 then jump rollback_malformed(saved = saved_start, pos = as(index, 0), code = 6) end
    let declared_buses: index = insert_count + send_count + as(index, 1)
    if declared_buses < insert_count then jump rollback_malformed(saved = saved_start, pos = as(index, 2), code = 7) end
    if declared_buses > (*storage).effects.bus_count then jump rollback_malformed(saved = saved_start, pos = as(index, 2), code = 8) end
    let part_bytes: index = part_count * as(index, 80)
    let insert_bytes: index = insert_count * as(index, 40)
    let send_bytes: index = send_count * as(index, 40)
    let total_a: index = part_bytes + insert_bytes
    if total_a < part_bytes then jump rollback_exhausted(saved = saved_start) end
    let total_b: index = total_a + send_bytes
    if total_b < total_a then jump rollback_exhausted(saved = saved_start) end
    let total_bytes: index = total_b + as(index, 40)
    if total_bytes < total_b then jump rollback_exhausted(saved = saved_start) end
    let alloc_start: index = ((*storage).arena.used + as(index, 7)) & ~as(index, 7)
    let finish: index = alloc_start + total_bytes
    if finish < alloc_start then jump rollback_exhausted(saved = saved_start) end
    if finish > (*storage).arena.cap then jump rollback_exhausted(saved = saved_start) end
    let insert_off: index = alloc_start + part_bytes
    let send_off: index = insert_off + insert_bytes
    let master_off: index = send_off + send_bytes
    let parts: ptr(PartPlan) = as(ptr(PartPlan), (*storage).arena.data + alloc_start)
    let inserts: ptr(EffectBusPlan) = as(ptr(EffectBusPlan), (*storage).arena.data + insert_off)
    let sends: ptr(EffectBusPlan) = as(ptr(EffectBusPlan), (*storage).arena.data + send_off)
    let master: ptr(EffectBusPlan) = as(ptr(EffectBusPlan), (*storage).arena.data + master_off)
    storage[0].arena.used = finish
    jump init_parts(i = as(index, 0), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved_start)
end
block init_parts(i: index, next: index, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), saved: index)
    if i >= part_count then jump init_inserts(i = as(index, 0), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved) end
    parts[i].enabled = false
    parts[i].layer_count = 0
    parts[i].midi_channel = 0
    parts[i].gain = as(f32, 0.0)
    parts[i].pan = as(f32, 0.0)
    jump init_parts(i = i + as(index, 1), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved)
end
block init_inserts(i: index, next: index, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), saved: index)
    if i >= insert_count then jump init_sends(i = as(index, 0), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved) end
    inserts[i].slots = view(as(ptr(EffectSlotPlan), nil), as(index, 0))
    inserts[i].slot_count = as(index, 0)
    inserts[i].send_gain = as(f32, 0.0)
    jump init_inserts(i = i + as(index, 1), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved)
end
block init_sends(i: index, next: index, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), saved: index)
    if i >= send_count then jump init_master(next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved) end
    sends[i].slots = view(as(ptr(EffectSlotPlan), nil), as(index, 0))
    sends[i].slot_count = as(index, 0)
    sends[i].send_gain = as(f32, 0.0)
    jump init_sends(i = i + as(index, 1), next = next, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, saved = saved)
end
block init_master(next: index, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), saved: index)
    master[0].slots = view(as(ptr(EffectSlotPlan), nil), as(index, 0))
    master[0].slot_count = as(index, 0)
    master[0].send_gain = as(f32, 0.0)
    let tuning: TuningTable = { ratios = view(as(ptr(f32), nil), as(index, 0)), count = as(index, 0), root_midi_note = 69, root_hz = as(f32, 440.0) }
    jump ready(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block no_header(count: index)
    jump malformed(pos = as(index, 0), code = 21)
end
block unsupported_section_start(kind: u8, index: index)
    jump unsupported_feature(code = as(i32, kind))
end
block malformed_start(pos: index, code: i32)
    jump malformed(pos = pos, code = code)
end
block rollback_malformed(saved: index, pos: index, code: i32)
    storage[0].arena.used = saved
    jump malformed(pos = pos, code = code)
end
block rollback_exhausted(saved: index)
    storage[0].arena.used = saved
    jump exhausted()
end
end

HLP.apply_program_section = region(section: PatchSection, next: index, storage: ptr(SynthStorage), header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index;
    continue(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    | done(count: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    | unsupported_feature(code: i32)
    | malformed(pos: index, code: i32)
    | exhausted)
entry start()
    if section.kind == @{BODY.K_SECTION_PART} then jump prep_part() end
    if section.kind == @{BODY.K_SECTION_LAYER} then jump prep_layer() end
    if section.kind == @{BODY.K_SECTION_TUNING} then jump prep_tuning() end
    if section.kind == @{BODY.K_SECTION_ADDITIVE} then jump prep_add() end
    if section.kind == @{BODY.K_SECTION_SUBTRACTIVE} then jump prep_sub() end
    if section.kind == @{BODY.K_SECTION_PAD} then jump prep_pad() end
    if section.kind == @{BODY.K_SECTION_MODULATION} then jump prep_mod() end
    if section.kind == @{BODY.K_SECTION_EFFECT_BUS} then jump prep_bus() end
    if section.kind == @{BODY.K_SECTION_END_MARKER} then jump done(count = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved) end
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_part()
    if section.index >= part_count then jump rollback_malformed(pos = as(index, 0), code = 9) end
    emit @{prepare_part_region}(section, &(*storage).pad_cache, &(*storage).arena; ready = part_ready, disabled = part_ready, unsupported_feature = unsupported_feature_part, malformed = malformed_scan, exhausted = exhausted_scan)
end
block part_ready(part: PartPlan)
    if part.enabled and as(index, part.midi_channel) >= (*storage).controls.channel_count then jump rollback_malformed(pos = as(index, 0), code = 10) end
    if part.layer_count > 255 then jump unsupported_feature_part(code = 11) end
    parts[section.index] = part
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_layer()
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    if pidx >= part_count then jump rollback_malformed(pos = as(index, 0), code = 12) end
    if lidx >= parts[pidx].layer_count then jump rollback_malformed(pos = as(index, 0), code = 13) end
    emit @{prepare_layer_region}(section, &(*storage).pad_cache, &(*storage).arena; ready = layer_ready, muted = layer_ready, unsupported_feature = unsupported_feature_part, malformed = malformed_scan, exhausted = exhausted_scan)
end
block layer_ready(layer: LayerPlan)
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    parts[pidx].layers[lidx] = layer
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_mod()
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    if pidx >= part_count or lidx >= parts[pidx].layer_count then jump rollback_malformed(pos = as(index, 0), code = 14) end
    emit @{prepare_modulation_region}(section, &(*storage).arena; ready = mod_ready, empty = mod_ready, malformed = malformed_scan, exhausted = exhausted_scan)
end
block mod_ready(plan: ModulationPlan)
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    parts[pidx].layers[lidx].mods = plan
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_add()
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    if pidx >= part_count or lidx >= parts[pidx].layer_count then jump rollback_malformed(pos = as(index, 0), code = 15) end
    emit @{prepare_additive_plan_region}(section, &(*storage).arena; ready = add_ready, disabled = add_ready, malformed = malformed_scan, exhausted = exhausted_scan)
end
block add_ready(plan: AdditivePlan)
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    parts[pidx].layers[lidx].additive = plan
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_sub()
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    if pidx >= part_count or lidx >= parts[pidx].layer_count then jump rollback_malformed(pos = as(index, 0), code = 16) end
    emit @{prepare_subtractive_plan_region}(section, &(*storage).arena; ready = sub_ready, disabled = sub_ready, malformed = malformed_scan, exhausted = exhausted_scan)
end
block sub_ready(plan: SubtractivePlan)
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    parts[pidx].layers[lidx].subtractive = plan
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_pad()
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    if pidx >= part_count or lidx >= parts[pidx].layer_count then jump rollback_malformed(pos = as(index, 0), code = 17) end
    emit @{prepare_pad_plan_region}(section, &(*storage).pad_cache, &(*storage).arena; ready = pad_ready, disabled = pad_ready, cache_rebuilt = pad_rebuilt, malformed = malformed_scan, exhausted = exhausted_scan)
end
block pad_ready(plan: PadPlan)
    let pidx: index = (section.index >> 8) & as(index, 255)
    let lidx: index = section.index & as(index, 255)
    parts[pidx].layers[lidx].pad = plan
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block pad_rebuilt(plan: PadPlan, generation: u16)
    jump pad_ready(plan = plan)
end
block prep_tuning()
    emit @{prepare_tuning_region}(section, &(*storage).arena; ready = tuning_ready, defaulted = tuning_ready, malformed = malformed_scan, exhausted = exhausted_scan)
end
block tuning_ready(tuning: TuningTable)
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block prep_bus()
    let master_index: index = insert_count + send_count
    if section.index > master_index then jump rollback_malformed(pos = as(index, 0), code = 18) end
    if section.index >= (*storage).effects.bus_count then jump rollback_malformed(pos = as(index, 0), code = 19) end
    emit @{prepare_effect_bus_region}(section, &(*storage).arena; ready = bus_ready, empty = bus_ready, malformed = malformed_scan, exhausted = exhausted_scan)
end
block bus_ready(bus: EffectBusPlan)
    if bus.slot_count > (*storage).effects.bus_slot_counts[section.index] then jump rollback_malformed(pos = as(index, 0), code = 20) end
    let master_index: index = insert_count + send_count
    if section.index < insert_count then jump set_insert_bus(bus = bus) end
    if section.index < master_index then jump set_send_bus(bus = bus) end
    master[0] = bus
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block set_insert_bus(bus: EffectBusPlan)
    inserts[section.index] = bus
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block set_send_bus(bus: EffectBusPlan)
    let idx: index = section.index - insert_count
    sends[idx] = bus
    jump continue(cursor = next, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block unsupported_feature_part(code: i32)
    storage[0].arena.used = saved
    jump unsupported_feature(code = code)
end
block malformed_scan(pos: index, code: i32)
    jump rollback_malformed(pos = pos, code = code)
end
block exhausted_scan()
    storage[0].arena.used = saved
    jump exhausted()
end
block rollback_malformed(pos: index, code: i32)
    storage[0].arena.used = saved
    jump malformed(pos = pos, code = code)
end
end

local apply_program_section_region = HLP.apply_program_section

HLP.process_next_program_section = region(src: PatchSource, storage: ptr(SynthStorage), cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index;
    continue(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    | done(count: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    | unsupported_feature(code: i32)
    | malformed(pos: index, code: i32)
    | exhausted)
entry start()
    emit @{next_patch_section}(src, header, cursor; section = got_section, done = sections_done, unsupported_section = unsupported_section_scan, malformed = malformed_scan)
end
block got_section(section: PatchSection, next: index)
    emit @{apply_program_section_region}(section, next, storage, header, parts, part_count, insert_count, send_count, inserts, sends, master, tuning, saved; continue = continue, done = done, unsupported_feature = unsupported_feature, malformed = malformed, exhausted = exhausted)
end
block sections_done(count: index)
    jump done(count = count, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block unsupported_section_scan(kind: u8, index: index)
    storage[0].arena.used = saved
    jump unsupported_feature(code = as(i32, kind))
end
block malformed_scan(pos: index, code: i32)
    storage[0].arena.used = saved
    jump malformed(pos = pos, code = code)
end
end

BODY.begin_program_preparation = HLP.begin_program_preparation
BODY.process_next_program_section = HLP.process_next_program_section
BODY.validate_rebuild_prepared_program = HLP.validate_rebuild_prepared_program

R.prepare_program = R.prepare_program(BODY)[[
entry start()
    if storage == nil then jump malformed(pos = as(index, 0), code = 1) end
    if (*storage).arena.data == nil then jump exhausted() end
    if src.format_id ~= @{MAGIC_ZYNM} then jump unsupported_format(format_id = src.format_id, version = src.version) end
    if src.version ~= @{PATCH_FORMAT_VERSION} then jump unsupported_format(format_id = src.format_id, version = src.version) end
    if src.bytes.data == nil then jump malformed(pos = as(index, 0), code = 1) end
    if src.bytes.len < as(index, 16) then jump malformed(pos = as(index, 0), code = 1) end
    let magic: u32 = as(u32, src.bytes.data[as(index, 0)]) | (as(u32, src.bytes.data[as(index, 1)]) << 8) | (as(u32, src.bytes.data[as(index, 2)]) << 16) | (as(u32, src.bytes.data[as(index, 3)]) << 24)
    if magic ~= @{MAGIC_ZYNM} then jump unsupported_format(format_id = magic, version = src.version) end
    let version: u32 = as(u32, src.bytes.data[as(index, 4)]) | (as(u32, src.bytes.data[as(index, 5)]) << 8) | (as(u32, src.bytes.data[as(index, 6)]) << 16) | (as(u32, src.bytes.data[as(index, 7)]) << 24)
    if version ~= @{PATCH_FORMAT_VERSION} then jump unsupported_format(format_id = src.format_id, version = version) end
    let flags: u32 = as(u32, src.bytes.data[as(index, 8)]) | (as(u32, src.bytes.data[as(index, 9)]) << 8) | (as(u32, src.bytes.data[as(index, 10)]) << 16) | (as(u32, src.bytes.data[as(index, 11)]) << 24)
    if flags ~= 0 then jump malformed(pos = as(index, 8), code = 10) end
    let count_u32: u32 = as(u32, src.bytes.data[as(index, 12)]) | (as(u32, src.bytes.data[as(index, 13)]) << 8) | (as(u32, src.bytes.data[as(index, 14)]) << 16) | (as(u32, src.bytes.data[as(index, 15)]) << 24)
    let count: index = as(index, count_u32)
    if count < 0 then jump malformed(pos = as(index, 12), code = 11) end
    let dir_bytes: index = count * as(index, 12)
    if count ~= 0 and dir_bytes / count ~= as(index, 12) then jump malformed(pos = as(index, 12), code = 2) end
    let dir_end: index = as(index, 16) + dir_bytes
    if dir_end < as(index, 16) then jump malformed(pos = as(index, 12), code = 2) end
    if dir_end > src.bytes.len then jump malformed(pos = src.bytes.len, code = 12) end
    let header: PatchHeader = { format_id = src.format_id, version = src.version, flags = 0, section_count = count }
    jump decoded(header = header)
end
block decoded(header: PatchHeader)
    emit @{begin_program_preparation}(src, storage, header; ready = begin_ready, unsupported_feature = unsupported_feature_start, malformed = malformed_start, exhausted = exhausted_start)
end
block begin_ready(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    jump scan_sections(cursor = cursor, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block scan_sections(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    emit @{process_next_program_section}(src, storage, cursor, header, parts, part_count, insert_count, send_count, inserts, sends, master, tuning, saved; continue = scan_continue, done = sections_done, unsupported_feature = unsupported_feature_start, malformed = malformed_start, exhausted = exhausted_start)
end
block scan_continue(cursor: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    jump scan_sections(cursor = cursor, header = header, parts = parts, part_count = part_count, insert_count = insert_count, send_count = send_count, inserts = inserts, sends = sends, master = master, tuning = tuning, saved = saved)
end
block sections_done(count: index, header: PatchHeader, parts: ptr(PartPlan), part_count: index, insert_count: index, send_count: index, inserts: ptr(EffectBusPlan), sends: ptr(EffectBusPlan), master: ptr(EffectBusPlan), tuning: TuningTable, saved: index)
    let start: index = ((*storage).arena.used + as(index, 7)) & ~as(index, 7)
    let finish: index = start + as(index, 216)
    if finish < start then jump rollback_exhausted(saved = saved) end
    if finish > (*storage).arena.cap then jump rollback_exhausted(saved = saved) end
    let out: ptr(PreparedProgram) = as(ptr(PreparedProgram), (*storage).arena.data + start)
    storage[0].arena.used = finish
    out[0].parts = view(parts, part_count)
    out[0].part_count = part_count
    out[0].effects.insert_fx = view(inserts, insert_count)
    out[0].effects.insert_count = insert_count
    out[0].effects.send_fx = view(sends, send_count)
    out[0].effects.send_count = send_count
    out[0].effects.send_routes = view(as(ptr(EffectRoute), nil), as(index, 0))
    out[0].effects.send_route_count = as(index, 0)
    out[0].effects.master_fx = master[0]
    out[0].tuning = tuning
    out[0].generation = as(u16, 1)
    emit @{validate_rebuild_prepared_program}(out, storage, saved; ready = program_ready, malformed = malformed_start, exhausted = exhausted_start)
end
block program_ready(program: ptr(PreparedProgram))
    jump ready(program = program)
end
block unsupported_feature_start(code: i32)
    jump unsupported_feature(code = code)
end
block malformed_start(pos: index, code: i32)
    jump malformed(pos = pos, code = code)
end
block exhausted_start()
    jump exhausted()
end
block rollback_exhausted(saved: index)
    storage[0].arena.used = saved
    jump exhausted()
end
]]


-------------------------------------------------------------------------------
-- Event/control and voice lifecycle protocols
-------------------------------------------------------------------------------

R.next_note_layer = R.next_note_layer(BODY)[[
entry start()
    if program == nil then jump done(count = as(index, 0)) end
    if cursor < 0 then jump skipped(next = as(index, 0)) end
    jump scan_part(pi = as(index, 0), base = as(index, 0))
end
block scan_part(pi: index, base: index)
    if pi >= (*program).part_count then jump done(count = base) end
    let part: PartPlan = (*program).parts[pi]
    let next_base: index = base + part.layer_count
    if cursor >= next_base then jump scan_part(pi = pi + as(index, 1), base = next_base) end
    if not part.enabled then jump skipped(next = next_base) end
    if part.midi_channel ~= channel then jump skipped(next = next_base) end
    let li: index = cursor - base
    if li < 0 or li >= part.layer_count then jump skipped(next = next_base) end
    let layer: LayerPlan = part.layers[li]
    if note < layer.keymap.first_note or note > layer.keymap.last_note then jump skipped(next = cursor + as(index, 1)) end
    let pref: PartRef = { index = as(u16, pi), generation = (*program).generation }
    let lref: LayerRef = { part_index = as(u16, pi), layer_index = as(u16, li), generation = (*program).generation }
    let base_hz: f32 = select((*program).tuning.root_hz > as(f32, 0.0), (*program).tuning.root_hz, as(f32, 440.0))
    let gain: f32 = velocity * part.gain * layer.nominal_gain
    jump layer(part = pref, layer = lref, base_frequency_hz = base_hz, gain = gain, next = cursor + as(index, 1))
end
]]

R.choose_voice_to_steal = R.choose_voice_to_steal(BODY)[[
entry start()
    if pool == nil then jump none() end
    if pool[0].active_count <= 0 then jump none() end
    jump scan(i = as(index, 0), have = false, best_index = as(index, 0), best_score = as(f32, -3.402823e38))
end
block scan(i: index, have: bool, best_index: index, best_score: f32)
    if i >= (*pool).active_count then jump finish(have = have, best_index = best_index, best_score = best_score) end
    let vr: VoiceRef = (*pool).active[i]
    if as(index, vr.index) < 0 or as(index, vr.index) >= (*pool).cap then jump stale_ref(v = vr) end
    if (*pool).generations[as(index, vr.index)] ~= vr.generation then jump stale_ref(v = vr) end
    let st: VoiceState = (*pool).states[as(index, vr.index)]
    let age_score: f32 = part[0].steal.age_weight * as(f32, st.age_frames)
    let quiet_score: f32 = part[0].steal.level_weight * (as(f32, 1.0) - st.last_mod.amp)
    let same_score: f32 = select(st.channel == channel and st.note == note, part[0].steal.same_note_bonus, as(f32, 0.0))
    let rel: bool = st.stage == @{VOICE_STAGE_RELEASE} or st.stage == @{VOICE_STAGE_FADEOUT} or st.stage == @{VOICE_STAGE_RETIRING}
    let rel_score: f32 = select(rel, part[0].steal.release_bonus, as(f32, 0.0))
    let mode_bonus: f32 = select(part[0].steal.mode == @{VOICE_STEAL_OLDEST}, age_score, select(part[0].steal.mode == @{VOICE_STEAL_QUIETEST}, quiet_score, select(part[0].steal.mode == @{VOICE_STEAL_RELEASE_FIRST}, rel_score + age_score, select(part[0].steal.mode == @{VOICE_STEAL_SAME_NOTE}, same_score + age_score, as(f32, 0.0)))))
    let score: f32 = age_score + quiet_score + same_score + rel_score + mode_bonus
    let better: bool = (not have) or score > best_score or (score == best_score and vr.index < (*pool).active[best_index].index)
    jump scan(i = i + as(index, 1), have = true, best_index = select(better, i, best_index), best_score = select(better, score, best_score))
end
block finish(have: bool, best_index: index, best_score: f32)
    if not have then jump none() end
    let v: VoiceRef = (*pool).active[best_index]
    let c: VoiceStealCandidate = { voice = v, score = best_score }
    jump candidate(candidate = c)
end
]]

local choose_voice_to_steal_region = R.choose_voice_to_steal
BODY.choose_voice_to_steal_region = choose_voice_to_steal_region

R.allocate_voice = R.allocate_voice(BODY)[[
entry start()
    if part == nil or pool == nil then jump full() end
    if not (*part).enabled then jump muted() end
    if velocity <= as(f32, 0.0) then jump muted() end
    if (*pool).free_head ~= as(u32, @{EMPTY_U32_VALUE}) then jump pop_free(idx = (*pool).free_head) end
    emit @{choose_voice_to_steal_region}(part, pool, channel, note, velocity; candidate = steal_candidate, none = no_voice, stale_ref = stale_voice)
end
block pop_free(idx: u32)
    let i: index = as(index, idx)
    if i < 0 or i >= (*pool).cap then jump full() end
    pool[0].free_head = (*pool).next_free[i]
    let v: VoiceRef = { index = idx, generation = (*pool).generations[i] }
    if (*pool).active_count < (*pool).cap then
        pool[0].active[(*pool).active_count] = v
        pool[0].active_count = (*pool).active_count + as(index, 1)
    end
    jump allocated(v = v)
end
block steal_candidate(candidate: VoiceStealCandidate)
    let i: index = as(index, candidate.voice.index)
    if i < 0 or i >= (*pool).cap then jump full() end
    pool[0].generations[i] = (*pool).generations[i] + as(u16, 1)
    if (*pool).generations[i] == 0 then pool[0].generations[i] = as(u16, 1) end
    let v: VoiceRef = { index = candidate.voice.index, generation = (*pool).generations[i] }
    jump stolen(v = v, previous = candidate.voice)
end
block no_voice()
    jump full()
end
block stale_voice(v: VoiceRef)
    jump full()
end
]]

R.start_voice = R.start_voice(BODY)[[
entry start()
    if program == nil or pool == nil then jump stale_ref(v = v) end
    let i: index = as(index, v.index)
    if i < 0 or i >= (*pool).cap then jump stale_ref(v = v) end
    if (*pool).generations[i] ~= v.generation then jump stale_ref(v = v) end
    let pi: index = as(index, part.index)
    let li: index = as(index, layer.layer_index)
    if pi < 0 or pi >= (*program).part_count then jump invalid_layer(layer = layer) end
    let pp: PartPlan = (*program).parts[pi]
    if li < 0 or li >= pp.layer_count then jump invalid_layer(layer = layer) end
    pool[0].states[i].part = part
    pool[0].states[i].layer = layer
    pool[0].states[i].note = note
    pool[0].states[i].channel = channel
    pool[0].states[i].velocity = velocity
    pool[0].states[i].gate = true
    pool[0].states[i].stage = @{VOICE_STAGE_ATTACK}
    pool[0].states[i].age_frames = as(u64, 0)
    pool[0].states[i].release_frame = as(u64, 0)
    pool[0].states[i].base_frequency_hz = base_frequency_hz
    pool[0].states[i].ad_phase = as(f32, 0.0)
    pool[0].states[i].sub_seed = (as(u64, note) << 32) | as(u64, channel)
    pool[0].states[i].pad_phase = as(f32, 0.0)
    pool[0].states[i].amp_env.phase = @{VOICE_STAGE_ATTACK}
    pool[0].states[i].amp_env.sample_pos = as(u64, 0)
    pool[0].states[i].amp_env.value = as(f32, 0.0)
    pool[0].states[i].pitch_env = pool[0].states[i].amp_env
    pool[0].states[i].filter_env = pool[0].states[i].amp_env
    pool[0].states[i].lfo1.phase = as(f32, 0.0)
    pool[0].states[i].lfo1.held_value = as(f32, 0.0)
    pool[0].states[i].lfo1.rng = pool[0].states[i].sub_seed
    pool[0].states[i].lfo2 = pool[0].states[i].lfo1
    pool[0].states[i].filter_state.z1_l = as(f32, 0.0)
    pool[0].states[i].filter_state.z2_l = as(f32, 0.0)
    pool[0].states[i].filter_state.z1_r = as(f32, 0.0)
    pool[0].states[i].filter_state.z2_r = as(f32, 0.0)
    pool[0].states[i].last_mod.amp = velocity
    pool[0].states[i].last_mod.pan = as(f32, 0.0)
    pool[0].states[i].last_mod.pitch_cents = as(f32, 0.0)
    pool[0].states[i].last_mod.filter_cutoff_hz = as(f32, 0.0)
    pool[0].states[i].last_mod.filter_q = as(f32, 0.0)
    pool[0].states[i].last_mod.ad_partial_gain = as(f32, 1.0)
    pool[0].states[i].last_mod.sub_band_gain = as(f32, 1.0)
    pool[0].states[i].last_mod.pad_position = as(f32, 0.0)
    pool[0].states[i].last_mod.effect_send = as(f32, 0.0)
    jump started(v = v)
end
]]

R.release_matching_voices = R.release_matching_voices(BODY)[[
entry start()
    if pool == nil then jump none() end
    jump scan(i = as(index, 0), count = as(index, 0))
end
block scan(i: index, count: index)
    if i >= (*pool).active_count then jump finish(count = count) end
    let v: VoiceRef = (*pool).active[i]
    let vi: index = as(index, v.index)
    if vi >= 0 and vi < (*pool).cap and (*pool).generations[vi] == v.generation and (*pool).states[vi].channel == channel and (*pool).states[vi].note == note and (*pool).states[vi].gate then
        pool[0].states[vi].gate = false
        pool[0].states[vi].stage = @{VOICE_STAGE_RELEASE}
        jump scan(i = i + as(index, 1), count = count + as(index, 1))
    end
    jump scan(i = i + as(index, 1), count = count)
end
block finish(count: index)
    if count > 0 then jump released_any(count = count) end
    jump none()
end
]]

R.release_sustained_voices = R.release_sustained_voices(BODY)[[
entry start()
    if controls == nil then jump none() end
    if as(index, channel) < (*controls).channel_count and (*controls).states[as(index, channel)].sustain then jump none() end
    jump scan(i = as(index, 0), count = as(index, 0))
end
block scan(i: index, count: index)
    if i >= (*pool).active_count then jump finish(count = count) end
    let v: VoiceRef = (*pool).active[i]
    let vi: index = as(index, v.index)
    if vi >= 0 and vi < (*pool).cap and (*pool).generations[vi] == v.generation and (*pool).states[vi].channel == channel and not (*pool).states[vi].gate then
        pool[0].states[vi].stage = @{VOICE_STAGE_RELEASE}
        jump scan(i = i + as(index, 1), count = count + as(index, 1))
    end
    jump scan(i = i + as(index, 1), count = count)
end
block finish(count: index)
    if count > 0 then jump released_any(count = count) end
    jump none()
end
]]

R.all_notes_off = R.all_notes_off(BODY)[[
entry start()
    if pool == nil then jump none() end
    jump scan(i = as(index, 0), count = as(index, 0))
end
block scan(i: index, count: index)
    if i >= (*pool).active_count then jump finish(count = count) end
    let v: VoiceRef = (*pool).active[i]
    let vi: index = as(index, v.index)
    if vi >= 0 and vi < (*pool).cap and (*pool).generations[vi] == v.generation and (*pool).states[vi].channel == channel and (*pool).states[vi].gate then
        pool[0].states[vi].gate = false
        pool[0].states[vi].stage = @{VOICE_STAGE_RELEASE}
        jump scan(i = i + as(index, 1), count = count + as(index, 1))
    end
    jump scan(i = i + as(index, 1), count = count)
end
block finish(count: index)
    if count > 0 then jump released_any(count = count) end
    jump none()
end
]]

R.panic_voices = R.panic_voices(BODY)[[
entry start()
    if pool == nil then jump already_silent() end
    let old: index = (*pool).active_count
    jump clear(i = as(index, 0), old = old)
end
block clear(i: index, old: index)
    if i >= (*pool).cap then jump finish(old = old) end
    pool[0].states[i].gate = false
    pool[0].states[i].stage = @{VOICE_STAGE_FREE}
    pool[0].generations[i] = (*pool).generations[i] + as(u16, 1)
    if (*pool).generations[i] == 0 then pool[0].generations[i] = as(u16, 1) end
    pool[0].next_free[i] = select(i + as(index, 1) < (*pool).cap, as(u32, i + as(index, 1)), as(u32, @{EMPTY_U32_VALUE}))
    jump clear(i = i + as(index, 1), old = old)
end
block finish(old: index)
    pool[0].active_count = as(index, 0)
    pool[0].free_head = select((*pool).cap > 0, as(u32, 0), as(u32, @{EMPTY_U32_VALUE}))
    if old > 0 then jump cleared(count = old) end
    jump already_silent()
end
]]

R.advance_voice_lifecycle = R.advance_voice_lifecycle(BODY)[[
entry start()
    if pool == nil then jump stale_ref(v = v) end
    let i: index = as(index, v.index)
    if i < 0 or i >= (*pool).cap then jump stale_ref(v = v) end
    if (*pool).generations[i] ~= v.generation then jump stale_ref(v = v) end
    pool[0].states[i].age_frames = (*pool).states[i].age_frames + as(u64, ctx.shape.frame_count)
    if (*pool).states[i].gate then jump alive(v = v) end
    if (*pool).states[i].stage == @{VOICE_STAGE_ATTACK} or (*pool).states[i].stage == @{VOICE_STAGE_DECAY} or (*pool).states[i].stage == @{VOICE_STAGE_SUSTAIN} then
        pool[0].states[i].stage = @{VOICE_STAGE_RELEASE}
        pool[0].states[i].release_frame = (*pool).states[i].age_frames
        jump released(v = v)
    end
    if (*pool).states[i].last_mod.amp <= ctx.dsp.denormal_floor then jump dead(v = v) end
    jump released(v = v)
end
]]

R.retire_voice = R.retire_voice(BODY)[[
entry start()
    if pool == nil then jump stale_ref(v = v) end
    let vi: index = as(index, v.index)
    if vi < 0 or vi >= (*pool).cap then jump stale_ref(v = v) end
    if (*pool).generations[vi] ~= v.generation then jump stale_ref(v = v) end
    if (*pool).states[vi].stage == @{VOICE_STAGE_FREE} then jump already_free() end
    jump find(i = as(index, 0))
end
block find(i: index)
    if i >= (*pool).active_count then jump already_free() end
    if (*pool).active[i].index == v.index then jump remove(pos = i) end
    jump find(i = i + as(index, 1))
end
block remove(pos: index)
    let last_pos: index = (*pool).active_count - as(index, 1)
    if pos < last_pos then pool[0].active[pos] = (*pool).active[last_pos] end
    pool[0].active_count = last_pos
    pool[0].states[as(index, v.index)].gate = false
    pool[0].states[as(index, v.index)].stage = @{VOICE_STAGE_FREE}
    pool[0].generations[as(index, v.index)] = (*pool).generations[as(index, v.index)] + as(u16, 1)
    if (*pool).generations[as(index, v.index)] == 0 then pool[0].generations[as(index, v.index)] = as(u16, 1) end
    pool[0].next_free[as(index, v.index)] = (*pool).free_head
    pool[0].free_head = v.index
    jump retired()
end
]]

BODY.next_note_layer = R.next_note_layer
BODY.allocate_voice = R.allocate_voice
BODY.start_voice = R.start_voice
BODY.release_matching_voices = R.release_matching_voices
BODY.release_sustained_voices = R.release_sustained_voices
BODY.all_notes_off = R.all_notes_off
BODY.panic_voices = R.panic_voices

local next_note_layer_region = R.next_note_layer
local allocate_voice_region = R.allocate_voice
local start_voice_region = R.start_voice
local release_matching_voices_region = R.release_matching_voices
local release_sustained_voices_region = R.release_sustained_voices
local all_notes_off_region = R.all_notes_off
local panic_voices_region = R.panic_voices

R.classify_host_event = R.classify_host_event(BODY)[[
entry start()
    if ev.kind == @{HOST_EVENT_MIDI} then jump midi(midi = ev.midi) end
    if ev.kind == @{HOST_EVENT_PARAMETER} then jump parameter(param = ev.parameter) end
    if ev.kind == @{HOST_EVENT_PROGRAM_CHANGE} then jump program_change(program = ev.program, frame = ev.frame) end
    if ev.kind == @{HOST_EVENT_TRANSPORT} then jump transport(transport = ev.transport, frame = ev.frame) end
    if ev.kind == @{HOST_EVENT_ALL_NOTES_OFF} then jump all_notes_off(frame = ev.frame) end
    if ev.kind == @{HOST_EVENT_PANIC} then jump panic(frame = ev.frame) end
    jump ignored()
end
]]

R.classify_midi_event = R.classify_midi_event(BODY)[[
entry start()
    let status: u8 = ev.kind & as(u8, 0xf0)
    if status == @{MIDI_NOTE_ON} then jump note_on_or_off() end
    if status == @{MIDI_NOTE_OFF} then jump note_off(channel = ev.channel, note = ev.a, frame = ev.frame) end
    if status == @{MIDI_CONTROL_CHANGE} then jump control_change(channel = ev.channel, cc = ev.a, value = ev.b, frame = ev.frame) end
    if status == @{MIDI_PITCH_BEND} then jump bend() end
    if status == @{MIDI_CHANNEL_PRESSURE} then jump channel_pressure(channel = ev.channel, value = as(f32, ev.a) / as(f32, 127.0), frame = ev.frame) end
    if status == @{MIDI_POLY_PRESSURE} then jump poly_pressure(channel = ev.channel, note = ev.a, value = as(f32, ev.b) / as(f32, 127.0), frame = ev.frame) end
    if status == @{MIDI_PROGRAM_CHANGE} then jump program_change(channel = ev.channel, program = ev.a, frame = ev.frame) end
    jump ignored()
end
block note_on_or_off()
    if ev.b == 0 then jump note_off(channel = ev.channel, note = ev.a, frame = ev.frame) end
    jump note_on(channel = ev.channel, note = ev.a, velocity = as(f32, ev.b) / as(f32, 127.0), frame = ev.frame)
end
block bend()
    let raw: i32 = as(i32, (as(u16, ev.b) << 7) | as(u16, ev.a)) - 8192
    jump pitch_bend(channel = ev.channel, value = as(f32, raw) / as(f32, 8192.0), frame = ev.frame)
end
]]

BODY.clamp_f32 = HLP.clamp_f32

R.update_control = R.update_control(BODY)[[
entry start()
    if controls == nil then jump invalid_channel(channel = channel) end
    let ch: index = as(index, channel)
    if ch < 0 or ch >= (*controls).channel_count then jump invalid_channel(channel = channel) end
    let v: f32 = emit @{clamp_f32}(value, as(f32, 0.0), as(f32, 1.0))
    let old: u8 = (*controls).cc_values[ch * as(index, 128) + as(index, cc)]
    let nv: u8 = select(v >= as(f32, 0.5), as(u8, 127), as(u8, 0))
    controls[0].cc_values[ch * as(index, 128) + as(index, cc)] = nv
    if cc == 1 then controls[0].states[ch].mod_wheel = v end
    if cc == 7 then controls[0].states[ch].volume = v end
    if cc == 10 then controls[0].states[ch].pan = v end
    if cc == 11 then controls[0].states[ch].expression = v end
    if cc == 64 then controls[0].states[ch].sustain = nv >= 64 end
    if old == nv then jump unchanged() end
    jump changed()
end
]]

R.resolve_parameter = R.resolve_parameter(BODY)[[
entry start()
    let rw: ParamPolicy = { min_value = as(f32, 0.0), max_value = as(f32, 1.0), default_value = as(f32, 0.0), smoothing_ms = as(f32, 5.0), read_only = false }
    let ro: ParamPolicy = { min_value = as(f32, 0.0), max_value = as(f32, 1.0), default_value = as(f32, 0.0), smoothing_ms = as(f32, 0.0), read_only = true }
    if address.scope == @{PARAM_SCOPE_GLOBAL} then
        if address.param == 0 then jump resolved(policy = rw) end
        if address.param == 1 then jump read_only(policy = ro) end
    end
    if address.scope == @{PARAM_SCOPE_PART} or address.scope == @{PARAM_SCOPE_LAYER} or address.scope == @{PARAM_SCOPE_MODULATION} or address.scope == @{PARAM_SCOPE_INSERT_FX} or address.scope == @{PARAM_SCOPE_SEND_FX} or address.scope == @{PARAM_SCOPE_MASTER_FX} then jump resolved(policy = rw) end
    jump unknown(address = address)
end
]]

local resolve_parameter_region = R.resolve_parameter
BODY.resolve_parameter_region = resolve_parameter_region
BODY.clamp_f32 = HLP.clamp_f32

R.apply_parameter_event = R.apply_parameter_event(BODY)[[
entry start()
    emit @{resolve_parameter_region}(program, ev.address; resolved = param_resolved, read_only = param_read_only, unknown = param_unknown)
end
block param_resolved(policy: ParamPolicy)
    let clamped: f32 = emit @{clamp_f32}(ev.value, policy.min_value, policy.max_value)
    if clamped ~= ev.value then jump out_of_range(address = ev.address, clamped = clamped) end
    if controls ~= nil and ev.address.scope == @{PARAM_SCOPE_GLOBAL} and as(index, ev.address.param) < (*controls).macro_count then
        controls[0].macro_values[as(index, ev.address.param)] = clamped
    end
    if policy.smoothing_ms > as(f32, 0.0) then jump smoothed(target = clamped, smoothing_ms = policy.smoothing_ms) end
    jump changed()
end
block param_read_only(policy: ParamPolicy)
    jump read_only(address = ev.address)
end
block param_unknown(address: ParamAddress)
    jump unknown_parameter(address = address)
end
]]

R.apply_transport_event = R.apply_transport_event(BODY)[[
entry start()
    if synth == nil then jump unchanged() end
    let changed_now: bool = (*synth).transport.playing ~= transport.playing or (*synth).transport.beat_pos ~= transport.beat_pos or (*synth).transport.bar_pos ~= transport.bar_pos or (*synth).transport.time_sig_num ~= transport.time_sig_num or (*synth).transport.time_sig_den ~= transport.time_sig_den
    synth[0].transport = transport
    if changed_now then jump changed() end
    jump unchanged()
end
]]

local classify_midi_event_region = R.classify_midi_event
BODY.classify_midi_event_region = classify_midi_event_region
BODY.next_note_layer_region = next_note_layer_region
BODY.allocate_voice_region = allocate_voice_region
BODY.start_voice_region = start_voice_region
BODY.release_matching_voices_region = release_matching_voices_region
BODY.release_sustained_voices_region = release_sustained_voices_region
BODY.update_control = R.update_control
BODY.clamp_f32 = HLP.clamp_f32


HLP.start_one_note_voice = region(program: ptr(PreparedProgram), pool: ptr(VoicePool), channel: u8, note: u8, velocity: f32, part: PartRef, layer: LayerRef, base_frequency_hz: f32;
    started
    | not_started)
entry start()
    let pi: index = as(index, part.index)
    if program == nil or pi < 0 or pi >= (*program).part_count then jump not_started() end
    emit @{allocate_voice_region}(&(*program).parts[pi], pool, channel, note, velocity; allocated = voice_allocated, stolen = voice_stolen, full = voice_full, muted = voice_muted)
end
block voice_allocated(v: VoiceRef)
    emit @{start_voice_region}(program, pool, v, part, layer, channel, note, velocity, base_frequency_hz; started = voice_started, stale_ref = voice_stale, invalid_layer = invalid_layer)
end
block voice_stolen(v: VoiceRef, previous: VoiceRef)
    emit @{start_voice_region}(program, pool, v, part, layer, channel, note, velocity, base_frequency_hz; started = voice_started, stale_ref = voice_stale, invalid_layer = invalid_layer)
end
block voice_started(v: VoiceRef)
    jump started()
end
block voice_full()
    jump not_started()
end
block voice_muted()
    jump not_started()
end
block voice_stale(v: VoiceRef)
    jump not_started()
end
block invalid_layer(layer: LayerRef)
    jump not_started()
end
end

local start_one_note_voice_region = HLP.start_one_note_voice
BODY.start_one_note_voice_region = start_one_note_voice_region

HLP.start_note_voices = region(program: ptr(PreparedProgram), pool: ptr(VoicePool), channel: u8, note: u8, velocity: f32, cursor: index, started_count: index;
    done(count: index))
entry start()
    emit @{next_note_layer_region}(program, channel, note, velocity, cursor; layer = got_layer, skipped = skipped_layer, done = done_layers)
end
block got_layer(part: PartRef, layer: LayerRef, base_frequency_hz: f32, gain: f32, next: index)
    emit @{start_one_note_voice_region}(program, pool, channel, note, velocity, part, layer, base_frequency_hz; started = one_started, not_started = one_not_started)
end
block one_started()
    jump done(count = started_count + as(index, 1))
end
block one_not_started()
    jump done(count = started_count)
end
block skipped_layer(next: index)
    jump done(count = started_count)
end
block done_layers(count: index)
    jump done(count = started_count)
end
end

local start_note_voices_region = HLP.start_note_voices
BODY.start_note_voices_region = start_note_voices_region

R.apply_midi_event = R.apply_midi_event(BODY)[[
entry start()
    emit @{classify_midi_event_region}(ev; note_on = midi_note_on, note_off = midi_note_off, control_change = midi_cc, pitch_bend = midi_bend, channel_pressure = midi_pressure, poly_pressure = midi_poly_pressure, program_change = midi_program, ignored = midi_ignored)
end
block midi_note_on(channel: u8, note: u8, velocity: f32, frame: index)
    emit @{start_note_voices_region}(program, pool, channel, note, velocity, as(index, 0), as(index, 0); done = note_start_done)
end
block note_start_done(count: index)
    if count > 0 then jump voices_started(count = count) end
    jump unchanged()
end
block midi_note_off(channel: u8, note: u8, frame: index)
    emit @{release_matching_voices_region}(pool, channel, note; released_any = released_notes, none = midi_unchanged)
end
block released_notes(count: index)
    jump voices_released(count = count)
end
block midi_cc(channel: u8, cc: u8, value: u8, frame: index)
    emit @{update_control}(controls, channel, cc, as(f32, value) / as(f32, 127.0); changed = midi_changed, unchanged = midi_unchanged, invalid_channel = invalid_cc_channel)
end
block invalid_cc_channel(channel: u8)
    jump unchanged()
end
block midi_bend(channel: u8, value: f32, frame: index)
    if controls == nil or as(index, channel) >= (*controls).channel_count then jump unchanged() end
    controls[0].states[as(index, channel)].pitch_bend = value
    jump changed()
end
block midi_pressure(channel: u8, value: f32, frame: index)
    if controls == nil or as(index, channel) >= (*controls).channel_count then jump unchanged() end
    controls[0].states[as(index, channel)].channel_pressure = value
    jump changed()
end
block midi_poly_pressure(channel: u8, note: u8, value: f32, frame: index)
    jump unchanged()
end
block midi_program(channel: u8, program: u8, frame: index)
    jump unchanged()
end
block midi_changed()
    jump changed()
end
block midi_unchanged()
    jump unchanged()
end
block midi_ignored()
    jump unchanged()
end
]]

local classify_host_event_region = R.classify_host_event
local apply_midi_event_region = R.apply_midi_event
local apply_parameter_event_region = R.apply_parameter_event
local apply_transport_event_region = R.apply_transport_event
BODY.classify_host_event_region = classify_host_event_region
BODY.apply_midi_event_region = apply_midi_event_region
BODY.apply_parameter_event_region = apply_parameter_event_region
BODY.apply_transport_event_region = apply_transport_event_region
BODY.all_notes_off_region = all_notes_off_region
BODY.panic_voices_region = panic_voices_region

R.apply_host_events = R.apply_host_events(BODY)[[
entry start()
    if synth == nil then jump unchanged() end
    if len(events) <= 0 then jump unchanged() end
    let ev: HostEvent = events[as(index, 0)]
    if ev.frame < 0 then jump unchanged() end
    if ev.kind == @{HOST_EVENT_PROGRAM_CHANGE} then jump requested_program(program = ev.program) end
    if ev.kind == @{HOST_EVENT_PANIC} then jump panic_requested() end
    if ev.kind == @{HOST_EVENT_TRANSPORT} then
        synth[0].transport = ev.transport
        jump changed()
    end
    if ev.kind == @{HOST_EVENT_MIDI} or ev.kind == @{HOST_EVENT_PARAMETER} or ev.kind == @{HOST_EVENT_ALL_NOTES_OFF} then jump changed() end
    jump unchanged()
end
]]

-- Future implementation slices should replace header closures in-place, e.g.:
--
--     R.some_protocol = region R.some_protocol
--     entry start()
--         ...
--     end
--     end
--
-- or equivalently:
--
--     F.some_abi = F.some_abi(BODY)[[ body-only Moonlift source ]]
--
-- ABI status integers remain confined to F.* bodies. Internal regions must exit
-- through their declared named protocols only.

return M

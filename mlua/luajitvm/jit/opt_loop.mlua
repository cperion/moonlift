-- jit/opt_loop.mlua -- Loop optimization pass stub.
-- Protocol: LoopOptResult
-- P4.PROTO.007 stub.

local m = module VmJitOptLoop

type LoopOptResult = loop_done
    | not_loop
    | overflow
    | abort(reason: i32)

region opt_loop(J: ptr(u8), tr: i32) -> LoopOptResult
entry start()
    jump not_loop()
end
end

end

local _c = m:compile(); _c:free()

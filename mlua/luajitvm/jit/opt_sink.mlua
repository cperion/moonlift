-- jit/opt_sink.mlua -- Allocation sinking pass stub.
-- Protocol: SinkResult

local m = module VmJitOptSink

type SinkResult = sink_done
    | disabled
    | abort(reason: i32)

region opt_sink(J: ptr(u8), tr: i32) -> SinkResult
entry start()
    jump disabled()
end
end

end

local _c = m:compile(); _c:free()

-- generated/opcodes.mlua -- Opcode enum and metadata (build-time generated stub).
-- Values mirror core/bytecode.mlua and the interpreter dispatch table.

local m = module "luajitvm.generated.opcodes"

-- Comparisons
export func BC_ISLT() -> i32   return 0   end

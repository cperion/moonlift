-- ffi/cdata.mlua -- CData index/store region stubs.
-- Protocol: CDataIndex

local proto = moon.require("luajitvm.protocols")
local m = module "luajitvm.ffi.cdata"


region cdata_index(L: ptr(u8), cd: ptr(u8), key_tag: i32, key_payload: i64) -> proto.CDataIndex
entry start()
    jump error(code = 0)
end
end

end

local _c = m:compile(); _c:free()

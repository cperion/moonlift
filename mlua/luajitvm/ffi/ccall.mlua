-- ffi/ccall.mlua -- C call preparation and emission stubs.
-- Protocol: FFIPrepCall, FFIEmitCall

local proto = moon.require("luajitvm.protocols")
local m = module "luajitvm.ffi.ccall"


region ffi_prepare_call(L: ptr(u8), cfun: ptr(u8), args: ptr(u8), nargs: i32) -> proto.FFIPrepCall
entry start()
    jump error(code = 0)
end
end

region ffi_emit_call(A: ptr(u8), ci: ptr(u8)) -> proto.FFIEmitCall
entry start()
    jump mcode_full()
end
end

end

local _c = m:compile(); _c:free()
